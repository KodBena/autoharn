#!/bin/sh
# autoharn pre-commit — the mechanical refusals, invoked by REPO-RELATIVE path.
#
# Adapted from claude_harness/tools/hooks/pre-commit [C18]: the old hook reached
# into a sibling repo by absolute path (the two-repo coupling the fresh home must
# not inherit) and ran the ADR-0016 standing-service umbrella gate — which has NO
# services to gate here (the NLP lane stays in the attic, C14). Running it here
# would be a silent vacuous pass (F49). It is therefore NOT wired; it rejoins
# autoharn only when autoharn's first standing service does.
#
# FINAL WIRING (BUILD-BRIEF Step 9): staging_guard -> no_lazy_imports -> fixture_census
# -> layout_census -> doc-legibility. layout_census is DISABLED here as of the maintainer
# ruling below (2026-07-09); it still appears in this history note as the Step-9 design.
# doc-legibility is wired REPORT-ONLY (runs and prints,
# does not block): the C15 scope-widening to ALL tracked *.md surfaces ~1429 acronym reports
# over the migrated corpus — mostly the crude heuristic misfiring on all-caps emphasis words
# and standards acronyms in docs never written against it. Making it a BLOCKING gate over the
# full corpus needs a corpus acronym-sweep (filed, BACKLOG); wiring it blocking now would make
# the repo uncommittable — the maintainer-flagged tension (C15 widen vs Step-9 block vs Step-10
# green). Its seen-red both-polarity proof already exists; only its pre-commit disposition is
# report-only pending the sweep. The other four gates BLOCK.
#
# Install (once per clone; .git/hooks is unversioned): git config core.hooksPath hooks
set -u
REPO_ROOT="$(git rev-parse --show-toplevel)"
PY="$HOME/w/vdc/venvs/generic/bin/python"
[ -x "$PY" ] || PY="$(command -v python3)"

# staging_guard FIRST — a swept-in path is a scope defect to resolve before any
# content gate matters (finding 33 foreclosure). Repo-local, its one home (P1).
"$PY" "$REPO_ROOT/gates/staging_guard.py" || {
    echo "" >&2
    echo "pre-commit: staging guard FAILED — commit refused (finding 33, commit-scope-sweep)." >&2
    exit 1
}

"$PY" "$REPO_ROOT/gates/no_lazy_imports.py" || {
    echo "" >&2
    echo "pre-commit: lazy-import gate FAILED — commit refused (CLAUDE.md edict 2026-07-02)." >&2
    echo "Hoist the imports to module top, then commit again." >&2
    exit 1
}

"$PY" "$REPO_ROOT/gates/fixture_census.py" || {
    echo "" >&2
    echo "pre-commit: fixture census FAILED — commit refused (a gate/seen-red is not intact, ADR-0011/C20)." >&2
    exit 1
}

# layout_census — DISABLED here (maintainer ruling, 2026-07-09): research repo, census is for
# downstream instances; disabled until further notice. gates/layout_census.py is untouched and
# remains shipped tooling — a downstream template consumer re-enables this block to get the
# ls-legibility guarantee in their own repo. Not removed from gates/, only from this hook's
# enforced set.

# doc-legibility — REPORT-ONLY (see header): runs for visibility, never blocks, pending the
# corpus acronym-sweep (BACKLOG / finding 48). Its exit code is deliberately NOT propagated.
"$PY" "$REPO_ROOT/gates/doc-legibility/check.py" >&2 || \
    echo "pre-commit: doc-legibility reported undefined acronyms (REPORT-ONLY — not blocking; see BACKLOG finding 48)." >&2
