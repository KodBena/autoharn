        print("  'opus', 'claude-sonnet-4-5' -- no spaces, so grouping by exact string match is honest)", file=sys.stderr)
        print("  SEAM-VERDICT must be non-empty (what the seam review concluded, in the orchestrator's", file=sys.stderr)
        print("  own words -- no closed vocabulary is imposed here)", file=sys.stderr)
        print("  DEFECTS-FOUND-AT-SEAM must be non-empty (name what was found, or state '0'/'none' --", file=sys.stderr)
        print("  never blank; a clean seam is a fact worth recording, not an absence)", file=sys.stderr)
        print("  NOTES must be non-empty (free text; state 'none' if there is nothing to add)", file=sys.stderr)
        print(f"  received ({len(parts)} field(s), whitespace-normalized): {normalized}", file=sys.stderr)
        print("  NOTHING was written -- fix the statement and re-run.", file=sys.stderr)
        print("  this is an OUTCOME for RETROSPECTIVE model-capability observation ONLY, never for", file=sys.stderr)
        print("  policing a model or a task -- the same never-police invariant `estimate:`/`actual:`", file=sys.stderr)
        print("  state applies here verbatim; MODEL is DECLARED-BY-DISPATCHER grade (diagnostic, not", file=sys.stderr)
        print("  witnessed) -- only the INTAKE SHAPE is refused here, never the observation's content.", file=sys.stderr)
        return False

    if len(parts) != len(fields):
        return refuse(f"expected exactly {len(fields)} '|'-separated fields, got {len(parts)}")
    slug, model, seam_verdict, defects, notes = parts
    if not _SLUG_RE.match(slug):
        return refuse(f"TASK-SLUG field {slug!r} does not match ^[a-z0-9][a-z0-9-]*$ (a bare slug, no spaces)")
    if not model_re.match(model):
        return refuse(f"MODEL field {model!r} does not match ^[a-zA-Z0-9][a-zA-Z0-9._-]*$ (a bare model identifier, no spaces)")
    if not seam_verdict:
        return refuse("SEAM-VERDICT field is empty -- state what the seam review concluded")
    if not defects:
        return refuse("DEFECTS-FOUND-AT-SEAM field is empty -- name what was found, or state '0'/'none'")
    if not notes:
        return refuse("NOTES field is empty -- state 'none' if there is nothing to add")
    return True


def _check_review_done(trimmed: str) -> bool:
    normalized = _normalize_statement(trimmed)
    body = normalized[len("review-done:"):]
    parts = [p.strip() for p in body.split("|")]
    fields = ("SLUG", "DISPOSITION")

    def refuse(msg: str) -> bool:
        print(f"led: REFUSED -- malformed 'review-done:' statement -- {msg}.", file=sys.stderr)
        print("  grammar (user-guide/USER-RECIPES-FAQ.md \"Your review queue\"):", file=sys.stderr)
        print("    review-done: <SLUG> | <DISPOSITION>", file=sys.stderr)
        print(f"  the two fields, in order: {', '.join(fields)}", file=sys.stderr)
        print("  SLUG must match ^[a-z0-9][a-z0-9-]*$ (a bare slug, no spaces -- the same grammar", file=sys.stderr)
        print("  'review:' uses)", file=sys.stderr)
        print("  DISPOSITION must be non-empty (state what you decided, or what happened)", file=sys.stderr)
        print(f"  received ({len(parts)} field(s), whitespace-normalized): {normalized}", file=sys.stderr)
        print("  NOTHING was written -- fix the statement and re-run.", file=sys.stderr)
        return False

    if len(parts) != len(fields):
        return refuse(f"expected exactly {len(fields)} '|'-separated fields, got {len(parts)}")
    slug, disposition = parts
    if not _SLUG_RE.match(slug):
        return refuse(f"SLUG field {slug!r} does not match ^[a-z0-9][a-z0-9-]*$ (a bare slug, no spaces)")
    if not disposition:
        return refuse("DISPOSITION field is empty -- state what you decided, or what happened")
    return True


# Ordered so `review-done:` is tried before `review:` -- both are literal, disjoint prefixes
# ("review-done:" does not start with "review:"), so order does not actually matter for
# correctness, but trying the longer/more-specific prefix first is the clearer read.
_GRAMMAR_CHECKERS = [
    ("resource:", _check_resource),
    ("estimate:", _check_estimate),
    ("actual:", _check_actual),
    ("taxon:", _check_taxon),
    ("interface:", _check_interface),
    ("outcome:", _check_outcome),
    ("review-done:", _check_review_done),
    ("review:", _check_review_queue),
]


def _preflight_grammar(statement: str) -> bool:
    """Returns True if `statement` is either subject to none of the eight ported grammars
    (resource:/estimate:/actual:/taxon:/interface:/outcome:/review:/review-done: -- the
    original six from phase 1 plus actual:/outcome: added phase 1B, ledger row 1149), or
    subject to one and it validates; False (having already printed REFUSED teach-text to
    stderr, byte-identical to legacy-led.tmpl's own) if a recognized prefix's statement fails
    its own grammar. Runs ONLY on the generic <kind> <statement...> write path (cmd_generic),
    exactly where legacy runs its checks -- never on `led review`/`led work *`, which build
    their own statements from typed fields, not user free text under one of these prefixes."""
    trimmed = statement.lstrip()
    for prefix, checker in _GRAMMAR_CHECKERS:
        if trimmed.startswith(prefix):
            return checker(trimmed)
    return True


_CLI_USAGE_HELP_TOKEN_RE = re.compile(r'(?:^|\s)--help(?:\s|$)')
_CLI_USAGE_LINE_RE = re.compile(r'(?:^|\n)\s*usage:\s', re.IGNORECASE)
_CLI_USAGE_FLAG_RE = re.compile(r'(?:^|\s)--[a-zA-Z][\w-]*')
_CLI_USAGE_FLAG_RUN_THRESHOLD = 3


def _cli_usage_guard_violation(statement: str) -> str | None:
    """Ledger row 1159 (garbage-statement guard, class-ratified fail-safe additive-refusal
    lane): the maintainer's own testimony -- 'I've never been able to understand the syntax of
    ./led and always too afraid to try, lest I add something to the ledger by mistake... fumbled
    agent invocations have WRITTEN CLI usage text into a ledger as permanent rows.' This is a
    HEURISTIC NET OVER THE CLASS (ADR-0011 Rule 4), never an exhaustive parser of every CLI's
    own usage-text shape -- three independent, deliberately loose fingerprints, any one of which
    is enough: (1) a bare `--help` token (the single most common fumbled-invocation residue);
    (2) a `usage:` line (argparse's/legacy-led.tmpl's own convention, and this file's own,
    verbatim); (3) a RUN of three or more `--flag`-shaped tokens (captured multi-option usage/
    help text reads as a dense cluster of these; an ordinary prose statement essentially never
    does). Returns the violation's own human-readable reason, or None when the statement is
    clean. Runs ONLY on the generic <kind> <statement...> write path (cmd_generic), exactly
    where `led review`/`led work *` do NOT run it -- those build their statements from typed
    fields, never raw user free text captured from a terminal."""
    if _CLI_USAGE_HELP_TOKEN_RE.search(statement):
        return "contains a bare '--help' token"
    if _CLI_USAGE_LINE_RE.search(statement):
        return "contains a 'usage:' line"
    flag_hits = _CLI_USAGE_FLAG_RE.findall(statement)
    if len(flag_hits) >= _CLI_USAGE_FLAG_RUN_THRESHOLD:
        sample = ", ".join(sorted({h.strip() for h in flag_hits})[:5])
        return f"contains a run of {len(flag_hits)} option-flag-shaped tokens ({sample}, ...)"
    return None


def cmd_json(cfg: bcc.ServedConfig, surface: str, source: str) -> int:
    if surface not in ("ledger", "review", "registration", "obligation"):
        print(f"led --json: REFUSED -- unrecognized surface {surface!r} (expected one of "
              f"ledger, review, registration, obligation)", file=sys.stderr)
        return 4
    text = sys.stdin.read() if source == "-" else Path(source).read_text(encoding="utf-8")
    try:
        payload = json.loads(text)
    except json.JSONDecodeError as e:
        print(f"led --json: REFUSED -- {source} is not valid JSON ({e})", file=sys.stderr)
        return 4
    if not isinstance(payload, dict):
        print(f"led --json: REFUSED -- payload must be a JSON object, got {type(payload).__name__}",
              file=sys.stderr)
        return 4
    return bcc.write_and_report(cfg.base, surface, payload)


def cmd_recent(cfg: bcc.ServedConfig, n: int, current_only: bool) -> int:
    """`led current [N]`: the legacy tool's own `ledger_current` reading, exactly. `led --recent
    [N]`: the legacy tool additionally walks the RAW ledger (superseded rows included, visibly
    marked) -- no boundary route serves the raw table (every route reads a KERNEL VIEW, spec §5's
    "no truth of its own" applied to routes too; a raw-ledger route is out of THIS amendment's own
    scope). Rather than silently narrowing --recent to look like `current`, this rebase says so
    loudly on stderr and serves the SAME `/rows/current` reading -- `./legacy/led --recent` is the
    byte-faithful original when the superseded-inclusive view is actually needed."""
    if not current_only:
        print("led --recent: NOTE -- this rebase's --recent reads /rows/current (in-force rows "
              "only, no raw-ledger route exists on the boundary) -- ./legacy/led --recent is "
              "byte-faithful if you need the superseded-inclusive raw read.", file=sys.stderr)
    rows = bcc.get_all_rows(cfg.base, "/rows/current", cursor="after_id")
    for r in sorted(rows, key=lambda r: -r["id"])[:n]:
        print(f"[{r['id']}] {r['kind']}: {r.get('statement', '')}")
    return 0


def cmd_show(cfg: bcc.ServedConfig, row_id: int) -> int:
    try:
        row = bcc.get_json(cfg.base, f"/rows/{row_id}")
    except bcc.BoundaryRefusal as e:
        if e.status == 404:
            print(f"led show: REFUSED -- no row {row_id}.", file=sys.stderr)
            print("  See 'led --recent [N]' or 'led current [N]' for ids that actually exist.", file=sys.stderr)
            return 1
        raise
    for k, v in row.items():
        if v is not None:
            print(f"{k:28s}: {v}")
    return 0


