    token_exact_re = re.compile(r"^\d+(\.\d+)?[KM]$", re.IGNORECASE)
    bare_number_re = re.compile(r"^\d+$")

    def refuse(msg: str) -> bool:
        print(f"led: REFUSED -- malformed 'actual:' statement -- {msg}.", file=sys.stderr)
        print("  grammar (user-guide/USER-RETROSPECTIVE-RECIPE.md \"The 'actual:' statement grammar\"):", file=sys.stderr)
        print("    actual: <TASK-SLUG> | <TOOL-CALLS> | <SUBAGENT-SPAWNS> | <WALL-CLOCK> | <TOKENS> | <SOURCE>", file=sys.stderr)
        print(f"  the six fields, in order: {', '.join(fields)}", file=sys.stderr)
        print("  TASK-SLUG must match ^[a-z0-9][a-z0-9-]*$ (a bare slug, no spaces -- may name a whole", file=sys.stderr)
        print("  work item or a single spawn within it, e.g. item-slug-b-round-2)", file=sys.stderr)
        print("  TOOL-CALLS/SUBAGENT-SPAWNS must be a bare non-negative integer -- NEVER a range (a", file=sys.stderr)
        print("  measurement is a point, not a range; this is the one deliberate divergence from", file=sys.stderr)
        print("  estimate:'s matching fields)", file=sys.stderr)
        print("  WALL-CLOCK must be a duration like 20m/2h/1d/90s, or a range 10m-30m", file=sys.stderr)
        print(f"  TOKENS must be an exact-ish K/M-suffixed count (204K, 1.2M), or one of the closed OOM", file=sys.stderr)
        print(f"  bucket vocabulary {' | '.join(valid_token_oom)}, or a bare number no greater than 999", file=sys.stderr)
        print("  (a bare number above 999 is refused -- ambiguous between a real count and a typo)", file=sys.stderr)
        print("  SOURCE must be non-empty (state where the measurement came from)", file=sys.stderr)
        print(f"  received ({len(parts)} field(s), whitespace-normalized): {normalized}", file=sys.stderr)
        print("  NOTHING was written -- fix the statement and re-run.", file=sys.stderr)
        print("  this is an ACTUAL for operational-efficiency retrospectives ONLY, never for cost", file=sys.stderr)
        print("  policing (the same never-police invariant estimate: states, stated twice at", file=sys.stderr)
        print("  commissioning, applies here verbatim) -- WALL-CLOCK/TOKENS are harness-sourced and", file=sys.stderr)
        print("  DIAGNOSTIC-GRADE, permanently, per the action-stream ruling (ledgered 2026-07-13);", file=sys.stderr)
        print("  see user-guide/USER-RETROSPECTIVE-RECIPE.md's actual: grammar section for the", file=sys.stderr)
        print("  TOOL-CALLS/SUBAGENT-SPAWNS grade exception -- only the INTAKE SHAPE is refused", file=sys.stderr)
        print("  here, never the measurement's meaning.", file=sys.stderr)
        return False

    if len(parts) != len(fields):
        return refuse(f"expected exactly {len(fields)} '|'-separated fields, got {len(parts)}")
    slug, tool_calls, spawns, wall_clock, tokens, source = parts
    if not _SLUG_RE.match(slug):
        return refuse(f"TASK-SLUG field {slug!r} does not match ^[a-z0-9][a-z0-9-]*$ (a bare slug, no spaces)")
    if not point_count_re.match(tool_calls):
        return refuse(f"TOOL-CALLS field {tool_calls!r} is not a bare non-negative integer (ranges are refused here)")
    if not point_count_re.match(spawns):
        return refuse(f"SUBAGENT-SPAWNS field {spawns!r} is not a bare non-negative integer (ranges are refused here)")
    if not duration_re.match(wall_clock):
        return refuse(f"WALL-CLOCK field {wall_clock!r} is not a duration like 20m/2h/1d/90s or a range 10m-30m")
    tokens_ok = (tokens in valid_token_oom or bool(token_exact_re.match(tokens))
                 or (bool(bare_number_re.match(tokens)) and int(tokens) <= 999))
    if not tokens_ok:
        return refuse(f"TOKENS field {tokens!r} is not an exact-ish K/M-suffixed count, a valid OOM "
                      f"bucket {valid_token_oom}, or a bare number <= 999")
    if not source:
        return refuse("SOURCE field is empty -- state where the measurement came from")
    return True


