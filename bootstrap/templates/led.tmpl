    except bcc.BoundaryRefusal as e:
        if e.status == 404:
            print(f"led artifact stat: REFUSED -- no artifact registered with hash '{hash_}'.",
                  file=sys.stderr)
            return 1
        raise
    for k, v in row.items():
        if v is not None:
            print(f"{k:15s}: {v}")
    return 0


def cmd_review(cfg: bcc.ServedConfig, entry_id: int, verdict: str, independence: str,
               antecedent: int | None, statement: str) -> int:
    actor = _resolve_actor(cfg)
    # basis = statement, VERBATIM -- the legacy tool's own choice (bootstrap/templates/
    # legacy-led.tmpl's `led review` case: "basis \"$statement\"", no separate --basis flag on
    # THIS verb -- contrast `led principal grant-competence`'s own --basis, an unrelated flag on
    # a different verb this rebase does not cover).
    payload: dict = {"regards": entry_id, "statement": statement, "verdict": verdict,
                      "independence": independence, "basis": statement}
    if antecedent is not None:
        payload["antecedent"] = antecedent
    if actor is not None:
        payload["actor"] = actor
    return bcc.write_and_report(cfg.base, "review", payload)


def _world_root() -> Path:
    """The directory the deployment record was actually found in -- the SAME resolution legacy-
    led.tmpl's `decomposition-review-status`/`briefing` use (never a second hand-derived notion
    of "world root", ADR-0012 P1)."""
    return DEPLOYMENT_PATH.resolve().parent


def cmd_decomposition_review_status(cfg: bcc.ServedConfig) -> int:
    """Ported off legacy-led.tmpl's own `decomposition-review-status`: (a) mode, read from
    <world-root>/.claude/apparatus.json's mechanisms.decomposition_review.mode, defaulted/
    validated line-for-line the same way legacy's own inline copy is (default 'observe', an
    unrecognized mode string never widens permissions); (b) countersign_obligation total/
    undischarged counts -- read here via GET /views/countersign_obligation and GET
    /views/review_gap, both walked to completion, and counted in Python rather than one SQL
    COUNT/FILTER (review_gap is NOT scope-filtered, same note as legacy's own doc comment);
    (c) the same one-line verdict."""
    world_root = _world_root()
    valid = ("off", "observe", "enforce")
    default = "observe"
    apparatus_path = world_root / ".claude" / "apparatus.json"
    try:
        apparatus = json.loads(apparatus_path.read_text(encoding="utf-8"))
        if not isinstance(apparatus, dict):
            apparatus = {}
    except Exception:
        apparatus = {}
    mechs = apparatus.get("mechanisms")
    entry = mechs.get("decomposition_review") if isinstance(mechs, dict) else None
    raw = entry.get("mode") if isinstance(entry, dict) else None
    if raw is None:
        mode = default
    elif raw in valid:
        mode = raw
    else:
        print(f"[apparatus] WARNING: mechanisms.decomposition_review.mode={raw!r} in "
              f"{apparatus_path} is unrecognized (must be one of {valid}) -- never widening "
              f"permissions; falling back to {default!r}.", file=sys.stderr)
        mode = default

    try:
        obligations = bcc.get_all_rows(cfg.base, "/views/countersign_obligation", cursor="after_slug")
        gap_rows = bcc.get_all_rows(cfg.base, "/views/review_gap", cursor="after_id")
    except bcc.BoundaryRefusal as e:
        if e.status == 404:
            print(f"mode: {mode}")
            print("countersign_obligation: UNAVAILABLE -- this world's kernel predates")
            print("  countersign_obligation (kernel/lineage/s15-schema.sql). Apply s15 (or a later")
            print("  generation) to this schema as a maintainer act to adopt the obligation regime, or --")
            print("  if this world never needs it -- there is nothing more to do here.")
            print("verdict: OFF" if mode == "off" else "verdict: VACUOUS (no obligation rows)")
            return 0
        raise
    gap_actors = {r.get("actor") for r in gap_rows}
    total = len(obligations)
    undischarged = sum(1 for o in obligations if o.get("obliges_actor") in gap_actors)
    print(f"mode: {mode}")
    print(f"countersign_obligation: total={total} undischarged={undischarged}")
    if mode == "off":
        print("verdict: OFF")
    elif total == 0:
        print("verdict: VACUOUS (no obligation rows)")
    elif mode == "enforce":
        print("verdict: ARMED-ENFORCING")
    else:
        print("verdict: ARMED-OBSERVING")
    return 0


_BRIEFING_TEXT = """\
Fresh-agent rules briefing -- three rules a new agent otherwise discovers only by tripping them.

1. The ledger change-gate. A source-file edit must be preceded by a ledger entry naming that
   file: `./led -f <basename> decision "<why>"`. Then RE-ISSUE THE SAME EDIT -- the gate re-checks
   on every attempt, so retrying after the insert is the whole fix. Do not write the file first
   and ledger it after; the gate blocks the write, not the record.

2. Flag-order asymmetry. Generic ledger flags go BEFORE the kind word: `./led --refs row:N
   decision "..."`. `led work <sub>` flags go AFTER the slug/title/verdict instead: `./led work
   open <slug> "<title>" --parent <parent-slug>`. A flag placed on the wrong side of that boundary
   is REFUSED, never silently swallowed into the statement's own prose -- move it to the other
   side and re-issue.

3. Same-actor countersign (segregation of duties). `led review <id> attest ...` is refused
   when the countersigning actor authored the row it regards -- keyed on actor/principal
   identity alone, unconditionally, regardless of the independence value chosen (the ledger
   INSERT that fires this check lands before independence is even known). The only fix:
   register a distinct principal (`./led register-principal <name> <class>`) and set
   LED_ACTOR=<name> before re-issuing the review. Solo-world fallback (no second principal
   genuinely available): register one anyway for the same operator, and countersign through
   it disclosing `independence self-review` -- honest labeling of the countersign, not a
   substitute for the distinct-actor step.

See user-guide/USER-RECIPES-FAQ.md for the full recipe corpus these rules are drawn from."""


def cmd_briefing() -> int:
    """Ported verbatim off legacy-led.tmpl's own `briefing` -- READ-ONLY, NO DB ACCESS AT ALL
    (this is why it takes no `cfg` -- unlike every other command here). Extension point:
    <world-root>/.claude/apparatus.json's mechanisms.rules_briefing.extra_items."""
    print(_BRIEFING_TEXT)
    world_root = _world_root()
    apparatus_path = world_root / ".claude" / "apparatus.json"
    try:
        apparatus = json.loads(apparatus_path.read_text(encoding="utf-8"))
        if not isinstance(apparatus, dict):
            apparatus = {}
    except FileNotFoundError:
        apparatus = {}
    except Exception as e:
        print(f"[led briefing] WARNING: could not parse {apparatus_path} "
              f"({type(e).__name__}: {e}) -- skipping world-specific extra_items; core "
              f"briefing above still stands.", file=sys.stderr)
        apparatus = {}
    mechs = apparatus.get("mechanisms")
    entry = mechs.get("rules_briefing") if isinstance(mechs, dict) else None
    if entry is not None and not isinstance(entry, dict):
        print(f"[led briefing] WARNING: mechanisms.rules_briefing in {apparatus_path} must be "
              f"a JSON object -- got {entry!r}; ignoring it, core briefing above still stands.",
              file=sys.stderr)
        return 0
    extra = entry.get("extra_items") if isinstance(entry, dict) else None
    if isinstance(entry, dict) and "extra_items" in entry and (
            not isinstance(extra, list) or not all(isinstance(x, str) for x in extra)):
        print(f"[led briefing] WARNING: mechanisms.rules_briefing.extra_items in "
              f"{apparatus_path} must be a JSON array of strings -- got {extra!r}; ignoring "
              f"it, core briefing above still stands.", file=sys.stderr)
        return 0
    if not extra:
        return 0
    print()
    print("Additional world-specific rules (.claude/apparatus.json mechanisms.rules_briefing.extra_items):")
    for item in extra:
        print(f"  - {item}")
    return 0


def cmd_work_open(cfg: bcc.ServedConfig, argv: list[str]) -> int:
    """Ported off legacy-led.tmpl's `work open`'s own s43 boundary branch: an s43 kernel carries
    s28 (work_parent)/s33 (work_discharge) by construction, so there is no column-existence
    gate here -- an omitted --parent/--discharge is simply an omitted payload key, and a
    world whose kernel genuinely lacks s28/s33 gets the KERNEL's own refusal (the boundary's
    own charter: the kernel enforces the real invariants, this shim only builds the payload)."""
    parent = discharge = refs = supersedes = None
    args: list[str] = []
    it = iter(argv)
    for tok in it:
        if tok == "--parent":
            parent = next(it, None)
        elif tok == "--discharge":
            discharge = next(it, None)
        elif tok == "--refs":
            refs = next(it, None)
        elif tok == "--supersedes":
            supersedes = next(it, None)
        elif tok.startswith("--"):
            print(f"led work open: REFUSED -- unrecognized flag '{tok}'.", file=sys.stderr)
            print("  led work open <slug> <title...> accepts only: --parent <parent-slug>,", file=sys.stderr)
            print("  --discharge composite, --refs <ref>, --supersedes <id>.", file=sys.stderr)
            print("  NOTHING was written.", file=sys.stderr)
            return 1
        else:
            args.append(tok)
    if len(args) < 2:
        print("usage: led work open <slug> <title...> [--parent <parent-slug>] "
              "[--discharge composite] [--refs <ref>] [--supersedes <id>]", file=sys.stderr)
        return 4
    if discharge and discharge != "composite":
        print(f"led work open: REFUSED -- --discharge accepts exactly one value: composite "
              f"(got {discharge!r}).", file=sys.stderr)
        return 1
    slug, title = args[0], " ".join(args[1:])
    if supersedes:
        print(f"led work open: --supersedes {supersedes} -- this opening act retracts ledger "
              f"row {supersedes} from current truth (kernel/lineage/s31-supersession-uniform-"
              f"retraction.sql: uniform across every kind, reinstatement-free). If row "
              f"{supersedes} was itself a work_opened row, ITS SLUG IS PERMANENTLY BURNED -- "
              f"'{slug}' must be, and is, a new, different slug.", file=sys.stderr)
    actor = _resolve_actor(cfg)
    payload: dict = {"kind": "work_opened", "work_slug": slug, "work_title": title,
                      "statement": f"work_opened: {slug} -- {title}"}
    if parent:
        payload["work_parent"] = parent
    if discharge:
        payload["work_discharge"] = discharge
    if refs:
        payload["refs"] = refs
    if supersedes:
        payload["supersedes"] = int(supersedes)
    if actor is not None:
        payload["actor"] = actor
    return bcc.write_and_report(cfg.base, "ledger", payload)


