def cmd_work_depends(cfg: bcc.ServedConfig, argv: list[str]) -> int:
    edge_type = supersedes = None
    args: list[str] = []
    it = iter(argv)
    for tok in it:
        if tok == "--type":
            edge_type = next(it, None)
        elif tok == "--supersedes":
            supersedes = next(it, None)
        elif tok.startswith("--"):
            print(f"led work depends: REFUSED -- unrecognized flag '{tok}'.", file=sys.stderr)
            print("  led work depends <slug> <on-slug> accepts only: --type", file=sys.stderr)
            print("  blocks-close|blocks-start|informs, --supersedes <ledger-id>.", file=sys.stderr)
            print("  NOTHING was written.", file=sys.stderr)
            return 1
        else:
            args.append(tok)
    if len(args) < 2:
        print("usage: led work depends <slug> <on-slug> [--type blocks-close|blocks-start|informs] "
              "[--supersedes <ledger-id>]", file=sys.stderr)
        return 4
    slug, on = args[0], args[1]
    if edge_type and edge_type not in ("blocks-close", "blocks-start", "informs"):
        print(f"led work depends: REFUSED -- --type must be blocks-close, blocks-start, or "
              f"informs (got {edge_type!r}).", file=sys.stderr)
        return 1
    # --supersedes VALIDATION (ledger item led-work-depends-supersedes), ported off legacy's own
    # three checks -- (i)/(ii) below read GET /rows/{id} (raw ledger by id) and a walk of
    # /rows/current for "already superseded"; DISCLOSED NARROWING versus legacy's raw-ledger
    # SQL -- see this file's own SCOPE comment near the top for the exact residual.
    if supersedes:
        try:
            target = bcc.get_json(cfg.base, f"/rows/{supersedes}")
        except bcc.BoundaryRefusal as e:
            if e.status == 404:
                print(f"led work depends: REFUSED -- --supersedes {supersedes} does not name "
                      f"any ledger row. NOTHING was written.", file=sys.stderr)
                return 1
            raise
        if target.get("kind") != "work_depends_on":
            print(f"led work depends: REFUSED -- --supersedes {supersedes} names a "
                  f"'{target.get('kind')}' row, not a work_depends_on row. NOTHING was written.",
                  file=sys.stderr)
            return 1
        current_rows = bcc.get_all_rows(cfg.base, "/rows/current", cursor="after_id")
        superseder = next((r for r in current_rows if str(r.get("supersedes")) == str(supersedes)), None)
        if superseder is not None:
            print(f"led work depends: REFUSED -- --supersedes {supersedes} is already "
                  f"superseded (by row {superseder['id']}). NOTHING was written.", file=sys.stderr)
            return 1
    if not edge_type:
        print(f"led work depends: recorded as informs (advisory only -- never enforced at "
              f"close or claim); if {on} must be finished before {slug} may close, use "
              f"--type blocks-close; if {on} must be CLOSED before {slug} may be CLAIMED, use "
              f"--type blocks-start (s39).", file=sys.stderr)
    actor = _resolve_actor(cfg)
    payload: dict = {"kind": "work_depends_on", "work_slug": slug, "work_depends_on": on,
                      "statement": f"work_depends_on: {slug} depends on {on}"}
    if edge_type:
        payload["edge_type"] = edge_type
    if supersedes:
        payload["supersedes"] = int(supersedes)
    if actor is not None:
        payload["actor"] = actor
    return bcc.write_and_report(cfg.base, "ledger", payload)


def _slug_claimant(cfg: bcc.ServedConfig, slug: str):
    """Reads GET /views/work_item_current for <slug>'s own `claimant` field -- the led-side
    claim-before-close gate's data source, ported off legacy's own raw
    `SELECT EXISTS(... kind='work_claimed' AND work_slug=...)` scan -- a disclosed
    representation change (reads the CURRENT view rather than the raw table), same true/false
    answer for the ordinary case (see this file's own SCOPE comment)."""
    rows = bcc.get_all_rows(cfg.base, "/views/work_item_current", cursor="after_slug")
    for r in rows:
        if r.get("slug") == slug:
            return r.get("claimant")
    return None


def cmd_work_close(cfg: bcc.ServedConfig, argv: list[str]) -> int:
    witness = review_witness = None
    review_deferred = review_bookkeeping = strict = False
    supersedes = None
    args: list[str] = []
    it = iter(argv)
    for tok in it:
        if tok == "--witness":
            witness = next(it, None)
        elif tok == "--review-witness":
            review_witness = next(it, None)
        elif tok == "--review-deferred":
            review_deferred = True
        elif tok == "--review-bookkeeping":
            review_bookkeeping = True
        elif tok == "--strict":
            strict = True
        elif tok == "--supersedes":
            supersedes = next(it, None)
        elif tok.startswith("--"):
            print(f"led work close: REFUSED -- unrecognized flag '{tok}'.", file=sys.stderr)
            print("  led work close <slug> <resolution> accepts only: --witness <ref>,", file=sys.stderr)
            print("  --review-witness <ref>, --review-deferred, --review-bookkeeping, --strict,", file=sys.stderr)
            print("  --supersedes <id>.", file=sys.stderr)
            print("  NOTHING was written.", file=sys.stderr)
            return 1
        else:
            args.append(tok)
    if len(args) < 2:
        print("usage: led work close <slug> <resolution> (--review-witness <ref> | "
              "--review-deferred | --review-bookkeeping --witness commit:<sha>) "
              "[--witness <ref>] [--strict]", file=sys.stderr)
        return 4
    slug, resolution = args[0], args[1]
    if resolution not in ("shipped", "superseded", "dropped", "deferred"):
        print(f"led work close: REFUSED -- resolution must be exactly one of shipped, "
              f"superseded, dropped, deferred (got {resolution!r}). NOTHING was written.",
              file=sys.stderr)
        return 1
    if resolution == "shipped" and not (witness and witness.strip()):
        print("led work close: REFUSED -- resolution=shipped REQUIRES a non-blank --witness "
              "<ref>. NOTHING was written.", file=sys.stderr)
        return 1
    # claim-before-close gate (led-side; the kernel's own trigger checks only that <slug> was
    # OPENED, not that anyone claimed it) -- run-5 forensics: two work items were closed with no
    # claim ever landing, unflagged.
    if _slug_claimant(cfg, slug) is None:
        print(f"led work close: REFUSED -- slug '{slug}' has no work_claimed row (claim it "
              f"first): ./led work claim {slug}", file=sys.stderr)
        return 1
    rc_count = sum([bool(review_witness), review_deferred, review_bookkeeping])
    if rc_count > 1:
        print("led work close: REFUSED -- --review-witness, --review-deferred, and", file=sys.stderr)
        print("  --review-bookkeeping are the THREE CONSTRUCTORS of a review disposition;", file=sys.stderr)
        print("  exactly ONE, never more than one, in one close act.", file=sys.stderr)
        return 1
    if rc_count == 0:
        print("led work close: REFUSED -- a review-silent close is unrepresentable.", file=sys.stderr)
        print("  Choose exactly ONE constructor:", file=sys.stderr)
        print("    --review-witness <ref>       a review already exists; cite it", file=sys.stderr)
        print("    --review-deferred            this close act itself becomes the review obligation", file=sys.stderr)
        print("    --review-bookkeeping         a judgment-free close whose entire content is a git", file=sys.stderr)
        print("                                 commit landing -- requires --witness commit:<sha>.", file=sys.stderr)
        return 1
    if review_deferred and strict:
        print("led work close: REFUSED -- --review-deferred + --strict is a contradiction in "
              "terms.", file=sys.stderr)
        return 1
    if review_bookkeeping and strict:
        print("led work close: REFUSED -- --review-bookkeeping + --strict is a contradiction "
              "in terms.", file=sys.stderr)
        return 1
    if review_bookkeeping:
        if not witness:
            print("led work close: REFUSED -- --review-bookkeeping requires --witness "
                  "commit:<sha> -- no --witness was given.", file=sys.stderr)
            return 1
        if not re.match(r"^commit:[0-9a-f]{7,40}$", witness):
            print(f"led work close: REFUSED -- --review-bookkeeping's --witness {witness!r} "
                  f"failed the COMMIT-SHAPE check (must match ^commit:[0-9a-f]{{7,40}}$).",
                  file=sys.stderr)
            return 1
        sha = witness[len("commit:"):]
        world_root = _world_root()
        r = subprocess.run(["git", "-C", str(world_root), "cat-file", "-e", f"{sha}^{{commit}}"],
                            capture_output=True)
        if r.returncode != 0:
            print(f"led work close: REFUSED -- --review-bookkeeping's --witness commit "
                  f"'{sha}' failed the COMMIT-EXISTENCE check against {world_root}.",
                  file=sys.stderr)
            return 1
    if review_witness:
        disposition, review_ref = "witnessed", review_witness
    elif review_bookkeeping:
        disposition, review_ref = "bookkeeping", witness
    else:
        disposition, review_ref = "deferred", None
    if supersedes:
        print(f"led work close: --supersedes {supersedes} -- this close retracts ledger row "
              f"{supersedes} from current truth. If row {supersedes} was itself a work_closed "
              f"row for '{slug}', the item now READS OPEN AGAIN.", file=sys.stderr)
    actor = _resolve_actor(cfg)
    payload: dict = {"kind": "work_closed", "work_slug": slug, "work_resolution": resolution,
                      "work_review_disposition": disposition, "work_strict_close": strict,
                      "statement": f"work_closed: {slug} ({resolution})"}
    if witness:
        payload["work_witness"] = witness
    if review_ref:
        payload["work_review_ref"] = review_ref
    if supersedes:
        payload["supersedes"] = int(supersedes)
    if actor is not None:
        payload["actor"] = actor
    return bcc.write_and_report(cfg.base, "ledger", payload)


