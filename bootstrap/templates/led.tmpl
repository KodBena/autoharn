      # column stays NULL and the kernel's set_actor trigger fills the default connection
      # principal, unchanged from before this fix. THIS was the witnessed misattribution class
      # (BACKLOG run-7 forensics, ledger row 63; comment at the top of this file ~line 636-638):
      # `led work open` was the ONE ledger-writing path that never called resolve_actor at all,
      # so LED_ACTOR silently landed every work_opened row under the default connection
      # principal regardless of what the operator set. resolve_actor (defined near the top of
      # this file) is now the ONE place LED_ACTOR is read and validated, shared with `led
      # review`, `led work claim`, and the generic <kind> <statement> path -- ALL FOUR of this
      # subcommand's INSERT branches below carry the same `actor` column and the same bind, so
      # no kernel-feature branch is left with the silent gap one level down.
      #
      # Four explicit branches (has_parent_col x has_discharge_col), each a STATIC INSERT column
      # list bound purely via psql -v -- mirrors this file's own standing convention of never
      # building SQL text dynamically from feature flags (auditability: every possible INSERT
      # shape is grep-able in this file, not synthesized at runtime). `supersedes` is bound and
      # inserted in EVERY branch (base schema since s10, unlike work_parent/work_discharge --
      # no column-existence gate needed, same reasoning as `refs`), via the identical
      # NULLIF(:'supersedes', '')::bigint cast the generic top-of-file path uses (line ~2429
      # above) -- one column, one write shape, never a second hand-copied cast. A same-slug
      # reuse after supersession is refused by validate_work_item()'s duplicate-open branch
      # (s31 Element 6, byte-identical condition, redo-idiom-naming message) -- that refusal
      # surfaces here as psql's own ERROR output (RAISE EXCEPTION text is already fully framed
      # and legible; this file adds no second wrapper around it, matching every other `exec
      # psql` INSERT in this subcommand).
      if [ "$has_parent_col" = "t" ] && [ "$has_discharge_col" = "t" ]; then
        exec psql -h "$PGHOST" -d "$PGDB" -v ON_ERROR_STOP=1 \
          -v slug="$slug" -v title="$title" -v parent="$parent" -v discharge="$discharge" \
          -v refs="$refs" -v supersedes="$supersedes" -v actor_name="$actor_name" \
          -v statement="work_opened: ${slug} -- ${title}" <<SQL
        SET ROLE ${ROLE};
        SET search_path = ${SCHEMA}, ${KERNEL};
        INSERT INTO ${SCHEMA}.ledger (kind, work_slug, work_title, work_parent, work_discharge, refs, supersedes, statement, actor)
        VALUES ('work_opened', :'slug', :'title', NULLIF(:'parent', ''), NULLIF(:'discharge', ''), NULLIF(:'refs', ''), NULLIF(:'supersedes', '')::bigint, :'statement',
                (SELECT id FROM principal WHERE name = NULLIF(:'actor_name', '')));
SQL
      elif [ "$has_parent_col" = "t" ]; then
        exec psql -h "$PGHOST" -d "$PGDB" -v ON_ERROR_STOP=1 \
          -v slug="$slug" -v title="$title" -v parent="$parent" \
          -v refs="$refs" -v supersedes="$supersedes" -v actor_name="$actor_name" \
          -v statement="work_opened: ${slug} -- ${title}" <<SQL
        SET ROLE ${ROLE};
        SET search_path = ${SCHEMA}, ${KERNEL};
        INSERT INTO ${SCHEMA}.ledger (kind, work_slug, work_title, work_parent, refs, supersedes, statement, actor)
        VALUES ('work_opened', :'slug', :'title', NULLIF(:'parent', ''), NULLIF(:'refs', ''), NULLIF(:'supersedes', '')::bigint, :'statement',
                (SELECT id FROM principal WHERE name = NULLIF(:'actor_name', '')));
SQL
      elif [ "$has_discharge_col" = "t" ]; then
        exec psql -h "$PGHOST" -d "$PGDB" -v ON_ERROR_STOP=1 \
          -v slug="$slug" -v title="$title" -v discharge="$discharge" \
          -v refs="$refs" -v supersedes="$supersedes" -v actor_name="$actor_name" \
          -v statement="work_opened: ${slug} -- ${title}" <<SQL
        SET ROLE ${ROLE};
        SET search_path = ${SCHEMA}, ${KERNEL};
        INSERT INTO ${SCHEMA}.ledger (kind, work_slug, work_title, work_discharge, refs, supersedes, statement, actor)
        VALUES ('work_opened', :'slug', :'title', NULLIF(:'discharge', ''), NULLIF(:'refs', ''), NULLIF(:'supersedes', '')::bigint, :'statement',
                (SELECT id FROM principal WHERE name = NULLIF(:'actor_name', '')));
SQL
      else
        exec psql -h "$PGHOST" -d "$PGDB" -v ON_ERROR_STOP=1 \
          -v slug="$slug" -v title="$title" -v refs="$refs" -v supersedes="$supersedes" \
          -v actor_name="$actor_name" \
          -v statement="work_opened: ${slug} -- ${title}" <<SQL
        SET ROLE ${ROLE};
        SET search_path = ${SCHEMA}, ${KERNEL};
        INSERT INTO ${SCHEMA}.ledger (kind, work_slug, work_title, refs, supersedes, statement, actor)
        VALUES ('work_opened', :'slug', :'title', NULLIF(:'refs', ''), NULLIF(:'supersedes', '')::bigint, :'statement',
                (SELECT id FROM principal WHERE name = NULLIF(:'actor_name', '')));
SQL
      fi
      ;;
    claim)
      shift
      usage_claim() {
        echo "usage: led work claim <slug>" >&2
        echo "       refused if <slug> has no opening act (validate_work_item(): every later" >&2
        echo "       event on an item must reference an item that has been opened)" >&2
        echo "       refused if <slug> carries an unresolved blocks-start antecedent -- an" >&2
        echo "       antecedent named by --type blocks-start (kernel/lineage/s39-blocks-start.sql)" >&2
        echo "       whose own work item has not yet reached state=closed. The refusal names" >&2
        echo "       every unresolved antecedent by slug; claim/finish it first, or re-edge if" >&2
        echo "       the dependency is wrong (see design/USER-RECIPES-FAQ.md). 'led work" >&2
        echo "       startable' lists items with no such refusal pending right now." >&2
        echo "       set LED_ACTOR=<principal-name> to claim as a registered principal other" >&2
        echo "       than the default connection principal" >&2
      }
      if [ $# -lt 1 ]; then
        usage_claim
        exit 1
      fi
      # `work claim` takes exactly one positional (<slug>) and no flags at all -- unlike
      # open/depends/close it never had a parse loop, so a typo'd flag or stray extra word
      # after <slug> was previously just silently ignored (same hazard-in-reach shape as the
      # other three subcommands' catch-alls, ledger item led-work-open-refs-swallowed point 4:
      # a claim that looks like it did something with an extra argument actually dropped it
      # with no error). Refused here instead of silently ignored.
      if [ $# -gt 1 ]; then
        echo "led work claim: REFUSED -- unexpected extra argument(s): ${*:2}" >&2
        usage_claim
        echo "  NOTHING was written." >&2
        exit 1
      fi
      slug="$1"
      resolve_actor
      # actor resolves via a subquery bind exactly as `led review` does above: NULLIF(:'actor_name','')
      # is NULL when LED_ACTOR is unset, so the claim lands under the default connection principal.
      # resolve_actor (defined near the top of this file) is the ONE place LED_ACTOR is read/
      # validated, shared with `led review` and the generic <kind> <statement> path.
      exec psql -h "$PGHOST" -d "$PGDB" -v ON_ERROR_STOP=1 \
        -v slug="$slug" -v actor_name="$actor_name" -v statement="work_claimed: ${slug}" <<SQL
        SET ROLE ${ROLE};
        SET search_path = ${SCHEMA}, ${KERNEL};
        INSERT INTO ${SCHEMA}.ledger (kind, work_slug, statement, actor)
        VALUES ('work_claimed', :'slug', :'statement',
                (SELECT id FROM principal WHERE name = NULLIF(:'actor_name', '')));
SQL
      ;;
    depends)
      shift
      type=""
      supersedes=""
      args=()
      while [ $# -gt 0 ]; do
        case "$1" in
          --type) type="${2:-}"; shift 2 ;;
          --supersedes) supersedes="${2:-}"; shift 2 ;;
          --*)
            # Same hazard-in-reach fix as `work open` above (ledger item
            # led-work-open-refs-swallowed, point 4): an unrecognized flag used to fall into
            # the catch-all below and sit unused past $1/$2 (slug/on-slug), silently dropped
            # with no error -- e.g. a typo'd --typ blocks-close would record NEITHER the type
            # nor any complaint. Refused here instead.
            echo "led work depends: REFUSED -- unrecognized flag '$1'." >&2
            echo "  led work depends <slug> <on-slug> accepts only: --type" >&2
            echo "  blocks-close|blocks-start|informs, --supersedes <ledger-id>." >&2
            echo "  NOTHING was written." >&2
            exit 1
            ;;
          *) args+=("$1"); shift ;;
        esac
      done
      set -- "${args[@]}"
      if [ $# -lt 2 ]; then
        echo "usage: led work depends <slug> <on-slug> [--type blocks-close|blocks-start|informs]" >&2
        echo "         [--supersedes <ledger-id>]" >&2
        echo "       <slug> must already be opened (refused otherwise)." >&2
        echo "       --type informs (the default, omit --type to get it): the antecedent" >&2
        echo "       (<on-slug>) is NOT required to be opened -- a dangling antecedent is" >&2
        echo "       deliberately NOT refused (spec invariant 4), surfaced instead by" >&2
        echo "       'led work violations' (depends_on_unknown_slug)." >&2
        echo "       --type blocks-close (kernel/lineage/s30-typed-dependency-edges.sql): the" >&2
        echo "       ONLY edge type the obligation AND-tree (s29 Element C / --strict close)" >&2
        echo "       conjoins. REFUSED at construction if <on-slug> has no opening act, if" >&2
        echo "       <slug> = <on-slug> (self-edge), or if it would create a cycle in the" >&2
        echo "       blocks-close subgraph. Requires this world's kernel to carry s30 -- omit" >&2
        echo "       --type (or pass --type informs) on a pre-s30 kernel." >&2
        echo "       --type blocks-start (kernel/lineage/s39-blocks-start.sql): <slug> may not" >&2
        echo "       be CLAIMED (led work claim) until <on-slug> reaches CLOSED -- checked at" >&2
        echo "       claim time, not merely advisory. REFUSED at construction under the SAME" >&2
        echo "       three conditions as blocks-close (dangling antecedent, self-edge, cycle --" >&2
        echo "       the blocks-start subgraph's own cycle check, independent of blocks-close's" >&2
        echo "       own). Requires this world's kernel to carry s39 -- omit --type (or pass" >&2
        echo "       --type informs) on a pre-s39 kernel." >&2
        echo "       --supersedes <ledger-id> (ledger.supersedes, base schema since s10 -- the" >&2
        echo "       SAME column/idiom 'led work open --supersedes' and 'led work" >&2
        echo "       resolve-violation --supersedes' already use, ADR-0012 P1, never a second" >&2
        echo "       copy): CORRECTS a mistaken work_depends_on row -- <ledger-id> is retracted" >&2
        echo "       from current truth (kernel/lineage/s31-supersession-uniform-retraction.sql)" >&2
        echo "       and THIS new row (which may carry a different --type or different" >&2
        echo "       <slug>/<on-slug> endpoints) becomes the corrected edge. REFUSED at" >&2
        echo "       construction if <ledger-id> does not exist, is not itself a" >&2
        echo "       work_depends_on row, or is already superseded (the row that superseded it" >&2
        echo "       is named). This is the recovery path s39's claim-time refusal and LIMITS" >&2
        echo "       section point to for a mistaken blocks-start/blocks-close edge -- see" >&2
        echo "       design/USER-RECIPES-FAQ.md's \"Correcting the record\" section." >&2
        exit 1
      fi
      slug="$1"; on="$2"
      if [ -n "$type" ] && [ "$type" != "blocks-close" ] && [ "$type" != "blocks-start" ] && [ "$type" != "informs" ]; then
        echo "led work depends: REFUSED -- --type must be blocks-close, blocks-start, or informs (got '${type}')." >&2
        echo "  'supersedes' is a RESERVED WORD here, not a legal edge_type -- row supersession" >&2
        echo "  already has its one home in the pre-existing ledger.supersedes column." >&2
        exit 1
      fi
      has_edge_type_col=$(psql -h "$PGHOST" -d "$PGDB" -tAq -v schema="$SCHEMA" <<SQL
        SELECT EXISTS (SELECT 1 FROM information_schema.columns
                       WHERE table_schema = :'schema' AND table_name = 'ledger'
                         AND column_name = 'edge_type');
SQL
      )
      if [ -n "$type" ] && [ "$has_edge_type_col" != "t" ]; then
        echo "led work depends: REFUSED -- --type requires kernel/lineage/s30-typed-dependency-edges.sql" >&2
        echo "  applied to this project's schema (edge_type column not found on" >&2
        echo "  ${SCHEMA}.ledger -- this world's kernel predates s30). Omit --type, or apply" >&2
        echo "  s30 to this schema as a maintainer act (ORCH-OPERATING-CARD.md's kernel-delta" >&2
        echo "  decision tree)." >&2
        exit 1
      fi
      # kernel/lineage/s39-blocks-start.sql's own pre-check idiom, one edge-type over from the
      # has_edge_type_col check immediately above: edge_type ALREADY EXISTS as of s30, so a
      # column-presence check alone cannot detect a pre-s39 kernel that lacks the WIDENED
      # vocabulary -- the constraint's own definition is inspected instead (pg_get_constraintdef,
      # matching this world's own s39 detect sibling's fingerprinting method).
      if [ "$type" = "blocks-start" ]; then
        has_blocks_start=$(psql -h "$PGHOST" -d "$PGDB" -tAq -v schema="$SCHEMA" <<SQL
          SELECT EXISTS (
            SELECT 1 FROM pg_constraint c
            JOIN pg_namespace n ON n.oid = c.connamespace
            WHERE n.nspname = :'schema' AND c.conname = 'edge_type_check'
              AND pg_get_constraintdef(c.oid) LIKE '%blocks-start%'
          );
SQL
        )
        if [ "$has_blocks_start" != "t" ]; then
          echo "led work depends: REFUSED -- --type blocks-start requires kernel/lineage/s39-blocks-start.sql" >&2
          echo "  applied to this project's schema (edge_type_check does not admit blocks-start on" >&2
          echo "  ${SCHEMA}.ledger -- this world's kernel predates s39). Omit --type, use --type" >&2
          echo "  blocks-close or informs, or apply s39 to this schema as a maintainer act" >&2
          echo "  (ORCH-OPERATING-CARD.md's kernel-delta decision tree)." >&2
          exit 1
        fi
      fi
      # --supersedes VALIDATION (ledger item led-work-depends-supersedes: s39's own claim-time
      # refusal text and LIMITS section both promise "the standard supersession recipe" for a
      # mistaken work_depends_on edge, but `led work depends` had no --supersedes flag at all --
      # the promise was unreachable through the sanctioned CLI). Three checks BEFORE any write,
      # mirroring `work resolve-violation --supersedes`'s own validate-then-teach shape one kind
      # over (same column, same NULLIF(...)::bigint cast, never a second copy -- ADR-0012 P1):
      #   (i)   <ledger-id> must exist and be a work_depends_on row -- read off the RAW ledger
      #         table (not ledger_current), so an already-superseded target is still found here
      #         and can get its own, more specific refusal in check (ii) rather than being
      #         folded into a generic "not found" message.
      #   (ii)  <ledger-id> must not ALREADY be superseded -- checked by looking for a row whose
      #         OWN supersedes column names it (this is ledger_current's own exclusion predicate,
      #         s31 Element "ledger_current excludes row R iff some row's supersedes = R", read
      #         directly rather than re-derived through the view). The refusal names the row that
      #         already did the superseding, so the operator can inspect it instead of guessing.
      #   (iii) no cycle/self-edge check is needed here beyond the SAME ones the type branches
      #         above already ran on <slug>/<on-slug> -- --supersedes only relates <ledger-id> to
      #         the fresh row via the supersedes column, a column the type/self/cycle checks
      #         above (and the kernel's own construction-time checks) do not read at all.
      if [ -n "$supersedes" ]; then
        target_row=$(psql -h "$PGHOST" -d "$PGDB" -tAq -F'|' -v sid="$supersedes" <<SQL
        SET ROLE ${ROLE};
        SET search_path = ${SCHEMA}, ${KERNEL};
        SELECT kind, work_slug, work_depends_on, COALESCE(edge_type, '')
        FROM ${SCHEMA}.ledger
        WHERE id = :'sid'::bigint;
SQL
        )
        if [ -z "$target_row" ]; then
          echo "led work depends: REFUSED -- --supersedes ${supersedes} does not name any ledger" >&2
          echo "  row (no id ${supersedes} exists in ${SCHEMA}.ledger). Run 'led work violations'" >&2
          echo "  or read the row's own printed id from when it was written to find the correct" >&2
          echo "  id. NOTHING was written." >&2
          exit 1
        fi
        target_kind="${target_row%%|*}"
        _rest="${target_row#*|}"
        old_slug="${_rest%%|*}"
        _rest="${_rest#*|}"
        old_on="${_rest%%|*}"
        old_type="${_rest#*|}"
        if [ "$target_kind" != "work_depends_on" ]; then
          echo "led work depends: REFUSED -- --supersedes ${supersedes} names a '${target_kind}'" >&2
          echo "  row, not a work_depends_on row -- supersession here only corrects a" >&2
          echo "  work_depends_on edge (a different kind of row is corrected via its OWN verb's" >&2
          echo "  --supersedes, e.g. 'led work open --supersedes' for a work_opened row). NOTHING" >&2
          echo "  was written." >&2
          exit 1
        fi
        superseder_id=$(psql -h "$PGHOST" -d "$PGDB" -tAq -v sid="$supersedes" <<SQL
        SET ROLE ${ROLE};
        SET search_path = ${SCHEMA}, ${KERNEL};
        SELECT id FROM ${SCHEMA}.ledger WHERE supersedes = :'sid'::bigint LIMIT 1;
SQL
        )
        if [ -n "$superseder_id" ]; then
          echo "led work depends: REFUSED -- --supersedes ${supersedes} is already superseded (by" >&2
          echo "  row ${superseder_id} -- supersession is reinstatement-free, s31 ratified fork 2)." >&2
          echo "  Correct row ${superseder_id} instead, if IT is now the one that is wrong, or" >&2
          echo "  read work_violation_history / raw ledger history to see the full chain. NOTHING" >&2
          echo "  was written." >&2
          exit 1
        fi
        # SLUG-REPOINT ADVISORY (WARN-ONLY, never a refusal): re-pointing a mistaken edge to
        # different slugs, or re-typing it, is LEGAL -- that is exactly what a "wrong edge"
        # correction usually is -- but it is easy to lose track of which endpoints changed once
        # buried in ledger history, so both old and new endpoints are named here, house-style
        # (mirrors 'led work open --supersedes's own unconditional advisory just above it).
        new_type_eff="${type:-informs}"
        old_type_eff="${old_type:-informs}"
        if [ "$old_slug" != "$slug" ] || [ "$old_on" != "$on" ] || [ "$old_type_eff" != "$new_type_eff" ]; then
          echo "led work depends: --supersedes ${supersedes} corrects a MIS-EDGED row -- old:" >&2
          echo "  ${old_slug} --[${old_type_eff}]--> ${old_on} (row ${supersedes}, now retracted)," >&2
          echo "  new: ${slug} --[${new_type_eff}]--> ${on}. History keeps row ${supersedes}" >&2
          echo "  visible (never obscured); current truth now reads the new edge only." >&2
        else
          echo "led work depends: --supersedes ${supersedes} re-issues the SAME edge" >&2
          echo "  (${slug} --[${new_type_eff}]--> ${on}) under a new row -- legal (e.g. correcting" >&2
          echo "  only the statement text/rationale), just not a re-POINT." >&2
        fi
      fi
      # DEFAULT-TYPE ADVISORY (root cause this closes: a live deployment session recorded
      # every genuine "must finish before" precedence constraint as informs and never once used
      # --type blocks-close, because nothing at the CLI said the unqualified default is
      # advisory-only -- surfaced neither in the deployed project docs nor at the moment the
      # constraint was typed). A caller who omits --type still gets the row written EXACTLY as
      # before (informs by omission, or -- on a pre-s30 kernel -- no edge_type column at all);
      # this only adds a one-line STDERR teach at the exact point of the omission. WARN-ONLY, not
      # a refusal -- informs is a legal, common, correct choice for a merely contextual edge, and
      # this advisory does not gate the write, it makes the choice visible.
      if [ -z "$type" ]; then
        echo "led work depends: recorded as informs (advisory only -- never enforced at close or claim);" >&2
        echo "  if ${on} must be finished before ${slug} may close, use --type blocks-close;" >&2
        echo "  if ${on} must be CLOSED before ${slug} may be CLAIMED, use --type blocks-start (s39)." >&2
      fi
      resolve_actor
      # actor resolves via a subquery bind exactly as `led review`/`led work claim`/`led work
      # open` above: NULLIF(:'actor_name','') is NULL when LED_ACTOR is unset, so the edge lands
      # under the default connection principal, byte-identical to before this wiring.
      # resolve_actor (defined near the top of this file) is the ONE place LED_ACTOR is read/
      # validated, shared across all seven ledger-writing paths.
      if [ "$has_edge_type_col" = "t" ]; then
        exec psql -h "$PGHOST" -d "$PGDB" -v ON_ERROR_STOP=1 \
          -v slug="$slug" -v on="$on" -v type="$type" -v supersedes="$supersedes" \
          -v actor_name="$actor_name" \
          -v statement="work_depends_on: ${slug} depends on ${on}" <<SQL
        SET ROLE ${ROLE};
        SET search_path = ${SCHEMA}, ${KERNEL};
        INSERT INTO ${SCHEMA}.ledger (kind, work_slug, work_depends_on, edge_type, supersedes, statement, actor)
        VALUES ('work_depends_on', :'slug', :'on', NULLIF(:'type', ''), NULLIF(:'supersedes', '')::bigint, :'statement',
                (SELECT id FROM principal WHERE name = NULLIF(:'actor_name', '')));
SQL
      else
        exec psql -h "$PGHOST" -d "$PGDB" -v ON_ERROR_STOP=1 \
          -v slug="$slug" -v on="$on" -v supersedes="$supersedes" \
          -v actor_name="$actor_name" \
          -v statement="work_depends_on: ${slug} depends on ${on}" <<SQL
        SET ROLE ${ROLE};
        SET search_path = ${SCHEMA}, ${KERNEL};
        INSERT INTO ${SCHEMA}.ledger (kind, work_slug, work_depends_on, supersedes, statement, actor)
        VALUES ('work_depends_on', :'slug', :'on', NULLIF(:'supersedes', '')::bigint, :'statement',
                (SELECT id FROM principal WHERE name = NULLIF(:'actor_name', '')));
SQL
      fi
      ;;
    close)
      shift
      witness=""
      review_witness=""
      review_deferred=""
      review_bookkeeping=""
      strict=""
      args=()
      while [ $# -gt 0 ]; do
        case "$1" in
          --witness) witness="${2:-}"; shift 2 ;;
          --review-witness) review_witness="${2:-}"; shift 2 ;;
          --review-deferred) review_deferred="1"; shift ;;
          # kernel/lineage/s38-bookkeeping-close.sql, design/FABLE-BOOKKEEPING-CLOSE-SPEC.md
          # Element 2: takes NO argument -- the commit witness rides the EXISTING --witness flag
          # (ADR-0012 P1: reuse, do not duplicate), derived into work_review_ref below after both
          # machine checks pass.
          --review-bookkeeping) review_bookkeeping="1"; shift ;;
          --strict) strict="1"; shift ;;
          --*)
            # Same hazard-in-reach fix as `work open`/`work depends` above (ledger item
            # led-work-open-refs-swallowed, point 4): an unrecognized flag used to fall into
            # the catch-all below and sit unused past $1/$2 (slug/resolution), silently
            # dropped with no error -- e.g. a typo'd --witnes <ref> would record no witness at
            # all on a shipped close, with nothing to say so. Refused here instead.
            echo "led work close: REFUSED -- unrecognized flag '$1'." >&2
            echo "  led work close <slug> <resolution> accepts only: --witness <ref>," >&2
            echo "  --review-witness <ref>, --review-deferred, --review-bookkeeping, --strict." >&2
            echo "  NOTHING was written." >&2
            exit 1
            ;;
          *) args+=("$1"); shift ;;
        esac
      done
      set -- "${args[@]}"
      usage_close() {
        echo "usage: led work close <slug> <resolution> (--review-witness <ref> | --review-deferred | --review-bookkeeping --witness commit:<sha>) [--witness <ref>] [--strict]" >&2
        echo "       resolution: shipped|superseded|dropped|deferred" >&2
        echo "       resolution=shipped REQUIRES --witness -- refused at construction time" >&2
        echo "       (work_shipped_requires_witness CHECK), never a tolerated-but-flagged row" >&2
        echo "       refused if <slug> has no work_claimed row yet -- claim it first:" >&2
        echo "       ./led work claim <slug>" >&2
        echo "       EXACTLY ONE of --review-witness <ref> / --review-deferred / --review-bookkeeping" >&2
        echo "       is REQUIRED (kernel/lineage/s29-.../s38-bookkeeping-close.sql, Element B) --" >&2
        echo "       a review-silent close is REFUSED at construction, never representable." >&2
        echo "         --review-witness <ref>  a review already exists; cite it" >&2
        echo "         --review-deferred       this close act itself becomes the item-keyed" >&2
        echo "                                 review obligation, discharged later by a" >&2
        echo "                                 DIFFERENT actor's ./led review <close-row-id> ..." >&2
        echo "         --review-bookkeeping    a JUDGMENT-FREE close whose entire content is a" >&2
        echo "                                 git commit landing (s38) -- takes NO argument," >&2
        echo "                                 requires --witness commit:<7-40 lowercase hex>," >&2
        echo "                                 verified to exist in this world's own repository" >&2
        echo "                                 at construction time. The category is CLOSED to" >&2
        echo "                                 exactly this one form (design/FABLE-BOOKKEEPING-" >&2
        echo "                                 CLOSE-SPEC.md, \"the category is CLOSED\")." >&2
        echo "       --strict refuses this close unless --review-witness was used AND every leaf" >&2
        echo "       of the obligation tree is resolved, naming every unresolved leaf" >&2
      }
      if [ $# -lt 2 ]; then
        usage_close
        exit 1
      fi
      slug="$1"; resolution="$2"
      # claim-before-close gate (led-side; s22's own trigger checks only that <slug> was OPENED,
      # not that anyone claimed it) -- run-5 forensics: two work items were closed with no claim
      # ever landing, unflagged. Mirrors the existing duplicate-open/unopened refusal style: a
      # named usage message on stderr, exit 1, no silent acceptance.
      claimed=$(psql -h "$PGHOST" -d "$PGDB" -tAq -v slug="$slug" <<SQL
        SET ROLE ${ROLE};
        SET search_path = ${SCHEMA}, ${KERNEL};
        SELECT EXISTS (SELECT 1 FROM ledger WHERE kind = 'work_claimed' AND work_slug = :'slug');
SQL
      )
      if [ "$claimed" != "t" ]; then
        echo "led work close: REFUSED -- slug '${slug}' has no work_claimed row (claim it first):" >&2
        echo "  ./led work claim ${slug}" >&2
        echo "  (a close with no claim ever landing is the run-5 finding: two work items were" >&2
        echo "  closed this way, unflagged, until an outside review caught it)" >&2
        exit 1
      fi
      # LIVE column-existence check (the SAME convention `work open --parent` above already uses):
      # s29 is NOT wired into every world's birth chain, so an unconditional
      # work_review_disposition in the INSERT column list would break `led work close` for every
      # world whose kernel predates s29 -- the exact hazard-in-reach CLAUDE.md's engineering-
      # responsibility corollary exists to catch before it ships, not after.
      has_review_disposition_col=$(psql -h "$PGHOST" -d "$PGDB" -tAq -v schema="$SCHEMA" <<SQL
        SELECT EXISTS (SELECT 1 FROM information_schema.columns
                       WHERE table_schema = :'schema' AND table_name = 'ledger'
                         AND column_name = 'work_review_disposition');
SQL
      )
      if [ "$has_review_disposition_col" != "t" ]; then
        if [ -n "$review_witness" ] || [ -n "$review_deferred" ] || [ -n "$review_bookkeeping" ] || [ -n "$strict" ]; then
          echo "led work close: REFUSED -- --review-witness/--review-deferred/--review-bookkeeping/" >&2
          echo "  --strict require kernel/lineage/s29-obligation-item-key-and-typed-close.sql" >&2
          echo "  applied to this project's schema (work_review_disposition column not found on" >&2
          echo "  ${SCHEMA}.ledger -- this world's kernel predates s29). Omit these flags, or" >&2
          echo "  apply s29 to this schema as a maintainer act (ORCH-OPERATING-CARD.md's" >&2
          echo "  kernel-delta decision tree)." >&2
          exit 1
        fi
        resolve_actor
        # actor resolves via the SAME subquery-bind idiom as every other ledger-writing path
        # (resolve_actor defined near the top of this file) -- unset LED_ACTOR is byte-identical
        # to before this wiring (NULLIF(:'actor_name','') -> NULL -> set_actor's default fill).
        exec psql -h "$PGHOST" -d "$PGDB" -v ON_ERROR_STOP=1 \
          -v slug="$slug" -v resolution="$resolution" -v witness="$witness" \
          -v actor_name="$actor_name" \
          -v statement="work_closed: ${slug} (${resolution})" <<SQL
        SET ROLE ${ROLE};
        SET search_path = ${SCHEMA}, ${KERNEL};
        INSERT INTO ${SCHEMA}.ledger (kind, work_slug, work_resolution, work_witness, statement, actor)
        VALUES ('work_closed', :'slug', :'resolution', NULLIF(:'witness', ''), :'statement',
                (SELECT id FROM principal WHERE name = NULLIF(:'actor_name', '')));
SQL
        exit $?
      fi
      # kernel/lineage/s38-bookkeeping-close.sql: LIVE CHECK-shape existence check (the SAME
      # convention as the column-existence check above, one level down -- s38 widens an EXISTING
      # column's vocabulary rather than adding a new column, so a column-existence probe cannot
      # distinguish a pre-s38 from a post-s38 kernel; a catalog CHECK-definition probe is the
      # correct live-shape test here, mirroring kernel/lineage/s38-bookkeeping-close.detect.sql's
      # own technique). --review-bookkeeping on a pre-s38 kernel is refused here, teach-text naming
      # the two honest pre-s38 alternatives, rather than reaching the kernel and failing on an
      # unrecognized vocabulary value with a bare constraint-violation error.
      if [ -n "$review_bookkeeping" ]; then
        has_bookkeeping_vocab=$(psql -h "$PGHOST" -d "$PGDB" -tAq -v schema="$SCHEMA" <<SQL
          SELECT EXISTS (
            SELECT 1 FROM pg_constraint con
              JOIN pg_class rel ON rel.oid = con.conrelid
              JOIN pg_namespace ns ON ns.oid = rel.relnamespace
             WHERE ns.nspname = :'schema' AND rel.relname = 'ledger' AND con.contype = 'c'
               AND pg_get_constraintdef(con.oid) LIKE '%bookkeeping%');
SQL
        )
        if [ "$has_bookkeeping_vocab" != "t" ]; then
