def _load_config() -> bcc.ServedConfig:
    try:
        return bcc.load_served_config(DEPLOYMENT_PATH)
    except bcc.BoundaryClientError as e:
        print(f"led: {e}", file=sys.stderr)
        sys.exit(4)


def _resolve_actor(cfg: bcc.ServedConfig) -> int | None:
    """LED_ACTOR (env var, not a flag) -- byte-identical semantics to the legacy tool's own
    `resolve_actor()`: unset means the payload omits `actor` entirely (the kernel's own
    `set_actor` default-resolution applies); set to an unregistered name REFUSES with teach-text,
    never a silent fallback to the default principal."""
    name = os.environ.get("LED_ACTOR", "")
    if not name:
        return None
    rows = bcc.get_all_rows(cfg.base, "/standing/principals", cursor="after_id")
    for r in rows:
        if r.get("name") == name:
            return r["id"]
    print(f"led: REFUSED -- LED_ACTOR={name!r} is not a registered principal.", file=sys.stderr)
    print(f"  Register it first: ./led register-principal {name} <human|model|subagent|tool>", file=sys.stderr)
    sys.exit(1)


# --- statement-grammar PRE-FLIGHT (legacy-led-retirement phase 1, ledger row 1149) -----------
# Ported byte-identically (same field lists, same regexes, same refusal text) off legacy-
# led.tmpl's own six intake validators -- resource:/estimate:/taxon:/interface:/review:/
# review-done: -- run ONLY on the generic <kind> <statement...> write path (cmd_generic below),
# exactly where legacy runs them, BEFORE the payload is ever built. This is a CLI-side
# convention check, not a kernel invariant: the kernel accepts any statement text under these
# kinds regardless, so a bypass of this CLI (e.g. `led --json`) is not narrowed by this at all.
_SLUG_RE = re.compile(r"^[a-z0-9][a-z0-9-]*$")


def _normalize_statement(raw: str) -> str:
    """Every run of \\r/\\n plus its following indentation collapsed to one space -- so a
    legitimate embedded newline (a paste reflowed by a terminal) is ACCEPTED rather than
    refused, identical convention to every legacy grammar block this ports."""
    return re.sub(r"[\r\n]+[ \t]*", " ", raw).strip()


def _check_resource(trimmed: str) -> bool:
    normalized = _normalize_statement(trimmed)
    body = normalized[len("resource:"):]
    parts = [p.strip() for p in body.split("|")]
    fields = ("NAME", "CLASS", "REACH", "WHAT-IT-PROVES", "GUIDANCE", "TIER")
    valid_classes = ("solver", "service", "backend", "binary", "library")

    def refuse(msg: str) -> bool:
        print(f"led: REFUSED -- malformed 'resource:' statement -- {msg}.", file=sys.stderr)
        print("  grammar (user-guide/USER-BLESSED-TABLE-TEMPLATE.md 'The statement grammars'):", file=sys.stderr)
        print("    resource: <NAME> | <CLASS> | <REACH> | <WHAT-IT-PROVES> | <GUIDANCE> | <TIER>", file=sys.stderr)
        print(f"  the six fields, in order: {', '.join(fields)}", file=sys.stderr)
        print(f"  CLASS must be one of: {' | '.join(valid_classes)}", file=sys.stderr)
        print("  TIER must be one of: available | blessed: <task-shape> | mandated: <task-shape> | "
              "forbidden: <task-shape>", file=sys.stderr)
        print(f"  received ({len(parts)} field(s), whitespace-normalized): {normalized}", file=sys.stderr)
        print("  NOTHING was written -- fix the statement and re-run.", file=sys.stderr)
        return False

    if len(parts) != len(fields):
        return refuse(f"expected exactly {len(fields)} '|'-separated fields, got {len(parts)}")
    _name, cls, _reach, _proves, _guidance, tier = parts
    if cls not in valid_classes:
        return refuse(f"CLASS field {cls!r} is not one of {valid_classes}")
    tier_prefixes = ("blessed:", "mandated:", "forbidden:")
    if not (tier == "available" or tier.startswith(tier_prefixes)):
        return refuse(f"TIER field {tier!r} is not 'available', 'blessed: <task-shape>', "
                      f"'mandated: <task-shape>', or 'forbidden: <task-shape>'")
    if tier.startswith(tier_prefixes) and not tier.split(":", 1)[1].strip():
        return refuse(f"TIER field {tier!r} names no <task-shape> after the colon")
    return True


def _check_estimate(trimmed: str) -> bool:
    normalized = _normalize_statement(trimmed)
    body = normalized[len("estimate:"):]
    parts = [p.strip() for p in body.split("|")]
    fields = ("TASK-SLUG", "TOOL-CALLS", "SUBAGENT-SPAWNS", "WALL-CLOCK", "TOKEN-OOM", "BASIS")
    valid_token_oom = ("1K", "10K", "100K", "1M", "10M+")
    count_re = re.compile(r"^\d+(-\d+)?$")
    duration_re = re.compile(r"^\d+(\.\d+)?[smhd](-\d+(\.\d+)?[smhd])?$", re.IGNORECASE)

    def refuse(msg: str) -> bool:
        print(f"led: REFUSED -- malformed 'estimate:' statement -- {msg}.", file=sys.stderr)
        print("  grammar (user-guide/USER-RETROSPECTIVE-RECIPE.md 'Estimate statement grammar'):", file=sys.stderr)
        print("    estimate: <TASK-SLUG> | <TOOL-CALLS> | <SUBAGENT-SPAWNS> | <WALL-CLOCK> | <TOKEN-OOM> | <BASIS>", file=sys.stderr)
        print(f"  the six fields, in order: {', '.join(fields)}", file=sys.stderr)
        print("  TASK-SLUG must match ^[a-z0-9][a-z0-9-]*$ (a bare slug, no spaces)", file=sys.stderr)
        print("  TOOL-CALLS/SUBAGENT-SPAWNS must be a non-negative integer or an integer range N-M (e.g. 12 or 8-15)", file=sys.stderr)
        print("  WALL-CLOCK must be a duration like 20m/2h/1d, or a range 10m-30m", file=sys.stderr)
        print(f"  TOKEN-OOM must be one of: {' | '.join(valid_token_oom)}", file=sys.stderr)
        print("  BASIS must be non-empty (state what the prediction is grounded in)", file=sys.stderr)
        print(f"  received ({len(parts)} field(s), whitespace-normalized): {normalized}", file=sys.stderr)
        print("  NOTHING was written -- fix the statement and re-run.", file=sys.stderr)
        print("  this is an ESTIMATE for operational-efficiency retrospectives ONLY, never for cost", file=sys.stderr)
        print("  policing (maintainer's own invariant, stated twice at commissioning) -- a missed", file=sys.stderr)
        print("  estimate is retrospective data, never a violation; only the INTAKE SHAPE is refused", file=sys.stderr)
        print("  here, never the prediction's eventual accuracy.", file=sys.stderr)
        return False

    if len(parts) != len(fields):
        return refuse(f"expected exactly {len(fields)} '|'-separated fields, got {len(parts)}")
    slug, tool_calls, spawns, wall_clock, token_oom, basis = parts
    if not _SLUG_RE.match(slug):
        return refuse(f"TASK-SLUG field {slug!r} does not match ^[a-z0-9][a-z0-9-]*$ (a bare slug, no spaces)")
    if not count_re.match(tool_calls):
        return refuse(f"TOOL-CALLS field {tool_calls!r} is not a non-negative integer or an N-M range")
    if not count_re.match(spawns):
        return refuse(f"SUBAGENT-SPAWNS field {spawns!r} is not a non-negative integer or an N-M range")
    if not duration_re.match(wall_clock):
        return refuse(f"WALL-CLOCK field {wall_clock!r} is not a duration like 20m/2h/1d or a range 10m-30m")
    if token_oom not in valid_token_oom:
        return refuse(f"TOKEN-OOM field {token_oom!r} is not one of {valid_token_oom}")
    if not basis:
        return refuse("BASIS field is empty -- name what the prediction is grounded in")
    return True


def _check_taxon(trimmed: str) -> bool:
    normalized = _normalize_statement(trimmed)
    body = normalized[len("taxon:"):]
    parts = [p.strip() for p in body.split("|")]
    fields = ("TAXONOMY", "TAXON", "PATTERNS", "GLOSS")

    def refuse(msg: str) -> bool:
        print(f"led: REFUSED -- malformed 'taxon:' statement -- {msg}.", file=sys.stderr)
        print("  grammar (user-guide/USER-TAXONOMY-DECLARATION.md 'The statement grammars'):", file=sys.stderr)
        print("    taxon: <TAXONOMY> | <TAXON> | <PATTERNS> | <GLOSS>", file=sys.stderr)
        print(f"  the four fields, in order: {', '.join(fields)}", file=sys.stderr)
        print("  TAXONOMY and TAXON must each match ^[a-z0-9][a-z0-9-]*$ (a bare slug, no spaces)", file=sys.stderr)
        print("  PATTERNS must be non-empty (one or more path globs assigning artifacts to the taxon)", file=sys.stderr)
        print("  GLOSS must be non-empty (state what the taxon means, for a human reader)", file=sys.stderr)
        print(f"  received ({len(parts)} field(s), whitespace-normalized): {normalized}", file=sys.stderr)
        print("  NOTHING was written -- fix the statement and re-run.", file=sys.stderr)
        return False

    if len(parts) != len(fields):
        return refuse(f"expected exactly {len(fields)} '|'-separated fields, got {len(parts)}")
    taxonomy, taxon, patterns, gloss = parts
    if not _SLUG_RE.match(taxonomy):
        return refuse(f"TAXONOMY field {taxonomy!r} does not match ^[a-z0-9][a-z0-9-]*$ (a bare slug, no spaces)")
    if not _SLUG_RE.match(taxon):
        return refuse(f"TAXON field {taxon!r} does not match ^[a-z0-9][a-z0-9-]*$ (a bare slug, no spaces)")
    if not patterns:
        return refuse("PATTERNS field is empty -- name at least one path glob assigning artifacts to the taxon")
    if not gloss:
        return refuse("GLOSS field is empty -- state what the taxon means, for a human reader")
    return True


