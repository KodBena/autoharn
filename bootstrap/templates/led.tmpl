normalized = re.sub(r"[\r\n]+[ \t]*", " ", raw).strip()
body = normalized[len("estimate:"):]
parts = [p.strip() for p in body.split("|")]


def refuse(msg: str) -> None:
    print(f"led: REFUSED -- malformed 'estimate:' statement -- {msg}.", file=sys.stderr)
