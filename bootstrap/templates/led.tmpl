def _load_config() -> bcc.ServedConfig:
    try:
        return bcc.load_served_config(DEPLOYMENT_PATH)
    except bcc.BoundaryClientError as e:
        print(f"led: {e}", file=sys.stderr)
        sys.exit(4)


def _resolve_actor(cfg: bcc.ServedConfig) -> int | None:
    """LED_ACTOR (env var, not a flag) -- byte-identical semantics to the legacy tool's own
    `resolve_actor()`: unset means the payload omits `actor` entirely (the kernel's own
    `set_actor` default-resolution applies); set to an unregistered name REFUSES with teach-text,
    never a silent fallback to the default principal."""
    name = os.environ.get("LED_ACTOR", "")
    if not name:
        return None
    rows = bcc.get_all_rows(cfg.base, "/standing/principals", cursor="after_id")
    for r in rows:
        if r.get("name") == name:
            return r["id"]
    print(f"led: REFUSED -- LED_ACTOR={name!r} is not a registered principal.", file=sys.stderr)
    print(f"  Register it first: ./led register-principal {name} <human|model|subagent|tool>", file=sys.stderr)
    sys.exit(1)


def _principals_by_name(cfg: bcc.ServedConfig) -> dict[str, int]:
    """Name -> id map off GET /standing/principals, walked to completion -- the SAME read
    `cmd_obligate`/`_resolve_actor` already use for principal-name resolution (shared lookup,
    not a second mechanism, ADR-0012 P1)."""
    rows = bcc.get_all_rows(cfg.base, "/standing/principals", cursor="after_id")
    return {r["name"]: r["id"] for r in rows}


def _health_capabilities(cfg: bcc.ServedConfig) -> dict:
    """GET /health's own `capabilities` dict -- the s41/s45 CLIENT-SIDE capability probes
    `cmd_principal`'s own verbs need (mirrors legacy-led.tmpl's `has_s41`/`has_s45_standing_
    lifecycle()`, object-existence/behavior-fingerprint detection, never a version literal),
    read off the SAME route `led`'s own boundary-unreachable teach-text already touches at
    startup -- no new route."""
    return bcc.get_json(cfg.base, "/health").get("capabilities", {})


def _current_rows(cfg: bcc.ServedConfig, kind: str, **filters) -> list[dict]:
    """GET /rows/current (the in-force, supersession-filtered read every other verb in this
    file already uses -- see `_current_row` below `cmd_work_startable`) filtered client-side to
    `kind` plus an exact match on every `filters` keyword -- the SAME no-server-side-filter-
    grammar discipline the whole rebase is built on."""
    out = []
    for r in bcc.get_all_rows(cfg.base, "/rows/current", cursor="after_id"):
        if r.get("kind") != kind:
            continue
        if all(r.get(k) == v for k, v in filters.items()):
            out.append(r)
    return out


def _latest_current(cfg: bcc.ServedConfig, kind: str, **filters) -> dict | None:
    rows = _current_rows(cfg, kind, **filters)
    return max(rows, key=lambda r: r["id"]) if rows else None


# --- `led principal *` (legacy-led-retirement inventory pass, ledger row 1149: the ONE family
# the served led.tmpl's own SCOPE section above never covered at all -- 13 sub-verbs, ported off
# legacy-led.tmpl's own `if [ "${1:-}" = "principal" ]` block, same payload shapes, same
# duplicate-active/value-continuity guards, same refusal texts where the underlying capability
# check is available through the boundary (s41_identity/s45_standing_lifecycle off GET /health,
# added this pass -- see boundary_models.py's CapabilityManifest). DISCLOSED NARROWING: a verb
# that legacy refuses via a bespoke has_s41-style message when this world's kernel genuinely
# lacks the needed lineage delta gets the SAME bespoke text here (both read the SAME single
# capability fact); a verb this file does NOT bespoke-gate (there is none left un-gated) would
# instead surface the kernel's own generic refusal -- named, not reached, in this port.
# --- typed per-sub-verb payload constructors (row 1173 finding 4, ledger row 1105 "no bare
# types" rule) -- REPLACES the former bag-of-16-bare-optional-parameters `_principal_write`.
# Mirrors serving/boundary_models.py's own pattern (one typed class per write surface, its own
# docstring naming the exact kernel CHECK/contract it enforces) adapted client-side via stdlib
# `dataclasses` (this file carries no pydantic dependency, and none is warranted for a CLI shim).
# Each class's `__post_init__` enforces ONLY what legacy actually enforced (relation closed
# vocabulary s41 D-2, role/activity non-empty, competence band/basis mandatory-on-grant/
# forbidden-on-withdrawal s41 D-1a) plus one ADDITIVE fail-safe check mirrored off a kernel CHECK
# the same way `_ARTIFACT_HASH_RE` already mirrors `artifact_hash_shape` (the key-fingerprint
# shape, s41's own `principal_key_fingerprint_shape` CHECK -- legacy left this to the kernel
# alone; catching the identical rule one hop earlier client-side is never looser, never
# stricter, the same regex). Every caller in `cmd_principal` below ALSO still runs its own
# inline REFUSED checks in legacy's own message order/text (message-precedence fidelity, e.g.
# "not a relation" before "not registered") -- the typed constructor's own contract is defense
# in depth, the single enforcing home a caller cannot route around, not a replacement for that
# ordering.
def _binding_base_fields(subject: int, active: bool | None, supersedes: int | str | None,
                          event_time: str | None) -> dict:
    """The field set every s40/s41 principal-family write shares (subject plus the optional
    active/supersedes/event_time triple) -- ONE home, reused by every typed payload class below
    (ADR-0012 P1)."""
    out: dict = {"principal_subject": subject}
    if active is not None:
        out["principal_binding_active"] = active
    if supersedes:
        out["supersedes"] = int(supersedes)
    if event_time:
        out["event_declared_ts"] = event_time
    return out


@dataclasses.dataclass(frozen=True)
class StandingDeclaredPayload:
    """declare-standing/undeclare-standing's own typed row shape. Contract: `db_role` must be
    non-empty (the one value this row exists to carry)."""
    subject: int
    db_role: str
    active: bool | None = None
    supersedes: int | str | None = None
    event_time: str | None = None

    def __post_init__(self) -> None:
        if not self.db_role:
            raise ValueError("a standing declaration needs a non-empty database role name")

    def fields(self) -> dict:
        out = _binding_base_fields(self.subject, self.active, self.supersedes, self.event_time)
        out["principal_db_role"] = self.db_role
        return out


@dataclasses.dataclass(frozen=True)
class StandingLifecyclePayload:
    """suspend/lift-suspension/revoke's own shape -- subject plus the shared active/supersedes/
    event_time triple; no value fields of its own (the row's further content beyond that is
    free-text folded into `statement` by the caller, legacy's own `$reason` convention)."""
    subject: int
    active: bool | None = None
    supersedes: int | str | None = None
    event_time: str | None = None

    def fields(self) -> dict:
        return _binding_base_fields(self.subject, self.active, self.supersedes, self.event_time)


_RELATION_VOCAB = ("acts-for", "dispatched-by", "same-natural-person", "succeeds")


@dataclasses.dataclass(frozen=True)
class RelationPayload:
    """relate/unrelate's own typed row shape (kernel/lineage/s41-principal-bindings-and-
    relations.sql D-2/D-3): a CLOSED relation vocabulary and a self-edge refusal, both enforced
    HERE at construction, so this shape cannot be built with an out-of-vocabulary relation or a
    self-referencing pair even by a future caller that forgets `cmd_principal`'s own inline
    checks."""
    subject: int
    relation: str
    obj: int
    active: bool
    supersedes: int | str | None = None
    event_time: str | None = None

    def __post_init__(self) -> None:
        if self.relation not in _RELATION_VOCAB:
            raise ValueError(f"'{self.relation}' is not a relation (closed vocabulary: "
                              f"{', '.join(_RELATION_VOCAB)} -- s41 D-2)")
        if self.subject == self.obj:
            raise ValueError(f"a principal cannot stand in relation '{self.relation}' to "
                              f"itself (s41 D-3's self-edge refusal)")

    def fields(self) -> dict:
        out = _binding_base_fields(self.subject, self.active, self.supersedes, self.event_time)
        out["principal_object"] = self.obj
        out["principal_relation"] = self.relation
        return out


