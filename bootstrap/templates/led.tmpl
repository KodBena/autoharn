# The OpenPGP v4 fingerprint shape, mirrored off the kernel's OWN CHECK (kernel/lineage/
# s41-principal-bindings-and-relations.sql's `principal_key_fingerprint_shape`,
# `^[0-9A-F]{40}$`) -- the SAME idiom `_ARTIFACT_HASH_RE` already establishes for the artifact
# store's own hash shape (module scope, one compiled pattern, one citation). Legacy never
# checked this client-side (it left the shape to the kernel alone); catching the IDENTICAL rule
# one hop earlier is an additive fail-safe refusal, never looser, never stricter.
_KEY_FINGERPRINT_RE = re.compile(r"^[0-9A-F]{40}$")


@dataclasses.dataclass(frozen=True)
class KeyBindingPayload:
    """bind-key/revoke-key's own typed shape. Contract: `fingerprint` must match the kernel's
    own `principal_key_fingerprint_shape` CHECK -- see `_KEY_FINGERPRINT_RE` above."""
    subject: int
    fingerprint: str
    active: bool
    supersedes: int | str | None = None
    event_time: str | None = None

    def __post_init__(self) -> None:
        if not _KEY_FINGERPRINT_RE.match(self.fingerprint):
            raise ValueError(f"fingerprint {self.fingerprint!r} is not a 40-uppercase-hex "
                              f"OpenPGP v4 fingerprint (kernel/lineage/s41-principal-bindings-"
                              f"and-relations.sql's own principal_key_fingerprint_shape CHECK)")

    def fields(self) -> dict:
        out = _binding_base_fields(self.subject, self.active, self.supersedes, self.event_time)
        out["principal_key_fingerprint"] = self.fingerprint
        return out


@dataclasses.dataclass(frozen=True)
class CompetencePayload:
    """grant-competence/withdraw-competence's own typed shape (s41 D-1a, the identity/value
    split): on a GRANT (`active=True`) `band`/`basis` are MANDATORY value fields; on a
    WITHDRAWAL (`active=False`) both are FORBIDDEN (the row's further content beyond the
    activity identity alone)."""
    subject: int
    activity: str
    active: bool
    band: str | None = None
    basis: str | None = None
    supersedes: int | str | None = None
    event_time: str | None = None

    def __post_init__(self) -> None:
        if not self.activity:
            raise ValueError("a competence row needs a non-empty --activity")
        if self.active:
            if not self.band or not self.basis:
                raise ValueError("--band and --basis are mandatory on a grant (G13's value "
                                  "fields; forbidden only on a withdrawal)")
        elif self.band or self.basis:
            raise ValueError("--band/--basis are VALUE fields, forbidden on a withdrawal (the "
                              "identity/value split, s41 D-1a)")

    def fields(self) -> dict:
        out = _binding_base_fields(self.subject, self.active, self.supersedes, self.event_time)
        out["principal_competence_activity"] = self.activity
        if self.band:
            out["principal_competence_band"] = self.band
        if self.basis:
            out["principal_competence_basis"] = self.basis
        return out


def _build_or_refuse(verb: str, ctor, **kw):
    """Constructs one of the typed payload dataclasses above, translating a `__post_init__`
    contract violation into this file's own REFUSED convention (nothing written) instead of an
    uncaught traceback. Returns the constructed payload, or None having already printed the
    REFUSED line."""
    try:
        return ctor(**kw)
    except ValueError as e:
        print(f"led principal {verb}: REFUSED -- {e}.", file=sys.stderr)
        return None


def _write_principal(cfg: bcc.ServedConfig, kind: str, statement: str, actor: int | None,
                      payload) -> int:
    """The ONE shared write point for all 13 principal verbs (mirrors legacy-led.tmpl's own
    `_principal_binding_insert`, one writer/many callers, ADR-0012 P1) -- POSTs to /write/ledger,
    the SAME generic surface `led work open`/the generic `<kind> <statement>` path already use.
    `payload` is one of the typed dataclasses above; its own `.fields()` is the only place that
    knows its own column names (row 1173 finding 4 -- replaces the former bag-of-bare-optionals
    `_principal_write`)."""
    body: dict = {"kind": kind, "statement": statement, **payload.fields()}
    if actor is not None:
        body["actor"] = actor
    return bcc.write_and_report(cfg.base, "ledger", body)


