_ARTIFACT_MEDIA_EXT_MAP = {".md": "text/markdown", ".markdown": "text/markdown",
                           ".toml": "application/toml", ".json": "application/json"}


def cmd_artifact_put(cfg: bcc.ServedConfig, path: str, media_type: str | None) -> int:
    """design/FABLE-LEGACY-LED-RETIREMENT-SPEC.md Part B: POST /artifacts, targeting
    kernel.artifact_write (kernel/lineage/s51-artifact-store.sql) through the boundary. Grammar
    and media_type-inference-by-extension are byte-for-byte legacy-led.tmpl's own (see that
    file's own `artifact put` case) -- the size cap is enforced by the kernel alone (P1: no
    second size limit; the boundary route imposes no artifact-specific bound of its own, see
    serving/boundary_service.py's MAX_ARTIFACT_BODY_BYTES docstring for the buffering-only bound
    that DOES exist)."""
    p = Path(path)
    if not p.is_file():
        print(f"led artifact put: REFUSED -- {path!r} does not exist or is not a regular file "
              f"-- nothing to register.", file=sys.stderr)
        return 1
    data = p.read_bytes()
    media = media_type or _ARTIFACT_MEDIA_EXT_MAP.get(p.suffix.lower(), "text/plain")
    actor = _resolve_actor(cfg)
    payload: dict = {"bytes": base64.b64encode(data).decode("ascii"), "media_type": media}
    if actor is not None:
        payload["actor"] = actor
    exit_code, verdict = bcc.post_artifact(cfg.base, payload)
    if exit_code == 0:
        print(f"led artifact put: {verdict.get('message')} (from {path})")
        return 0
    sys.stderr.write(
        f"led artifact put: REFUSED by the kernel write boundary (SQLSTATE {verdict.get('sqlstate')}; "
        f"journaled as write_refused row {verdict.get('refusal_id')}):\n"
        f"  {verdict.get('message')}\n")
    return 1


def cmd_artifact_get(cfg: bcc.ServedConfig, hash_: str, out: str | None) -> int:
    """design/FABLE-LEGACY-LED-RETIREMENT-SPEC.md Part B: GET /artifacts/{hash}. Re-verifies the
    received bytes against `hash_` CLIENT-SIDE too -- belt-and-braces with the boundary's own
    server-side re-verification on the way out (serving/boundary_service.py's `artifact_get`),
    preserving legacy-led.tmpl's own WA6 corruption-drill teach-text byte-for-byte (a corrupt
    store must fail loud here too, never serve silently-wrong bytes, even if the server-side
    check somehow regressed)."""
    if not re.match(r'^[0-9a-f]{64}$', hash_):
        print(f"usage: led artifact get <64-hex-char-sha256-hash> [--out <path>]", file=sys.stderr)
        return 4
    try:
        raw, _content_type = bcc.get_bytes(cfg.base, f"/artifacts/{hash_}")
    except bcc.BoundaryRefusal as e:
        if e.status == 404:
            print(f"led artifact get: REFUSED -- no artifact registered with hash '{hash_}'.",
                  file=sys.stderr)
            print("  See 'led artifact stat <hash>' to check, or 'led artifact put <path>' to "
                  "register one.", file=sys.stderr)
            return 1
        raise
    computed = hashlib.sha256(raw).hexdigest()
    if computed != hash_:
        print(f"led artifact get: REFUSED -- CORRUPT STORE -- the bytes returned for hash",
              file=sys.stderr)
        print(f"  '{hash_}' do NOT hash to '{hash_}' (computed '{computed}' instead).",
              file=sys.stderr)
        print("  kernel/lineage/s51-artifact-store.sql: a corrupt store fails loud here, never",
              file=sys.stderr)
        print("  serves silently-wrong bytes under a claimed hash. Nothing was written.",
              file=sys.stderr)
        return 1
    if out:
        Path(out).write_bytes(raw)
        print(f"led artifact get: wrote {hash_} -> {out} (hash verified).", file=sys.stderr)
    else:
        sys.stdout.buffer.write(raw)
    return 0


def cmd_artifact_stat(cfg: bcc.ServedConfig, hash_: str) -> int:
    """design/FABLE-LEGACY-LED-RETIREMENT-SPEC.md Part B: GET /artifacts/{hash}/stat."""
    if not re.match(r'^[0-9a-f]{64}$', hash_):
        print(f"usage: led artifact stat <64-hex-char-sha256-hash>", file=sys.stderr)
        return 4
