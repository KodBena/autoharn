def cmd_work_close(cfg: bcc.ServedConfig, argv: list[str]) -> int:
    witness = review_witness = None
    review_deferred = review_bookkeeping = strict = False
    supersedes = None
    args: list[str] = []
    it = iter(argv)
    for tok in it:
        if tok == "--witness":
            witness = next(it, None)
        elif tok == "--review-witness":
            review_witness = next(it, None)
        elif tok == "--review-deferred":
            review_deferred = True
        elif tok == "--review-bookkeeping":
            review_bookkeeping = True
        elif tok == "--strict":
