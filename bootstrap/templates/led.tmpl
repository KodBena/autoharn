def cmd_work_depends(cfg: bcc.ServedConfig, argv: list[str]) -> int:
    edge_type = supersedes = None
    args: list[str] = []
    it = iter(argv)
    for tok in it:
        if tok == "--type":
            edge_type = next(it, None)
        elif tok == "--supersedes":
            supersedes = next(it, None)
        elif tok.startswith("--"):
            print(f"led work depends: REFUSED -- unrecognized flag '{tok}'.", file=sys.stderr)
            print("  led work depends <slug> <on-slug> accepts only: --type", file=sys.stderr)
            print("  blocks-close|blocks-start|informs, --supersedes <ledger-id>.", file=sys.stderr)
            print("  NOTHING was written.", file=sys.stderr)
            return 1
        else:
            args.append(tok)
    if len(args) < 2:
        print("usage: led work depends <slug> <on-slug> [--type blocks-close|blocks-start|informs] "
              "[--supersedes <ledger-id>]", file=sys.stderr)
        return 4
    slug, on = args[0], args[1]
    if edge_type and edge_type not in ("blocks-close", "blocks-start", "informs"):
        print(f"led work depends: REFUSED -- --type must be blocks-close, blocks-start, or "
              f"informs (got {edge_type!r}).", file=sys.stderr)
        return 1
    # --supersedes VALIDATION (ledger item led-work-depends-supersedes), ported off legacy's own
    # three checks -- (i)/(ii) below read GET /rows/{id} (raw ledger by id) and a walk of
    # /rows/current for "already superseded"; DISCLOSED NARROWING versus legacy's raw-ledger
    # SQL -- see this file's own SCOPE comment near the top for the exact residual.
    if supersedes:
        try:
            target = bcc.get_json(cfg.base, f"/rows/{supersedes}")
        except bcc.BoundaryRefusal as e:
            if e.status == 404:
                print(f"led work depends: REFUSED -- --supersedes {supersedes} does not name "
                      f"any ledger row. NOTHING was written.", file=sys.stderr)
                return 1
            raise
        if target.get("kind") != "work_depends_on":
            print(f"led work depends: REFUSED -- --supersedes {supersedes} names a "
                  f"'{target.get('kind')}' row, not a work_depends_on row. NOTHING was written.",
                  file=sys.stderr)
            return 1
        current_rows = bcc.get_all_rows(cfg.base, "/rows/current", cursor="after_id")
        superseder = next((r for r in current_rows if str(r.get("supersedes")) == str(supersedes)), None)
        if superseder is not None:
            print(f"led work depends: REFUSED -- --supersedes {supersedes} is already "
                  f"superseded (by row {superseder['id']}). NOTHING was written.", file=sys.stderr)
            return 1
    if not edge_type:
        print(f"led work depends: recorded as informs (advisory only -- never enforced at "
              f"close or claim); if {on} must be finished before {slug} may close, use "
              f"--type blocks-close; if {on} must be CLOSED before {slug} may be CLAIMED, use "
              f"--type blocks-start (s39).", file=sys.stderr)
    actor = _resolve_actor(cfg)
    payload: dict = {"kind": "work_depends_on", "work_slug": slug, "work_depends_on": on,
                      "statement": f"work_depends_on: {slug} depends on {on}"}
    if edge_type:
        payload["edge_type"] = edge_type
    if supersedes:
        payload["supersedes"] = int(supersedes)
    if actor is not None:
        payload["actor"] = actor
    return bcc.write_and_report(cfg.base, "ledger", payload)


