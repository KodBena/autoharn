#!/usr/bin/env bash
# led — one-liner decision-ledger entries for this project.
#
# Usage:
#   led [flags] <kind> <statement...>          e.g. led decision "perceptual distance = CIEDE2000"
#
#   flags (any order, any subset, all optional, consumed before <kind>):
#     -f a.py,b.py           declares files: a.py,b.py in the entry's rationale, so the
#                            PreToolUse change gate (autoharn hooks/pretooluse_change_gate.py)
#                            recognizes this entry as authorizing an edit to those files
#     -e id1,id2             enacts: this entry carries the named EARLIER own-session row(s)
#                            into a file (s15 validate_enacts; each id must resolve to an
#                            earlier row in the same session or the trigger refuses)
#     --supersedes id        this entry supersedes an earlier row; the superseded row drops out
#                            of ledger_current and is marked SUPERSEDED in `led --recent`/`led current`
#     --amends id --amends-scope "<verbatim clause>"
#                            clause-level revision: id's clause named by amends-scope is
#                            defeated while the rest of id stands (id itself is NOT superseded).
#                            amends-scope must be an EXACT, unambiguous (occurs-once) 10+ char
#                            substring of id's own statement or rationale (s15 validate_amends)
#                            — both-or-neither; a mismatched/ambiguous quote is refused
#     --answers id           this entry (any kind) resolves an earlier kind=question row id
#                            (s15 validate_answers); shows up in `led question-status`
#     --refs "<text>"        free-text cross-reference (ledger.refs). CONVENTION for citing an
#                            antecedent ledger row from ANY kind: `--refs row:<id>` (e.g. a
#                            verification result citing its pre-registered criteria row:
#                            `led --refs row:12 --evidence "..." verification "criteria met"`).
#                            This is the kernel's own sanctioned channel for a bare row
#                            reference on a non-review kind — s15's enacts column comment says
#                            it outright: "a bare reference uses refs". The TYPED regards edge
#                            stays reserved for kind=review (s15 validate_review, unchanged
#                            through s21: "regards is reserved for kind=review") and is written
#                            only by `led review`'s own <entry-id> positional arg; a --regards
#                            flag on a generic kind would be refused by the kernel every time,
#                            so none is offered.
#     --concern design|enactment|process|other
#     --evidence "<text>"
#     --confidence low|medium|high
#
#   LED_ACTOR=<principal-name>   (env var, not a flag) resolves the actor/principal for EVERY
#                            ledger-writing verb -- the generic <kind> <statement> path below,
#                            `led review`, and `led work claim` alike (ONE resolution point,
#                            resolve_actor(), defined once and shared by all three). Unset, a
#                            write lands under the default connection principal (`author`). Set to
#                            an unregistered name, the write is REFUSED with teach-text (register
#                            it first: `led register-principal <name> <class>`) rather than
#                            silently falling back to the default principal.
#
#   led --recent [N]                          last N ledger rows (default 10), newest first;
#                                              marks a row SUPERSEDED when a later row's
#                                              `supersedes` names it (never displays a
#                                              superseded row as if it were still current)
#   led current [N]                           last N rows of ledger_current (supersedes-filtered
#                                              read) — the view a consumer should read by default
#   led question-status                       question_status view: every open/answered question
#   led review-gap                            review_gap view: EVERY row (any kind) by an obliged
#                                              actor with no distinct-actor attest countersign yet —
#                                              not scope-filtered (see `led obligate` below)
#   led stamp-distinctness                    review_stamp_distinctness view: for each review,
#                                              whether the SAME invocation wrote it and its target
#
#   led register-principal <name> <class>     register a principal (class: human|model|subagent|tool)
#                                              so a countersign can be attributed to it — the
#                                              writer registers its own principals, the kernel
#                                              pre-seeds none but the one connection principal
#
#   led review <entry-id> <verdict> <independence> [--antecedent id] <statement...>
#                                              countersign an earlier row. verdict:
#                                              attest|attest_with_reservations|refuse. independence:
#                                              self-review|technical|managerial|financial (technical/
#                                              managerial/financial REQUIRE a stamp-distinct invocation
#                                              — else the trigger refuses and teaches self-review).
#                                              --antecedent id names the EARLIER defeated row this
#                                              review affirms <entry-id> survives (review_detail.antecedent,
#                                              NULL for a plain countersign). `statement` doubles as
#                                              review_detail's `basis`. Set LED_ACTOR=<principal-name> to
#                                              countersign as a registered principal other than the default
#                                              connection principal (`author`) — WITHOUT it, every write
#                                              resolves to the same principal and a review is refused as
#                                              self-review (validate_review keys on the actor/principal,
#                                              never on the stamped invocation identity).
#
#   led obligate <scope> <assigned-by-principal> <obliged-actor-principal>
#                                              register a countersign_obligation. DIRECTION, spelled
#                                              out because getting it backwards is the recurring
#                                              obligate mistake (BACKLOG run-5 AND run-7 forensics,
#                                              two consecutive runs, each cost a workaround round):
#                                              <obliged-actor-principal> is the WORKER — the principal
#                                              whose rows need outside eyes. It must NEVER be the
#                                              reviewer/countersigner. <assigned-by-principal> is
#                                              whoever is imposing the obligation (must differ from
#                                              the obliged actor — the obligation_not_self_assigned
#                                              CHECK refuses a self-ASSIGNED obligation; distinct from
#                                              `led register-principal`'s unrelated self-registration).
#                                              <scope> is a free-text LABEL naming this obligation row
#                                              (its PK) — it is NOT a filter key: `review_gap` joins on
#                                              actor identity alone (o.obliges_actor = l.actor), and
#                                              the ledger table carries no scope column to narrow it
#                                              against. KNOWN OVER-CATCH (fail-safe direction, no
#                                              maintainer ruling yet — kernel/lineage s13/s14 review_gap):
#                                              once a principal is obliged, `led review-gap` counts
#                                              EVERY uncountersigned row that principal ever writes —
#                                              any kind, including that principal's OWN later review/
#                                              attest rows — not only rows "in scope". Obliging the
#                                              REVIEWER by mistake makes the reviewer's own countersigns
#                                              show up as debt, forcing an author counter-countersign
#                                              round (this already happened twice — see BACKLOG).
#                                              Worked example: `led obligate decomposition-review
#                                              orchestrator author` — after this, someone other than
#                                              'author' must countersign every one of author's ledger
#                                              rows (any kind) or `led review-gap` shows debt for each.
#   led obligate revoke <scope>               delete a countersign_obligation row by scope (its PK).
#                                              Whether this succeeds or is REFUSED depends on the
#                                              connecting role's LIVE grants on countersign_obligation,
#                                              checked here via has_table_privilege (never assumed,
#                                              never hardcoded) — s20 granted this role SELECT,INSERT
#                                              ONLY on countersign_obligation, by deliberate ruling (an
#                                              obligation is standing OPERATOR-owned policy config, not
#                                              a role self-service capability), so under an unmodified
#                                              kernel this REFUSES every time, with teach-text naming
#                                              the maintainer act that does revoke it. `led` never
#                                              widens its own grants to bypass this.
#
#   led work open <slug> <title...>           open a work item (kernel/lineage/s22-work-item-ledger.sql's
#                                              validate_work_item(): one opening act per slug — a
#                                              duplicate open is REFUSED at insert, never silently
#                                              accepted; the Q5 defect made unrepresentable)
#   led work claim <slug>                     claim an already-opened item as the acting principal
#                                              (refused if <slug> has no opening act). Set
#                                              LED_ACTOR=<principal-name> to claim as a registered
#                                              principal other than the default connection principal
#                                              (else the claim lands under that default principal)
#   led work depends <slug> <on-slug>         record that <slug> (must already be opened) depends on
#                                              <on-slug>. <on-slug> itself is NOT required to be
#                                              opened — a dangling antecedent is deliberately NOT
#                                              refused (spec invariant 4); it is surfaced instead by
#                                              `led work violations` (depends_on_unknown_slug)
#   led work close <slug> <resolution> [--witness <ref>]
#                                              close a work item. REFUSED if <slug> has no
#                                              work_claimed row yet (led-side gate, mirroring the
#                                              existing duplicate-open/unopened refusals — run-5
#                                              forensics: two work items were closed with no claim
#                                              ever landing, unflagged, until an outside review
#                                              caught it) — claim it first: `./led work claim <slug>`.
#                                              resolution: shipped|superseded|dropped|deferred.
#                                              resolution=shipped REQUIRES --witness — refused at
#                                              construction time (work_shipped_requires_witness
#                                              CHECK), never a tolerated-but-flagged row
#   led work list                             work_item_current: one row per slug — state (open/
#                                              closed), title, resolution, witness, claimant
#   led work violations                       work_item_violations: duplicate_open and
#                                              shipped_without_witness (both provably vacuous under
#                                              normal operation — refused at insert above, listed as
#                                              defense in depth) plus the two genuinely-reachable,
#                                              deliberately-unrefused members depends_on_unknown_slug
#                                              and dependency_cycle
#   led work asof <timestamp>                 READ-ONLY point-in-time reconstruction: work-item
#                                              states (open/claimed/closed) AS OF <timestamp>,
#                                              derived by filtering the append-only work_* ledger
#                                              rows to ts <= <timestamp> before picking each item's
#                                              latest opened/claimed/closed row — no kernel change,
#                                              a pure SELECT over existing columns (BACKLOG "Omega
#                                              work-tracking disposition" 2026-07-11, item 2)
#                                              (these seven verbs require kernel/lineage/s22-work-item-
#                                              ledger.sql applied to this project's schema — s22 is
#                                              an additive delta on the s15/s17/s19/s20/s21 birth
#                                              chain, part of it from s22 onward — see OPERATING-CARD.md)
#
# Connection defaults are sourced LIVE from this project's deployment.json at RUN TIME (BACKLOG
# maintainer ruling 2026-07-11, "runs are strictly linear" disposition 6, "live verbs"). This file
# is no longer copied into a project and sed-substituted at scaffold time -- the scaffolded ./led
# is a 3-line shim that `exec`s THIS file directly out of the autoharn checkout, every invocation,
# so a template fix (this file) reaches every already-scaffolded world instantly, not just the
# next scaffold (the asymmetry that let one just-fixed defect live on in five worlds forever).
# deployment.json is found next to the shim -- the shim passes its own directory through via the
# PICKUP_DEPLOYMENT env var (the same mechanism `judge`/`pickup` already used for this; the name
# predates `led` joining the convention, kept as ONE shared mechanism rather than three
# near-identical env vars, ADR-0012 P1) -- loaded via autoharn's filing/deployment_record.py (the
# ONE home for that JSON shape). autoharn's own location is resolved from THIS file's own on-disk
# path (it executes in place now, never copied), overridable with AUTOHARN=/path/to/autoharn for a
# differently-laid-out checkout (same convention `judge`/`pickup` use).
# Override the resolved values via LED_PGHOST/LED_PGDB/LED_SCHEMA/LED_KERNEL/LED_ROLE if this
# project's kernel is re-applied under different names -- unchanged from before.
set -euo pipefail

HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
AUTOHARN_ROOT="${AUTOHARN:-$(cd "$HERE/../.." && pwd)}"
DEPLOYMENT="${PICKUP_DEPLOYMENT:-$HERE/deployment.json}"

# One live read of deployment.json, via autoharn's filing/deployment_record.py (the ONE home for
# that shape -- this script does not grow a second JSON parser). Prints shell-quoted DEP_* bindings
# for `eval` below; refuses loudly (teach-text on stderr, exit 2) on a missing/malformed record,
# never a guessed default (ADR-0002).
_dep_vars="$(python3 - "$AUTOHARN_ROOT" "$DEPLOYMENT" <<'PYEOF'
import sys, shlex
autoharn_root, dep_path = sys.argv[1:3]
sys.path.insert(0, autoharn_root + "/filing")
import deployment_record as dr
try:
    d = dr.load_deployment(dep_path)
except dr.DeploymentError as e:
    print(f"led: {e}", file=sys.stderr)
    sys.exit(2)
for k in ("db", "host", "schema", "kern", "role"):
    print(f"DEP_{k.upper()}={shlex.quote(getattr(d, k))}")
PYEOF
)" || exit 2
eval "$_dep_vars"

PGHOST="${LED_PGHOST:-$DEP_HOST}"
PGDB="${LED_PGDB:-$DEP_DB}"
SCHEMA="${LED_SCHEMA:-$DEP_SCHEMA}"
KERNEL="${LED_KERNEL:-$DEP_KERN}"
ROLE="${LED_ROLE:-$DEP_ROLE}"

# --- flags (any order, any subset), consumed up front so the verb dispatch below and the
# generic <kind> <statement...> path both see a clean $@ -------------------------------------
files=""
enacts=""
supersedes=""
amends=""
amends_scope=""
answers=""
refs=""
concern=""
evidence=""
confidence=""
while true; do
  case "${1:-}" in
    -f) files="${2:-}"; shift 2 ;;
    -e) enacts="${2:-}"; shift 2 ;;
    --supersedes) supersedes="${2:-}"; shift 2 ;;
    --amends) amends="${2:-}"; shift 2 ;;
    --amends-scope) amends_scope="${2:-}"; shift 2 ;;
    --answers) answers="${2:-}"; shift 2 ;;
    --refs) refs="${2:-}"; shift 2 ;;
    --concern) concern="${2:-}"; shift 2 ;;
    --evidence) evidence="${2:-}"; shift 2 ;;
    --confidence) confidence="${2:-}"; shift 2 ;;
    *) break ;;
  esac
done

# --- LED_ACTOR resolution (ONE point, used by every ledger-writing path below: `led review`,
# `led work claim`, and the generic <kind> <statement> path) -----------------------------------
# Sets $actor_name to LED_ACTOR (may be empty). Downstream, NULLIF(:'actor_name','') still turns
# an empty value into NULL so the kernel's set_actor trigger fills the default connection
# principal, unchanged from before. What's new here: an explicit, up-front existence check. A
# NAMED but unregistered LED_ACTOR used to fall through that same NULL path too -- the subquery
# `SELECT id FROM principal WHERE name = ...` matches no row and also returns NULL -- so it landed
# attributed to the default principal exactly like an unset LED_ACTOR, indistinguishable
# misattribution, never surfaced. This function forecloses that as a CLASS (ADR-0000: one fact,
# one writer) instead of leaving it as three separately-patchable instances: it used to be
# duplicated inline in the review/work-claim paths and OMITTED entirely from the generic path --
# the generic path never read LED_ACTOR at all, so every `led <kind> ...` write landed under the
# default principal regardless of LED_ACTOR (BACKLOG run-7 forensics, ledger row 63:
# LED_ACTOR=reviewer landed as actor='author').
resolve_actor() {
  actor_name="${LED_ACTOR:-}"
  if [ -n "$actor_name" ]; then
    local registered
    registered=$(psql -h "$PGHOST" -d "$PGDB" -tAq -v actor_name="$actor_name" <<SQL
      SET ROLE ${ROLE};
      SET search_path = ${SCHEMA}, ${KERNEL};
      SELECT EXISTS (SELECT 1 FROM principal WHERE name = :'actor_name');
SQL
    )
    if [ "$registered" != "t" ]; then
      echo "led: REFUSED -- LED_ACTOR='${actor_name}' is not a registered principal." >&2
      echo "  Register it first: ./led register-principal ${actor_name} <human|model|subagent|tool>" >&2
      exit 1
    fi
  fi
}

# --- flag-in-statement tripwire (BACKLOG "Chocofarm experiment-ledger disposition" 2026-07-11
# night shift, finding 2, run7 row 71): a flag typed INSIDE the quoted statement text is invisible
# ceremony -- by the time the top-of-file flag loop runs, that text is already part of the
# statement word(s), so the flag never reaches the parser and the typed FK column it names
# (supersedes/refs/regards/amends/answers/evidence/confidence) lands NULL, silently (run7 row 71:
# statement text ended `--supersedes 48 --refs row:57,row:58,row:59`; both columns were NULL --
# across all 79 run7 rows, supersedes/amends/answers were used zero times despite the vocabulary
# existing). WARN-ONLY, never refuses: a statement can legitimately QUOTE one of these tokens in
# prose (e.g. reporting someone else's command verbatim), so a false positive here is a harmless
# notice, not a blocked write -- a tripwire, not a gate (mirrors demurral_detect.py's own
# observer-only posture). led's OWN flag vocabulary is spelled out once, here, so a future flag
# added to the top-of-file parser is not silently invisible to this check (ADR-0012 P1: one list).
LED_FLAG_VOCAB="--supersedes --refs --regards --amends --answers --evidence --confidence"
warn_flag_in_statement() {
  local text="$1" flag
  for flag in $LED_FLAG_VOCAB; do
    case "$text" in
      *"$flag"*)
        echo "led: WARNING -- the statement text contains '${flag}', which looks like one of" >&2
        echo "  led's own flags. Flags inside the quoted statement are NOT parsed -- if you meant" >&2
        echo "  to set the typed column, re-issue the command with ${flag} OUTSIDE the quotes." >&2
        echo "  (warn-only tripwire, not a refusal -- a statement that legitimately quotes" >&2
        echo "  '${flag}' in prose just sees this notice; the write proceeds either way)" >&2
        ;;
    esac
  done
}

if [ "${1:-}" = "--recent" ] || [ "${1:-}" = "current" ]; then
  # `current` reads ledger_current (supersedes already filtered server-side, the ledger's own view).
  # `--recent` reads the raw table but MARKS a superseded row visibly instead of silently
  # showing it as current -- stamp_agent: the invocation identity that actually WROTE the row --
  # "main" for the top-level context, a subagent's own agent_id otherwise, NULL when unstamped
  # (a non-intercepted write path). Shown alongside the writer-supplied actor principal so a
  # reader can see WHO (principal) and, independently, WHICH INVOCATION wrote each row.
  if [ "${1:-}" = "current" ]; then
    n="${2:-10}"
    exec psql -h "$PGHOST" -d "$PGDB" -tAc "
      SELECT l.id, l.kind, l.statement, p.name
      FROM ${SCHEMA}.ledger_current l JOIN ${KERNEL}.principal p ON p.id = l.actor
      ORDER BY l.id DESC LIMIT ${n};"
  fi
  n="${2:-10}"
  exec psql -h "$PGHOST" -d "$PGDB" -tAc "
    SELECT l.id, l.kind, l.statement, p.name, l.stamp_agent, l.stamp_verified,
           CASE WHEN EXISTS (SELECT 1 FROM ${SCHEMA}.ledger s WHERE s.supersedes = l.id)
                THEN 'SUPERSEDED' ELSE 'current' END AS status_now
    FROM ${SCHEMA}.ledger l JOIN ${KERNEL}.principal p ON p.id = l.actor
    ORDER BY l.id DESC LIMIT ${n};"
fi

if [ "${1:-}" = "question-status" ]; then
  exec psql -h "$PGHOST" -d "$PGDB" -c "SELECT * FROM ${SCHEMA}.question_status ORDER BY question_id;"
fi

if [ "${1:-}" = "review-gap" ]; then
  exec psql -h "$PGHOST" -d "$PGDB" -c "SELECT * FROM ${SCHEMA}.review_gap ORDER BY id;"
fi

if [ "${1:-}" = "stamp-distinctness" ]; then
  exec psql -h "$PGHOST" -d "$PGDB" -c "SELECT * FROM ${SCHEMA}.review_stamp_distinctness ORDER BY review_id;"
fi

if [ "${1:-}" = "register-principal" ]; then
  name="${2:-}"; class="${3:-}"
  if [ -z "$name" ] || [ -z "$class" ]; then
    echo "usage: led register-principal <name> <human|model|subagent|tool>" >&2
    exit 1
  fi
  exec psql -h "$PGHOST" -d "$PGDB" -v ON_ERROR_STOP=1 -v name="$name" -v class="$class" <<SQL
    SET ROLE ${ROLE};
    SET search_path = ${SCHEMA}, ${KERNEL};
    INSERT INTO principal (name, agent_class) VALUES (:'name', :'class')
    ON CONFLICT (name) DO NOTHING;
SQL
fi

if [ "${1:-}" = "obligate" ]; then
  shift
  if [ "${1:-}" = "revoke" ]; then
    shift
    if [ $# -lt 1 ]; then
      echo "usage: led obligate revoke <scope>" >&2
      echo "       deletes a countersign_obligation row (scope is its PK). Whether this succeeds" >&2
      echo "       or is refused depends on the connecting role's LIVE grants on" >&2
      echo "       countersign_obligation -- checked here via has_table_privilege, never assumed" >&2
      echo "       (s20 granted this role SELECT,INSERT only, by deliberate ruling: an obligation" >&2
      echo "       is standing OPERATOR-owned policy config, never a role self-service capability)" >&2
      exit 1
    fi
    scope="$1"
    # LIVE check, not a hardcoded assumption: if a future kernel delta ever grants DELETE, this
    # verb starts working with no code change here -- the grant state has one home (pg_catalog),
    # never a second hand-copied boolean in this script (ADR-0012 P1).
    can_delete=$(psql -h "$PGHOST" -d "$PGDB" -tAc \
      "SELECT has_table_privilege('${ROLE}', '${SCHEMA}.countersign_obligation', 'DELETE');")
    if [ "$can_delete" != "t" ]; then
      echo "led obligate revoke: REFUSED -- role '${ROLE}' has no DELETE grant on" >&2
      echo "  ${SCHEMA}.countersign_obligation (checked live via has_table_privilege, not" >&2
      echo "  hardcoded). This is s20's deliberate ruling, not an oversight: an obligation is" >&2
      echo "  standing operator-owned policy config, never a role-level self-service capability" >&2
      echo "  -- widening the grant would be a kernel delta and is out of scope for this verb to" >&2
      echo "  take on itself. To revoke scope '${scope}', a maintainer runs, AS THE SCHEMA OWNER" >&2
      echo "  (never as ${ROLE}, never by widening ${ROLE}'s grants):" >&2
      echo "    psql -h ${PGHOST} -d ${PGDB} -v ON_ERROR_STOP=1 -c \\" >&2
      echo "      \"DELETE FROM ${SCHEMA}.countersign_obligation WHERE scope = '${scope}';\"" >&2
      exit 1
    fi
    exec psql -h "$PGHOST" -d "$PGDB" -v ON_ERROR_STOP=1 -v scope="$scope" <<SQL
      SET ROLE ${ROLE};
      SET search_path = ${SCHEMA}, ${KERNEL};
      DELETE FROM ${SCHEMA}.countersign_obligation WHERE scope = :'scope';
SQL
  fi
  if [ $# -lt 3 ]; then
    echo "usage: led obligate <scope> <assigned-by-principal> <obliged-actor-principal>" >&2
    echo "  DIRECTION MATTERS -- this is the mistake that has cost a workaround two runs" >&2
    echo "  running (BACKLOG run-5, run-7): <obliged-actor-principal> is the WORKER whose" >&2
    echo "  rows need outside eyes -- never the reviewer. <assigned-by-principal> is whoever" >&2
    echo "  imposes the obligation and must be a DIFFERENT registered principal than the" >&2
    echo "  obliged actor (obligation_not_self_assigned CHECK refuses a self-ASSIGNED" >&2
    echo "  obligation -- distinct from register-principal's self-REGISTRATION). <scope> is" >&2
    echo "  a free-text label, not a filter: review_gap joins on actor identity alone, so" >&2
    echo "  it counts EVERY row (any kind) the obliged actor writes, not just this scope's" >&2
    echo "  rows -- obliging the reviewer by mistake catches the reviewer's own countersigns." >&2
    echo "  example: led obligate decomposition-review orchestrator author" >&2
    echo "    -> after this, someone other than 'author' must countersign every one of" >&2
    echo "       author's ledger rows or \`led review-gap\` shows debt for each." >&2
    echo "       led obligate revoke <scope>" >&2
    exit 1
  fi
  scope="$1"; assigned_by_name="$2"; obliges_actor_name="$3"
  exec psql -h "$PGHOST" -d "$PGDB" -v ON_ERROR_STOP=1 \
    -v scope="$scope" -v assigned_by_name="$assigned_by_name" -v obliges_actor_name="$obliges_actor_name" <<SQL
    SET ROLE ${ROLE};
    SET search_path = ${SCHEMA}, ${KERNEL};
    INSERT INTO ${SCHEMA}.countersign_obligation (scope, assigned_by, obliges_actor)
    VALUES (:'scope',
            (SELECT id FROM principal WHERE name = :'assigned_by_name'),
            (SELECT id FROM principal WHERE name = :'obliges_actor_name'));
SQL
fi

if [ "${1:-}" = "review" ]; then
  shift
  antecedent=""
  args=()
  while [ $# -gt 0 ]; do
    case "$1" in
      --antecedent) antecedent="${2:-}"; shift 2 ;;
      *) args+=("$1"); shift ;;
    esac
  done
  set -- "${args[@]}"
  if [ $# -lt 4 ]; then
    echo "usage: led review <entry-id> <verdict> <independence> [--antecedent id] <statement...>" >&2
    echo "       verdict: attest|attest_with_reservations|refuse" >&2
    echo "       independence: self-review|technical|managerial|financial" >&2
    echo "       set LED_ACTOR=<principal-name> to countersign as a registered principal" >&2
    exit 1
  fi
  regards="$1"; verdict="$2"; independence="$3"; shift 3
  statement="$*"
  warn_flag_in_statement "$statement"
  resolve_actor
  # actor resolves via a subquery bind below, NOT string-spliced: NULLIF(:'actor_name','') is NULL
  # when LED_ACTOR is unset, so the ledger's actor column stays NULL and the kernel's set_actor
  # trigger fills the default connection principal -- the same principal every other led write
  # uses, so an un-set LED_ACTOR against one's own earlier row is refused as self-review (the
  # honest, intended outcome). resolve_actor (defined near the top of this file) is the ONE place
  # LED_ACTOR is read and validated, shared with `led work claim` and the generic
  # <kind> <statement> path.
  psql -h "$PGHOST" -d "$PGDB" -v ON_ERROR_STOP=1 \
    -v regards="$regards" -v verdict="$verdict" -v independence="$independence" \
    -v statement="$statement" -v actor_name="$actor_name" -v antecedent="$antecedent" <<SQL
    SET ROLE ${ROLE};
    SET search_path = ${SCHEMA}, ${KERNEL};
    BEGIN;
    INSERT INTO ${SCHEMA}.ledger (kind, statement, regards, actor)
    VALUES ('review', :'statement', :'regards'::bigint,
            (SELECT id FROM principal WHERE name = NULLIF(:'actor_name', '')))
    RETURNING id \gset r_
    INSERT INTO ${SCHEMA}.review_detail (ledger_id, verdict, independence, basis, antecedent)
    VALUES (:r_id, :'verdict', :'independence', :'statement', NULLIF(:'antecedent', '')::bigint);
    COMMIT;
SQL
  exit $?
fi

if [ "${1:-}" = "work" ]; then
  shift
  sub="${1:-}"
  case "$sub" in
    open)
      shift
      if [ $# -lt 2 ]; then
        echo "usage: led work open <slug> <title...>" >&2
        echo "       refused if <slug> already has an opening act (validate_work_item(): one" >&2
        echo "       opening act per slug -- the Q5 defect made unrepresentable, never a silent" >&2
        echo "       duplicate)" >&2
        exit 1
      fi
      slug="$1"; shift
      title="$*"
      exec psql -h "$PGHOST" -d "$PGDB" -v ON_ERROR_STOP=1 \
        -v slug="$slug" -v title="$title" -v statement="work_opened: ${slug} -- ${title}" <<SQL
        SET ROLE ${ROLE};
        SET search_path = ${SCHEMA}, ${KERNEL};
        INSERT INTO ${SCHEMA}.ledger (kind, work_slug, work_title, statement)
        VALUES ('work_opened', :'slug', :'title', :'statement');
SQL
      ;;
    claim)
      shift
      if [ $# -lt 1 ]; then
        echo "usage: led work claim <slug>" >&2
        echo "       refused if <slug> has no opening act (validate_work_item(): every later" >&2
        echo "       event on an item must reference an item that has been opened)" >&2
        echo "       set LED_ACTOR=<principal-name> to claim as a registered principal other" >&2
        echo "       than the default connection principal" >&2
        exit 1
      fi
      slug="$1"
      resolve_actor
      # actor resolves via a subquery bind exactly as `led review` does above: NULLIF(:'actor_name','')
      # is NULL when LED_ACTOR is unset, so the claim lands under the default connection principal.
      # resolve_actor (defined near the top of this file) is the ONE place LED_ACTOR is read/
      # validated, shared with `led review` and the generic <kind> <statement> path.
      exec psql -h "$PGHOST" -d "$PGDB" -v ON_ERROR_STOP=1 \
        -v slug="$slug" -v actor_name="$actor_name" -v statement="work_claimed: ${slug}" <<SQL
        SET ROLE ${ROLE};
        SET search_path = ${SCHEMA}, ${KERNEL};
        INSERT INTO ${SCHEMA}.ledger (kind, work_slug, statement, actor)
        VALUES ('work_claimed', :'slug', :'statement',
                (SELECT id FROM principal WHERE name = NULLIF(:'actor_name', '')));
SQL
      ;;
    depends)
      shift
      if [ $# -lt 2 ]; then
        echo "usage: led work depends <slug> <on-slug>" >&2
        echo "       <slug> must already be opened (refused otherwise); <on-slug> (the" >&2
        echo "       antecedent) is NOT required to be opened -- a dangling antecedent is" >&2
        echo "       deliberately NOT refused (spec invariant 4), it is surfaced instead by" >&2
        echo "       'led work violations' (depends_on_unknown_slug)" >&2
        exit 1
      fi
      slug="$1"; on="$2"
      exec psql -h "$PGHOST" -d "$PGDB" -v ON_ERROR_STOP=1 \
        -v slug="$slug" -v on="$on" -v statement="work_depends_on: ${slug} depends on ${on}" <<SQL
        SET ROLE ${ROLE};
        SET search_path = ${SCHEMA}, ${KERNEL};
        INSERT INTO ${SCHEMA}.ledger (kind, work_slug, work_depends_on, statement)
        VALUES ('work_depends_on', :'slug', :'on', :'statement');
SQL
      ;;
    close)
      shift
      witness=""
      args=()
      while [ $# -gt 0 ]; do
        case "$1" in
          --witness) witness="${2:-}"; shift 2 ;;
          *) args+=("$1"); shift ;;
        esac
      done
      set -- "${args[@]}"
      if [ $# -lt 2 ]; then
        echo "usage: led work close <slug> <resolution> [--witness <ref>]" >&2
        echo "       resolution: shipped|superseded|dropped|deferred" >&2
        echo "       resolution=shipped REQUIRES --witness -- refused at construction time" >&2
        echo "       (work_shipped_requires_witness CHECK), never a tolerated-but-flagged row" >&2
        echo "       refused if <slug> has no work_claimed row yet -- claim it first:" >&2
        echo "       ./led work claim <slug>" >&2
        exit 1
      fi
      slug="$1"; resolution="$2"
      # claim-before-close gate (led-side; s22's own trigger checks only that <slug> was OPENED,
      # not that anyone claimed it) -- run-5 forensics: two work items were closed with no claim
      # ever landing, unflagged. Mirrors the existing duplicate-open/unopened refusal style: a
      # named usage message on stderr, exit 1, no silent acceptance.
      claimed=$(psql -h "$PGHOST" -d "$PGDB" -tAq -v slug="$slug" <<SQL
        SET ROLE ${ROLE};
        SET search_path = ${SCHEMA}, ${KERNEL};
        SELECT EXISTS (SELECT 1 FROM ledger WHERE kind = 'work_claimed' AND work_slug = :'slug');
SQL
      )
      if [ "$claimed" != "t" ]; then
        echo "led work close: REFUSED -- slug '${slug}' has no work_claimed row (claim it first):" >&2
        echo "  ./led work claim ${slug}" >&2
        echo "  (a close with no claim ever landing is the run-5 finding: two work items were" >&2
        echo "  closed this way, unflagged, until an outside review caught it)" >&2
        exit 1
      fi
      exec psql -h "$PGHOST" -d "$PGDB" -v ON_ERROR_STOP=1 \
        -v slug="$slug" -v resolution="$resolution" -v witness="$witness" \
        -v statement="work_closed: ${slug} (${resolution})" <<SQL
        SET ROLE ${ROLE};
        SET search_path = ${SCHEMA}, ${KERNEL};
        INSERT INTO ${SCHEMA}.ledger (kind, work_slug, work_resolution, work_witness, statement)
        VALUES ('work_closed', :'slug', :'resolution', NULLIF(:'witness', ''), :'statement');
SQL
      ;;
    list)
      exec psql -h "$PGHOST" -d "$PGDB" -c "
        SELECT w.slug, w.title, w.state, w.resolution, w.witness, p.name AS claimant
        FROM ${SCHEMA}.work_item_current w LEFT JOIN ${KERNEL}.principal p ON p.id = w.claimant
        ORDER BY w.slug;"
      ;;
    violations)
      exec psql -h "$PGHOST" -d "$PGDB" -c "
        SELECT violation, slug, detail FROM ${SCHEMA}.work_item_violations ORDER BY violation, slug;"
      ;;
    asof)
      shift
      if [ $# -lt 1 ]; then
        echo "usage: led work asof <timestamp>" >&2
        echo "       point-in-time backlog reconstruction -- work-item states AS OF <timestamp>," >&2
        echo "       derived purely by filtering the append-only work_* ledger rows to ts <=" >&2
        echo "       <timestamp> (read-only; no kernel change, no new table -- BACKLOG 'Omega" >&2
        echo "       work-tracking disposition' 2026-07-11, item 2). <timestamp> is anything" >&2
        echo "       postgres's timestamptz cast accepts, e.g. '2026-07-11 10:23:00' or an ISO" >&2
        echo "       8601 string; quote it if it contains a space." >&2
        exit 1
      fi
      asof="$1"
      # Three states (open/claimed/closed), NOT work_item_current's two (open/closed +
      # claimant column) -- the omega-disposition ask was explicitly "open/claimed/closed as of
      # T", so this mirrors work_item_current's own opened/claimed/closed CTE shape (s22) with
      # ONE addition: every CTE is filtered to ts <= :asof before the DISTINCT ON latest-row
      # pick, so "latest as of T" replaces "latest ever". An item whose opening act is itself
      # after T does not exist yet as of T and is correctly absent (INNER JOIN on opened).
      # Bound via psql -v/heredoc (a psql bind, not string concatenation or -c), same convention
      # this file's own generic <kind> <statement> path documents below: psql's :'var'
      # interpolation is only applied to a script read from stdin/-f, NOT to a -c argument -- so
      # this is fed via stdin like every OTHER work verb above, not -c like the parameter-free
      # list/violations reads.
      exec psql -h "$PGHOST" -d "$PGDB" -v ON_ERROR_STOP=1 -v asof="$asof" <<SQL
        WITH opened AS (
          SELECT work_slug AS slug, work_title AS title, id AS opened_id
          FROM ${SCHEMA}.ledger
          WHERE kind = 'work_opened' AND ts <= :'asof'::timestamptz
        ),
        claimed AS (
          SELECT DISTINCT ON (work_slug) work_slug AS slug, actor AS claimant, id AS claimed_id
          FROM ${SCHEMA}.ledger
          WHERE kind = 'work_claimed' AND ts <= :'asof'::timestamptz
          ORDER BY work_slug, id DESC
        ),
        closed AS (
          SELECT DISTINCT ON (work_slug) work_slug AS slug, work_resolution AS resolution,
                 work_witness AS witness, id AS closed_id
          FROM ${SCHEMA}.ledger
          WHERE kind = 'work_closed' AND ts <= :'asof'::timestamptz
          ORDER BY work_slug, id DESC
        )
        SELECT o.slug, o.title,
               CASE WHEN c.slug IS NOT NULL THEN 'closed'
                    WHEN cl.slug IS NOT NULL THEN 'claimed'
                    ELSE 'open' END AS state_asof,
               c.resolution, c.witness, p.name AS claimant
        FROM opened o
        LEFT JOIN claimed cl ON cl.slug = o.slug
        LEFT JOIN closed  c  ON c.slug  = o.slug
        LEFT JOIN ${KERNEL}.principal p ON p.id = cl.claimant
        ORDER BY o.slug;
SQL
      ;;
    *)
      echo "usage: led work open <slug> <title...>" >&2
      echo "       led work claim <slug>" >&2
      echo "       led work depends <slug> <on-slug>" >&2
      echo "       led work close <slug> <resolution> [--witness <ref>]" >&2
      echo "       led work list          (work_item_current)" >&2
      echo "       led work violations    (work_item_violations)" >&2
      echo "       led work asof <timestamp>  (point-in-time reconstruction, read-only)" >&2
      exit 1
      ;;
  esac
fi

if [ $# -lt 2 ]; then
  echo "usage: led [flags] <kind> <statement...>   (see top-of-file comment for the full flag list:" >&2
  echo "       -f -e --supersedes --amends --amends-scope --answers --refs --concern --evidence" >&2
  echo "       --confidence; cite an antecedent row from any kind via --refs row:<id>)" >&2
  echo "       led --recent [N] | led current [N] | led question-status | led review-gap | led stamp-distinctness" >&2
  echo "       led register-principal <name> <class>" >&2
  echo "       led obligate <scope> <assigned-by-principal> <obliged-actor-principal>" >&2
  echo "       led obligate revoke <scope>" >&2
  echo "       led review <entry-id> <verdict> <independence> [--antecedent id] <statement...>" >&2
  echo "       led work open|claim|depends|close|list|violations|asof  (see top-of-file comment)" >&2
  exit 1
fi

kind="$1"; shift
statement="$*"
warn_flag_in_statement "$statement"
rationale=""
if [ -n "$files" ]; then
  rationale="files: ${files}"
fi
enacts_lit=""
if [ -n "$enacts" ]; then
  enacts_lit="{${enacts}}"
fi
resolve_actor
# actor resolves via a subquery bind below exactly as `led review`/`led work claim` do above:
# NULLIF(:'actor_name','') is NULL when LED_ACTOR is unset, so the ledger's actor column stays
# NULL and the kernel's set_actor trigger fills the default connection principal. THIS was the
# witnessed defect (BACKLOG run-7 forensics, ledger row 63): this generic path never read
# LED_ACTOR at all, so every `led <kind> ...` write landed under the default principal regardless
# of LED_ACTOR. resolve_actor (defined near the top of this file) is now the ONE place LED_ACTOR
# is read and validated, shared with `led review` and `led work claim`.

# Bound via psql -v (a psql bind, not string concatenation) so `statement`/`rationale` can
# contain quotes, semicolons, or anything else without escaping into SQL (P2: a boundary
# translates-and-validates untrusted text; it does not hand-splice it into a query). NOTE: psql's
# :'var' interpolation is only applied to a script read from stdin/-f, NOT to a -c argument -- so
# the script is fed via stdin, not -c.
psql -h "$PGHOST" -d "$PGDB" -v ON_ERROR_STOP=1 \
  -v kind="$kind" -v statement="$statement" -v rationale="$rationale" \
  -v supersedes="$supersedes" -v amends="$amends" -v amends_scope="$amends_scope" \
  -v answers="$answers" -v refs="$refs" -v concern="$concern" \
  -v evidence="$evidence" -v confidence="$confidence" -v enacts="$enacts_lit" \
  -v actor_name="$actor_name" <<SQL
    SET ROLE ${ROLE};
    SET search_path = ${SCHEMA}, ${KERNEL};
    INSERT INTO ${SCHEMA}.ledger
        (kind, statement, rationale, supersedes, amends, amends_scope, answers,
         refs, concern, evidence, confidence, enacts, actor)
    VALUES (:'kind', :'statement', NULLIF(:'rationale', ''),
            NULLIF(:'supersedes', '')::bigint,
            NULLIF(:'amends', '')::bigint,
            NULLIF(:'amends_scope', ''),
            NULLIF(:'answers', '')::bigint,
            NULLIF(:'refs', ''),
            NULLIF(:'concern', ''),
            NULLIF(:'evidence', ''),
            NULLIF(:'confidence', ''),
            NULLIF(:'enacts', '')::bigint[],
            (SELECT id FROM principal WHERE name = NULLIF(:'actor_name', '')));
SQL
