#!/usr/bin/env bash
# led — one-liner decision-ledger entries for this project.
#
# Usage:
#   led [flags] <kind> <statement...>          e.g. led decision "perceptual distance = CIEDE2000"
#
#   flags (any order, any subset, all optional, consumed before <kind>):
#     -f a.py,b.py           declares files: a.py,b.py in the entry's rationale, so the
#                            PreToolUse change gate (autoharn hooks/pretooluse_change_gate.py)
#                            recognizes this entry as authorizing an edit to those files
#     -e id1,id2             enacts: this entry carries the named EARLIER own-session row(s)
#                            into a file (s15 validate_enacts; each id must resolve to an
#                            earlier row in the same session or the trigger refuses)
#     --supersedes id        this entry supersedes an earlier row; the superseded row drops out
#                            of ledger_current and is marked SUPERSEDED in `led --recent`/`led current`
#     --amends id --amends-scope "<verbatim clause>"
#                            clause-level revision: id's clause named by amends-scope is
#                            defeated while the rest of id stands (id itself is NOT superseded).
#                            amends-scope must be an EXACT, unambiguous (occurs-once) 10+ char
#                            substring of id's own statement or rationale (s15 validate_amends)
#                            — both-or-neither; a mismatched/ambiguous quote is refused
#     --answers id           this entry (any kind) resolves an earlier kind=question row id
#                            (s15 validate_answers); shows up in `led question-status`
#     --refs "<text>"        free-text cross-reference (ledger.refs). CONVENTION for citing an
#                            antecedent ledger row from ANY kind: `--refs row:<id>` (e.g. a
#                            verification result citing its pre-registered criteria row:
#                            `led --refs row:12 --evidence "..." verification "criteria met"`).
#                            This is the kernel's own sanctioned channel for a bare row
#                            reference on a non-review kind — s15's enacts column comment says
#                            it outright: "a bare reference uses refs". The TYPED regards edge
#                            stays reserved for kind=review (s15 validate_review, unchanged
#                            through s21: "regards is reserved for kind=review") and is written
#                            only by `led review`'s own <entry-id> positional arg; a --regards
#                            flag on a generic kind would be refused by the kernel every time,
#                            so none is offered.
#     --concern design|enactment|process|other
#     --evidence "<text>"          path-shaped values (start with / or ./, or contain a path
#                            separator) are dereferenced against the filesystem AT WRITE TIME
#                            and REFUSED, loudly, if nothing exists there (item
#                            artifact-claim-dereference-guard; ledger rows 896-899's specimen
#                            class -- a Write to a mistyped path succeeds silently, and the
#                            writer records artifact-written-at-<path> as witnessed without ever
#                            dereferencing the claimed path). row:<id> ledger citations and URLs
#                            are never path-shaped and are never checked. A genuinely-remote
#                            artifact (real, but not on this checkout) is cited by ROW, not by a
#                            bare path that cannot yet dereference: --refs row:<id> against a
#                            ledger row that describes it, per this file's own existing
#                            "a bare reference uses refs" convention (see --refs above) --
#                            invent no new citation form here.
#     --confidence low|medium|high
#     --event-time <iso-ts>  declares WHEN the recorded event actually occurred, distinct from
#                            this row's write time (kernel/lineage/s24-declared-event-time.sql's
#                            nullable event_declared_ts column; design/LATE-ENTRY-AND-INTAKE-
#                            SEMANTICS.md Proposal 2). Recording an act after the fact? Declare
#                            its event time -- never narrate the past as if live. Omitting this
#                            flag means "this row records a present act" (today's semantics,
#                            unchanged); a declared time far enough before the write time is what
#                            `./audit` reads as an honest LATE_DECLARED entry rather than an
#                            undeclared, suspect one. NOT a stamp: writer-supplied, unverified,
#                            trusted exactly as far as the writer is honest. Supported ONLY on the
#                            generic <kind> <statement...> path today -- `led review`/`led work
#                            *`/etc. each have their own INSERT that does not carry the column, so
#                            this flag is REFUSED loudly on those verbs (never a silent drop; see
#                            the coverage guard near the top of this file's own logic).
#
#   LED_ACTOR=<principal-name>   (env var, not a flag) resolves the actor/principal for ALL SEVEN
#                            ledger-writing paths -- the generic <kind> <statement> path below,
#                            `led review`, `led work claim`, `led work open`, `led work depends`,
#                            `led work close`, and `led work resolve-violation` (ONE resolution
#                            point, resolve_actor(), defined once and shared by all seven; work
#                            item write-path-actor-completion wired the last three -- depends,
#                            close, resolve-violation -- closing the class). Unset, a write lands
#                            under the default connection principal (`author`). Set to an
#                            unregistered name, the write is REFUSED with teach-text (register it
#                            first: `led register-principal <name> <class>`) rather than silently
#                            falling back to the default principal.
#
#   led --recent [N]                          last N ledger rows (default 10), newest first;
#                                              marks a row SUPERSEDED when a later row's
#                                              `supersedes` names it (never displays a
#                                              superseded row as if it were still current)
#   led current [N]                           last N rows of ledger_current (supersedes-filtered
#                                              read) — the view a consumer should read by default
#   led show <id>                             ONE ledger row, every column, in full (`psql -x`
#                                              expanded display — statement/rationale never
#                                              truncated). READ-ONLY: refuses loudly, teach-text,
#                                              on a missing <id> rather than falling through to
#                                              the generic <kind> <statement...> write path below
#                                              (run-11 class-b finding: `show` is not a member of
#                                              ledger_kind_check's vocabulary, so an un-dispatched
#                                              `led show <id>` used to be silently accepted by the
#                                              arg-count guard as kind="show", burning a sequence
#                                              id on the kernel's refusal — BACKLOG "Run-11
#                                              first-shift forensics", item 7 / change proposal 1)
#   led question-status                       question_status view: every open/answered question
#   led review-gap                            review_gap view: EVERY row (any kind) by an obliged
#                                              actor with no distinct-actor attest countersign yet —
#                                              not scope-filtered (see `led obligate` below)
#   led stamp-distinctness                    review_stamp_distinctness view: for each review,
#                                              whether the SAME invocation wrote it and its target
#   led decomposition-review-status           READ-ONLY: is this world's decomposition-review gate
#                                              armed, and in what mode. Reports (a) mode, read from
#                                              <world-root>/.claude/apparatus.json's
#                                              mechanisms.decomposition_review.mode, defaulted/
#                                              validated EXACTLY as hooks/pretooluse_change_gate.py's
#                                              own _resolve_mode() does (default 'observe', not
#                                              'enforce' -- this mechanism's own deliberate
#                                              departure; an unrecognized mode string never widens
#                                              permissions, falls back to 'observe' with a stderr
#                                              warning) -- ONE definition of that default, not a
#                                              second hand-copied one (ADR-0012 P1); (b) row counts
#                                              from countersign_obligation, total and undischarged --
#                                              "undischarged" reuses `review_gap`'s own actor-identity
#                                              join (o.obliges_actor = l.actor, NOT scope-filtered --
#                                              see `led obligate`'s own note above) rather than a
#                                              second discharge predicate; (c) a one-line verdict:
#                                              ARMED-ENFORCING | ARMED-OBSERVING | VACUOUS (no
#                                              obligation rows) | OFF. LIVE table-existence check on
#                                              countersign_obligation, teach-text (never a bare psql
#                                              error) on a kernel that predates it (kernel/lineage/
#                                              s15-schema.sql, the current standalone generation --
#                                              s10-s14 are earlier, superseded generations).
#   led briefing                               READ-ONLY, no DB access: prints the fresh-agent
#                                              rules briefing -- the three house rules a new agent
#                                              otherwise discovers only by tripping them (the ledger
#                                              change-gate, the flag-order asymmetry, the same-
#                                              session countersign refusal), then one pointer line to
#                                              design/USER-RECIPES-FAQ.md. Extension point: reads
#                                              <world-root>/.claude/apparatus.json's
#                                              mechanisms.rules_briefing.extra_items (a JSON array of
#                                              strings) -- world-root resolved EXACTLY as
#                                              `decomposition-review-status` above resolves it (the
#                                              directory DEPLOYMENT was actually found in), not a
#                                              second hand-derived notion of "world root" (ADR-0012
#                                              P1). Present and valid: each string prints verbatim
#                                              under an "additional world-specific rules" line.
#                                              Absent: silence, zero interference. Present but
#                                              malformed (not a JSON array of strings): a single loud
#                                              stderr warning naming the file and the bad value,
#                                              core briefing still prints in full -- never a crash,
#                                              never a silent drop. This is the SessionStart hook
#                                              hooks/sessionstart_rules_briefing.py's own transport:
#                                              that hook carries no copy of the briefing text, it
#                                              only invokes this verb and forwards its output.
#
#   led decision --grade <word> <statement...>  writes a kind=decision row carrying a durability
#                                              GRADE (kernel/lineage/s36-decision-grade.sql,
#                                              design/FABLE-GRADED-DECISIONS-SPEC.md; starter
#                                              vocabulary: durable). --grade is parsed in THIS
#                                              verb's OWN loop (not the top-of-file flag loop) --
#                                              an unrecognized --flag here is refused, never
#                                              swallowed into statement prose (ledger item
#                                              led-work-open-refs-swallowed's own lesson).
#                                              LIVE column-existence check: refused with
#                                              teach-text on a pre-s36 world, never a silent drop.
#   led standing                              standing_decisions view: every in-force (super-
#                                              session-filtered) graded decision, no recency
#                                              limit. REFUSED with teach-text on a pre-s36 world.
#
#   led register-principal <name> <class> --purpose "<why>"
#                                              register a principal (class: human|model|subagent|tool)
#                                              so a countersign can be attributed to it — the
#                                              writer registers its own principals, the kernel
#                                              pre-seeds none but the one connection principal.
#                                              s40 CEREMONY (kernel/lineage/s40-principal-
#                                              identity-events.sql §3.7): a duplicate name is
#                                              REFUSED loudly (never a silent no-op — both class
#                                              polarities, teach-text quoting the existing
#                                              principal), --purpose is mandatory on an s40
#                                              kernel, and the anchor row + its
#                                              principal_registered event land atomically (the
#                                              kernel's deferred anchor-coupling trigger makes a
#                                              bare anchor INSERT unable to commit at all).
#                                              Honors --event-time; pre-s40 worlds keep the
#                                              legacy anchor-only INSERT (with the loud duplicate
#                                              refusal, which needs no s40 machinery).
#
#   led principal declare-standing <name> [--db-role <role>]
#                                              bind a database role's default attribution to a
#                                              registered principal, as an explicit recorded act
#                                              (a principal_standing_declared event — the
#                                              declared-not-silent default strict attribution
#                                              resolves through; s40 §3.6). Re-declaring for the
#                                              same role auto-supersedes the prior declaration
#                                              (rotation). NOTE: unrelated to `led standing`
#                                              (s36 decision durability) — "standing" here is an
#                                              identity's own status.
#   led principal suspend <name> [reason...]   withdraw a principal's standing (a
#                                              principal_suspended event). Writes under it are
#                                              then refused at the kernel. NO v1 verb lifts a
#                                              suspension — the only path back is a fresh
#                                              successor principal (s40 §3.4, ratified).
#   led principal revoke <name> [reason...]    same, terminally (principal_revoked; revoked
#                                              dominates suspended in the derived standing).
#
#   led principal relate <subj> <rel> <obj>    assert a typed principal<->principal relation
#                                              (acts-for | dispatched-by | same-natural-person |
#                                              succeeds -- s41 D-2's closed vocabulary; same-
#                                              natural-person is canonicalized to lower-id
#                                              subject, kernel-CHECKed). Duplicate active
#                                              assertions refused.
#   led principal unrelate <subj> <rel> <obj> --supersedes <id>
#                                              retract it (a superseding active=false row
#                                              restating the triple; mismatched targets refused).
#   led principal bind-role <name> --role "<r>"          / release-role ... --supersedes <id>
#                                              organizational role bindings (FREE non-empty role
#                                              names -- ratified §9(c); recordable, NOT gating).
#   led principal bind-key <name> --fingerprint "<fp>"   / revoke-key ... --supersedes <id>
#                                              OpenPGP v4 key bindings (human subjects only --
#                                              agent keys refused; the empty-until-ceremony slot,
#                                              key GENERATION stays deferred by standing ruling).
#   led principal grant-competence <name> --activity "<a>" --band "<b>" --basis "<c>" [--supersedes <id>]
#   led principal withdraw-competence <name> --activity "<a>" --supersedes <id>
#                                              G13 competence records (recordable, NOT gating in
#                                              v1; band/basis free text -- a RATIFIED PLACEHOLDER,
#                                              basis §9(g) loud note). All eight verbs honor
#                                              --event-time and refuse the other shared flags.
#
#   led review <entry-id> <verdict> <independence> [--antecedent id] <statement...>
#                                              countersign an earlier row. verdict:
#                                              attest|attest_with_reservations|refuse. independence:
#                                              self-review|technical|managerial|financial (technical/
#                                              managerial/financial REQUIRE a stamp-distinct invocation
#                                              — else the trigger refuses and teaches self-review).
#                                              --antecedent id names the EARLIER defeated row this
#                                              review affirms <entry-id> survives (review_detail.antecedent,
#                                              NULL for a plain countersign). `statement` doubles as
#                                              review_detail's `basis`. Set LED_ACTOR=<principal-name> to
#                                              countersign as a registered principal other than the default
#                                              connection principal (`author`) — WITHOUT it, every write
#                                              resolves to the same principal and a review is refused as
#                                              self-review (validate_review keys on the actor/principal,
#                                              never on the stamped invocation identity). A very short
#                                              <statement> prints a WARN-ONLY tripwire (never a refusal --
#                                              the write proceeds) naming engine/review_gap_audit.py's
#                                              `./audit --review-gap` check, which flags exactly this shape
#                                              of row IF it discharges a countersign obligation (tracker
#                                              item `content-free-review-audit`; WITNESSED SPECIMEN: run12
#                                              ledger row 20, statement="test").
#
#   led obligate <scope> <assigned-by-principal> <obliged-actor-principal>
#                                              register a countersign_obligation. DIRECTION, spelled
#                                              out because getting it backwards is the recurring
#                                              obligate mistake (BACKLOG run-5 AND run-7 forensics,
#                                              two consecutive runs, each cost a workaround round):
#                                              <obliged-actor-principal> is the WORKER — the principal
#                                              whose rows need outside eyes. It must NEVER be the
#                                              reviewer/countersigner. <assigned-by-principal> is
#                                              whoever is imposing the obligation (must differ from
#                                              the obliged actor — the obligation_not_self_assigned
#                                              CHECK refuses a self-ASSIGNED obligation; distinct from
#                                              `led register-principal`'s unrelated self-registration).
#                                              <scope> is a free-text LABEL naming this obligation row
#                                              (its PK) — it is NOT a filter key: `review_gap` joins on
#                                              actor identity alone (o.obliges_actor = l.actor), and
#                                              the ledger table carries no scope column to narrow it
#                                              against. KNOWN OVER-CATCH (fail-safe direction, no
#                                              maintainer ruling yet — kernel/lineage s13/s14 review_gap):
#                                              once a principal is obliged, `led review-gap` counts
#                                              EVERY uncountersigned row that principal ever writes —
#                                              any kind, including that principal's OWN later review/
#                                              attest rows — not only rows "in scope". Obliging the
#                                              REVIEWER by mistake makes the reviewer's own countersigns
#                                              show up as debt, forcing an author counter-countersign
#                                              round (this already happened twice — see BACKLOG).
#                                              Worked example: `led obligate decomposition-review
#                                              orchestrator author` — after this, someone other than
#                                              'author' must countersign every one of author's ledger
#                                              rows (any kind) or `led review-gap` shows debt for each.
#   led obligate revoke <scope>               delete a countersign_obligation row by scope (its PK).
#                                              Whether this succeeds or is REFUSED depends on the
#                                              connecting role's LIVE grants on countersign_obligation,
#                                              checked here via has_table_privilege (never assumed,
#                                              never hardcoded) — s20 granted this role SELECT,INSERT
#                                              ONLY on countersign_obligation, by deliberate ruling (an
#                                              obligation is standing OPERATOR-owned policy config, not
#                                              a role self-service capability), so under an unmodified
#                                              kernel this REFUSES every time, with teach-text naming
#                                              the maintainer act that does revoke it. `led` never
#                                              widens its own grants to bypass this.
#
#   led work open <slug> <title...> [--parent <parent-slug>] [--discharge composite] [--refs <ref>] [--supersedes <id>]
#                                              open a work item (kernel/lineage/s22-work-item-ledger.sql's
#                                              validate_work_item(): one opening act per slug — a
#                                              duplicate open is REFUSED at insert, never silently
#                                              accepted; the Q5 defect made unrepresentable).
#                                              --parent types this item as a CHILD of an
#                                              already-opened work item (kernel/lineage/
#                                              s28-work-parent-edge.sql, tracker slug
#                                              work-tree-rollup) — REFUSED at construction on a
#                                              dangling parent (unlike `work depends`'s antecedent,
#                                              which stays deliberately unrefused, s22) and REFUSED
#                                              on a cycle. Requires this world's kernel to carry
#                                              s28 (LIVE-checked, not assumed; omitting --parent
#                                              works unchanged on a pre-s28 kernel). RETROSPECTIVE
#                                              topology only — never a gate, never polices scope or
#                                              cost (the maintainer's standing invariant, same as
#                                              the estimate:/resource: conventions below).
#                                              --discharge composite (kernel/lineage/
#                                              s33-composite-discharge.sql, ledger item
#                                              composite-parent-autodischarge) types this item as a
#                                              COMPOSITE whose discharge is DERIVED from its
#                                              children's obligation tree, never a hand-authored
#                                              close act — see `work list`'s effective_state note
#                                              below. Set exactly once, at open time; a composite
#                                              close is STRICT-BY-TYPE (every future close of this
#                                              slug routes through the SAME obligation-tree check
#                                              `--strict` uses, automatically — no --strict flag
#                                              needed or accepted-differently). Requires this
#                                              world's kernel to carry s33 (LIVE-checked; omitting
#                                              --discharge works unchanged on a pre-s33 kernel).
#                                              --supersedes <id> (ledger.supersedes, base schema
#                                              since s10, no column-existence gate — ledger item
#                                              led-work-open-supersedes): this opening act
#                                              retracts ledger row <id> from current truth
#                                              (kernel/lineage/s31-supersession-uniform-
#                                              retraction.sql: supersession is UNIFORM across
#                                              every kind, reinstatement-free — no per-kind
#                                              compatibility refusal on the write). If <id> is
#                                              itself a work_opened row, ITS SLUG IS PERMANENTLY
#                                              BURNED (s31 ratified fork 2, s28's cycle-vacuity
#                                              induction) — <slug> here MUST be a new, different
#                                              slug; reusing the burned slug is REFUSED by
#                                              validate_work_item()'s duplicate-open branch (s31
#                                              Element 6). A one-time advisory prints on stderr
#                                              before the write, naming the retraction and the
#                                              slug-burn consequence — the kernel enforces, this
#                                              text only teaches. Combinable with --parent/
#                                              --discharge/--refs. Any surviving edges/claims that
#                                              cited the OLD slug (surfaced by `led work
#                                              violations` as orphaned_by_retraction) must be
#                                              re-issued against the NEW slug.
#   led work claim <slug>                     claim an already-opened item as the acting principal
#                                              (refused if <slug> has no opening act). Set
#                                              LED_ACTOR=<principal-name> to claim as a registered
#                                              principal other than the default connection principal
#                                              (else the claim lands under that default principal)
#   led work depends <slug> <on-slug> [--type blocks-close|blocks-start|informs]
#                                              record that <slug> (must already be opened) depends on
#                                              <on-slug>. <on-slug> itself is NOT required to be
#                                              opened — a dangling antecedent is deliberately NOT
#                                              refused (spec invariant 4); it is surfaced instead by
#                                              `led work violations` (depends_on_unknown_slug).
#                                              --type informs (default): advisory only, never
#                                              enforced. --type blocks-close (kernel/lineage/
#                                              s30-typed-dependency-edges.sql): the obligation
#                                              AND-tree (--strict close) conjoins it. --type
#                                              blocks-start (kernel/lineage/s39-blocks-start.sql):
#                                              <slug> may not be CLAIMED until <on-slug> reaches
#                                              CLOSED — checked at claim time (`led work claim`),
#                                              refused by name. Both typed forms are REFUSED at
#                                              construction on a self-edge, a dangling antecedent, or
#                                              a cycle in their OWN subgraph (independent subgraphs —
#                                              a blocks-close edge and a blocks-start edge between
#                                              the same two slugs, opposite directions, is legal, not
#                                              a cycle).
#   led work close <slug> <resolution> (--review-witness <ref> | --review-deferred | --review-bookkeeping --witness commit:<sha>) [--witness <ref>] [--strict]
#                                              close a work item. REFUSED if <slug> has no
#                                              work_claimed row yet (led-side gate, mirroring the
#                                              existing duplicate-open/unopened refusals — run-5
#                                              forensics: two work items were closed with no claim
#                                              ever landing, unflagged, until an outside review
#                                              caught it) — claim it first: `./led work claim <slug>`.
#                                              resolution: shipped|superseded|dropped|deferred.
#                                              resolution=shipped REQUIRES --witness — refused at
#                                              construction time (work_shipped_requires_witness
#                                              CHECK), never a tolerated-but-flagged row.
#                                              EXACTLY ONE of two REVIEW-DISPOSITION constructors is
#                                              REQUIRED (kernel/lineage/s29-obligation-item-key-and-
#                                              typed-close.sql, Element B — design/MAINT-COUNTERSIGN-
#                                              CLOSE-SEMANTICS-SPEC.md): a review-silent close is
#                                              REFUSED at construction, never representable.
#                                                --review-witness <ref>   a review already exists;
#                                                  cite it (a ledger row id, commit hash, or
#                                                  artifact path). DELIBERATELY SEPARATE from
#                                                  --witness (the SHIP witness, above) — see the
#                                                  kernel delta's own header for why the two facts
#                                                  are kept apart.
#                                                --review-deferred        this close act itself
#                                                  BECOMES the review obligation (item-keyed by
#                                                  <slug>, origin-identified by this close row's own
#                                                  ledger id) — discharge it later with
#                                                  `./led review <close-row-id> attest ... `, written
#                                                  by a DIFFERENT actor (surfaced meanwhile by
#                                                  `led work review-gap`).
#                                              --strict (opt-in, Element C, "a declared posture, not
#                                                a universal mandate") REFUSES this close unless
#                                                --review-witness was used AND every leaf of this
#                                                item's obligation tree (its own s28 descendants,
#                                                and every tree member's work-depends antecedents)
#                                                is independently resolved — REFUSED naming every
#                                                unresolved leaf, no stored verdict anywhere (a pure,
#                                                read-time-derived query). --review-deferred +
#                                                --strict is REFUSED directly (a just-deferred
#                                                obligation is, by definition, unresolved the moment
#                                                it is created).
#                                              STRICT-BY-TYPE (kernel/lineage/
#                                              s33-composite-discharge.sql): closing a slug opened
#                                              with `--discharge composite` runs this SAME strict
#                                              check automatically, whether or not --strict is
#                                              passed — no new refusal, the type sets the flag.
#   led work review-gap                       work_review_gap: item-keyed close acts with
#                                              disposition=deferred not yet discharged by a
#                                              distinct-actor attest review (s29's own sibling of
#                                              the pre-existing ACTOR-keyed `led review-gap`)
#   led work list [--all]                     work_item_current: one row per slug — state (open/
#                                              closed), title, resolution, witness, claimant, and
#                                              (kernel/lineage/s33-composite-discharge.sql, LIVE
#                                              column-existence checked — never assumed) an
#                                              effective_state_if_diff column: a composite item's
#                                              DERIVED discharge status (e.g.
#                                              discharged-by-obligations, or a re-opened hand-close
#                                              defeated by a later child) whenever it DIFFERS from
#                                              the raw state column; blank when they agree or on a
#                                              pre-s33 kernel. DISPLAY-ONLY — which rows are
#                                              returned is governed purely by the state filter
#                                              below, unchanged either way.
#                                              DEFAULT excludes state='closed' (the "what is open
#                                              or claimed NOW" view — at ~60 lifetime items, the
#                                              unfiltered dump overflowed an orchestrator context
#                                              read; maintainer directive 2026-07-13,
#                                              led-work-list-state-filter). `--all` restores the
#                                              full historical view (closed included), unchanged
#                                              from before this default flipped. Nothing is deleted
#                                              or hidden from the ledger itself — this is a read-verb
#                                              default only; `led work asof <ts>` and the raw ledger
#                                              rows remain the complete, unfiltered record
#   led work violations                       work_item_violations: duplicate_open and
#                                              shipped_without_witness (both provably vacuous under
#                                              normal operation — refused at insert above, listed as
#                                              defense in depth) plus the two genuinely-reachable,
#                                              deliberately-unrefused members depends_on_unknown_slug
#                                              and dependency_cycle
#   led work asof <timestamp>                 READ-ONLY point-in-time reconstruction: work-item
#                                              states (open/claimed/closed) AS OF <timestamp>,
#                                              derived by filtering the append-only work_* ledger
#                                              rows to ts <= <timestamp> before picking each item's
#                                              latest opened/claimed/closed row — no kernel change,
#                                              a pure SELECT over existing columns (BACKLOG "Omega
#                                              work-tracking disposition" 2026-07-11, item 2).
#                                              RAW event-reconstructed state ONLY — a composite
#                                              item's DERIVED discharge status (effective_state) is
#                                              a CURRENT-view concept (s33) and is deliberately NOT
#                                              retrofitted here; see `led work list`'s
#                                              effective_state_if_diff column for that view instead.
#                                              (these seven verbs require kernel/lineage/s22-work-item-
#                                              ledger.sql applied to this project's schema — s22 is
#                                              an additive delta on the s15/s17/s19/s20/s21 birth
#                                              chain, part of it from s22 onward — see ORCH-OPERATING-CARD.md)
#
# Connection defaults are sourced LIVE from this project's deployment.json at RUN TIME (BACKLOG
# maintainer ruling 2026-07-11, "runs are strictly linear" disposition 6, "live verbs"). This file
# is no longer copied into a project and sed-substituted at scaffold time -- the scaffolded ./led
# is a 3-line shim that `exec`s THIS file directly out of the autoharn checkout, every invocation,
# so a template fix (this file) reaches every already-scaffolded world instantly, not just the
# next scaffold (the asymmetry that let one just-fixed defect live on in five worlds forever).
# deployment.json is found next to the shim -- the shim passes its own directory through via the
# PICKUP_DEPLOYMENT env var (the same mechanism `judge`/`pickup` already used for this; the name
# predates `led` joining the convention, kept as ONE shared mechanism rather than three
# near-identical env vars, ADR-0012 P1) -- loaded via autoharn's filing/deployment_record.py (the
# ONE home for that JSON shape). autoharn's own location is resolved from THIS file's own on-disk
# path (it executes in place now, never copied), overridable with AUTOHARN=/path/to/autoharn for a
# differently-laid-out checkout (same convention `judge`/`pickup` use).
# Override the resolved values via LED_PGHOST/LED_PGDB/LED_SCHEMA/LED_KERNEL/LED_ROLE if this
# project's kernel is re-applied under different names -- unchanged from before.
set -euo pipefail

HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
AUTOHARN_ROOT="${AUTOHARN:-$(cd "$HERE/../.." && pwd)}"
DEPLOYMENT="${PICKUP_DEPLOYMENT:-$HERE/deployment.json}"

# One live read of deployment.json, via autoharn's filing/deployment_record.py (the ONE home for
# that shape -- this script does not grow a second JSON parser). Prints shell-quoted DEP_* bindings
# for `eval` below; refuses loudly (teach-text on stderr, exit 2) on a missing/malformed record,
# never a guessed default (ADR-0002).
_dep_vars="$(python3 - "$AUTOHARN_ROOT" "$DEPLOYMENT" <<'PYEOF'
import sys, shlex
autoharn_root, dep_path = sys.argv[1:3]
sys.path.insert(0, autoharn_root + "/filing")
import deployment_record as dr
try:
    d = dr.load_deployment(dep_path)
except dr.DeploymentError as e:
    print(f"led: {e}", file=sys.stderr)
    sys.exit(2)
for k in ("db", "host", "schema", "kern", "role"):
    print(f"DEP_{k.upper()}={shlex.quote(getattr(d, k))}")
PYEOF
)" || exit 2
eval "$_dep_vars"

PGHOST="${LED_PGHOST:-$DEP_HOST}"
PGDB="${LED_PGDB:-$DEP_DB}"
SCHEMA="${LED_SCHEMA:-$DEP_SCHEMA}"
KERNEL="${LED_KERNEL:-$DEP_KERN}"
ROLE="${LED_ROLE:-$DEP_ROLE}"

# --- flags (any order, any subset), consumed up front so the verb dispatch below and the
# generic <kind> <statement...> path both see a clean $@ -------------------------------------
files=""
enacts=""
supersedes=""
amends=""
amends_scope=""
answers=""
refs=""
concern=""
evidence=""
confidence=""
event_time=""
while true; do
  case "${1:-}" in
    -f) files="${2:-}"; shift 2 ;;
    -e) enacts="${2:-}"; shift 2 ;;
    --supersedes) supersedes="${2:-}"; shift 2 ;;
    --amends) amends="${2:-}"; shift 2 ;;
    --amends-scope) amends_scope="${2:-}"; shift 2 ;;
    --answers) answers="${2:-}"; shift 2 ;;
    --refs) refs="${2:-}"; shift 2 ;;
    --concern) concern="${2:-}"; shift 2 ;;
    --evidence) evidence="${2:-}"; shift 2 ;;
    --confidence) confidence="${2:-}"; shift 2 ;;
    --event-time) event_time="${2:-}"; shift 2 ;;
    *) break ;;
  esac
done

# --- --evidence PATH-DEREFERENCE GUARD (item artifact-claim-dereference-guard; register (b) of
# the three candidate enforcement registers named on that item -- a fail-safe additive refusal,
# plausibly class-ratified under the 2026-07-09 ruling: it only ADDS a refusal, nothing existing
# is relaxed and no existing semantics change). Ledger rows 896-899 are the specimen class this
# closes: row 896 recorded an artifact-written-at-<path> claim; row 897 is the correction (the
# Write silently landed at a DIFFERENT, mistyped path -- "Write returned success" witnessed A
# path, not THE claimed path); row 898 names the cheap universal check the specimen skipped (ls
# of the exact claimed path) and the class itself, artifact-claim-without-dereference; row 899
# opened this item. The harness is uniquely positioned to make this unrepresentable for `led`'s
# own --evidence flag specifically: the check is cheap (a single `test -e`), so it runs here
# rather than being left to a human or a downstream reader to notice.
#
# Detection is PATH-SHAPED, not "any string that could be a filesystem location" -- deliberately
# narrow so free-text evidence (commit lists, prose, ledger citations) is never mistaken for a
# path:
#   - row:<id> (led's own existing bare-reference citation form, "a bare reference uses refs")
#     and anything containing "://" (a URL) are NEVER path-shaped -- never checked, no exception
#     needed because they were never claiming a LOCAL dereferenceable path in the first place.
#   - anything starting with "/" or "./", or containing a "/" path separator anywhere, IS
#     path-shaped -- cheap to check (`test -e`), so it is checked, unconditionally, before any
#     verb dispatch below sees it (one check point for every verb that accepts --evidence, not
#     one per call site).
# A path-shaped value that does not exist on disk right now is REFUSED with teach-text pointing
# at the specimen class and at the non-path citation form (--refs row:<id>) for a genuinely-
# remote artifact -- never a silent write of an unwitnessed claim.
#
# NIGHT-BUILD-DEFECT-REPAIR (verifier finding, this file's own row 977 correction): the guard
# above went through fresh-context verification and was found NARROWED on two axes, both closed
# here:
#   (a) it only ever looked at --evidence, never at $statement -- the ORIGINAL rows 896-897
#       specimen was a path embedded IN THE STATEMENT TEXT itself ("artifact written at <path>"),
#       not passed via --evidence at all, so the guard above never would have caught its own
#       motivating case. See warn_path_shaped_in_statement() below, called at every point a
#       verb assembles its own $statement (the generic <kind> <statement...> path and `led
#       review`). Free text is asymmetric to --evidence and WARN-ONLY, not a refusal -- see that
#       function's own docstring for why.
#   (b) `test -e` is true for a directory, so a bare directory used to sail through this check
#       even though row 898's remediation is explicitly "ls/wc of a FILE" -- a directory citation
#       reads as satisfying that remediation but does not. Closed just below: an existing
#       path-shaped --evidence value must be a regular FILE, or a directory explicitly cited as
#       one via a trailing "/" (an unambiguous, visible opt-in -- never inferred).
if [ -n "$evidence" ]; then
  case "$evidence" in
    row:*|*://*)
      : # ledger row citations and URLs are never path-shaped; never checked
      ;;
    /*|./*|*/*)
      if [ ! -e "$evidence" ]; then
        echo "led: REFUSED -- --evidence '${evidence}' is path-shaped (starts with / or ./, or" >&2
        echo "  contains a path separator) but nothing exists at that path right now." >&2
        echo "  This is the artifact-claim-without-dereference class (ledger rows 896-899): a" >&2
        echo "  Write to a mistyped path can succeed silently, and 'the Write call returned" >&2
        echo "  success' witnesses A path, not THE claimed path -- row 898's cheap universal" >&2
        echo "  check (ls/wc of the exact claimed path) is the one the specimen skipped." >&2
        echo "  If the artifact is real but genuinely not on this checkout yet, do not cite it" >&2
        echo "  as a bare path that cannot dereference: cite an antecedent ledger row that" >&2
        echo "  describes it instead, e.g. --refs row:<id> (led's own existing 'a bare" >&2
        echo "  reference uses refs' citation form) -- or re-run once the path is real." >&2
        exit 1
      elif [ -d "$evidence" ]; then
        case "$evidence" in
          */)
            : # trailing slash = an explicit, deliberate directory citation -- accepted
            ;;
          *)
            echo "led: REFUSED -- --evidence '${evidence}' exists but is a DIRECTORY, not a" >&2
            echo "  file (night-build-defect-repair: 'test -e' is also true for a directory, but" >&2
            echo "  row 898's remediation is explicitly 'ls/wc of a FILE' -- a bare directory" >&2
            echo "  citation reads as satisfying that remediation without actually doing so)." >&2
            echo "  If you deliberately mean to cite the directory itself as the artifact, repeat" >&2
            echo "  the flag with a trailing slash to say so explicitly:" >&2
            echo "    --evidence '${evidence}/'" >&2
            echo "  Otherwise cite the specific file inside it that is the actual evidence." >&2
            exit 1
            ;;
        esac
      elif [ ! -f "$evidence" ]; then
        echo "led: REFUSED -- --evidence '${evidence}' exists but is not a regular file (a" >&2
        echo "  symlink to nowhere, a device, a socket, or similar) -- cite the concrete file" >&2
        echo "  the artifact claim actually points at." >&2
        exit 1
      fi
      ;;
  esac
fi

# STATEMENT PATH-SHAPE SCAN (night-build-defect-repair, register (a) of the gap above): the same
# path-shape test as --evidence's, applied to every whitespace-separated token of a verb's own
# $statement once it is assembled -- called explicitly at each of the (small, enumerated) points
# in this file where a verb builds its own $statement from user-supplied words: the generic
# <kind> <statement...> path and `led review`'s <statement...>. `led work *`'s statements are all
# BUILT BY THIS FILE ITSELF from typed fields (slug/title/resolution), never raw user free text,
# so they carry no user-suppliable path-shaped token to scan -- not a gap, just nothing to check.
#
# WARN-ONLY, DELIBERATELY ASYMMETRIC TO --evidence's hard REFUSE, and that asymmetry is a
# considered choice, not a shortcut: --evidence is a dedicated, single-purpose flag whose entire
# job is to assert "this artifact exists, right now, dereference it" -- there is no legitimate
# reason for it to name a path that does not yet exist, so refusing is exactly right. A
# STATEMENT is free-text narration of an event; a path token inside it can legitimately describe
# something ABOUT TO be created ("writing the spec to design/X.md next"), something that exists
# on a different host/checkout than this one, or a path quoted verbatim from someone else's
# report -- treating every such mention as a hard claim-of-existence-now would refuse honest
# prose. A miss here is exactly what row 898 itself calls a cheap check that a HUMAN reader
# should not have to notice unaided -- so it surfaces as a WARNING, not a blocked write.
warn_path_shaped_in_statement() {
  local text="$1" word
  set -f  # no glob expansion while scanning statement words
  for word in $text; do
    case "$word" in
      row:*|*://*)
        : # ledger row citations and URLs are never path-shaped; never checked (same rule as --evidence)
        ;;
      /*|./*|*/*)
        if [ ! -e "$word" ]; then
          echo "led: WARNING -- the statement contains a path-shaped token '${word}' with nothing" >&2
          echo "  at that path right now (artifact-claim-dereference-guard / night-build-defect-" >&2
          echo "  repair: the original ledger rows 896-897 specimen was exactly this shape -- a" >&2
          echo "  path embedded in STATEMENT PROSE, not passed via --evidence)." >&2
          echo "  WARN-ONLY, not a refusal: a statement may legitimately narrate a path that is" >&2
          echo "  about to be created, or one that lives on a different host/checkout. If this" >&2
          echo "  statement is asserting the artifact exists NOW, re-check '${word}' before" >&2
          echo "  trusting this row later." >&2
        fi
        ;;
    esac
  done
  set +f
}

# --event-time COVERAGE GUARD -- --event-time is parsed by the SHARED top-of-file loop above
# (same convention as every other flag here), but only the generic <kind> <statement...> path's
# INSERT at the bottom of this file, `led register-principal`, and the `led principal ...`
# identity verbs (s40+, kernel/lineage/s40-principal-identity-events.sql -- the s24 convention
# honored per the basis's §3.7) actually write event_declared_ts. Every OTHER dispatched verb
# below (--recent/current/question-status/review-gap/stamp-distinctness/obligate/review/work/
# decomposition-review-status/briefing) has its OWN
# INSERT INTO ledger that does not carry the column. REFUSE loudly here rather than silently
# dropping a value the operator explicitly asked to be recorded (the class this file's own
# `refuse_flag_in_statement`/missing-column-refusal idioms both exist to foreclose) -- the flag is
# scoped to the generic path + the principal-identity verbs today (design/MAINT-LATE-ENTRY-AND-
# INTAKE-SEMANTICS.md Proposal 2's own worked example is the generic path); widening it to
# `review`/`work` is a future increment, not a silent gap.
if [ -n "$event_time" ]; then
  case "${1:-}" in
    --recent|current|question-status|review-gap|stamp-distinctness|standing|obligate|review|work|decomposition-review-status|briefing)
      echo "led: REFUSED -- --event-time is only supported on the generic <kind> <statement...>" >&2
      echo "  path today (e.g. './led --event-time <ts> finding \"...\"'); '${1:-}' has its own" >&2
      echo "  INSERT that does not carry event_declared_ts, so the value would otherwise be" >&2
      echo "  silently dropped. Omit --event-time for this verb, or route the declaration" >&2
      echo "  through the generic path instead." >&2
      exit 1
      ;;
  esac
fi

# --- LED_ACTOR resolution (ONE point, used by ALL SEVEN of the ledger-writing paths below:
# `led review`, `led work claim`, `led work open`, `led work depends`, `led work close`,
# `led work resolve-violation`, and the generic <kind> <statement> path -- work item
# write-path-actor-completion wired the final three, depends/close/resolve-violation, closing
# the class across every ledger-writing path in this file) --------------------------------------
# Sets $actor_name to LED_ACTOR (may be empty). Downstream, NULLIF(:'actor_name','') still turns
# an empty value into NULL so the kernel's set_actor trigger fills the default connection
# principal, unchanged from before. What's new here: an explicit, up-front existence check. A
# NAMED but unregistered LED_ACTOR used to fall through that same NULL path too -- the subquery
# `SELECT id FROM principal WHERE name = ...` matches no row and also returns NULL -- so it landed
# attributed to the default principal exactly like an unset LED_ACTOR, indistinguishable
# misattribution, never surfaced. This function forecloses that as a CLASS (ADR-0000: one fact,
# one writer) instead of leaving it as three separately-patchable instances: it used to be
# duplicated inline in the review/work-claim paths and OMITTED entirely from the generic path --
# the generic path never read LED_ACTOR at all, so every `led <kind> ...` write landed under the
# default principal regardless of LED_ACTOR (BACKLOG run-7 forensics, ledger row 63:
# LED_ACTOR=reviewer landed as actor='author'). `led work open` was a FOURTH, separately-
# discovered instance of the same gap (this file's own B-pass over design/USER-RECIPES-FAQ.md,
# 2026-07-16/17: a shipped FAQ recipe depends on LED_ACTOR working for work open, and it silently
# didn't) -- now wired into resolve_actor() the same way. `led work depends` (both
# has_edge_type_col branches), `led work close` (both its pre-s29 and s29+/s38 INSERT branches),
# and `led work resolve-violation` were THREE more, remaining instances of the same gap (their
# rows landed under the default connection principal regardless of LED_ACTOR -- the panel
# deployment's five witnessed LED_ACTOR=item-countersign closes all landed actor=author, rows
# 1710/1716/1719/1732/1746) -- work item write-path-actor-completion wires all three the same
# way, closing the class across every ledger-writing path in this file rather than leaving an
# eighth as an exercise for the next reader.
resolve_actor() {
  actor_name="${LED_ACTOR:-}"
  if [ -n "$actor_name" ]; then
    local registered
    registered=$(psql -h "$PGHOST" -d "$PGDB" -tAq -v actor_name="$actor_name" <<SQL
      SET ROLE ${ROLE};
      SET search_path = ${SCHEMA}, ${KERNEL};
      SELECT EXISTS (SELECT 1 FROM principal WHERE name = :'actor_name');
SQL
    )
    if [ "$registered" != "t" ]; then
      echo "led: REFUSED -- LED_ACTOR='${actor_name}' is not a registered principal." >&2
      echo "  Register it first: ./led register-principal ${actor_name} <human|model|subagent|tool>" >&2
      exit 1
    fi
  fi
}

# --- shared-channel disposal for the principal-identity verbs (s40/s41; the meta-consult Axis 1
# discipline the basis's §3.7 names: every new verb either HONORS or LOUDLY REFUSES each channel
# the shared top-of-file flag loop parses -- never a silent drop, the exact class that once
# swallowed LED_ACTOR). The principal verbs HONOR --event-time (the s24 convention, written into
# their own INSERTs) and REFUSE every other shared channel by name: their row content is built
# from typed fields (name/class/purpose/role/fingerprint/...), and a supersession, where a verb
# needs one, is that verb's OWN post-subcommand --supersedes flag, never the top-of-file one --
# two parse points for one column would be exactly the silently-diverging duplicate this file's
# resolve_actor consolidation exists to foreclose.
refuse_shared_flags_for_principal_verb() {
  local verb="$1" bad=""
  [ -n "$files" ]        && bad="$bad -f"
  [ -n "$enacts" ]       && bad="$bad -e"
  [ -n "$supersedes" ]   && bad="$bad --supersedes"
  [ -n "$amends" ]       && bad="$bad --amends"
  [ -n "$amends_scope" ] && bad="$bad --amends-scope"
  [ -n "$answers" ]      && bad="$bad --answers"
  [ -n "$refs" ]         && bad="$bad --refs"
  [ -n "$concern" ]      && bad="$bad --concern"
  [ -n "$evidence" ]     && bad="$bad --evidence"
  [ -n "$confidence" ]   && bad="$bad --confidence"
  if [ -n "$bad" ]; then
    echo "led ${verb}: REFUSED -- the shared flag(s)${bad} are not honored by this verb and" >&2
    echo "  would otherwise be silently dropped (the meta-consult Axis 1 channel class --" >&2
    echo "  the same silent-drop shape that once swallowed LED_ACTOR). This verb's row content" >&2
    echo "  is built from its own typed arguments; only --event-time (the s24 late-entry" >&2
    echo "  declaration) rides through. Where a supersession is needed (s41's release/revoke/" >&2
    echo "  withdraw/unrelate verbs), it is that verb's OWN trailing --supersedes flag, placed" >&2
    echo "  AFTER the subcommand words -- not the top-of-file one." >&2
    exit 1
  fi
}

# --- flag-in-statement REFUSAL (BACKLOG "Chocofarm experiment-ledger disposition" 2026-07-11
# night shift, finding 2, run7 row 71; escalated from WARN-ONLY to a REFUSAL by ledger item
# `led-refs-flag-order-parser-bug` after the WARN-ONLY tripwire below proved insufficient -- the
# SAME mis-parse re-bit the orchestrator (autoharn1 rows 1053/1054) and an experience-world
# reviewer TWICE in one day (rows 65/66/71, again at 87), each costing a superseding rewrite. A
# WARNING that is easy to miss in scrollback does not stop a lying-signature-class defect; ADR-0000
# Rule 2(a) asks for the type that makes the class unrepresentable -- a flag placed after the
# variadic <statement...> capture is unrepresentable input for THIS parser now, not a noticed-too-
# late mistake): a flag typed AFTER (or inside) the quoted statement text is invisible ceremony --
# by the time the top-of-file flag loop runs, that text is already part of the statement word(s),
# so the flag never reaches the parser and the typed FK column it names (supersedes/refs/regards/
# amends/answers/evidence/confidence/antecedent) lands NULL, silently (run7 row 71: statement text
# ended `--supersedes 48 --refs row:57,row:58,row:59`; both columns were NULL -- across all 79
# run7 rows, supersedes/amends/answers were used zero times despite the vocabulary existing).
#
# BOUNDARY, DELIBERATELY NARROW (documented here because a false positive on legitimately-quoted
# prose would be its own defect): this function scans the ORIGINAL, UNJOINED shell argv words that
# make up the statement -- i.e. the caller passes "$@" as it stood right after the kind/positional
# args were shifted off, BEFORE they are collapsed into one "$*" string. It refuses ONLY when one
# of those words is an EXACT, WHOLE match for a known led flag token. This is why a genuinely
# quoted mention survives: `./led decision "this references --refs flag in prose"` is a SINGLE
# shell argument (one $@ word, the whole sentence) -- "--refs" is a SUBSTRING of that one word, not
# a standalone word of its own, so it never matches and is never refused. Only
# `./led decision "some text" --refs row:16`, where --refs arrives as its OWN separate shell
# argument (exactly the trailing-flag mistake this item exists to catch), matches. Re-splitting an
# already-joined statement string on whitespace (the old WARN-ONLY implementation's approach) does
# NOT have this property -- a multi-word quoted argument containing "--refs" surrounded by spaces
# would re-split into a spurious standalone "--refs" token and false-positive, which is exactly the
# false-positive class this rewrite avoids by never re-joining-then-re-splitting.
#
# led's OWN flag vocabulary is spelled out once, here, so a future flag added to the top-of-file
# parser (or to `led review`'s own --antecedent) is not silently invisible to this check (ADR-0012
# P1: one list).
LED_FLAG_VOCAB="-f -e --supersedes --amends --amends-scope --answers --refs --concern --evidence --confidence --event-time --antecedent"
refuse_flag_in_statement() {
  local usage="$1"; shift
  local -a words=("$@")
  local i word value
  for ((i = 0; i < ${#words[@]}; i++)); do
    word="${words[$i]}"
    case " $LED_FLAG_VOCAB " in
      *" $word "*)
        value="${words[$((i + 1))]:-<value>}"
        echo "led: REFUSED -- the statement contains '${word}' as a TRAILING (or embedded) shell" >&2
        echo "  argument, which is a known led flag token. Flags are consumed by the top-of-file" >&2
        echo "  parser BEFORE the variadic <statement...> capture begins -- a flag placed after" >&2
        echo "  the statement is silently swallowed into statement prose instead of being parsed," >&2
        echo "  and the typed column it names lands NULL with no error (ledger item" >&2
        echo "  led-refs-flag-order-parser-bug; BACKLOG autoharn1 rows 1053/1054, experience-world" >&2
        echo "  rows 65/66/71/87 -- each occurrence cost a superseding rewrite)." >&2
        echo "  NOTHING was written. Flags go BEFORE the statement -- re-issue as:" >&2
        echo "    ./led ${usage} ${word} ${value} \"<statement...>\"" >&2
        echo "  (a statement that legitimately QUOTES '${word}' inside a single shell argument --" >&2
        echo "  e.g. prose reporting someone else's command verbatim -- is not affected: this" >&2
        echo "  check only fires when '${word}' arrives as its OWN separate shell argument)" >&2
        exit 1
        ;;
    esac
  done
}

# --- content-free-review-statement tripwire (tracker item `content-free-review-audit`; WITNESSED
# SPECIMEN: run12 ledger row 20, statement="test" (4 chars) -- a review row whose ENTIRE statement
# was 4 characters mechanically discharged another row's countersign obligation under
# `<schema>.review_gap`'s own semantics (kernel/lineage/s13-schema.sql: ANY unsuperseded,
# distinct-actor `attest` review discharges -- content is NEVER examined by the view). None of
# run12's six reviewer passes ever caught it; it stands attested in the append-only record.
# WARN-ONLY, mirrors warn_path_shaped_in_statement's own posture (same function shape, same
# tone) -- unlike refuse_flag_in_statement above, which was escalated to a hard REFUSE (ledger
# item led-refs-flag-order-parser-bug): a legitimately terse review DOES exist ("Confirmed, matches row 4's stated criteria
# exactly." clears easily), so a false positive here is a harmless notice, not a blocked write --
# the write PROCEEDS either way, never refused. The retroactive, content-examining half of this
# check lives in engine/review_gap_audit.py (\`./audit --review-gap\`) -- this tripwire is
# intake-time and length-only, exactly the honest limit that module's own docstring names.
# THE SHARED THRESHOLD LIVES ONE PLACE (ADR-0012 P1): engine/review_gap_thresholds.py, read here
# via the SAME python3-subprocess convention this file already uses for
# filing/deployment_record.py (see this file's own top-of-file \`_dep_vars\` block) -- never a
# second, hand-copied number. Fails OPEN on any subprocess trouble (python3 missing, a bad exit)
# -- a tripwire that cannot run must never block the write it is only ever supposed to warn about.
warn_content_free_review_statement() {
  local text="$1" verdict
  verdict=$(python3 "$AUTOHARN_ROOT/engine/review_gap_thresholds.py" "$text" 2>/dev/null) || return 0
  case "$verdict" in
    FLAGGED*)
      echo "led: WARNING -- this review's statement is very short (${verdict#FLAGGED } "  >&2
      echo "  whitespace-normalized chars). engine/review_gap_audit.py (./audit --review-gap," >&2
      echo "  tracker item 'content-free-review-audit') will FLAG this row if it discharges a" >&2
      echo "  countersign obligation -- state what you actually checked, not just the verdict." >&2
      echo "  (warn-only tripwire, not a refusal -- a legitimate terse review exists; the write" >&2
      echo "  proceeds either way)" >&2
      ;;
  esac
}

if [ "${1:-}" = "--recent" ] || [ "${1:-}" = "current" ]; then
  # `current` reads ledger_current (supersedes already filtered server-side, the ledger's own view).
  # `--recent` reads the raw table but MARKS a superseded row visibly instead of silently
  # showing it as current -- stamp_agent: the invocation identity that actually WROTE the row --
  # "main" for the top-level context, a subagent's own agent_id otherwise, NULL when unstamped
  # (a non-intercepted write path). Shown alongside the writer-supplied actor principal so a
  # reader can see WHO (principal) and, independently, WHICH INVOCATION wrote each row.
  if [ "${1:-}" = "current" ]; then
    n="${2:-10}"
    exec psql -h "$PGHOST" -d "$PGDB" -tAc "
      SELECT l.id, l.kind, l.statement, p.name
      FROM ${SCHEMA}.ledger_current l JOIN ${KERNEL}.principal p ON p.id = l.actor
      ORDER BY l.id DESC LIMIT ${n};"
  fi
  n="${2:-10}"
  exec psql -h "$PGHOST" -d "$PGDB" -tAc "
    SELECT l.id, l.kind, l.statement, p.name, l.stamp_agent, l.stamp_verified,
           CASE WHEN EXISTS (SELECT 1 FROM ${SCHEMA}.ledger s WHERE s.supersedes = l.id)
                THEN 'SUPERSEDED' ELSE 'current' END AS status_now
    FROM ${SCHEMA}.ledger l JOIN ${KERNEL}.principal p ON p.id = l.actor
    ORDER BY l.id DESC LIMIT ${n};"
fi

if [ "${1:-}" = "show" ]; then
  # led show <id> — a real, read-only subcommand (run-11 class-b finding, BACKLOG "Run-11
  # first-shift forensics" item 7 / change proposal 1): before this, `led show <id>` cleared
  # the generic path's `$# -lt 2` usage guard and fell through to the generic <kind>
  # <statement...> INSERT with kind="show", refused by ledger_kind_check -- a phantom sequence
  # burn on what reads as an intuitive read-only verb (mirroring `git show`/`docker inspect`).
  # This block sits BEFORE the generic dispatch below, so `show` never reaches the write path.
  id="${2:-}"
  case "$id" in
    ''|*[!0-9]*)
      echo "usage: led show <id>" >&2
      echo "       <id> must be a positive integer ledger row id (see 'led --recent' or" >&2
      echo "       'led current' to find one) -- prints EVERY column of that one row, in" >&2
      echo "       full (psql -x expanded display; statement/rationale never truncated)." >&2
      exit 1
      ;;
  esac
  found=$(psql -h "$PGHOST" -d "$PGDB" -tAq -v id="$id" <<SQL
    SELECT EXISTS (SELECT 1 FROM ${SCHEMA}.ledger WHERE id = :id::bigint);
SQL
  )
  if [ "$found" != "t" ]; then
    echo "led show: REFUSED -- no ledger row with id=${id}." >&2
    echo "  This is a READ-ONLY refusal: nothing was written, no sequence id was burned." >&2
    echo "  See 'led --recent [N]' or 'led current [N]' for ids that actually exist." >&2
    exit 1
  fi
  # NOTE (this file's own established gotcha, see `led work asof` below): psql's :'var'/:var
  # interpolation is only applied to a script read from stdin/-f, NOT to a -c argument -- so
  # this is fed via heredoc, not -c, exactly like every other bound query in this file.
  exec psql -h "$PGHOST" -d "$PGDB" -x -v id="$id" <<SQL
    SELECT l.*, p.name AS actor_name
    FROM ${SCHEMA}.ledger l LEFT JOIN ${KERNEL}.principal p ON p.id = l.actor
    WHERE l.id = :id::bigint;
SQL
fi

if [ "${1:-}" = "question-status" ]; then
  exec psql -h "$PGHOST" -d "$PGDB" -c "SELECT * FROM ${SCHEMA}.question_status ORDER BY question_id;"
fi

if [ "${1:-}" = "review-gap" ]; then
  exec psql -h "$PGHOST" -d "$PGDB" -c "SELECT * FROM ${SCHEMA}.review_gap ORDER BY id;"
fi

if [ "${1:-}" = "stamp-distinctness" ]; then
  exec psql -h "$PGHOST" -d "$PGDB" -c "SELECT * FROM ${SCHEMA}.review_stamp_distinctness ORDER BY review_id;"
fi

if [ "${1:-}" = "standing" ]; then
  # led standing — trivial reader over standing_decisions (kernel/lineage/s36-decision-grade.sql,
  # design/FABLE-GRADED-DECISIONS-SPEC.md element 6). The escape hatch both the SessionStart
  # hook's (hooks/sessionstart_durable_decisions.py) and pickup's STANDING-DECISIONS section's own
  # loud-truncation messages point at ("N more standing decisions not shown -- run ./led
  # standing") -- READ-ONLY, no recency limit (standing_decisions is already the FULL in-force
  # graded set, s31's own supersession semantics drop a retracted one automatically).
  #
  # GRACEFUL TEACH-TEXT REFUSAL on a pre-s36 world -- LIVE column-existence check, the SAME
  # convention `work open --parent`/`work open --discharge` above already use (this file executes
  # IN PLACE for every already-scaffolded world, live verbs doctrine, and s36 is NOT wired into
  # every world's birth chain -- it ships authored+scratch-witnessed only, per its own header's
  # PARAMETERIZATION note), so an unconditional `SELECT * FROM standing_decisions` here would
  # error with a bare "relation does not exist" instead of teaching the fix.
  has_grade_col=$(psql -h "$PGHOST" -d "$PGDB" -tAq -v schema="$SCHEMA" <<SQL
    SELECT EXISTS (SELECT 1 FROM information_schema.columns
                   WHERE table_schema = :'schema' AND table_name = 'ledger'
                     AND column_name = 'decision_grade');
SQL
  )
  if [ "$has_grade_col" != "t" ]; then
    echo "led standing: REFUSED -- this world's kernel predates s36 (decision_grade column not" >&2
    echo "  found on ${SCHEMA}.ledger, so standing_decisions does not exist either). Apply" >&2
    echo "  kernel/lineage/s36-decision-grade.sql to this schema as a maintainer act" >&2
    echo "  (ORCH-OPERATING-CARD.md's kernel-delta decision tree), or -- if this world never" >&2
    echo "  needs graded standing decisions -- there is nothing more to do here." >&2
    exit 1
  fi
  exec psql -h "$PGHOST" -d "$PGDB" -c "SELECT * FROM ${SCHEMA}.standing_decisions ORDER BY id;"
fi

if [ "${1:-}" = "register-principal" ]; then
  # s40 REGISTRATION CEREMONY (kernel/lineage/s40-principal-identity-events.sql §3.7). The
  # historical `ON CONFLICT (name) DO NOTHING` is DELETED: a duplicate name is refused LOUDLY
  # before the INSERT, with teach-text quoting the existing principal's id, class, and
  # registration purpose -- closing the panel's ask #2 AND the meta-consult Axis 6 finding (this
  # exact silent no-op was the one sibling an earlier fix left uncovered) in BOTH class
  # polarities: same-class duplicate refused (re-registration is never a no-op), class-mismatch
  # duplicate refused naming the mismatch (classes are immutable; a different class is a
  # different principal). The duplicate refusal runs on EVERY world's kernel (it needs only the
  # anchor table); the EVENT half is live-checked (an s40 kernel carries principal_subject) so
  # this live template neither breaks a pre-s40 world nor silently skips the event on an s40 one.
  shift
  name=""; class=""; purpose=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --purpose) purpose="${2:-}"; shift 2 ;;
      --*)
        echo "led register-principal: REFUSED -- unrecognized flag '$1'." >&2
        echo "usage: led register-principal <name> <human|model|subagent|tool> --purpose \"<why this identity exists>\"" >&2
        exit 1 ;;
      *)
        if [ -z "$name" ]; then name="$1"
        elif [ -z "$class" ]; then class="$1"
        else
          echo "led register-principal: REFUSED -- unexpected argument '$1' (name and class already given)." >&2
          exit 1
        fi
        shift ;;
    esac
  done
  if [ -z "$name" ] || [ -z "$class" ]; then
    echo "usage: led register-principal <name> <human|model|subagent|tool> --purpose \"<why this identity exists>\"" >&2
    exit 1
  fi
  refuse_shared_flags_for_principal_verb "register-principal"
  resolve_actor
  existing=$(psql -h "$PGHOST" -d "$PGDB" -tAq -v name="$name" <<SQL
    SET ROLE ${ROLE};
    SET search_path = ${SCHEMA}, ${KERNEL};
    SELECT p.id || '|' || p.agent_class || '|' || coalesce(
             (SELECT lc.principal_purpose FROM ${SCHEMA}.ledger_current lc
              WHERE lc.kind = 'principal_registered' AND lc.principal_subject = p.id
              ORDER BY lc.id LIMIT 1), '(no recorded purpose -- pre-s40 registration)')
    FROM principal p WHERE p.name = :'name';
SQL
  )
  if [ -n "$existing" ]; then
    ex_id="${existing%%|*}"; rest="${existing#*|}"; ex_class="${rest%%|*}"; ex_purpose="${rest#*|}"
    echo "led register-principal: REFUSED -- principal '${name}' is already registered" >&2
    echo "  (id ${ex_id}, class ${ex_class}, purpose: ${ex_purpose})." >&2
    if [ "$ex_class" = "$class" ]; then
      echo "  Re-registration is never a silent no-op (s40 §3.7 -- the panel's silent" >&2
      echo "  ON CONFLICT DO NOTHING class, closed): if you meant this existing principal," >&2
      echo "  just use it (LED_ACTOR=${name}); if you meant a NEW identity, pick a new name." >&2
    else
      echo "  Registered as ${ex_class}; classes are IMMUTABLE -- a different class is a" >&2
      echo "  DIFFERENT principal: pick a new name and, if this succeeds the old identity," >&2
      echo "  record the succession -- ./led principal relate ${name}-2 succeeds ${name} once" >&2
      echo "  this kernel carries s41 (kernel/lineage/s41-principal-bindings-and-relations.sql);" >&2
      echo "  on an s40-only kernel, file a decision row naming the successor instead" >&2
      echo "  (./led decision \"principal <new-name> succeeds ${name} (class change ${ex_class} -> ${class})\")." >&2
    fi
    exit 1
  fi
  has_s40=$(psql -h "$PGHOST" -d "$PGDB" -tAc \
    "SELECT EXISTS (SELECT 1 FROM information_schema.columns WHERE table_schema = '${SCHEMA}' AND table_name = 'ledger' AND column_name = 'principal_subject');")
  if [ "$has_s40" = "t" ]; then
    if [ -z "$purpose" ]; then
      echo "led register-principal: REFUSED -- --purpose is mandatory on an s40 kernel: a" >&2
      echo "  registration is a recorded, attributed event with a stated purpose (AC-2's" >&2
      echo "  'account with a stated purpose'; kernel/lineage/s40-principal-identity-events.sql)." >&2
      echo "usage: led register-principal <name> <human|model|subagent|tool> --purpose \"<why this identity exists>\"" >&2
      exit 1
    fi
    # One statement = one transaction: anchor INSERT + registration event via a data-modifying
    # CTE, so the kernel's deferred anchor-coupling trigger (a bare anchor cannot commit) is
    # satisfied atomically. Registrar = the event's actor (resolve_actor / the standing default).
    if [ -n "$event_time" ]; then
      exec psql -h "$PGHOST" -d "$PGDB" -v ON_ERROR_STOP=1 \
        -v name="$name" -v class="$class" -v purpose="$purpose" \
        -v actor_name="$actor_name" -v event_time="$event_time" <<SQL
        SET ROLE ${ROLE};
        SET search_path = ${SCHEMA}, ${KERNEL};
        WITH new_p AS (
          INSERT INTO principal (name, agent_class) VALUES (:'name', :'class')
          RETURNING id, name, agent_class
        )
        INSERT INTO ${SCHEMA}.ledger
            (kind, statement, actor, principal_subject, principal_purpose, event_declared_ts)
        SELECT 'principal_registered',
               format('principal ''%s'' registered (class %s)', np.name, np.agent_class),
               (SELECT id FROM principal WHERE name = NULLIF(:'actor_name', '')),
               np.id, :'purpose', NULLIF(:'event_time', '')::timestamptz
        FROM new_p np;
SQL
    else
      exec psql -h "$PGHOST" -d "$PGDB" -v ON_ERROR_STOP=1 \
        -v name="$name" -v class="$class" -v purpose="$purpose" -v actor_name="$actor_name" <<SQL
        SET ROLE ${ROLE};
        SET search_path = ${SCHEMA}, ${KERNEL};
        WITH new_p AS (
          INSERT INTO principal (name, agent_class) VALUES (:'name', :'class')
          RETURNING id, name, agent_class
        )
        INSERT INTO ${SCHEMA}.ledger
            (kind, statement, actor, principal_subject, principal_purpose)
        SELECT 'principal_registered',
               format('principal ''%s'' registered (class %s)', np.name, np.agent_class),
               (SELECT id FROM principal WHERE name = NULLIF(:'actor_name', '')),
               np.id, :'purpose'
        FROM new_p np;
SQL
    fi
  fi
  # pre-s40 kernel: no event machinery exists. The duplicate refusal above already ran (the
  # Axis 6 fix reaches every world); --purpose has no typed home here and is refused rather
  # than silently dropped.
  if [ -n "$purpose" ]; then
    echo "led register-principal: REFUSED -- --purpose was given, but this world's kernel" >&2
    echo "  predates s40 (no principal_subject column on ${SCHEMA}.ledger), so the registration" >&2
    echo "  event that would carry it cannot be recorded. Omit --purpose on this world, or" >&2
    echo "  scaffold a new world whose birth chain carries s40." >&2
    exit 1
  fi
  exec psql -h "$PGHOST" -d "$PGDB" -v ON_ERROR_STOP=1 -v name="$name" -v class="$class" <<SQL
    SET ROLE ${ROLE};
    SET search_path = ${SCHEMA}, ${KERNEL};
    INSERT INTO principal (name, agent_class) VALUES (:'name', :'class');
SQL
fi

# --- `led principal ...` -- the s40 identity-lifecycle verbs (kernel/lineage/
# s40-principal-identity-events.sql §3.7; s41 adds the binding/relation verbs to this same
# namespace). Thin verbs writing the corresponding event kinds, each through resolve_actor,
# each honoring --event-time (the s24 convention) and loudly refusing every other shared
# channel (refuse_shared_flags_for_principal_verb -- meta-consult Axis 1). NAMESPACED
# `led principal ...` deliberately: "standing" here is an IDENTITY's status (active/suspended/
# revoked), unrelated to `led standing`'s s36 decision-durability vocabulary.
if [ "${1:-}" = "principal" ]; then
  shift
  sub="${1:-}"; shift 2>/dev/null || true
  _principal_usage() {
    echo "usage: led principal declare-standing <name> [--db-role <role>]   # bind a db role's default attribution to <name> (rotation auto-supersedes)" >&2
    echo "       led principal suspend <name> [reason...]                   # withdraw standing (no v1 verb lifts it -- see s40 §3.4)" >&2
    echo "       led principal revoke <name> [reason...]                    # withdraw standing, terminally (revoked dominates suspended)" >&2
    echo "  (s41 kernels add: relate/unrelate, bind-role/release-role, bind-key/revoke-key," >&2
    echo "   grant-competence/withdraw-competence -- each refused with teach-text on an s40-only kernel)" >&2
  }
  has_s40=$(psql -h "$PGHOST" -d "$PGDB" -tAc \
    "SELECT EXISTS (SELECT 1 FROM information_schema.columns WHERE table_schema = '${SCHEMA}' AND table_name = 'ledger' AND column_name = 'principal_subject');")
  if [ "$has_s40" != "t" ]; then
    echo "led principal: REFUSED -- this world's kernel predates s40 (no principal_subject" >&2
    echo "  column on ${SCHEMA}.ledger): identity lifecycle events have no typed home here." >&2
    echo "  These verbs work on a world whose birth chain carries" >&2
    echo "  kernel/lineage/s40-principal-identity-events.sql." >&2
    exit 1
  fi
  # every subcommand's subject principal must exist; resolved once, here.
  _principal_subject_id() {
    psql -h "$PGHOST" -d "$PGDB" -tAq -v name="$1" <<SQL
      SET ROLE ${ROLE};
      SET search_path = ${SCHEMA}, ${KERNEL};
      SELECT id FROM principal WHERE name = :'name';
SQL
  }
  case "$sub" in
    declare-standing)
      name="${1:-}"; shift 2>/dev/null || true
      db_role="$ROLE"
      while [ $# -gt 0 ]; do
        case "$1" in
          --db-role) db_role="${2:-}"; shift 2 ;;
          *) echo "led principal declare-standing: REFUSED -- unrecognized argument '$1'." >&2; _principal_usage; exit 1 ;;
        esac
      done
      if [ -z "$name" ]; then _principal_usage; exit 1; fi
      refuse_shared_flags_for_principal_verb "principal declare-standing"
      resolve_actor
      pid=$(_principal_subject_id "$name")
      if [ -z "$pid" ]; then
        echo "led principal declare-standing: REFUSED -- '${name}' is not a registered principal." >&2
        echo "  Register it first: ./led register-principal ${name} <class> --purpose \"...\"" >&2
        exit 1
      fi
      # rotation: a newer declaration for the same db_role supersedes the current one (the
      # `principal_role` view's latest-unsuperseded read makes this belt-and-braces; the
      # supersession keeps the event graph honest -- exactly one in-force declaration per role).
      old_id=$(psql -h "$PGHOST" -d "$PGDB" -tAq -v db_role="$db_role" <<SQL
        SET ROLE ${ROLE};
        SET search_path = ${SCHEMA}, ${KERNEL};
        SELECT lc.id FROM ${SCHEMA}.ledger_current lc
        WHERE lc.kind = 'principal_standing_declared' AND lc.principal_db_role = :'db_role'
        ORDER BY lc.id DESC LIMIT 1;
SQL
      )
      [ -n "$old_id" ] && echo "led principal declare-standing: rotating -- superseding standing declaration row ${old_id} for role '${db_role}'."
      exec psql -h "$PGHOST" -d "$PGDB" -v ON_ERROR_STOP=1 \
        -v name="$name" -v db_role="$db_role" -v pid="$pid" -v old_id="$old_id" \
        -v actor_name="$actor_name" -v event_time="$event_time" <<SQL
        SET ROLE ${ROLE};
        SET search_path = ${SCHEMA}, ${KERNEL};
        INSERT INTO ${SCHEMA}.ledger
            (kind, statement, actor, principal_subject, principal_db_role, supersedes,
             event_declared_ts)
        VALUES ('principal_standing_declared',
                format('database role ''%s'' speaks for principal ''%s'' by default (standing declaration)', :'db_role', :'name'),
                (SELECT id FROM principal WHERE name = NULLIF(:'actor_name', '')),
                :'pid'::bigint, :'db_role',
                NULLIF(:'old_id', '')::bigint,
                NULLIF(:'event_time', '')::timestamptz);
SQL
      ;;
    suspend|revoke)
      name="${1:-}"; shift 2>/dev/null || true
      reason="$*"
      if [ -z "$name" ]; then _principal_usage; exit 1; fi
      case "$name" in --*) _principal_usage; exit 1 ;; esac
      refuse_shared_flags_for_principal_verb "principal ${sub}"
      resolve_actor
      pid=$(_principal_subject_id "$name")
      if [ -z "$pid" ]; then
        echo "led principal ${sub}: REFUSED -- '${name}' is not a registered principal." >&2
        exit 1
      fi
      kind_val="principal_${sub}"
      case "$sub" in suspend) kind_val="principal_suspended" ;; revoke) kind_val="principal_revoked" ;; esac
      stmt="principal '${name}' ${sub}d -- standing withdrawn"
      [ -n "$reason" ] && stmt="${stmt}: ${reason}"
      exec psql -h "$PGHOST" -d "$PGDB" -v ON_ERROR_STOP=1 \
        -v kind_val="$kind_val" -v stmt="$stmt" -v pid="$pid" \
        -v actor_name="$actor_name" -v event_time="$event_time" <<SQL
        SET ROLE ${ROLE};
        SET search_path = ${SCHEMA}, ${KERNEL};
        INSERT INTO ${SCHEMA}.ledger
            (kind, statement, actor, principal_subject, event_declared_ts)
        VALUES (:'kind_val', :'stmt',
                (SELECT id FROM principal WHERE name = NULLIF(:'actor_name', '')),
                :'pid'::bigint,
                NULLIF(:'event_time', '')::timestamptz);
SQL
      ;;
    relate|unrelate|bind-role|release-role|bind-key|revoke-key|grant-competence|withdraw-competence)
      # s41 binding/relation verbs (kernel/lineage/s41-principal-bindings-and-relations.sql
      # D-1a/D-2). Live-checked so an s40-only kernel refuses with teach-text instead of a bare
      # undefined-column error. Shared discipline, every verb: resolve_actor; --event-time
      # honored, every other shared channel refused (refuse_shared_flags_for_principal_verb);
      # duplicate-ACTIVE guards and supersession-target checks run against the D-5 views (the
      # definition of "active" -- a row's own principal_binding_active column read in isolation
      # never changes once set, even after superseding); a retraction restates its identity
      # fields and a mismatched restated value is REFUSED, never silently written as a new,
      # unrelated fact wearing a supersession pointer (value-continuity, CLI-side by ratified
      # design -- the kernel's own CHECK machinery cannot express a cross-row lookup; s41 §8).
      has_s41=$(psql -h "$PGHOST" -d "$PGDB" -tAc \
        "SELECT EXISTS (SELECT 1 FROM information_schema.columns WHERE table_schema = '${SCHEMA}' AND table_name = 'ledger' AND column_name = 'principal_binding_active');")
      if [ "$has_s41" != "t" ]; then
        echo "led principal ${sub}: REFUSED -- this world's kernel carries s40 but not s41" >&2
        echo "  (no principal_binding_active column on ${SCHEMA}.ledger): binding/relation" >&2
        echo "  events have no typed home here. These verbs work on a world whose birth chain" >&2
        echo "  carries kernel/lineage/s41-principal-bindings-and-relations.sql." >&2
        exit 1
      fi
      refuse_shared_flags_for_principal_verb "principal ${sub}"
      resolve_actor
      # one shared INSERT point for all eight verbs (ADR-0012 P1: one writer, eight callers).
      # Args via psql -v binds; empty string -> NULL via NULLIF, matching the generic path.
      _principal_binding_insert() {
        # $1 kind, $2 statement, $3 subject-id, $4 active(t/f), $5 supersedes(or ''),
        # $6 object-id, $7 relation, $8 role-name, $9 fingerprint, $10 activity, $11 band, $12 basis
        psql -h "$PGHOST" -d "$PGDB" -v ON_ERROR_STOP=1 \
          -v kind_val="$1" -v stmt="$2" -v pid="$3" -v active="$4" -v sup="$5" \
          -v obj="$6" -v rel="$7" -v role_name="$8" -v fp="$9" \
          -v activity="${10}" -v band="${11}" -v basis="${12}" \
          -v actor_name="$actor_name" -v event_time="$event_time" <<SQL
          SET ROLE ${ROLE};
          SET search_path = ${SCHEMA}, ${KERNEL};
          INSERT INTO ${SCHEMA}.ledger
              (kind, statement, actor, principal_subject, principal_binding_active, supersedes,
               principal_object, principal_relation, principal_role_name,
               principal_key_fingerprint, principal_competence_activity,
               principal_competence_band, principal_competence_basis, event_declared_ts)
          VALUES (:'kind_val', :'stmt',
                  (SELECT id FROM principal WHERE name = NULLIF(:'actor_name', '')),
                  :'pid'::bigint, :'active'::boolean,
                  NULLIF(:'sup', '')::bigint,
                  NULLIF(:'obj', '')::bigint,
                  NULLIF(:'rel', ''),
                  NULLIF(:'role_name', ''),
                  NULLIF(:'fp', ''),
                  NULLIF(:'activity', ''),
                  NULLIF(:'band', ''),
                  NULLIF(:'basis', ''),
                  NULLIF(:'event_time', '')::timestamptz);
SQL
      }
      case "$sub" in
        relate|unrelate)
          # led principal relate   <subject> <relation> <object>
          # led principal unrelate <subject> <relation> <object> --supersedes <old-id>
          subj_name="${1:-}"; rel="${2:-}"; obj_name="${3:-}"; shift 3 2>/dev/null || true
          sup_id=""
          while [ $# -gt 0 ]; do
            case "$1" in
              --supersedes) sup_id="${2:-}"; shift 2 ;;
              *) echo "led principal ${sub}: REFUSED -- unrecognized argument '$1'." >&2; exit 1 ;;
            esac
          done
          if [ -z "$subj_name" ] || [ -z "$rel" ] || [ -z "$obj_name" ]; then
            echo "usage: led principal relate <subject> <acts-for|dispatched-by|same-natural-person|succeeds> <object>" >&2
            echo "       led principal unrelate <subject> <relation> <object> --supersedes <old-row-id>" >&2
            exit 1
          fi
          case "$rel" in
            acts-for|dispatched-by|same-natural-person|succeeds) : ;;
            *) echo "led principal ${sub}: REFUSED -- '${rel}' is not a relation (closed vocabulary: acts-for, dispatched-by, same-natural-person, succeeds -- s41 D-2)." >&2; exit 1 ;;
          esac
          subj_id=$(_principal_subject_id "$subj_name"); obj_id=$(_principal_subject_id "$obj_name")
          if [ -z "$subj_id" ] || [ -z "$obj_id" ]; then
            echo "led principal ${sub}: REFUSED -- both endpoints must be registered principals ('${subj_name}' -> id '${subj_id:-none}', '${obj_name}' -> id '${obj_id:-none}')." >&2
            exit 1
          fi
          if [ "$subj_id" = "$obj_id" ]; then
            echo "led principal ${sub}: REFUSED -- a principal cannot stand in relation '${rel}' to itself (s41 D-3's self-edge refusal; the kernel refuses this too)." >&2
            exit 1
          fi
          # CANONICALIZATION (s41 D-2, kernel-backstopped by the principal_snp_canonical_order
          # CHECK): same-natural-person is symmetric, so BOTH relate and unrelate normalize to
          # lower-id-subject before writing or comparing -- a caller never needs to remember
          # which order was originally used.
          if [ "$rel" = "same-natural-person" ] && [ "$subj_id" -gt "$obj_id" ]; then
            _t="$subj_id"; subj_id="$obj_id"; obj_id="$_t"
            _t="$subj_name"; subj_name="$obj_name"; obj_name="$_t"
            echo "led principal ${sub}: note -- same-natural-person is symmetric; canonicalizing to subject='${subj_name}' (lower id), object='${obj_name}'."
          fi
          cur_id=$(psql -h "$PGHOST" -d "$PGDB" -tAq -v s="$subj_id" -v r="$rel" -v o="$obj_id" <<SQL
            SET ROLE ${ROLE};
            SET search_path = ${SCHEMA}, ${KERNEL};
            SELECT row_id FROM ${SCHEMA}.principal_relations
            WHERE subject = :'s'::bigint AND relation = :'r' AND object = :'o'::bigint
            ORDER BY row_id DESC LIMIT 1;
SQL
          )
          if [ "$sub" = "relate" ]; then
            if [ -n "$cur_id" ]; then
              echo "led principal relate: REFUSED -- an active '${rel}' assertion already exists for this exact pair (row ${cur_id}); no duplicate active truth. To retract it: ./led principal unrelate ${subj_name} ${rel} ${obj_name} --supersedes ${cur_id}" >&2
              exit 1
            fi
            _principal_binding_insert principal_relation_asserted \
              "principal '${subj_name}' ${rel} principal '${obj_name}' (relation asserted)" \
              "$subj_id" t "" "$obj_id" "$rel" "" "" "" "" ""
          else
            if [ -z "$sup_id" ]; then
              echo "led principal unrelate: REFUSED -- --supersedes <old-row-id> is mandatory (a retraction supersedes the assertion it retracts; find the id in principal_relations.row_id)." >&2
              exit 1
            fi
            if [ "$cur_id" != "$sup_id" ]; then
              echo "led principal unrelate: REFUSED -- row '${sup_id}' is not the active '${rel}' assertion for '${subj_name}' -> '${obj_name}' (the view shows ${cur_id:-none}). A retraction must name the live assertion of the SAME triple -- a mismatched target is refused, never silently written (value-continuity, s41 D-2/D-3)." >&2
              exit 1
            fi
            _principal_binding_insert principal_relation_asserted \
              "relation retracted: principal '${subj_name}' no longer ${rel} principal '${obj_name}'" \
              "$subj_id" f "$sup_id" "$obj_id" "$rel" "" "" "" "" ""
          fi
          ;;
        bind-role|release-role)
          name="${1:-}"; shift 1 2>/dev/null || true
          role_name=""; sup_id=""
          while [ $# -gt 0 ]; do
            case "$1" in
              --role) role_name="${2:-}"; shift 2 ;;
              --supersedes) sup_id="${2:-}"; shift 2 ;;
              *) echo "led principal ${sub}: REFUSED -- unrecognized argument '$1'." >&2; exit 1 ;;
            esac
          done
          if [ -z "$name" ] || [ -z "$role_name" ]; then
            echo "usage: led principal bind-role <name> --role \"<role-name>\"" >&2
            echo "       led principal release-role <name> --role \"<role-name>\" --supersedes <old-row-id>" >&2
            echo "  (role names are FREE non-empty text -- organizational configuration, ratified basis §9(c); nothing kernel-side enumerates them)" >&2
            exit 1
          fi
          pid=$(_principal_subject_id "$name")
          [ -z "$pid" ] && { echo "led principal ${sub}: REFUSED -- '${name}' is not a registered principal." >&2; exit 1; }
          cur_id=$(psql -h "$PGHOST" -d "$PGDB" -tAq -v p="$pid" -v r="$role_name" <<SQL
            SET ROLE ${ROLE};
            SET search_path = ${SCHEMA}, ${KERNEL};
            SELECT row_id FROM ${SCHEMA}.principal_role_bindings
            WHERE subject = :'p'::bigint AND role_name = :'r'
            ORDER BY row_id DESC LIMIT 1;
SQL
          )
          if [ "$sub" = "bind-role" ]; then
            [ -n "$sup_id" ] && { echo "led principal bind-role: REFUSED -- --supersedes belongs to release-role (release first to rebind the same role)." >&2; exit 1; }
            if [ -n "$cur_id" ]; then
              echo "led principal bind-role: REFUSED -- '${name}' already holds an active '${role_name}' binding (row ${cur_id}); no duplicate active truth. Bind a DIFFERENT role, or release first: ./led principal release-role ${name} --role \"${role_name}\" --supersedes ${cur_id}" >&2
              exit 1
            fi
            _principal_binding_insert principal_role_bound \
              "principal '${name}' bound to role '${role_name}'" \
              "$pid" t "" "" "" "$role_name" "" "" "" ""
          else
            [ -z "$sup_id" ] && { echo "led principal release-role: REFUSED -- --supersedes <old-row-id> is mandatory (find it in principal_role_bindings.row_id)." >&2; exit 1; }
            if [ "$cur_id" != "$sup_id" ]; then
              echo "led principal release-role: REFUSED -- row '${sup_id}' is not the active '${role_name}' binding for '${name}' (the view shows ${cur_id:-none}). The release restates the SAME role name its target carried -- a mismatched value or an already-inactive target is refused (value-continuity, s41 D-2)." >&2
              exit 1
            fi
            _principal_binding_insert principal_role_bound \
              "role binding released: principal '${name}' no longer bound to role '${role_name}'" \
              "$pid" f "$sup_id" "" "" "$role_name" "" "" "" ""
          fi
          ;;
        bind-key|revoke-key)
          name="${1:-}"; shift 1 2>/dev/null || true
          fp=""; sup_id=""
          while [ $# -gt 0 ]; do
            case "$1" in
              --fingerprint) fp="${2:-}"; shift 2 ;;
              --supersedes) sup_id="${2:-}"; shift 2 ;;
              *) echo "led principal ${sub}: REFUSED -- unrecognized argument '$1'." >&2; exit 1 ;;
            esac
          done
          if [ -z "$name" ] || [ -z "$fp" ]; then
            echo "usage: led principal bind-key <name> --fingerprint \"<40-uppercase-hex OpenPGP v4 fingerprint>\"" >&2
            echo "       led principal revoke-key <name> --fingerprint \"<fp>\" --supersedes <old-row-id>" >&2
            echo "  (human principals only -- agent keys stay refused, MAINT-GPG-TRUST-LAYER.md §6; the" >&2
            echo "   binding is the empty-until-ceremony slot -- key GENERATION stays deferred by standing ruling)" >&2
            exit 1
          fi
          pid=$(_principal_subject_id "$name")
          [ -z "$pid" ] && { echo "led principal ${sub}: REFUSED -- '${name}' is not a registered principal." >&2; exit 1; }
          cur_id=$(psql -h "$PGHOST" -d "$PGDB" -tAq -v p="$pid" -v f="$fp" <<SQL
            SET ROLE ${ROLE};
            SET search_path = ${SCHEMA}, ${KERNEL};
            SELECT row_id FROM ${SCHEMA}.principal_keys
            WHERE subject = :'p'::bigint AND fingerprint = :'f'
            ORDER BY row_id DESC LIMIT 1;
SQL
          )
          if [ "$sub" = "bind-key" ]; then
            if [ -n "$cur_id" ]; then
              echo "led principal bind-key: REFUSED -- this exact fingerprint is already actively bound to '${name}' (row ${cur_id}); no duplicate active truth." >&2
              exit 1
            fi
            _principal_binding_insert principal_key_bound \
              "OpenPGP key ${fp} bound to principal '${name}'" \
              "$pid" t "" "" "" "" "$fp" "" "" ""
          else
            [ -z "$sup_id" ] && { echo "led principal revoke-key: REFUSED -- --supersedes <old-row-id> is mandatory (find it in principal_keys.row_id)." >&2; exit 1; }
            if [ "$cur_id" != "$sup_id" ]; then
              echo "led principal revoke-key: REFUSED -- row '${sup_id}' is not the active binding of this exact fingerprint for '${name}' (the view shows ${cur_id:-none}). The revocation restates the SAME fingerprint its target carried -- a mismatch or an already-inactive target is refused (value-continuity, s41 D-2)." >&2
              exit 1
            fi
            _principal_binding_insert principal_key_bound \
              "key binding revoked: OpenPGP key ${fp} no longer bound to principal '${name}'" \
              "$pid" f "$sup_id" "" "" "" "$fp" "" "" ""
          fi
          ;;
        grant-competence|withdraw-competence)
          name="${1:-}"; shift 1 2>/dev/null || true
          activity=""; band=""; basis=""; sup_id=""
          while [ $# -gt 0 ]; do
            case "$1" in
              --activity) activity="${2:-}"; shift 2 ;;
              --band) band="${2:-}"; shift 2 ;;
              --basis) basis="${2:-}"; shift 2 ;;
              --supersedes) sup_id="${2:-}"; shift 2 ;;
              *) echo "led principal ${sub}: REFUSED -- unrecognized argument '$1'." >&2; exit 1 ;;
            esac
          done
          if [ -z "$name" ] || [ -z "$activity" ]; then
            echo "usage: led principal grant-competence <name> --activity \"<a>\" --band \"<b>\" --basis \"<c>\" [--supersedes <old-row-id>]" >&2
            echo "       led principal withdraw-competence <name> --activity \"<a>\" --supersedes <old-row-id>" >&2
            echo "  (G13's competence record -- recordable, NOT gating in v1; band/basis are free text v1," >&2
            echo "   a RATIFIED PLACEHOLDER awaiting a real band system -- basis §9(g)'s loud note)" >&2
            exit 1
          fi
          pid=$(_principal_subject_id "$name")
          [ -z "$pid" ] && { echo "led principal ${sub}: REFUSED -- '${name}' is not a registered principal." >&2; exit 1; }
          cur_id=$(psql -h "$PGHOST" -d "$PGDB" -tAq -v p="$pid" -v a="$activity" <<SQL
            SET ROLE ${ROLE};
            SET search_path = ${SCHEMA}, ${KERNEL};
            SELECT row_id FROM ${SCHEMA}.principal_competences
            WHERE subject = :'p'::bigint AND activity = :'a'
            ORDER BY row_id DESC LIMIT 1;
SQL
          )
          if [ "$sub" = "grant-competence" ]; then
            if [ -z "$band" ] || [ -z "$basis" ]; then
              echo "led principal grant-competence: REFUSED -- --band and --basis are mandatory on a grant (G13's value fields; forbidden only on a withdrawal)." >&2
              exit 1
            fi
            if [ -n "$cur_id" ] && [ -z "$sup_id" ]; then
              echo "led principal grant-competence: REFUSED -- an active grant already exists for '${name}' / activity '${activity}' (row ${cur_id}); no duplicate active truth. To correct its band/basis, re-grant WITH --supersedes ${cur_id} (the s39-depends-correction idiom); to withdraw it: ./led principal withdraw-competence ${name} --activity \"${activity}\" --supersedes ${cur_id}" >&2
              exit 1
            fi
            if [ -n "$sup_id" ] && [ "$cur_id" != "$sup_id" ]; then
              echo "led principal grant-competence: REFUSED -- --supersedes '${sup_id}' is not the active grant for '${name}' / activity '${activity}' (the view shows ${cur_id:-none})." >&2
              exit 1
            fi
            _principal_binding_insert principal_competence_granted \
              "competence granted: principal '${name}' held competent for '${activity}' at band '${band}'" \
              "$pid" t "$sup_id" "" "" "" "" "$activity" "$band" "$basis"
          else
            if [ -n "$band" ] || [ -n "$basis" ]; then
              echo "led principal withdraw-competence: REFUSED -- --band/--basis are VALUE fields, forbidden on a withdrawal (the identity/value split, s41 D-1a: a retraction restates only WHICH grant it retracts -- the activity)." >&2
              exit 1
            fi
            [ -z "$sup_id" ] && { echo "led principal withdraw-competence: REFUSED -- --supersedes <old-row-id> is mandatory (find it in principal_competences.row_id)." >&2; exit 1; }
            if [ "$cur_id" != "$sup_id" ]; then
              echo "led principal withdraw-competence: REFUSED -- row '${sup_id}' is not the active grant for '${name}' / activity '${activity}' (the view shows ${cur_id:-none}). A mismatched activity or an already-inactive target is refused (value-continuity, s41 D-1a)." >&2
              exit 1
            fi
            _principal_binding_insert principal_competence_granted \
              "competence withdrawn: principal '${name}' no longer held competent for '${activity}'" \
              "$pid" f "$sup_id" "" "" "" "" "$activity" "" ""
          fi
          ;;
      esac
      exit $?
      ;;
    *)
      _principal_usage; exit 1 ;;
  esac
fi

if [ "${1:-}" = "obligate" ]; then
  shift
  if [ "${1:-}" = "revoke" ]; then
    shift
    if [ $# -lt 1 ]; then
      echo "usage: led obligate revoke <scope>" >&2
      echo "       deletes a countersign_obligation row (scope is its PK). Whether this succeeds" >&2
      echo "       or is refused depends on the connecting role's LIVE grants on" >&2
      echo "       countersign_obligation -- checked here via has_table_privilege, never assumed" >&2
      echo "       (s20 granted this role SELECT,INSERT only, by deliberate ruling: an obligation" >&2
      echo "       is standing OPERATOR-owned policy config, never a role self-service capability)" >&2
      exit 1
    fi
    scope="$1"
    # LIVE check, not a hardcoded assumption: if a future kernel delta ever grants DELETE, this
    # verb starts working with no code change here -- the grant state has one home (pg_catalog),
    # never a second hand-copied boolean in this script (ADR-0012 P1).
    can_delete=$(psql -h "$PGHOST" -d "$PGDB" -tAc \
      "SELECT has_table_privilege('${ROLE}', '${SCHEMA}.countersign_obligation', 'DELETE');")
    if [ "$can_delete" != "t" ]; then
      # TEACH-THE-REFUSAL (tracker scaffold-owner-credential-separation LEG 2, 2026-07-14 ent
      # self-escalation incident, ledger row 640): this block used to end with the exact
      # schema-owner DELETE line printed ready to paste -- teach-text in FORM but, in substance,
      # an invitation to route around the refusal by reaching for owner privilege directly, which
      # is what the incident's agent did (connected as ent_owner and ran the DELETE itself). The
      # lawful next step this refusal must teach is LEDGER + STOP + ESCALATE, never "here is the
      # owner command" -- escalation has to be the CHEAPER path or a struggling agent reaches for
      # the workaround instead (ADR-0000 Rule 2(b): a recurring struggle is the executive's net to
      # build, not the implementer's to route around; ADR-0013's "fair dealing" posture that a
      # refusal is a place to stop, not a puzzle to solve).
      echo "led obligate revoke: REFUSED -- role '${ROLE}' has no DELETE grant on" >&2
      echo "  ${SCHEMA}.countersign_obligation (checked live via has_table_privilege, not" >&2
      echo "  hardcoded). This is s20's deliberate ruling, not an oversight: an obligation is" >&2
      echo "  standing operator-owned policy config, never a role-level self-service capability" >&2
      echo "  -- widening the grant would be a kernel delta and is out of scope for this verb to" >&2
      echo "  take on itself." >&2
      echo "" >&2
      echo "  DO NOT connect as the schema owner (or any other elevated identity) to run this" >&2
      echo "  DELETE yourself, however reachable that identity may be from this environment --" >&2
      echo "  that is a self-escalation, not a fix, regardless of whether the outcome is benign." >&2
      echo "" >&2
      echo "  The lawful next step, in order:" >&2
      echo "    1. LEDGER the block now, from THIS session, so the refusal is on the record" >&2
      echo "       before anything else happens:" >&2
      echo "         ./led finding \"obligate revoke blocked: role '${ROLE}' lacks DELETE on\" \\" >&2
      echo "           \"${SCHEMA}.countersign_obligation for scope '${scope}' -- needs a\" \\" >&2
      echo "           \"maintainer act to revoke, not a role-level workaround\"" >&2
      echo "    2. STOP work on this scope. Do not attempt the DELETE via any other connection," >&2
      echo "       role, or credential this environment can reach." >&2
      echo "    3. ESCALATE for orchestrator/maintainer sign-off -- surface the ledgered finding" >&2
      echo "       and wait for a maintainer act. Only the maintainer, as the schema owner, in" >&2
      echo "       their own session, decides whether and how scope '${scope}' is revoked." >&2
      exit 1
    fi
    exec psql -h "$PGHOST" -d "$PGDB" -v ON_ERROR_STOP=1 -v scope="$scope" <<SQL
      SET ROLE ${ROLE};
      SET search_path = ${SCHEMA}, ${KERNEL};
      DELETE FROM ${SCHEMA}.countersign_obligation WHERE scope = :'scope';
SQL
  fi
  if [ $# -lt 3 ]; then
    echo "usage: led obligate <scope> <assigned-by-principal> <obliged-actor-principal>" >&2
    echo "  DIRECTION MATTERS -- this is the mistake that has cost a workaround two runs" >&2
    echo "  running (BACKLOG run-5, run-7): <obliged-actor-principal> is the WORKER whose" >&2
    echo "  rows need outside eyes -- never the reviewer. <assigned-by-principal> is whoever" >&2
    echo "  imposes the obligation and must be a DIFFERENT registered principal than the" >&2
    echo "  obliged actor (obligation_not_self_assigned CHECK refuses a self-ASSIGNED" >&2
    echo "  obligation -- distinct from register-principal's self-REGISTRATION). <scope> is" >&2
    echo "  a free-text label, not a filter: review_gap joins on actor identity alone, so" >&2
    echo "  it counts EVERY row (any kind) the obliged actor writes, not just this scope's" >&2
    echo "  rows -- obliging the reviewer by mistake catches the reviewer's own countersigns." >&2
    echo "  example: led obligate decomposition-review orchestrator author" >&2
    echo "    -> after this, someone other than 'author' must countersign every one of" >&2
    echo "       author's ledger rows or \`led review-gap\` shows debt for each." >&2
    echo "       led obligate revoke <scope>" >&2
    exit 1
  fi
  scope="$1"; assigned_by_name="$2"; obliges_actor_name="$3"
  # BOUNDARY VALIDATION, refuse-before-write (tracker scaffold-owner-credential-separation LEG 3;
  # 2026-07-14 ent self-escalation incident, ledger row 640: "its own obligate command
  # accidentally globalized to 813 historical countersign_obligation rows"). <scope> READS as a
  # narrow label but is not a filter -- review_gap joins on the obliged actor's IDENTITY alone
  # (see the usage text above), so every countersign_obligation row for a given actor is
  # redundantly global, and a second (or 813th) row for the SAME actor adds no new coverage --
  # only more governance-config rows an operator must later reason about and, per the incident,
  # more rows an under-pressure agent may try to mass-delete. Mirroring the malformed-statement
  # refuse-before-write idiom the generic <kind> path already uses (estimate:/outcome: etc.),
  # this checks LIVE whether the obliged actor already carries an obligation and refuses before
  # the INSERT rather than silently accumulating -- a duplicate is exactly as questionable as a
  # duplicate work_opened (line ~158 above), just not yet enforced by a kernel constraint.
  existing_scope=$(psql -h "$PGHOST" -d "$PGDB" -tAq -v obliges_actor_name="$obliges_actor_name" <<SQL
    SET ROLE ${ROLE};
    SET search_path = ${SCHEMA}, ${KERNEL};
    SELECT o.scope FROM countersign_obligation o
    JOIN principal p ON p.id = o.obliges_actor
    WHERE p.name = :'obliges_actor_name'
    LIMIT 1;
SQL
  )
  if [ -n "$existing_scope" ]; then
    echo "led obligate: REFUSED -- principal '${obliges_actor_name}' already carries an" >&2
    echo "  obligation (scope '${existing_scope}'). Adding scope '${scope}' would NOT narrow or" >&2
    echo "  extend coverage -- review_gap counts every row this actor writes regardless of how" >&2
    echo "  many countersign_obligation rows name them, so a second row is redundant governance" >&2
    echo "  config, not a stronger obligation (this is the same globalization the 2026-07-14" >&2
    echo "  incident's 813-row accumulation came from)." >&2
    echo "" >&2
    echo "  If '${existing_scope}' is the wrong label and you mean to REPLACE it with" >&2
    echo "  '${scope}', revoke the old one first (a role with DELETE grant can do this itself;" >&2
    echo "  otherwise ledger the block and escalate, per \`led obligate revoke\`'s own refusal):" >&2
    echo "    ./led obligate revoke ${existing_scope}" >&2
    echo "  then re-run this command." >&2
    exit 1
  fi
  exec psql -h "$PGHOST" -d "$PGDB" -v ON_ERROR_STOP=1 \
    -v scope="$scope" -v assigned_by_name="$assigned_by_name" -v obliges_actor_name="$obliges_actor_name" <<SQL
    SET ROLE ${ROLE};
    SET search_path = ${SCHEMA}, ${KERNEL};
    INSERT INTO ${SCHEMA}.countersign_obligation (scope, assigned_by, obliges_actor)
    VALUES (:'scope',
            (SELECT id FROM principal WHERE name = :'assigned_by_name'),
            (SELECT id FROM principal WHERE name = :'obliges_actor_name'));
SQL
fi

if [ "${1:-}" = "decomposition-review-status" ]; then
  shift
  # NO FLAGS accepted -- any token here is unrecognized (same refuse-unknown-flags discipline
  # `led work open`'s own UNKNOWN-FLAG REFUSAL and `led work list [--all]`'s bare-arg case above
  # apply): a typo'd/unsupported flag is refused loudly, never silently swallowed or ignored.
  if [ $# -gt 0 ]; then
    echo "led decomposition-review-status: REFUSED -- unrecognized argument '$1'." >&2
    echo "  This verb takes NO flags or arguments -- see top-of-file comment." >&2
    exit 1
  fi

  # (a) MODE. Read from <world-root>/.claude/apparatus.json's mechanisms.decomposition_review.mode,
  # world root == the directory the deployment record was actually found in (the SAME resolution
  # this file's own top-of-file DEPLOYMENT variable already uses, and the SAME convention
  # pickup.tmpl's `_load_apparatus()`/`DEPLOYMENT_PATH.parent` use -- never a second hand-derived
  # notion of "world root"). Default/validation logic is a LINE-FOR-LINE mirror of hooks/
  # pretooluse_change_gate.py's own `_resolve_mode()` -- NOT a single-sourced import of it (an
  # import would pay pretooluse_change_gate.py's own module-load cost and process footprint for a
  # one-shot shell verb; as of the change-gate-foreign-defaults pass, 2026-07-17, that module no
  # longer performs a filesystem read at import time at all -- GOVERNED_PATTERNS is resolved inside
  # `_configure()`, once per invocation, never at module scope -- so the historical foreign-path
  # read this comment used to name is gone; revisiting the copy-vs-import choice itself is a
  # possible FUTURE item, not required by this fix). This is a DELIBERATE additional per-process
  # copy, following the SAME duplication posture this project already carries across eleven
  # hooks/*.py files, each with its own
  # `_resolve_mode` -- see filing/apparatus_registry.py's own docstring ("WHY A DERIVED REGISTRY,
  # NOT A HAND-MAINTAINED LIST"): the mechanism is reconciled by MECHANICALLY SCANNING every copy,
  # never by forcing one shared import across independent short-lived processes. This 'observe'
  # literal tracks pretooluse_change_gate.py's DECOMPOSITION_REVIEW_MODE by the SAME discipline
  # every other hook's copy already relies on -- not a fresh gap, the twelfth instance of an
  # entrenched, documented one: missing apparatus.json / missing "mechanisms" key
  # / missing "decomposition_review" entry -> default 'observe' (NOT 'enforce' -- this is the one
  # mechanism that departs from enforce-by-default, per that module's own docstring); an
  # unrecognized mode string never widens permissions -- falls back to 'observe' with a loud
  # stderr warning naming the bad value and the file it came from, exactly as the gate's own
  # _resolve_mode does.
  world_root="$(cd "$(dirname "$DEPLOYMENT")" && pwd)"
  mode="$(python3 - "$world_root" <<'PYEOF'
import json, os, sys
root = sys.argv[1]
_VALID = ("off", "observe", "enforce")
default = "observe"
path = os.path.join(root, ".claude", "apparatus.json")
try:
    with open(path, encoding="utf-8") as f:
        cfg = json.load(f)
    apparatus = cfg if isinstance(cfg, dict) else {}
except Exception:
    apparatus = {}
mechs = apparatus.get("mechanisms")
entry = mechs.get("decomposition_review") if isinstance(mechs, dict) else None
raw = entry.get("mode") if isinstance(entry, dict) else None
if raw is None:
    print(default)
elif raw in _VALID:
    print(raw)
else:
    print(f"[apparatus] WARNING: mechanisms.decomposition_review.mode={raw!r} in {path} is "
          f"unrecognized (must be one of {_VALID}) -- never widening permissions; falling back "
          f"to {default!r}.", file=sys.stderr)
    print(default)
PYEOF
  )"

  # (b) countersign_obligation row counts. LIVE table-existence check (the SAME convention
  # `work list`/`work violations`/`standing` above all already use) -- a kernel that predates
  # kernel/lineage/s15-schema.sql (countersign_obligation's own origin; s10-s14 are earlier,
  # superseded standalone generations) has no such table at all, and this degrades to an honest
  # teach-text rather than a bare psql error.
  has_tbl=$(psql -h "$PGHOST" -d "$PGDB" -tAq -v schema="$SCHEMA" <<SQL
    SELECT EXISTS (SELECT 1 FROM information_schema.tables
                   WHERE table_schema = :'schema' AND table_name = 'countersign_obligation');
SQL
  )
  if [ "$has_tbl" != "t" ]; then
    echo "mode: $mode"
    echo "countersign_obligation: UNAVAILABLE -- this world's kernel predates"
    echo "  countersign_obligation (kernel/lineage/s15-schema.sql). Apply s15 (or a later"
    echo "  generation) to this schema as a maintainer act to adopt the obligation regime, or --"
    echo "  if this world never needs it -- there is nothing more to do here."
    if [ "$mode" = "off" ]; then
      echo "verdict: OFF"
    else
      echo "verdict: VACUOUS (no obligation rows)"
    fi
    exit 0
  fi
  # total, undischarged. "undischarged" reuses `review_gap`'s OWN actor-identity join
  # (o.obliges_actor = l.actor) rather than a second, independently-authored discharge predicate
  # (ADR-0012 P1) -- review_gap is NOT scope-filtered (kernel/lineage/s15-schema.sql; see this
  # file's own `led obligate` doc comment above), so an obligation row counts as undischarged iff
  # the actor it obliges has AT LEAST ONE row review_gap surfaces, regardless of that row's kind
  # or of which scope label produced the match.
  counts=$(psql -h "$PGHOST" -d "$PGDB" -tAq <<SQL
    SELECT count(*), count(*) FILTER (
      WHERE EXISTS (SELECT 1 FROM ${SCHEMA}.review_gap g WHERE g.actor = o.obliges_actor)
    )
    FROM ${SCHEMA}.countersign_obligation o;
SQL
  )
  total="${counts%%|*}"
  undischarged="${counts##*|}"

  echo "mode: $mode"
  echo "countersign_obligation: total=$total undischarged=$undischarged"
  # (c) verdict. OFF only when mode itself is 'off' (the operator switched the mechanism off,
  # regardless of what obligation rows exist); VACUOUS when the mechanism could act but there is
  # nothing for it to act ON (zero obligation rows -- an armed gate with no ammunition); otherwise
  # ARMED, split by mode into ENFORCING (refuses) vs OBSERVING (warns only).
  if [ "$mode" = "off" ]; then
    echo "verdict: OFF"
  elif [ "$total" = "0" ]; then
    echo "verdict: VACUOUS (no obligation rows)"
  elif [ "$mode" = "enforce" ]; then
    echo "verdict: ARMED-ENFORCING"
  else
    echo "verdict: ARMED-OBSERVING"
  fi
  exit 0
fi

if [ "${1:-}" = "briefing" ]; then
  shift
  # NO FLAGS accepted -- same refuse-unknown-flags discipline `decomposition-review-status` above
  # already uses: a typo'd/unsupported argument is refused loudly, never silently swallowed.
  if [ $# -gt 0 ]; then
    echo "led briefing: REFUSED -- unrecognized argument '$1'." >&2
    echo "  This verb takes NO flags or arguments -- see top-of-file comment." >&2
    exit 1
  fi

  cat <<'BRIEFING'
Fresh-agent rules briefing -- three rules a new agent otherwise discovers only by tripping them.

1. The ledger change-gate. A source-file edit must be preceded by a ledger entry naming that
   file: `./led -f <basename> decision "<why>"`. Then RE-ISSUE THE SAME EDIT -- the gate re-checks
   on every attempt, so retrying after the insert is the whole fix. Do not write the file first
   and ledger it after; the gate blocks the write, not the record.

2. Flag-order asymmetry. Generic ledger flags go BEFORE the kind word: `./led --refs row:N
   decision "..."`. `led work <sub>` flags go AFTER the slug/title/verdict instead: `./led work
   open <slug> "<title>" --parent <parent-slug>`. A flag placed on the wrong side of that boundary
   is REFUSED, never silently swallowed into the statement's own prose -- move it to the other
   side and re-issue.

3. Same-actor countersign (segregation of duties). `led review <id> attest ...` is refused
   when the countersigning actor authored the row it regards -- keyed on actor/principal
   identity alone, unconditionally, regardless of the independence value chosen (the ledger
   INSERT that fires this check lands before independence is even known). The only fix:
   register a distinct principal (`./led register-principal <name> <class>`) and set
   LED_ACTOR=<name> before re-issuing the review. Solo-world fallback (no second principal
   genuinely available): register one anyway for the same operator, and countersign through
   it disclosing `independence self-review` -- honest labeling of the countersign, not a
   substitute for the distinct-actor step.

See design/USER-RECIPES-FAQ.md for the full recipe corpus these rules are drawn from.
BRIEFING

  # Extension point: <world-root>/.claude/apparatus.json's mechanisms.rules_briefing.extra_items.
  # world_root resolved EXACTLY as `decomposition-review-status` above resolves it -- the directory
  # DEPLOYMENT was actually found in, not a second hand-derived notion of "world root" (ADR-0012 P1).
  world_root="$(cd "$(dirname "$DEPLOYMENT")" && pwd)"
  python3 - "$world_root" <<'PYEOF'
import json, os, sys

root = sys.argv[1]
path = os.path.join(root, ".claude", "apparatus.json")
try:
    with open(path, encoding="utf-8") as f:
        cfg = json.load(f)
    apparatus = cfg if isinstance(cfg, dict) else {}
except FileNotFoundError:
    apparatus = {}
except Exception as e:
    print(f"[led briefing] WARNING: could not parse {path} ({type(e).__name__}: {e}) -- "
          f"skipping world-specific extra_items; core briefing above still stands.", file=sys.stderr)
    apparatus = {}

mechs = apparatus.get("mechanisms")
entry = mechs.get("rules_briefing") if isinstance(mechs, dict) else None
extra = entry.get("extra_items") if isinstance(entry, dict) else None

# Diagnostic fix (ledgered fold-into-next-led.tmpl-touch, 2026-07-17): the two malformed shapes --
# `rules_briefing` itself not a dict/object (a non-dict scalar), vs. `rules_briefing.extra_items`
# present but not a list-of-strings -- are DIFFERENT defects and used to be reported through the
# SAME message, which always names `extra` (computed as None whenever entry is not a dict, since
# the `.get` above never runs) -- so a non-dict `rules_briefing` scalar (e.g. a bare string) was
# always reported as "got None", never naming the actual offending value. Split into two checks,
# each naming the value that is actually wrong.
if entry is not None and not isinstance(entry, dict):
    print(f"[led briefing] WARNING: mechanisms.rules_briefing in {path} must be a JSON object -- "
          f"got {entry!r}; ignoring it, core briefing above still stands.", file=sys.stderr)
    sys.exit(0)

if isinstance(entry, dict) and "extra_items" in entry and (
        not isinstance(extra, list) or not all(isinstance(x, str) for x in extra)):
    print(f"[led briefing] WARNING: mechanisms.rules_briefing.extra_items in {path} must be a "
          f"JSON array of strings -- got {extra!r}; ignoring it, core briefing above still stands.",
          file=sys.stderr)
    sys.exit(0)

if not extra:
    sys.exit(0)  # absent, or present-but-empty -- zero interference either way

print()
print("Additional world-specific rules (.claude/apparatus.json mechanisms.rules_briefing.extra_items):")
for item in extra:
    print(f"  - {item}")
PYEOF
  exit 0
fi

if [ "${1:-}" = "review" ]; then
  shift
  antecedent=""
  args=()
  while [ $# -gt 0 ]; do
    case "$1" in
      --antecedent) antecedent="${2:-}"; shift 2 ;;
      *) args+=("$1"); shift ;;
    esac
  done
  set -- "${args[@]}"
  if [ $# -lt 4 ]; then
    echo "usage: led review <entry-id> <verdict> <independence> [--antecedent id] <statement...>" >&2
    echo "       verdict: attest|attest_with_reservations|refuse" >&2
    echo "       independence: self-review|technical|managerial|financial" >&2
    echo "       set LED_ACTOR=<principal-name> to countersign as a registered principal" >&2
    exit 1
  fi
  regards="$1"; verdict="$2"; independence="$3"; shift 3
  refuse_flag_in_statement "review ${regards} ${verdict} ${independence}" "$@"
  statement="$*"
  warn_content_free_review_statement "$statement"
  warn_path_shaped_in_statement "$statement"
  resolve_actor
  # actor resolves via a subquery bind below, NOT string-spliced: NULLIF(:'actor_name','') is NULL
  # when LED_ACTOR is unset, so the ledger's actor column stays NULL and the kernel's set_actor
  # trigger fills the default connection principal -- the same principal every other led write
  # uses, so an un-set LED_ACTOR against one's own earlier row is refused as self-review (the
  # honest, intended outcome). resolve_actor (defined near the top of this file) is the ONE place
  # LED_ACTOR is read and validated, shared with `led work claim` and the generic
  # <kind> <statement> path.
  psql -h "$PGHOST" -d "$PGDB" -v ON_ERROR_STOP=1 \
    -v regards="$regards" -v verdict="$verdict" -v independence="$independence" \
    -v statement="$statement" -v actor_name="$actor_name" -v antecedent="$antecedent" <<SQL
    SET ROLE ${ROLE};
    SET search_path = ${SCHEMA}, ${KERNEL};
    BEGIN;
    INSERT INTO ${SCHEMA}.ledger (kind, statement, regards, actor)
    VALUES ('review', :'statement', :'regards'::bigint,
            (SELECT id FROM principal WHERE name = NULLIF(:'actor_name', '')))
    RETURNING id \gset r_
    INSERT INTO ${SCHEMA}.review_detail (ledger_id, verdict, independence, basis, antecedent)
    VALUES (:r_id, :'verdict', :'independence', :'statement', NULLIF(:'antecedent', '')::bigint);
    COMMIT;
SQL
  exit $?
fi

if [ "${1:-}" = "work" ]; then
  shift
  sub="${1:-}"
  case "$sub" in
    open)
      shift
      # --parent <parent-slug> (kernel/lineage/s28-work-parent-edge.sql, tracker slug
      # work-tree-rollup): parsed like `work close`'s own --witness flag below, any position
      # among the remaining args. LIVE column-existence check, not a hardcoded kernel-version
      # assumption (the SAME convention `led obligate revoke`'s has_table_privilege check above
      # already uses) -- this file executes IN PLACE out of the autoharn checkout for EVERY
      # already-scaffolded world (the "live verbs" doctrine, ORCH-OPERATING-CARD.md), and s28 is
      # NOT wired into every world's birth chain (it ships authored+scratch-witnessed only, per
      # its own header's FAIL-SAFE CLASSIFICATION note) -- so an unconditional `work_parent` in
      # the INSERT column list below would break `led work open` for every world whose kernel
      # predates s28, the exact hazard-in-reach CLAUDE.md's engineering-responsibility corollary
      # exists to catch before it ships, not after.
      # --discharge composite (kernel/lineage/s33-composite-discharge.sql, ledger item
      # composite-parent-autodischarge): parsed exactly like --parent above -- same LIVE
      # column-existence convention, same reason (s33 is not wired into every world's birth
      # chain either).
      # --refs <ref> (ledger.refs, base schema since s10 -- no column-existence check needed,
      # unlike --parent/--discharge above): CONVENTION for citing an antecedent ledger row,
      # e.g. --refs row:<id> (the commission-decomposition "child cites parent" convention).
      # Scalar, last-wins on repeat -- deliberately consistent with the top-of-file generic
      # --refs parser (line ~354 above), which is also a plain overwrite, not an accumulator.
      #
      # --supersedes <id> (ledger.supersedes, base schema since s10 -- no column-existence check
      # needed, same reason as --refs above): ledger item led-work-open-supersedes. Kernel-side,
      # superseding a work_opened row is ALREADY legal and semantically settled by
      # kernel/lineage/s31-supersession-uniform-retraction.sql: retraction is UNIFORM across
      # every kind (ratified fork 1 -- no kind-compatibility refusal on writes), but a
      # superseded work_opened's SLUG IS PERMANENTLY BURNED, reinstatement-free (ratified fork 2
      # -- s28's cycle-vacuity induction requires "a slug is opened exactly once, parent fixed
      # at birth"). Before this fix the kernel already accepted a work_opened row's id as the
      # <id> target of ANY entry's --supersedes (the generic top-of-file flag, line ~364 above)
      # -- only `work open` itself had no flag to land ITS OWN opening act's supersedes column,
      # so a mis-encoded work_opened row could not be superseded through the CLI at all (an
      # adopting deployment's orchestrator was reduced to proposing a raw SQL UPDATE, refused --
      # UPDATE is not supersession, blocked by append_only, and would break the row-hash chain if
      # forced). Lands on the SAME `ledger.supersedes` column the generic top-of-file parser
      # writes (mirrored below, identical NULLIF(...)::bigint bind) -- one column, one writer
      # (ADR-0012 P1), never a second hand-copied supersession mechanism. Combinable with
      # --refs/--parent/--discharge. The kernel enforces every consequence (FK existence, slug
      # burn on reopen) -- this flag only WRITES the column; see the advisory printed just before
      # the INSERT below for the operator-facing teach-text, and validate_work_item()'s own
      # duplicate-open RAISE EXCEPTION (s31 Element 6) for the slug-burn refusal's own text.
      #
      # UNKNOWN-FLAG REFUSAL (ledger item led-work-open-refs-swallowed): before this fix, any
      # token this loop didn't recognize fell into the `*) args+=("$1")` catch-all below and
      # was silently concatenated into the title via `title="$*"` -- so `--refs row:N` (or any
      # OTHER typo'd/unsupported flag) landed as literal text inside work_title, and the
      # structured column it named stayed NULL, with no error at all. Witnessed downstream: an
      # adopting deployment had 27/27 work_opened rows with NULL refs. A bare `--*`-shaped word
      # is now refused here instead of silently absorbed -- ordinary title words are untouched
      # because this only fires when a token IS, in full, `--*` (mirrors
      # refuse_flag_in_statement's word-level-match posture above, not a substring/re-split
      # check), so a title that happens to CONTAIN "--" inside a longer word survives.
      parent=""
      discharge=""
      refs=""
      supersedes=""
      args=()
      while [ $# -gt 0 ]; do
        case "$1" in
          --parent) parent="${2:-}"; shift 2 ;;
          --discharge) discharge="${2:-}"; shift 2 ;;
          --refs) refs="${2:-}"; shift 2 ;;
          --supersedes) supersedes="${2:-}"; shift 2 ;;
          --*)
            echo "led work open: REFUSED -- unrecognized flag '$1'." >&2
            echo "  led work open <slug> <title...> accepts only: --parent <parent-slug>," >&2
            echo "  --discharge composite, --refs <ref>, --supersedes <id>. An unrecognized" >&2
            echo "  --flag used to be silently concatenated into the title text instead of" >&2
            echo "  erroring (ledger item led-work-open-refs-swallowed: 27/27 work_opened rows" >&2
            echo "  in an adopting deployment had NULL refs because '--refs row:N' landed in" >&2
            echo "  work_title)." >&2
            echo "  NOTHING was written. Fix the flag name, or drop it if it was meant as" >&2
            echo "  ordinary title text (title text containing '--' inside a longer word is" >&2
            echo "  never affected by this check -- only a standalone --* argument is)." >&2
            exit 1
            ;;
          *) args+=("$1"); shift ;;
        esac
      done
      set -- "${args[@]}"
      if [ $# -lt 2 ]; then
        echo "usage: led work open <slug> <title...> [--parent <parent-slug>] [--discharge composite] [--refs <ref>] [--supersedes <id>]" >&2
        echo "       refused if <slug> already has an opening act (validate_work_item(): one" >&2
        echo "       opening act per slug -- the Q5 defect made unrepresentable, never a silent" >&2
        echo "       duplicate)" >&2
        echo "       set LED_ACTOR=<principal-name> to open as a registered principal other" >&2
        echo "       than the default connection principal" >&2
        echo "       --parent <parent-slug> types this item as a CHILD of an already-opened work" >&2
        echo "       item (kernel/lineage/s28-work-parent-edge.sql). REFUSED at construction if" >&2
        echo "       <parent-slug> has no opening act (dangling parents ARE refused here, unlike" >&2
        echo "       'led work depends's antecedent, which is deliberately left unrefused, s22)," >&2
        echo "       and refused if honoring it would create a cycle. Requires this world's" >&2
        echo "       kernel to carry s28 -- omit --parent on a pre-s28 kernel." >&2
        echo "       --discharge composite types this item as a COMPOSITE whose discharge is" >&2
        echo "       DERIVED from its children's obligation tree (kernel/lineage/" >&2
        echo "       s33-composite-discharge.sql) -- every future close of <slug> becomes" >&2
        echo "       STRICT-BY-TYPE (no --strict flag needed). Requires this world's kernel to" >&2
        echo "       carry s33 -- omit --discharge on a pre-s33 kernel." >&2
        echo "       --refs <ref> lands on ledger.refs (base schema; always available) -- the" >&2
        echo "       CONVENTION for citing an antecedent ledger row, e.g. --refs row:<id>." >&2
        echo "       --supersedes <id> lands on ledger.supersedes (base schema; always" >&2
        echo "       available) -- this opening act retracts ledger row <id> from current truth" >&2
        echo "       (kernel/lineage/s31-supersession-uniform-retraction.sql: uniform across" >&2
        echo "       every kind). If <id> is itself a work_opened row, its slug is PERMANENTLY" >&2
        echo "       BURNED, reinstatement-free -- <slug> here must be a NEW, different slug." >&2
        exit 1
      fi
      if [ -n "$discharge" ] && [ "$discharge" != "composite" ]; then
        echo "led work open: REFUSED -- --discharge accepts exactly one value: composite" >&2
        echo "  (kernel/lineage/s33-composite-discharge.sql's closed vocabulary; got '${discharge}')." >&2
        exit 1
      fi
      slug="$1"; shift
      title="$*"
      has_parent_col=$(psql -h "$PGHOST" -d "$PGDB" -tAq -v schema="$SCHEMA" <<SQL
        SELECT EXISTS (SELECT 1 FROM information_schema.columns
                       WHERE table_schema = :'schema' AND table_name = 'ledger'
                         AND column_name = 'work_parent');
SQL
      )
      if [ -n "$parent" ] && [ "$has_parent_col" != "t" ]; then
        echo "led work open: REFUSED -- --parent requires kernel/lineage/s28-work-parent-edge.sql" >&2
        echo "  applied to this project's schema (work_parent column not found on" >&2
        echo "  ${SCHEMA}.ledger -- this world's kernel predates s28). Omit --parent, or apply" >&2
        echo "  s28 to this schema as a maintainer act (ORCH-OPERATING-CARD.md's kernel-delta" >&2
        echo "  decision tree)." >&2
        exit 1
      fi
      has_discharge_col=$(psql -h "$PGHOST" -d "$PGDB" -tAq -v schema="$SCHEMA" <<SQL
        SELECT EXISTS (SELECT 1 FROM information_schema.columns
                       WHERE table_schema = :'schema' AND table_name = 'ledger'
                         AND column_name = 'work_discharge');
SQL
      )
      if [ -n "$discharge" ] && [ "$has_discharge_col" != "t" ]; then
        echo "led work open: REFUSED -- --discharge requires" >&2
        echo "  kernel/lineage/s33-composite-discharge.sql applied to this project's schema" >&2
        echo "  (work_discharge column not found on ${SCHEMA}.ledger -- this world's kernel" >&2
        echo "  predates s33). Omit --discharge, or apply s33 to this schema as a maintainer" >&2
        echo "  act (ORCH-OPERATING-CARD.md's kernel-delta decision tree)." >&2
        exit 1
      fi
      # --supersedes ADVISORY (printed once, unconditionally on stderr, BEFORE the INSERT --
      # ledger item led-work-open-supersedes): the kernel (s31) enforces every consequence of a
      # supersedes write -- this text only TEACHES the operator what just happened, it never
      # gates the write (the flag is either present or absent; there is nothing to block on).
      if [ -n "$supersedes" ]; then
        echo "led work open: --supersedes ${supersedes} -- this opening act retracts ledger row" >&2
        echo "  ${supersedes} from current truth (kernel/lineage/s31-supersession-uniform-" >&2
        echo "  retraction.sql: supersession is UNIFORM across every kind, reinstatement-free)." >&2
        echo "  If row ${supersedes} was itself a work_opened row, ITS SLUG IS PERMANENTLY" >&2
        echo "  BURNED (s31 ratified fork 2, s28's cycle-vacuity induction) -- this new item" >&2
        echo "  must carry, and IS carrying, a different slug ('${slug}'). Any surviving" >&2
        echo "  edges/claims (work_claimed, work_depends_on, or a child's work_parent) that" >&2
        echo "  still cite the OLD slug are now orphaned (surfaced by 'led work violations'" >&2
        echo "  as orphaned_by_retraction, s31 Element 5) and must be RE-ISSUED against" >&2
        echo "  '${slug}' -- re-running 'led work claim'/'led work depends'/'led work open" >&2
        echo "  --parent' with the new slug, as appropriate. The kernel enforces the retraction" >&2
        echo "  and the slug burn; this text only teaches the consequence." >&2
        echo "  Once orphaned, answer each row with 'led work resolve-violation' (a typed," >&2
        echo "  reviewed disposition -- debt until answered, record forever, kernel/lineage/" >&2
        echo "  s37-violation-disposition.sql) rather than leaving it permanent debt; if this" >&2
        echo "  supersede is repairing a COMPOSITE parent with children, 'led work" >&2
        echo "  supersede-cascade' composes the same primitive over the whole direct-child set." >&2
