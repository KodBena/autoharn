def cmd_work_asof(cfg: bcc.ServedConfig, ts: str) -> int:
    """DISCLOSED PARTIAL PORT (see this file's own SCOPE comment for the full disclosure):
    reuses GET /rows/asof/{ts} -- the same supersession-filtered reconstruction asof-export.tmpl
    already serves -- filtered client-side to kind in work_opened/work_claimed/work_closed and
    reduced to latest-row-per-slug, exactly as legacy's own three CTEs do. Diverges from legacy
    in exactly one respect: this source route IS supersession-aware (a retracted work_opened row
    correctly disappears once its own retraction lands at-or-before <ts>), where legacy's raw
    event-replay never consults `supersedes` at all."""
    try:
        datetime.datetime.fromisoformat(ts)
    except ValueError:
        print(f"led work asof: REFUSED -- <timestamp> must be a valid ISO-8601 timestamp "
              f"(GET /rows/asof/{{ts}}'s own grammar, stricter than legacy's looser postgres-"
              f"timestamptz-cast acceptance); got {ts!r}.", file=sys.stderr)
        return 4
    print("note: asof is a RAW event-reconstruction (open/claimed/closed only), read through "
          "GET /rows/asof/{ts} -- supersession-aware, which is the one disclosed divergence "
          "from legacy's own raw-replay reconstruction (see this file's own SCOPE comment).",
          file=sys.stderr)
    rows = bcc.get_all_rows(cfg.base, f"/rows/asof/{ts}", cursor="after_id")
    opened: dict[str, dict] = {}
    claimed: dict[str, dict] = {}
    closed: dict[str, dict] = {}
    for r in rows:
        slug = r.get("work_slug")
        if slug is None:
            continue
        kind = r.get("kind")
        if kind == "work_opened":
            if slug not in opened or r["id"] > opened[slug]["id"]:
                opened[slug] = r
        elif kind == "work_claimed":
            if slug not in claimed or r["id"] > claimed[slug]["id"]:
                claimed[slug] = r
        elif kind == "work_closed":
            if slug not in closed or r["id"] > closed[slug]["id"]:
                closed[slug] = r
    for slug in sorted(opened):
        o = opened[slug]
        c = closed.get(slug)
        cl = claimed.get(slug)
        state = "closed" if c else ("claimed" if cl else "open")
        out = {"slug": slug, "title": o.get("work_title"), "state_asof": state,
               "resolution": c.get("work_resolution") if c else None,
               "witness": c.get("work_witness") if c else None,
               "claimant": cl.get("actor") if cl else None}
        print(json.dumps(out, sort_keys=True))
    return 0


