_MISSING = object()  # sentinel distinguishing "flag was the last token" from "flag's value was
                     # itself an empty string" -- both are refused identically below (row 1173
                     # round-2 faithfulness finding), but the sentinel keeps that refusal's own
                     # condition (`not val`) honest about which case it is: `next(it, "")` could
                     # not tell the two apart at all (both silently read as "").


def _parse_principal_flags(argv: list[str], flag_names: set[str],
                            verb: str) -> tuple[list[str], dict[str, str]] | None:
    """A tiny shared flag/positional splitter (every `led principal *` sub-verb's own grammar:
    `--flag value` pairs from `flag_names`, everything else positional, in any order -- mirrors
    legacy-led.tmpl's own per-verb `while [ $# -gt 0 ]; case "$1" in --xxx) ...` loops). An
    unrecognized `--*` token is left in the RETURNED positionals (the caller decides -- some
    verbs, e.g. suspend/revoke, fold unrecognized non-flag words into a free-text reason).

    ROW 1173 ROUND-2 FAITHFULNESS FINDING (SEVERE): a recognized flag with a MISSING or EMPTY
    value is now REFUSED here, at the class (both parsers), not left to each call site to
    notice. Before this fix, `flags[tok] = next(it, "")` silently produced `""` for BOTH "the
    flag was the last token" and "the flag's value was itself an empty string" -- and at least
    one call site (`declare-standing`/`undeclare-standing`'s own `db_role = flags.get(...) or
    cfg.record.role`) treated that `""` as "value omitted, use the default", so `led principal
    declare-standing <name> --db-role` (trailing, no value) SILENTLY WROTE a real standing row
    for the DEFAULT role -- not a refusal, not even the value the operator (mis)typed, a
    DIFFERENT one, live-witnessed on a scratch world before this fix. DISCLOSED, not a
    regression: legacy's own behavior on the identical input was an accidental `shift 2`-past-
    end crash under `set -euo pipefail` (exit 1, nothing written, no teach-text) -- this fix
    trades that accidental crash for a DELIBERATE refusal with the SAME observable contract
    (nonzero exit, zero writes) plus teaching where legacy had a bare stack trace. A wrong
    write beats a crash for badness; this closes the gap without reopening it as some OTHER
    silent substitution."""
    pos: list[str] = []
    flags: dict[str, str] = {}
    it = iter(argv)
    for tok in it:
        if tok in flag_names:
            val = next(it, _MISSING)
            if val is _MISSING or val == "":
                print(f"led principal {verb}: REFUSED -- flag '{tok}' requires a non-empty "
                      f"value.", file=sys.stderr)
                return None
            flags[tok] = val
        else:
            pos.append(tok)
    return pos, flags


def _parse_principal_flags_strict(argv: list[str], flag_names: set[str], n_positional: int,
                                   verb: str) -> tuple[list[str], dict[str, str]] | None:
    """STRICT variant (row 1173 finding 5, the leftover-token refusal): takes exactly
    `n_positional` leading tokens as positionals VERBATIM (mirrors legacy-led.tmpl's own fixed
    `shift N` ahead of each per-verb flag loop), then walks the remainder recognizing ONLY
    `flag_names` -- ANY other token (an unrecognized flag OR a stray extra positional) is
    REFUSED immediately, byte-similar to legacy's own catch-all
    `*) echo REFUSED -- unrecognized argument '$1'.; exit 1 ;;`. Used by the TEN `led principal
    *` sub-verbs whose payload is built from a fixed positional shape (declare-standing/
    undeclare-standing/relate/unrelate/bind-role/release-role/bind-key/revoke-key/grant-
    competence/withdraw-competence) -- contrast suspend/revoke/lift-suspension, which fold any
    non-flag remainder into a free-text reason and stay on the permissive `_parse_principal_
    flags` above (legacy's own grammar: those three verbs never refuse on a stray word, they
    absorb it into `$reason`). Returns None (having printed REFUSED) on a violation.

    Also refuses a recognized flag's MISSING/EMPTY value -- see `_parse_principal_flags`'s own
    docstring above (row 1173 round-2 SEVERE finding); this strict variant is where the finding
    was actually caught (`declare-standing`/`undeclare-standing` both parse `--db-role` here)."""
    pos = list(argv[:n_positional])
    rest = argv[n_positional:]
    flags: dict[str, str] = {}
    it = iter(rest)
    for tok in it:
        if tok in flag_names:
            val = next(it, _MISSING)
            if val is _MISSING or val == "":
                print(f"led principal {verb}: REFUSED -- flag '{tok}' requires a non-empty "
                      f"value.", file=sys.stderr)
                return None
            flags[tok] = val
        else:
            print(f"led principal {verb}: REFUSED -- unrecognized argument '{tok}'.",
                  file=sys.stderr)
            return None
    return pos, flags


def _refuse_other_shared_flags(verb_label: str, shared: dict[str, str]) -> int | None:
    """Mirrors legacy-led.tmpl's own `refuse_shared_flags_for_principal_verb` (row 1173 finding
    1, the flag-before-verb grammar, ported faithfully): `register-principal` and every `led
    principal *` sub-verb HONOR --event-time (the s24 late-entry declaration, the one shared
    channel legacy threads through to these verbs) and REFUSE every OTHER shared channel
    (-f/-e/--supersedes/--amends/--amends-scope/--answers/--refs/--concern/--evidence/
    --confidence) BY NAME -- these verbs' row content is built entirely from typed arguments,
    and a supersession, where one of them needs it, is that verb's OWN trailing --supersedes
    flag (placed AFTER the subcommand words), never the shared, front-anchored one -- two parse
    points for one column would be exactly the silently-diverging duplicate this file's actor
    resolution already exists to foreclose. Returns 1 (having printed REFUSED) on a violation,
    None when the combination is clean."""
    bad = sorted(f for f in shared if f != "--event-time")
    if bad:
        print(f"led {verb_label}: REFUSED -- the shared flag(s) {' '.join(bad)} are not "
              f"honored by this verb and would otherwise be silently dropped (mirrors legacy-"
              f"led.tmpl's own refuse_shared_flags_for_principal_verb -- the same silent-drop "
              f"shape that once swallowed LED_ACTOR). This verb's row content is built from its "
              f"own typed arguments; only --event-time (the s24 late-entry declaration) rides "
              f"through. Where a supersession is needed, it is that verb's OWN trailing "
              f"--supersedes flag, placed AFTER the subcommand words -- not the shared one.",
              file=sys.stderr)
        return 1
    return None


def cmd_principal(cfg: bcc.ServedConfig, argv: list[str], shared: dict[str, str]) -> int:
    sub = argv[0] if argv else ""
    rest = argv[1:]
    # row 1173 finding 1 (flag-before-verb grammar): --event-time is now parsed ONCE, front-
    # anchored, by main()'s own shared-flag strip -- passed down here, never re-parsed per-verb.
    # Every OTHER shared channel is refused by name here (legacy's own
    # refuse_shared_flags_for_principal_verb), before any capability probe or write.
    rc = _refuse_other_shared_flags(f"principal {sub}".rstrip(), shared)
    if rc is not None:
        return rc
    event_time = shared.get("--event-time")
    actor = _resolve_actor(cfg)

    def refuse_unregistered(verb: str, name: str) -> int:
        print(f"led principal {verb}: REFUSED -- '{name}' is not a registered principal.",
              file=sys.stderr)
        return 1

    def refuse_write_boundary(verb: str) -> int:
        print(f"led principal {verb}: REFUSED -- 'write-boundary' is the kernel write "
              f"boundary's own recording identity (kernel/lineage/s43-typed-verdict-write-"
              f"boundary.sql Element 6): every write_refused row is authored by it, so "
              f"{('suspending' if verb == 'suspend' else 'revoking')} it bricks refusal "
              f"recording -- every later refusal would abort loudly instead of landing as a "
              f"committed record. This guard is CLI-grade; if you genuinely mean to retire "
              f"this world's refusal recorder, that is a maintainer decision, not a verb.",
              file=sys.stderr)
        return 1

    if sub in ("declare-standing", "undeclare-standing", "suspend", "lift-suspension", "revoke"):
        caps = _health_capabilities(cfg)
        has_s45 = bool(caps.get("s45_standing_lifecycle"))
        by_name = _principals_by_name(cfg)

        if sub == "declare-standing":
            parsed = _parse_principal_flags_strict(rest, {"--db-role"}, 1, sub)
            if parsed is None:
                return 1
            pos, flags = parsed
            if not pos:
                _principal_usage()
                return 1
            name = pos[0]
            db_role = flags.get("--db-role") or cfg.record.role
            pid = by_name.get(name)
            if pid is None:
                return refuse_unregistered(sub, name)
            old = _latest_current(cfg, "principal_standing_declared", principal_db_role=db_role,
                                   **({"principal_binding_active": True} if has_s45 else {}))
            old_id = old["id"] if old else None
            if old_id:
                print(f"led principal declare-standing: rotating -- superseding standing "
                      f"declaration row {old_id} for role '{db_role}'.")
            stmt = (f"database role '{db_role}' speaks for principal '{name}' by default "
                    f"(standing declaration)")
            payload = _build_or_refuse(sub, StandingDeclaredPayload, subject=pid, db_role=db_role,
                                        active=(True if has_s45 else None), supersedes=old_id,
                                        event_time=event_time)
            if payload is None:
                return 1
            return _write_principal(cfg, "principal_standing_declared", stmt, actor, payload)

        if sub == "undeclare-standing":
            parsed = _parse_principal_flags_strict(rest, {"--db-role"}, 0, sub)
            if parsed is None:
                return 1
            _pos, flags = parsed
            db_role = flags.get("--db-role") or cfg.record.role
            if not has_s45:
                print("led principal undeclare-standing: REFUSED -- this world's kernel "
                      "predates s45-standing-lifecycle (kernel/lineage/s45-standing-lifecycle."
                      "sql): standing declarations there cannot be retracted (s40 C8's own "
                      "disclosed limit).", file=sys.stderr)
                return 1
            gov = _latest_current(cfg, "principal_standing_declared", principal_db_role=db_role,
                                   principal_binding_active=True)
            if gov is None:
                print(f"led principal undeclare-standing: REFUSED -- role '{db_role}' has no "
                      f"in-force standing declaration -- nothing to unbind.", file=sys.stderr)
                return 1
            stmt = (f"database role '{db_role}' unbound -- standing declaration retracted "
                    f"(role reverts to undeclared)")
            payload = _build_or_refuse(sub, StandingDeclaredPayload, subject=gov["principal_subject"],
                                        db_role=db_role, active=False, supersedes=gov["id"],
                                        event_time=event_time)
            if payload is None:
                return 1
            rc = _write_principal(cfg, "principal_standing_declared", stmt, actor, payload)
            if rc == 0:
                print(f"led principal undeclare-standing: role '{db_role}' unbound "
                      f"(superseded declaration row {gov['id']}).")
                print("  This unbind is FORWARD-ONLY: rows already written under the outgoing "
                      "declaration stay attributed to their outgoing principal forever.",
                      file=sys.stderr)
            return rc

        if sub == "suspend":
            parsed = _parse_principal_flags(rest, {"--supersedes"}, sub)
            if parsed is None:
                return 1
            pos, flags = parsed
            if not pos or pos[0].startswith("--"):
                _principal_usage()
                return 1
            name, reason = pos[0], " ".join(pos[1:])
            sup_id = flags.get("--supersedes")
            if name == "write-boundary":
                return refuse_write_boundary("suspend")
            if sup_id and not has_s45:
                print("led principal suspend: REFUSED -- --supersedes (a rationale-correcting "
                      "re-suspend) needs an s45 kernel (kernel/lineage/s45-standing-lifecycle."
                      "sql); this world's kernel predates it.", file=sys.stderr)
                return 1
            pid = by_name.get(name)
            if pid is None:
                return refuse_unregistered(sub, name)
            if has_s45:
                cur = _latest_current(cfg, "principal_suspended", principal_subject=pid,
                                       principal_binding_active=True)
                cur_id = cur["id"] if cur else None
                if cur_id and str(cur_id) != str(sup_id):
                    print(f"led principal suspend: REFUSED -- '{name}' already carries an "
                          f"in-force suspension (row {cur_id}); no duplicate active truth. To "
                          f"correct its rationale, re-suspend WITH --supersedes {cur_id}; to "
                          f"lift it instead: ./led principal lift-suspension {name}",
                          file=sys.stderr)
                    return 1
                if sup_id and str(cur_id) != str(sup_id):
                    print(f"led principal suspend: REFUSED -- --supersedes '{sup_id}' is not "
                          f"the in-force suspension for '{name}' (the current one is "
                          f"{cur_id or 'none'}).", file=sys.stderr)
                    return 1
            stmt = f"principal '{name}' suspended -- standing withdrawn"
            if reason:
                stmt += f": {reason}"
            payload = _build_or_refuse(sub, StandingLifecyclePayload, subject=pid,
                                        active=(True if has_s45 else None),
                                        supersedes=(sup_id if has_s45 else None),
                                        event_time=event_time)
            if payload is None:
                return 1
            return _write_principal(cfg, "principal_suspended", stmt, actor, payload)

        if sub == "lift-suspension":
            parsed = _parse_principal_flags(rest, set(), sub)
            if parsed is None:
                return 1
            pos, flags = parsed
            if not pos:
                print("usage: led principal lift-suspension <name> [reason...]", file=sys.stderr)
                return 1
            name, reason = pos[0], " ".join(pos[1:])
            if not has_s45:
                print("led principal lift-suspension: REFUSED -- this world's kernel predates "
                      "s45-standing-lifecycle (kernel/lineage/s45-standing-lifecycle.sql): "
                      "suspensions there cannot be lifted (s40 Element 4's own disclosed v1 "
                      "limit).", file=sys.stderr)
                return 1
            pid = by_name.get(name)
            if pid is None:
                return refuse_unregistered(sub, name)
            cur = _latest_current(cfg, "principal_suspended", principal_subject=pid,
                                   principal_binding_active=True)
            if cur is None:
                print(f"led principal lift-suspension: REFUSED -- principal '{name}' has no "
                      f"in-force suspension.", file=sys.stderr)
                return 1
            is_revoked = _latest_current(cfg, "principal_revoked", principal_subject=pid) is not None
            stmt = f"principal '{name}' suspension lifted"
            if reason:
                stmt += f": {reason}"
            payload = _build_or_refuse(sub, StandingLifecyclePayload, subject=pid, active=False,
                                        supersedes=cur["id"], event_time=event_time)
            if payload is None:
                return 1
            rc = _write_principal(cfg, "principal_suspended", stmt, actor, payload)
            if rc == 0 and is_revoked:
                print(f"led principal lift-suspension: note -- '{name}' is ALSO revoked; "
                      f"standing remains 'revoked' (revoked dominates suspended, s40 §3.4).",
                      file=sys.stderr)
            return rc

        if sub == "revoke":
            parsed = _parse_principal_flags(rest, set(), sub)
            if parsed is None:
                return 1
            pos, flags = parsed
            if not pos or pos[0].startswith("--"):
                _principal_usage()
                return 1
            name, reason = pos[0], " ".join(pos[1:])
            if name == "write-boundary":
                return refuse_write_boundary("revoke")
            pid = by_name.get(name)
            if pid is None:
                return refuse_unregistered(sub, name)
            stmt = f"principal '{name}' revoked -- standing withdrawn"
            if reason:
                stmt += f": {reason}"
            payload = _build_or_refuse(sub, StandingLifecyclePayload, subject=pid,
                                        event_time=event_time)
            if payload is None:
                return 1
            return _write_principal(cfg, "principal_revoked", stmt, actor, payload)

    if sub in ("relate", "unrelate", "bind-role", "release-role", "bind-key", "revoke-key",
               "grant-competence", "withdraw-competence"):
        caps = _health_capabilities(cfg)
        if not caps.get("s41_identity"):
            print(f"led principal {sub}: REFUSED -- this world's kernel carries s40 but not "
                  f"s41 (no principal_binding_active column on ledger): binding/relation "
                  f"events have no typed home here. These verbs work on a world whose birth "
                  f"chain carries kernel/lineage/s41-principal-bindings-and-relations.sql.",
                  file=sys.stderr)
            return 1
        by_name = _principals_by_name(cfg)

        if sub in ("relate", "unrelate"):
            parsed = _parse_principal_flags_strict(rest, {"--supersedes"}, 3, sub)
            if parsed is None:
                return 1
            pos, flags = parsed
            sup_id = flags.get("--supersedes")
            if len(pos) < 3:
                _principal_usage()
                return 1
            subj_name, rel, obj_name = pos[0], pos[1], pos[2]
            if rel not in ("acts-for", "dispatched-by", "same-natural-person", "succeeds"):
                print(f"led principal {sub}: REFUSED -- '{rel}' is not a relation (closed "
                      f"vocabulary: acts-for, dispatched-by, same-natural-person, succeeds -- "
                      f"s41 D-2).", file=sys.stderr)
                return 1
            subj_id, obj_id = by_name.get(subj_name), by_name.get(obj_name)
            if subj_id is None or obj_id is None:
                print(f"led principal {sub}: REFUSED -- both endpoints must be registered "
                      f"principals ('{subj_name}' -> id {subj_id}, '{obj_name}' -> id {obj_id}).",
                      file=sys.stderr)
                return 1
            if subj_id == obj_id:
                print(f"led principal {sub}: REFUSED -- a principal cannot stand in relation "
                      f"'{rel}' to itself (s41 D-3's self-edge refusal).", file=sys.stderr)
                return 1
            if rel == "same-natural-person" and subj_id > obj_id:
                subj_id, obj_id = obj_id, subj_id
                subj_name, obj_name = obj_name, subj_name
                print(f"led principal {sub}: note -- same-natural-person is symmetric; "
                      f"canonicalizing to subject='{subj_name}' (lower id), object='{obj_name}'.")
            cur = _latest_current(cfg, "principal_relation_asserted", principal_subject=subj_id,
                                   principal_object=obj_id, principal_relation=rel,
                                   principal_binding_active=True)
            cur_id = cur["id"] if cur else None
            if sub == "relate":
                if cur_id:
                    print(f"led principal relate: REFUSED -- an active '{rel}' assertion "
                          f"already exists for this exact pair (row {cur_id}); no duplicate "
                          f"active truth. To retract it: ./led principal unrelate {subj_name} "
                          f"{rel} {obj_name} --supersedes {cur_id}", file=sys.stderr)
                    return 1
                stmt = f"principal '{subj_name}' {rel} principal '{obj_name}' (relation asserted)"
                payload = _build_or_refuse(sub, RelationPayload, subject=subj_id, relation=rel,
                                            obj=obj_id, active=True, event_time=event_time)
                if payload is None:
                    return 1
                return _write_principal(cfg, "principal_relation_asserted", stmt, actor, payload)
            if not sup_id:
                print("led principal unrelate: REFUSED -- --supersedes <old-row-id> is "
                      "mandatory.", file=sys.stderr)
                return 1
            if str(cur_id) != str(sup_id):
                print(f"led principal unrelate: REFUSED -- row '{sup_id}' is not the active "
                      f"'{rel}' assertion for '{subj_name}' -> '{obj_name}' (the view shows "
                      f"{cur_id or 'none'}).", file=sys.stderr)
                return 1
            stmt = f"relation retracted: principal '{subj_name}' no longer {rel} principal '{obj_name}'"
            payload = _build_or_refuse(sub, RelationPayload, subject=subj_id, relation=rel,
                                        obj=obj_id, active=False, supersedes=sup_id,
                                        event_time=event_time)
            if payload is None:
                return 1
            return _write_principal(cfg, "principal_relation_asserted", stmt, actor, payload)

        if sub in ("bind-role", "release-role"):
            parsed = _parse_principal_flags_strict(rest, {"--role", "--supersedes"}, 1, sub)
            if parsed is None:
                return 1
            pos, flags = parsed
            role_name = flags.get("--role", "")
            sup_id = flags.get("--supersedes")
            if not pos or not role_name:
                print(f"usage: led principal bind-role <name> --role \"<role-name>\"",
                      file=sys.stderr)
                print(f"       led principal release-role <name> --role \"<role-name>\" "
                      f"--supersedes <old-row-id>", file=sys.stderr)
                return 1
            name = pos[0]
            pid = by_name.get(name)
            if pid is None:
                return refuse_unregistered(sub, name)
            cur = _latest_current(cfg, "principal_role_bound", principal_subject=pid,
                                   principal_role_name=role_name, principal_binding_active=True)
            cur_id = cur["id"] if cur else None
            if sub == "bind-role":
                if sup_id:
                    print("led principal bind-role: REFUSED -- --supersedes belongs to "
                          "release-role (release first to rebind the same role).",
                          file=sys.stderr)
                    return 1
                if cur_id:
                    print(f"led principal bind-role: REFUSED -- '{name}' already holds an "
                          f"active '{role_name}' binding (row {cur_id}); no duplicate active "
                          f"truth.", file=sys.stderr)
                    return 1
                payload = _build_or_refuse(sub, RoleBindingPayload, subject=pid,
                                            role_name=role_name, active=True,
                                            event_time=event_time)
                if payload is None:
                    return 1
                return _write_principal(cfg, "principal_role_bound",
                                         f"principal '{name}' bound to role '{role_name}'",
                                         actor, payload)
            if not sup_id:
                print("led principal release-role: REFUSED -- --supersedes <old-row-id> is "
                      "mandatory.", file=sys.stderr)
                return 1
            if str(cur_id) != str(sup_id):
                print(f"led principal release-role: REFUSED -- row '{sup_id}' is not the "
                      f"active '{role_name}' binding for '{name}' (the view shows "
                      f"{cur_id or 'none'}).", file=sys.stderr)
                return 1
            payload = _build_or_refuse(sub, RoleBindingPayload, subject=pid, role_name=role_name,
                                        active=False, supersedes=sup_id, event_time=event_time)
            if payload is None:
                return 1
            return _write_principal(
                cfg, "principal_role_bound",
                f"role binding released: principal '{name}' no longer bound to role '{role_name}'",
                actor, payload)

        if sub in ("bind-key", "revoke-key"):
            parsed = _parse_principal_flags_strict(
                rest, {"--fingerprint", "--supersedes"}, 1, sub)
            if parsed is None:
                return 1
            pos, flags = parsed
            fp = flags.get("--fingerprint", "")
            sup_id = flags.get("--supersedes")
            if not pos or not fp:
                print("usage: led principal bind-key <name> --fingerprint \"<fp>\"",
                      file=sys.stderr)
                print("       led principal revoke-key <name> --fingerprint \"<fp>\" "
                      "--supersedes <old-row-id>", file=sys.stderr)
                return 1
            name = pos[0]
            pid = by_name.get(name)
            if pid is None:
                return refuse_unregistered(sub, name)
            cur = _latest_current(cfg, "principal_key_bound", principal_subject=pid,
                                   principal_key_fingerprint=fp, principal_binding_active=True)
            cur_id = cur["id"] if cur else None
            if sub == "bind-key":
                if cur_id:
                    print(f"led principal bind-key: REFUSED -- this exact fingerprint is "
                          f"already actively bound to '{name}' (row {cur_id}); no duplicate "
                          f"active truth.", file=sys.stderr)
                    return 1
                payload = _build_or_refuse(sub, KeyBindingPayload, subject=pid, fingerprint=fp,
                                            active=True, event_time=event_time)
                if payload is None:
                    return 1
                return _write_principal(cfg, "principal_key_bound",
                                         f"OpenPGP key {fp} bound to principal '{name}'",
                                         actor, payload)
            if not sup_id:
                print("led principal revoke-key: REFUSED -- --supersedes <old-row-id> is "
                      "mandatory.", file=sys.stderr)
                return 1
            if str(cur_id) != str(sup_id):
                print(f"led principal revoke-key: REFUSED -- row '{sup_id}' is not the active "
                      f"binding of this exact fingerprint for '{name}' (the view shows "
                      f"{cur_id or 'none'}).", file=sys.stderr)
                return 1
            payload = _build_or_refuse(sub, KeyBindingPayload, subject=pid, fingerprint=fp,
                                        active=False, supersedes=sup_id, event_time=event_time)
            if payload is None:
                return 1
            return _write_principal(
                cfg, "principal_key_bound",
                f"key binding revoked: OpenPGP key {fp} no longer bound to principal '{name}'",
                actor, payload)

        if sub in ("grant-competence", "withdraw-competence"):
            parsed = _parse_principal_flags_strict(
                rest, {"--activity", "--band", "--basis", "--supersedes"}, 1, sub)
            if parsed is None:
                return 1
            pos, flags = parsed
            activity = flags.get("--activity", "")
            band = flags.get("--band", "")
            basis = flags.get("--basis", "")
            sup_id = flags.get("--supersedes")
            if not pos or not activity:
                print("usage: led principal grant-competence <name> --activity \"<a>\" "
                      "--band \"<b>\" --basis \"<c>\" [--supersedes <old-row-id>]",
                      file=sys.stderr)
                print("       led principal withdraw-competence <name> --activity \"<a>\" "
                      "--supersedes <old-row-id>", file=sys.stderr)
                return 1
            name = pos[0]
            pid = by_name.get(name)
            if pid is None:
                return refuse_unregistered(sub, name)
            cur = _latest_current(cfg, "principal_competence_granted", principal_subject=pid,
                                   principal_competence_activity=activity,
                                   principal_binding_active=True)
            cur_id = cur["id"] if cur else None
            if sub == "grant-competence":
                if not band or not basis:
                    print("led principal grant-competence: REFUSED -- --band and --basis are "
                          "mandatory on a grant (G13's value fields; forbidden only on a "
                          "withdrawal).", file=sys.stderr)
                    return 1
                if cur_id and not sup_id:
                    print(f"led principal grant-competence: REFUSED -- an active grant "
                          f"already exists for '{name}' / activity '{activity}' (row "
                          f"{cur_id}); no duplicate active truth. To correct its band/basis, "
                          f"re-grant WITH --supersedes {cur_id}; to withdraw it: ./led "
                          f"principal withdraw-competence {name} --activity \"{activity}\" "
                          f"--supersedes {cur_id}", file=sys.stderr)
                    return 1
                if sup_id and str(cur_id) != str(sup_id):
                    print(f"led principal grant-competence: REFUSED -- --supersedes "
                          f"'{sup_id}' is not the active grant for '{name}' / activity "
                          f"'{activity}' (the view shows {cur_id or 'none'}).", file=sys.stderr)
                    return 1
                payload = _build_or_refuse(sub, CompetencePayload, subject=pid, activity=activity,
                                            active=True, band=band, basis=basis,
                                            supersedes=sup_id, event_time=event_time)
                if payload is None:
                    return 1
                return _write_principal(
                    cfg, "principal_competence_granted",
                    f"competence granted: principal '{name}' held competent for '{activity}' "
                    f"at band '{band}'", actor, payload)
            if band or basis:
                print("led principal withdraw-competence: REFUSED -- --band/--basis are VALUE "
                      "fields, forbidden on a withdrawal (the identity/value split, s41 D-1a).",
                      file=sys.stderr)
                return 1
            if not sup_id:
                print("led principal withdraw-competence: REFUSED -- --supersedes "
                      "<old-row-id> is mandatory.", file=sys.stderr)
                return 1
            if str(cur_id) != str(sup_id):
                print(f"led principal withdraw-competence: REFUSED -- row '{sup_id}' is not "
                      f"the active grant for '{name}' / activity '{activity}' (the view shows "
                      f"{cur_id or 'none'}).", file=sys.stderr)
                return 1
            payload = _build_or_refuse(sub, CompetencePayload, subject=pid, activity=activity,
                                        active=False, supersedes=sup_id, event_time=event_time)
            if payload is None:
                return 1
            return _write_principal(
                cfg, "principal_competence_granted",
                f"competence withdrawn: principal '{name}' no longer held competent for "
                f"'{activity}'", actor, payload)

    _principal_usage()
    return 1


# --- statement-grammar PRE-FLIGHT (legacy-led-retirement phase 1, ledger row 1149) -----------
# Ported byte-identically (same field lists, same regexes, same refusal text) off legacy-
# led.tmpl's own six intake validators -- resource:/estimate:/taxon:/interface:/review:/
# review-done: -- run ONLY on the generic <kind> <statement...> write path (cmd_generic below),
# exactly where legacy runs them, BEFORE the payload is ever built. This is a CLI-side
# convention check, not a kernel invariant: the kernel accepts any statement text under these
# kinds regardless, so a bypass of this CLI (e.g. `led --json`) is not narrowed by this at all.
_SLUG_RE = re.compile(r"^[a-z0-9][a-z0-9-]*$")


def _normalize_statement(raw: str) -> str:
    """Every run of \\r/\\n plus its following indentation collapsed to one space -- so a
    legitimate embedded newline (a paste reflowed by a terminal) is ACCEPTED rather than
    refused, identical convention to every legacy grammar block this ports."""
    return re.sub(r"[\r\n]+[ \t]*", " ", raw).strip()


def _check_resource(trimmed: str) -> bool:
    normalized = _normalize_statement(trimmed)
    body = normalized[len("resource:"):]
    parts = [p.strip() for p in body.split("|")]
    fields = ("NAME", "CLASS", "REACH", "WHAT-IT-PROVES", "GUIDANCE", "TIER")
    valid_classes = ("solver", "service", "backend", "binary", "library")

    def refuse(msg: str) -> bool:
        print(f"led: REFUSED -- malformed 'resource:' statement -- {msg}.", file=sys.stderr)
        print("  grammar (user-guide/USER-BLESSED-TABLE-TEMPLATE.md 'The statement grammars'):", file=sys.stderr)
        print("    resource: <NAME> | <CLASS> | <REACH> | <WHAT-IT-PROVES> | <GUIDANCE> | <TIER>", file=sys.stderr)
        print(f"  the six fields, in order: {', '.join(fields)}", file=sys.stderr)
        print(f"  CLASS must be one of: {' | '.join(valid_classes)}", file=sys.stderr)
        print("  TIER must be one of: available | blessed: <task-shape> | mandated: <task-shape> | "
              "forbidden: <task-shape>", file=sys.stderr)
        print(f"  received ({len(parts)} field(s), whitespace-normalized): {normalized}", file=sys.stderr)
        print("  NOTHING was written -- fix the statement and re-run.", file=sys.stderr)
        return False

    if len(parts) != len(fields):
        return refuse(f"expected exactly {len(fields)} '|'-separated fields, got {len(parts)}")
    _name, cls, _reach, _proves, _guidance, tier = parts
    if cls not in valid_classes:
        return refuse(f"CLASS field {cls!r} is not one of {valid_classes}")
    tier_prefixes = ("blessed:", "mandated:", "forbidden:")
    if not (tier == "available" or tier.startswith(tier_prefixes)):
        return refuse(f"TIER field {tier!r} is not 'available', 'blessed: <task-shape>', "
                      f"'mandated: <task-shape>', or 'forbidden: <task-shape>'")
    if tier.startswith(tier_prefixes) and not tier.split(":", 1)[1].strip():
        return refuse(f"TIER field {tier!r} names no <task-shape> after the colon")
