#!/usr/bin/env python3
"""led -- REBASED onto the boundary service (design/FABLE-BOUNDARY-MULTIPLEX-AND-CLI-REBASE-
SPEC.md §5, ratified ledger row 1631; design/FABLE-BOUNDARY-READ-SURFACE-SPEC.md, ratified row
1652). The direct-psql original is `legacy-led.tmpl` (`./legacy/led`) -- 5300+ lines covering a
much larger subcommand surface than this rebase reaches; see the "SCOPE, HONESTLY NAMED" section
below for exactly what does and does not run through the boundary here.

TRANSPORT: every read is a GET against `/rows/*`/`/views/*`/`/standing/principals` (paginated,
walked to completion client-side, spec's own "no server-side filter grammar" discipline); every
write is a POST against `/write/<surface>`, the kernel's own `write_verdict` passed through
byte-verbatim (spec §5: "same typed verdicts"). Exit codes follow `boundary_cli_client.py`'s own
convention (module docstring there): 0 kernel-accepted, 1 kernel-refused (byte-identical to the
legacy tool's own exit for this case), 3 boundary-refused, 4 boundary-unreachable/client error.

SCOPE, HONESTLY NAMED (what this rebase covers vs. what stays `./legacy/led`-only):
  COVERED:
    led --recent [N] / led current [N] / led show <id>      (reads, /rows/current, /rows/{id})
    led question-status / review-gap / stamp-distinctness / standing   (reads, /views/{view})
    led --json <ledger|review|registration|obligation> <file|->        (write, verbatim payload)
    led [flags] <kind> <statement...>          the generic write path -- LED_ACTOR resolution,
        -f/-e/--supersedes/--amends/--amends-scope/--answers/--refs/--concern/--evidence/
        --confidence/--event-time, and `decision`'s own --grade, ALL carried through to the
        payload exactly as the legacy tool's own flag set names them.
    led register-principal <name> <class>      (write, registration_write)
    led obligate <scope> <assigned-by> <obliged-actor>                 (write, obligation_write)
    led review <entry-id> <verdict> <independence> [--antecedent id] <statement...>  (write)
  NOT COVERED (refuses, teaching `./legacy/led`, never silently falling through):
    led obligate revoke <scope>    -- a raw, privilege-gated DELETE (has_table_privilege-checked
        in the legacy tool itself) -- STRUCTURALLY incompatible with the boundary's own charter
        ("the service NEVER falls back to raw INSERT [or any DML]; there is no code path that
        writes SQL DML", design/FABLE-LEDGER-BOUNDARY-SERVICE-SPEC.md §4) -- the SAME class of
        exclusion spec §5 itself names for `judge` ("not a ledger client in the boundary's
        sense"), applied here to one subcommand rather than a whole verb.
    led decomposition-review-status / led briefing / led work *   -- UNEXERCISED by this build,
        named rather than silently dropped (a real, disclosed scope boundary of THIS commission,
        not a structural incompatibility the way obligate-revoke is -- a future pass can extend
        `boundary_cli_client.py`'s coverage to them the same way this one did for the six
        surfaces above).
    the `review:`/`review-done:`/`resource:`/`estimate:`/`taxon:`/`interface:` statement-grammar
        PRE-FLIGHT validation the legacy generic path runs client-side before writing -- this is
        a CLI-side convention check, not a kernel invariant (the kernel accepts any statement
        text under those kinds regardless); omitted here as a disclosed, bounded narrowing, not
        a correctness gap.

Lazy imports banned (CLAUDE.md, 2026-07-02): every import is top-of-file."""
from __future__ import annotations

import argparse
import json
import os
import sys
from pathlib import Path

HERE = Path(__file__).resolve().parent
AUTOHARN = Path(os.environ.get("AUTOHARN", str(HERE / ".." / ".."))).resolve()
DEPLOYMENT_PATH = Path(os.environ.get("PICKUP_DEPLOYMENT", str(HERE / "deployment.json")))

sys.path.insert(0, str(AUTOHARN / "serving"))
sys.path.insert(0, str(AUTOHARN / "filing"))
try:
    import boundary_cli_client as bcc  # noqa: E402
except ImportError as _e:
    print(f"led: cannot import autoharn's serving/boundary_cli_client.py under "
          f"AUTOHARN={AUTOHARN} ({_e.__class__.__name__}: {_e})", file=sys.stderr)
    print("        set AUTOHARN=/path/to/autoharn, or place a sibling checkout at ../autoharn", file=sys.stderr)
    sys.exit(4)


def _load_config() -> bcc.ServedConfig:
    try:
        return bcc.load_served_config(DEPLOYMENT_PATH)
    except bcc.BoundaryClientError as e:
        print(f"led: {e}", file=sys.stderr)
        sys.exit(4)


def _resolve_actor(cfg: bcc.ServedConfig) -> int | None:
    """LED_ACTOR (env var, not a flag) -- byte-identical semantics to the legacy tool's own
    `resolve_actor()`: unset means the payload omits `actor` entirely (the kernel's own
    `set_actor` default-resolution applies); set to an unregistered name REFUSES with teach-text,
    never a silent fallback to the default principal."""
    name = os.environ.get("LED_ACTOR", "")
    if not name:
        return None
    rows = bcc.get_all_rows(cfg.base, "/standing/principals", cursor="after_id")
    for r in rows:
        if r.get("name") == name:
            return r["id"]
    print(f"led: REFUSED -- LED_ACTOR={name!r} is not a registered principal.", file=sys.stderr)
    print(f"  Register it first: ./led register-principal {name} <human|model|subagent|tool>", file=sys.stderr)
    sys.exit(1)


def cmd_json(cfg: bcc.ServedConfig, surface: str, source: str) -> int:
    if surface not in ("ledger", "review", "registration", "obligation"):
        print(f"led --json: REFUSED -- unrecognized surface {surface!r} (expected one of "
              f"ledger, review, registration, obligation)", file=sys.stderr)
        return 4
    text = sys.stdin.read() if source == "-" else Path(source).read_text(encoding="utf-8")
    try:
        payload = json.loads(text)
    except json.JSONDecodeError as e:
        print(f"led --json: REFUSED -- {source} is not valid JSON ({e})", file=sys.stderr)
        return 4
    if not isinstance(payload, dict):
        print(f"led --json: REFUSED -- payload must be a JSON object, got {type(payload).__name__}",
              file=sys.stderr)
        return 4
    return bcc.write_and_report(cfg.base, surface, payload)


def cmd_recent(cfg: bcc.ServedConfig, n: int, current_only: bool) -> int:
    """`led current [N]`: the legacy tool's own `ledger_current` reading, exactly. `led --recent
    [N]`: the legacy tool additionally walks the RAW ledger (superseded rows included, visibly
    marked) -- no boundary route serves the raw table (every route reads a KERNEL VIEW, spec §5's
    "no truth of its own" applied to routes too; a raw-ledger route is out of THIS amendment's own
    scope). Rather than silently narrowing --recent to look like `current`, this rebase says so
    loudly on stderr and serves the SAME `/rows/current` reading -- `./legacy/led --recent` is the
    byte-faithful original when the superseded-inclusive view is actually needed."""
    if not current_only:
        print("led --recent: NOTE -- this rebase's --recent reads /rows/current (in-force rows "
              "only, no raw-ledger route exists on the boundary) -- ./legacy/led --recent is "
              "byte-faithful if you need the superseded-inclusive raw read.", file=sys.stderr)
    rows = bcc.get_all_rows(cfg.base, "/rows/current", cursor="after_id")
    for r in sorted(rows, key=lambda r: -r["id"])[:n]:
        print(f"[{r['id']}] {r['kind']}: {r.get('statement', '')}")
    return 0


def cmd_show(cfg: bcc.ServedConfig, row_id: int) -> int:
    try:
        row = bcc.get_json(cfg.base, f"/rows/{row_id}")
    except bcc.BoundaryRefusal as e:
        if e.status == 404:
            print(f"led show: REFUSED -- no row {row_id}.", file=sys.stderr)
            print("  See 'led --recent [N]' or 'led current [N]' for ids that actually exist.", file=sys.stderr)
            return 1
        raise
    for k, v in row.items():
        if v is not None:
            print(f"{k:28s}: {v}")
    return 0


def cmd_view(cfg: bcc.ServedConfig, view: str, cursor: str) -> int:
    rows = bcc.get_all_rows(cfg.base, f"/views/{view}", cursor=cursor)
    for r in rows:
        print(json.dumps(r, sort_keys=True))
    return 0


def cmd_register_principal(cfg: bcc.ServedConfig, name: str, agent_class: str) -> int:
    actor = _resolve_actor(cfg)
    payload: dict = {"name": name, "agent_class": agent_class,
                      "purpose": f"registered via ./led register-principal"}
    if actor is not None:
        payload["actor"] = actor
    return bcc.write_and_report(cfg.base, "registration", payload)


def cmd_obligate(cfg: bcc.ServedConfig, scope: str, assigned_by_name: str, obliges_actor_name: str) -> int:
    rows = bcc.get_all_rows(cfg.base, "/standing/principals", cursor="after_id")
    by_name = {r["name"]: r["id"] for r in rows}
    missing = [n for n in (assigned_by_name, obliges_actor_name) if n not in by_name]
    if missing:
        print(f"led obligate: REFUSED -- unregistered principal name(s): {missing}", file=sys.stderr)
        return 1
    payload = {"scope": scope, "assigned_by": by_name[assigned_by_name],
               "obliges_actor": by_name[obliges_actor_name]}
    return bcc.write_and_report(cfg.base, "obligation", payload, echo_row_id=False)


def cmd_obligate_revoke(scope: str) -> int:
    print("led obligate revoke: NOT SERVED -- a raw, privilege-gated DELETE, structurally "
          "outside the boundary's own charter (it never issues SQL DML; design/"
          "FABLE-LEDGER-BOUNDARY-SERVICE-SPEC.md §4). Use ./legacy/led obligate revoke "
          f"{scope!r} instead.", file=sys.stderr)
    return 4


def cmd_review(cfg: bcc.ServedConfig, entry_id: int, verdict: str, independence: str,
               antecedent: int | None, statement: str) -> int:
    actor = _resolve_actor(cfg)
    # basis = statement, VERBATIM -- the legacy tool's own choice (bootstrap/templates/
    # legacy-led.tmpl's `led review` case: "basis \"$statement\"", no separate --basis flag on
    # THIS verb -- contrast `led principal grant-competence`'s own --basis, an unrelated flag on
    # a different verb this rebase does not cover).
    payload: dict = {"regards": entry_id, "statement": statement, "verdict": verdict,
                      "independence": independence, "basis": statement}
    if antecedent is not None:
        payload["antecedent"] = antecedent
    if actor is not None:
        payload["actor"] = actor
    return bcc.write_and_report(cfg.base, "review", payload)


def cmd_generic(cfg: bcc.ServedConfig, args: argparse.Namespace) -> int:
    payload: dict = {"kind": args.kind, "statement": " ".join(args.statement)}
    if args.files:
        payload["rationale"] = f"files: {args.files}"
    if args.enacts:
        payload["enacts"] = [int(x) for x in args.enacts.split(",") if x]
    if args.supersedes is not None:
        payload["supersedes"] = args.supersedes
    if args.amends is not None:
        payload["amends"] = args.amends
    if args.amends_scope is not None:
        payload["amends_scope"] = args.amends_scope
    if args.answers is not None:
        payload["answers"] = args.answers
    if args.refs is not None:
        payload["refs"] = args.refs
    if args.concern is not None:
        payload["concern"] = args.concern
    if args.evidence is not None:
        payload["evidence"] = args.evidence
    if args.confidence is not None:
        payload["confidence"] = args.confidence
    if args.event_time is not None:
        payload["event_declared_ts"] = args.event_time
    if args.kind == "decision" and args.grade is not None:
        payload["decision_grade"] = args.grade
    actor = _resolve_actor(cfg)
    if actor is not None:
        payload["actor"] = actor
    return bcc.write_and_report(cfg.base, "ledger", payload)


def main(argv: list[str]) -> int:
    if argv and argv[0] in ("--help", "-h", "help"):
        print(__doc__)
        return 0
    cfg = _load_config()

    if argv and argv[0] == "--json":
        if len(argv) != 3:
            print("usage: led --json <ledger|review|registration|obligation> <file|->", file=sys.stderr)
            return 4
        return cmd_json(cfg, argv[1], argv[2])

    if argv and argv[0] == "--recent":
        n = int(argv[1]) if len(argv) > 1 else 10
        return cmd_recent(cfg, n, current_only=False)
    if argv and argv[0] == "current":
        n = int(argv[1]) if len(argv) > 1 else 10
        return cmd_recent(cfg, n, current_only=True)
    if argv and argv[0] == "show":
        if len(argv) != 2 or not argv[1].isdigit():
            print("usage: led show <id>", file=sys.stderr)
            return 4
        return cmd_show(cfg, int(argv[1]))
    if argv and argv[0] == "question-status":
        return cmd_view(cfg, "question_status", "after_id")
    if argv and argv[0] == "review-gap":
        return cmd_view(cfg, "review_gap", "after_id")
    if argv and argv[0] == "stamp-distinctness":
        return cmd_view(cfg, "review_stamp_distinctness", "after_id")
    if argv and argv[0] == "standing":
        return cmd_view(cfg, "standing_decisions", "after_id")
    if argv and argv[0] == "register-principal":
        if len(argv) != 3:
            print("usage: led register-principal <name> <class>", file=sys.stderr)
            return 4
        return cmd_register_principal(cfg, argv[1], argv[2])
    if argv and argv[0] == "obligate":
        if len(argv) >= 2 and argv[1] == "revoke":
            if len(argv) != 3:
                print("usage: led obligate revoke <scope>", file=sys.stderr)
                return 4
            return cmd_obligate_revoke(argv[2])
        if len(argv) != 4:
            print("usage: led obligate <scope> <assigned-by-principal> <obliged-actor-principal>", file=sys.stderr)
            return 4
        return cmd_obligate(cfg, argv[1], argv[2], argv[3])
    if argv and argv[0] == "review":
        p = argparse.ArgumentParser(prog="led review")
        p.add_argument("entry_id", type=int)
        p.add_argument("verdict")
        p.add_argument("independence")
        p.add_argument("--antecedent", type=int, default=None)
        p.add_argument("statement", nargs="+")
        ns = p.parse_args(argv[1:])
        return cmd_review(cfg, ns.entry_id, ns.verdict, ns.independence, ns.antecedent,
                           " ".join(ns.statement))
    if argv and argv[0] in ("decomposition-review-status", "briefing") or (argv and argv[0] == "work"):
        print(f"led {argv[0]}: UNEXERCISED by the boundary rebase (design/"
              f"FABLE-BOUNDARY-MULTIPLEX-AND-CLI-REBASE-SPEC.md §5) -- named, not silently "
              f"dropped; use ./legacy/led {' '.join(argv)} instead.", file=sys.stderr)
        return 4

    # The generic <kind> <statement...> write path, flags consumed before the positional kind.
    p = argparse.ArgumentParser(prog="led", add_help=False)
    p.add_argument("-f", dest="files", default=None)
    p.add_argument("-e", dest="enacts", default=None)
    p.add_argument("--supersedes", type=int, default=None)
    p.add_argument("--amends", type=int, default=None)
    p.add_argument("--amends-scope", dest="amends_scope", default=None)
    p.add_argument("--answers", type=int, default=None)
    p.add_argument("--refs", default=None)
    p.add_argument("--concern", default=None)
    p.add_argument("--evidence", default=None)
    p.add_argument("--confidence", default=None)
    p.add_argument("--event-time", dest="event_time", default=None)
    p.add_argument("--grade", default=None)
    p.add_argument("kind")
    p.add_argument("statement", nargs="+")
    try:
        ns = p.parse_args(argv)
    except SystemExit:
        return 4
    return cmd_generic(cfg, ns)


if __name__ == "__main__":
    try:
        sys.exit(main(sys.argv[1:]))
    except (bcc.BoundaryRefusal, bcc.BoundaryUnreachable, bcc.BoundaryClientError) as e:
        sys.exit(bcc.report_boundary_exception("led", e))
