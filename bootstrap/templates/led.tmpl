def _current_row(cfg: bcc.ServedConfig, kind: str, slug: str) -> dict | None:
    """Walks GET /rows/current (the in-force, supersession-filtered read) looking for the ONE
    row of `kind` whose work_slug is `slug` -- validate_work_item() (s22+) admits at most one
    CURRENT such row per (kind, slug) for work_opened; used the same way for work_claimed/
    work_closed (also at-most-one-current in ordinary operation). Returns None if no match."""
    for r in bcc.get_all_rows(cfg.base, "/rows/current", cursor="after_id"):
        if r.get("kind") == kind and r.get("work_slug") == slug:
            return r
    return None


def _work_item_current_row(cfg: bcc.ServedConfig, slug: str) -> dict | None:
    for r in bcc.get_all_rows(cfg.base, "/views/work_item_current", cursor="after_slug"):
        if r.get("slug") == slug:
            return r
    return None


def _violations_for_slug(cfg: bcc.ServedConfig, slug: str, violation: str) -> list[int]:
    """Sorted target_id list matching (slug, violation) off GET /views/work_item_violations --
    the same view `led work violations` already reads, filtered client-side (no server-side
    filter grammar, spec's own discipline)."""
    rows = bcc.get_all_rows(cfg.base, "/views/work_item_violations", cursor="after_slug")
    return sorted({r["target_id"] for r in rows
                   if r.get("slug") == slug and r.get("violation") == violation
                   and r.get("target_id") is not None})


def cmd_work_resolve_violation(cfg: bcc.ServedConfig, argv: list[str]) -> int:
    """Ported off legacy-led.tmpl's `work resolve-violation` (kernel/lineage/
    s37-violation-disposition.sql). Class is RE-DERIVED against work_item_violations (or, on
    the --supersedes correction path, against the disposition row being corrected) at write
    time -- never parsed from display text, exactly legacy's own discipline."""
    witness = review_witness = supersedes = class_flag = None
    review_deferred = False
    args: list[str] = []
    it = iter(argv)
    for tok in it:
        if tok == "--witness":
            witness = next(it, None)
        elif tok == "--review-witness":
            review_witness = next(it, None)
        elif tok == "--review-deferred":
            review_deferred = True
        elif tok == "--supersedes":
            supersedes = next(it, None)
        elif tok == "--class":
            class_flag = next(it, None)
        elif tok.startswith("--"):
            print(f"led work resolve-violation: REFUSED -- unrecognized flag '{tok}'.", file=sys.stderr)
            print("  led work resolve-violation <violating-act-id> <reissued|retired> \"<basis>\"", file=sys.stderr)
            print("    accepts only: --witness <successor-ref>, --review-witness <ref>,", file=sys.stderr)
            print("    --review-deferred, --supersedes <old-disposition-id>, --class <name>.", file=sys.stderr)
            print("    NOTHING was written.", file=sys.stderr)
            return 1
        else:
            args.append(tok)
    if len(args) < 3:
        print("usage: led work resolve-violation <violating-act-id> <reissued|retired> \"<basis>\"",
              file=sys.stderr)
        print("         (--review-witness <ref> | --review-deferred) [--witness <successor-ref>]",
              file=sys.stderr)
        print("         [--supersedes <old-disposition-id>] [--class <name>]", file=sys.stderr)
        return 4
    target_id, resolution = args[0], args[1]
    basis = " ".join(args[2:])
    if supersedes and class_flag:
        print("led work resolve-violation: REFUSED -- --class and --supersedes are not combined: "
              "--class disambiguates the ordinary construction path; --supersedes (the correction "
              "path) derives class from the disposition it corrects. Omit --class when using "
              "--supersedes.", file=sys.stderr)
        return 1
    if resolution not in ("reissued", "retired"):
        print(f"led work resolve-violation: REFUSED -- resolution must be exactly 'reissued' or "
              f"'retired' (got {resolution!r}).", file=sys.stderr)
        return 1
    if review_witness and review_deferred:
        print("led work resolve-violation: REFUSED -- --review-witness and --review-deferred are "
              "the TWO CONSTRUCTORS of a review disposition; exactly ONE, never both.", file=sys.stderr)
        return 1
    if not review_witness and not review_deferred:
        print("led work resolve-violation: REFUSED -- a review-silent disposition is "
              "unrepresentable. Choose exactly ONE: --review-witness <ref> | --review-deferred.",
              file=sys.stderr)
        return 1
    if resolution == "reissued" and not witness:
        print("led work resolve-violation: WARNING -- reissued with no --witness <successor-ref> "
              "cited -- the kernel cannot verify successor equivalence, so this is NOT refused, "
              "but the disposition's checkable basis then holds VACUOUSLY. Prefer citing the "
              "successor row id when one exists.", file=sys.stderr)

    if supersedes:
        old = _current_row_by_id(cfg, supersedes)
        if old is None or old.get("kind") != "work_violation_disposition":
            print(f"led work resolve-violation: REFUSED -- --supersedes {supersedes} does not "
                  f"name a currently in-force work_violation_disposition row (already "
                  f"superseded, wrong kind, or does not exist). Run 'led work violations' or "
                  f"read work_violation_history to find the row you mean.", file=sys.stderr)
            return 1
        class_ = old.get("work_violation_class")
        old_target = old.get("work_violation_target_id")
        if str(old_target) != str(target_id):
            print(f"led work resolve-violation: REFUSED -- --supersedes {supersedes} answers "
                  f"target {old_target}, not {target_id} (this command's own first argument) -- "
                  f"a correction must name the SAME target its predecessor answered.", file=sys.stderr)
            return 1
    else:
        rows = bcc.get_all_rows(cfg.base, "/views/work_item_violations", cursor="after_slug")
        classes = sorted({r["violation"] for r in rows if str(r.get("target_id")) == str(target_id)})
        if not classes:
            print(f"led work resolve-violation: REFUSED -- target {target_id} is not currently "
                  f"an in-force work_item_violations member (re-derived against the view "
                  f"itself). Run './led work violations' to see what is currently answerable. "
                  f"(If you are CORRECTING a wrong disposition rather than answering a fresh "
                  f"violation, add --supersedes <the wrong disposition's row id>.)", file=sys.stderr)
            return 1
        if len(classes) > 1:
            if class_flag:
                if class_flag not in classes:
                    print(f"led work resolve-violation: REFUSED -- --class {class_flag!r} is "
                          f"not one of the classes target {target_id} currently matches: "
                          f"{classes}.", file=sys.stderr)
                    return 1
                class_ = class_flag
            else:
                print(f"led work resolve-violation: REFUSED -- target {target_id} matches MORE "
                      f"THAN ONE work_item_violations class at once: {classes}. Disambiguate "
                      f"with --class <name>. Each matched class is a SEPARATE disposition -- "
                      f"resolve them ONE AT A TIME, one --class per invocation.", file=sys.stderr)
                return 1
        else:
            class_ = classes[0]
            if class_flag and class_flag != class_:
                print(f"led work resolve-violation: REFUSED -- --class {class_flag!r} does not "
                      f"match the one class target {target_id} currently matches ({class_!r}).",
                      file=sys.stderr)
                return 1

    disposition, review_ref = ("witnessed", review_witness) if review_witness else ("deferred", None)
    actor = _resolve_actor(cfg)
    payload: dict = {"kind": "work_violation_disposition", "work_violation_class": class_,
                      "work_violation_target_id": int(target_id), "work_resolution": resolution,
                      "rationale": basis, "work_review_disposition": disposition,
                      "statement": f"work_violation_disposition: {class_} target {target_id} ({resolution})"}
    if witness:
        try:
            payload["work_violation_witness"] = int(witness)
        except ValueError:
            print(f"led work resolve-violation: REFUSED -- --witness {witness!r} must be a "
                  f"ledger row id (a bare integer, the successor row's own id).", file=sys.stderr)
            return 4
    if review_ref:
        payload["work_review_ref"] = review_ref
    if supersedes:
        payload["supersedes"] = int(supersedes)
    if actor is not None:
        payload["actor"] = actor
    return bcc.write_and_report(cfg.base, "ledger", payload)


def _current_row_by_id(cfg: bcc.ServedConfig, row_id: str) -> dict | None:
    """Walks GET /rows/current looking for the exact row id -- ledger_current's own "in force"
    reading (a superseded row is simply absent from this walk), used by the --supersedes
    correction path above exactly the way legacy's own `ledger_current WHERE id = :sid` does."""
    try:
        rid = int(row_id)
    except ValueError:
        return None
    for r in bcc.get_all_rows(cfg.base, "/rows/current", cursor="after_id"):
        if r.get("id") == rid:
            return r
    return None


def cmd_work_supersede_cascade(cfg: bcc.ServedConfig, argv: list[str]) -> int:
    """Ported off legacy-led.tmpl's `work supersede-cascade` (kernel/lineage/
    s37-violation-disposition.sql element 5) -- a CLI COMPOSITION of ordinary acts (`work open
    --supersedes`, `work resolve-violation`), no kernel involvement beyond what those two
    already provide. DISCLOSED IMPLEMENTATION-SHAPE DIFFERENCE, not a semantic one: legacy
    re-execs `./led work open ...`/`./led work resolve-violation ...` as fresh subprocesses;
    this port calls `cmd_work_open`/`cmd_work_resolve_violation` as ordinary in-process function
    calls (the natural shape once the whole tool is one Python process) and re-derives each
    step's own written row id via GET /rows/current exactly as legacy's own recursive shell-outs
    do (neither parses the other call's OWN stdout)."""
    cascade_parent = cascade_discharge = cascade_refs = None
    args: list[str] = []
    it = iter(argv)
    for tok in it:
        if tok == "--parent":
            cascade_parent = next(it, None)
        elif tok == "--discharge":
            cascade_discharge = next(it, None)
        elif tok == "--refs":
            cascade_refs = next(it, None)
        elif tok.startswith("--"):
            print(f"led work supersede-cascade: REFUSED -- unrecognized flag '{tok}'.", file=sys.stderr)
            print("  accepts only: --parent <grandparent-slug>, --discharge composite, --refs <ref>.",
                  file=sys.stderr)
            return 1
        else:
            args.append(tok)
    if len(args) < 3:
        print("usage: led work supersede-cascade <old-slug> <new-slug> <title...>", file=sys.stderr)
        print("         [--parent <grandparent-slug>] [--discharge composite] [--refs <ref>]",
              file=sys.stderr)
        print("       Supersedes <old-slug> under <new-slug>, then cascades <old-slug>'s DIRECT "
              "children only (one level).", file=sys.stderr)
        return 4
    old_slug, new_slug = args[0], args[1]
    cascade_title = " ".join(args[2:])

    old_open = _current_row(cfg, "work_opened", old_slug)
    if old_open is None:
        print(f"led work supersede-cascade: REFUSED -- '{old_slug}' is not currently an in-force "
              f"work_opened item (already superseded, or never opened) -- refusing on this dirty "
              f"starting state rather than guessing what was meant.", file=sys.stderr)
        return 1
    old_open_id = old_open["id"]

    edges = bcc.get_all_rows(cfg.base, "/views/work_edge_parent", cursor="after_slug")
    children = sorted({e["child_slug"] for e in edges if e.get("parent_slug") == old_slug})
    has_grandchild = any(e.get("parent_slug") in children for e in edges)
    if has_grandchild:
        print(f"led work supersede-cascade: REFUSED -- '{old_slug}' has a grandchild-shaped "
              f"descendant (a child that itself has children) -- this convenience verb walks "
              f"ONE level only. Repair the deeper level by hand (led work resolve-violation "
              f"...), or re-invoke this verb one level at a time, bottom-up.", file=sys.stderr)
        return 1

    print(f"led work supersede-cascade: superseding '{old_slug}' (row {old_open_id}) under "
          f"'{new_slug}'...", file=sys.stderr)
    open_argv = [new_slug, cascade_title, "--supersedes", str(old_open_id)]
    if cascade_parent:
        open_argv += ["--parent", cascade_parent]
    if cascade_discharge:
        open_argv += ["--discharge", cascade_discharge]
    if cascade_refs:
        open_argv += ["--refs", cascade_refs]
    rc = cmd_work_open(cfg, open_argv)
    if rc != 0:
        print(f"led work supersede-cascade: STOPPED -- 'led work open {new_slug} ...' did not "
              f"succeed (see its own error above). No child was touched.", file=sys.stderr)
        return rc
    new_open = _current_row(cfg, "work_opened", new_slug)
    if new_open is None:
        print(f"led work supersede-cascade: STOPPED -- 'led work open {new_slug} ...' did not "
              f"succeed (see its own error above). No child was touched.", file=sys.stderr)
        return 1

    for child in children:
        child_row = _work_item_current_row(cfg, child)
        child_state = child_row.get("state") if child_row else None
        if child_state == "closed":
            iteration = 0
            first = True
            while True:
                targets = _violations_for_slug(cfg, child, "orphaned_by_retraction")
                if not targets:
                    if first:
                        print(f"led work supersede-cascade: '{child}' is closed but no "
                              f"orphaned_by_retraction violation surfaced for it -- skipping "
                              f"(already answered, or nothing to answer).", file=sys.stderr)
                    break
                first = False
                iteration += 1
                if iteration > 20:
                    print(f"led work supersede-cascade: REFUSED -- the closed-child orphan "
                          f"disposal for '{child}' did not converge after 20 steps -- refusing "
                          f"rather than looping forever.", file=sys.stderr)
                    return 1
                rc = cmd_work_resolve_violation(cfg, [
                    str(targets[0]), "retired",
                    f"child closed and settled at cascade time (supersede-cascade, parent "
                    f"superseded {old_slug} -> {new_slug})", "--review-deferred"])
                if rc != 0:
                    return rc
        else:
            new_child = f"{child}--via-{new_slug}"
            child_open = _current_row(cfg, "work_opened", child)
            child_open_id = child_open["id"] if child_open else None
            rc = cmd_work_open(cfg, [
                new_child, f"reopened under {new_slug} (supersede-cascade)",
                "--parent", new_slug, "--supersedes", str(child_open_id),
                "--refs", f"row:{child_open_id}"])
            if rc != 0:
                return rc
            new_child_open = _current_row(cfg, "work_opened", new_child)
            new_child_open_id = new_child_open["id"] if new_child_open else None
            iteration = 0
            while True:
                targets = _violations_for_slug(cfg, child, "orphaned_by_retraction")
                if not targets:
                    break
                iteration += 1
                if iteration > 20:
                    print(f"led work supersede-cascade: REFUSED -- the orphan recursion for "
                          f"'{child}' did not converge after 20 steps -- refusing rather than "
                          f"looping forever.", file=sys.stderr)
                    return 1
                rc = cmd_work_resolve_violation(cfg, [
                    str(targets[0]), "reissued",
                    f"surviving act on the old slug '{child}' orphaned one level down by the "
                    f"reopen (supersede-cascade recursion)", "--review-deferred",
                    "--witness", str(new_child_open_id)])
                if rc != 0:
                    return rc
    print(f"led work supersede-cascade: done -- '{new_slug}' opened, direct children of "
          f"'{old_slug}' cascaded. Run 'led work violations' to confirm.", file=sys.stderr)
    return 0


def cmd_generic(cfg: bcc.ServedConfig, kind: str, statement: str, shared: dict[str, str],
                grade: str | None, allow_cli_text: bool) -> int:
    """The generic `<kind> <statement...>` write path. `shared` is main()'s own front-anchored
    shared-flag strip (row 1173 finding 1) -- -f/-e/--supersedes/--amends/--amends-scope/
    --answers/--refs/--concern/--evidence/--confidence/--event-time, exactly legacy's own
    vocabulary, all of which this path (and only this path, plus register-principal/principal)
    honors."""
    if not _preflight_grammar(statement):
        return 1
    if not allow_cli_text:
        violation = _cli_usage_guard_violation(statement)
        if violation is not None:
            print(f"led: REFUSED -- this statement {violation} -- it pattern-matches CAPTURED "
                  f"CLI usage/help output, not authored prose (garbage-statement guard, ledger "
                  f"row 1159: the maintainer's own testimony that fumbled agent invocations "
                  f"have written CLI usage text into the ledger as permanent rows). NOTHING "
                  f"was written.", file=sys.stderr)
            print(f"  If this statement genuinely, deliberately needs to quote CLI usage/help "
                  f"text (e.g. reporting a real bug in that text), re-run with "
                  f"--statement-really-contains-cli-text to override.", file=sys.stderr)
            return 1
    payload: dict = {"kind": kind, "statement": statement}
    if shared.get("-f"):
        payload["rationale"] = f"files: {shared['-f']}"
    if shared.get("-e"):
        payload["enacts"] = [int(x) for x in shared["-e"].split(",") if x]
    if shared.get("--supersedes"):
        payload["supersedes"] = int(shared["--supersedes"])
    if shared.get("--amends"):
        payload["amends"] = int(shared["--amends"])
    if shared.get("--amends-scope"):
        payload["amends_scope"] = shared["--amends-scope"]
    if shared.get("--answers"):
        payload["answers"] = int(shared["--answers"])
    if shared.get("--refs"):
        payload["refs"] = shared["--refs"]
    if shared.get("--concern"):
        payload["concern"] = shared["--concern"]
    if shared.get("--evidence"):
        payload["evidence"] = shared["--evidence"]
    if shared.get("--confidence"):
        payload["confidence"] = shared["--confidence"]
    if shared.get("--event-time"):
        payload["event_declared_ts"] = shared["--event-time"]
    if kind == "decision" and grade is not None:
        payload["decision_grade"] = grade
    actor = _resolve_actor(cfg)
    if actor is not None:
        payload["actor"] = actor
    return bcc.write_and_report(cfg.base, "ledger", payload)


# --- FLAG-BEFORE-VERB GRAMMAR (row 1173 finding 1) --------------------------------------------
# legacy-led.tmpl's own top-of-file shared flag loop (recovered source ~lines 584-612) parses
# these ELEVEN shared flags FRONT-ANCHORED -- in any order among themselves, but strictly BEFORE
# the verb word -- before dispatching on $1 at all. This served rebase used to dispatch on
# argv[0] FIRST and only parse shared flags inside the generic path's own argparse call, so
# `led --event-time <ts> work open x "y"` never reached `work`'s own dispatch branch at all: argv[0]
# was "--event-time", which matched none of the verb checks, so control fell all the way through
# to the generic path, which then (mis)treated "work" as a `<kind>` and "open"/"x"/"y" as the
# statement -- a silent misroute into an unrelated write, not a refusal. `_strip_shared_flags`
# below restores legacy's own front-anchored grammar: consume the leading run of recognized
# shared flags, stop at the first token that is not one, and dispatch on THAT (post-strip) token.
_SHARED_FLAG_NAMES = {"-f", "-e", "--supersedes", "--amends", "--amends-scope", "--answers",
                      "--refs", "--concern", "--evidence", "--confidence", "--event-time"}


def _strip_shared_flags(argv: list[str]) -> tuple[dict[str, str], list[str]]:
    """Consumes a FRONT-ANCHORED run of `_SHARED_FLAG_NAMES` (each takes exactly one following
    token as its value, legacy's own `shift 2` convention -- a flag with nothing after it gets
    an empty-string value, never an IndexError) and returns (parsed flags, remaining argv). Once
    a token that is not a recognized shared flag is seen, the loop stops -- exactly legacy's own
    `while true; do case "${1:-}" in -f) ...; *) break ;; esac; done`: a shared flag can only
    appear BEFORE the verb, never interspersed after it."""
    flags: dict[str, str] = {}
    i = 0
    while i < len(argv) and argv[i] in _SHARED_FLAG_NAMES:
        flags[argv[i]] = argv[i + 1] if i + 1 < len(argv) else ""
        i += 2
    return flags, argv[i:]


# legacy's own --event-time COVERAGE GUARD (recovered source ~lines 753-777): every verb below
# has its OWN INSERT that does not carry `event_declared_ts` -- REFUSE loudly here rather than
# silently dropping a value the operator explicitly asked to be recorded. `register-principal`
# and the 13 `led principal *` sub-verbs are DELIBERATELY ABSENT from this set (they honor
# --event-time, see `_refuse_other_shared_flags`/`cmd_register_principal`'s own `event_time`
# parameter) -- as is the generic `<kind> <statement...>` path (its whole reason to exist).
# `artifact` is an ADDITIVE entry beyond legacy's own list: legacy predates the artifact-store
# routes entirely (design/FABLE-LEGACY-LED-RETIREMENT-SPEC.md Part B, this build), so legacy
# never had occasion to name it -- but `cmd_artifact_put`'s own payload carries no
# `event_declared_ts` slot either, the SAME silent-drop hazard this guard exists to foreclose,
# noticed in reach of this exact fix (CLAUDE.md's hazard-fixing duty) and closed here rather
# than left for the next caller to trip.
_EVENT_TIME_UNSUPPORTED_VERBS = {
    "--recent", "current", "question-status", "review-gap", "stamp-distinctness", "standing",
    "obligate", "review", "work", "decomposition-review-status", "briefing", "artifact",
}


def main(argv: list[str]) -> int:
    if argv and argv[0] in ("--help", "-h", "help"):
        print(__doc__)
        return 0
    cfg = _load_config()
    shared, argv = _strip_shared_flags(argv)
    event_time = shared.get("--event-time")
    if event_time and argv and argv[0] in _EVENT_TIME_UNSUPPORTED_VERBS:
        print(f"led: REFUSED -- --event-time is only supported on the generic <kind> "
              f"<statement...> path today (e.g. './led --event-time <ts> finding \"...\"'), "
              f"plus register-principal and 'led principal <sub-verb>' (kernel/lineage/"
              f"s40-principal-identity-events.sql); '{argv[0]}' has its own INSERT that does "
              f"not carry event_declared_ts, so the value would otherwise be silently dropped. "
              f"Omit --event-time for this verb, or route the declaration through the generic "
              f"path instead.", file=sys.stderr)
        return 1

    if argv and argv[0] == "--json":
        if len(argv) != 3:
            print("usage: led --json <ledger|review|registration|obligation> <file|->", file=sys.stderr)
            return 4
        return cmd_json(cfg, argv[1], argv[2])

    if argv and argv[0] == "--recent":
        n = int(argv[1]) if len(argv) > 1 else 10
        return cmd_recent(cfg, n, current_only=False)
    if argv and argv[0] == "current":
        n = int(argv[1]) if len(argv) > 1 else 10
        return cmd_recent(cfg, n, current_only=True)
    if argv and argv[0] == "show":
        if len(argv) != 2 or not argv[1].isdigit():
            print("usage: led show <id>", file=sys.stderr)
            return 4
        return cmd_show(cfg, int(argv[1]))
    if argv and argv[0] == "question-status":
        return cmd_view(cfg, "question_status", "after_id")
    if argv and argv[0] == "review-gap":
        return cmd_view(cfg, "review_gap", "after_id")
    if argv and argv[0] == "stamp-distinctness":
        return cmd_view(cfg, "review_stamp_distinctness", "after_id")
    if argv and argv[0] == "standing":
        return cmd_view(cfg, "standing_decisions", "after_id")
    if argv and argv[0] == "register-principal":
        # design/FABLE-LEGACY-LED-RETIREMENT-SPEC.md Part C completion (row 1158/1159): found
        # live -- this verb's own grammar was missing legacy-led.tmpl's `--purpose "<why>"` flag
        # entirely (a real gap, surfaced only once tools/setup_tui/principals_authority.py's own
        # re-sequencing made this the DEFAULT path for register-principal, where before it always
        # used legacy/led instead). `--purpose` is OPTIONAL here exactly as legacy's own grammar
        # treats it (a caller that omits it gets this CLI's own placeholder text, unchanged
        # behavior for every existing caller); `cmd_register_principal` now threads whatever is
        # given straight to the kernel's own registration_write payload.
        rc = _refuse_other_shared_flags("register-principal", shared)
        if rc is not None:
            return rc
        p = argparse.ArgumentParser(prog="led register-principal", add_help=False)
        p.add_argument("name")
        p.add_argument("agent_class")
        p.add_argument("--purpose", default=None)
        try:
            ns = p.parse_args(argv[1:])
        except SystemExit:
            print("usage: led register-principal <name> <class> [--purpose \"<why>\"]", file=sys.stderr)
            return 4
        return cmd_register_principal(cfg, ns.name, ns.agent_class, ns.purpose, event_time)
    if argv and argv[0] == "obligate":
        if len(argv) >= 2 and argv[1] == "revoke":
            p = argparse.ArgumentParser(prog="led obligate revoke", add_help=False)
            p.add_argument("scope")
            p.add_argument("--reason", default=None)
            try:
                ns = p.parse_args(argv[2:])
            except SystemExit:
                print("usage: led obligate revoke <scope> --reason \"<text>\"", file=sys.stderr)
                return 4
            if not ns.reason or not ns.reason.strip():
                print("led obligate revoke: REFUSED -- --reason is MANDATORY (kernel/lineage/"
                      "s57-obligation-revocation-event.sql: a revocation is a maintainer act, "
                      "and its stated ground is part of the record).", file=sys.stderr)
                print("usage: led obligate revoke <scope> --reason \"<text>\"", file=sys.stderr)
                return 4
            return cmd_obligate_revoke(cfg, ns.scope, ns.reason)
        if len(argv) != 4:
            print("usage: led obligate <scope> <assigned-by-principal> <obliged-actor-principal>", file=sys.stderr)
            return 4
        return cmd_obligate(cfg, argv[1], argv[2], argv[3])
    if argv and argv[0] == "review":
        p = argparse.ArgumentParser(prog="led review")
        p.add_argument("entry_id", type=int)
        p.add_argument("verdict")
        p.add_argument("independence")
        p.add_argument("--antecedent", type=int, default=None)
        p.add_argument("statement", nargs="+")
        ns = p.parse_args(argv[1:])
        return cmd_review(cfg, ns.entry_id, ns.verdict, ns.independence, ns.antecedent,
                           " ".join(ns.statement))
    if argv and argv[0] == "decomposition-review-status":
        if len(argv) != 1:
            print(f"led decomposition-review-status: REFUSED -- unrecognized argument "
                  f"'{argv[1]}'.", file=sys.stderr)
            # row 1173 review round 1, minor 1: legacy's own trailing clause (recovered source,
            # both this verb's and `briefing`'s refusal), dropped in the earlier port -- restored.
            print("  This verb takes NO flags or arguments -- see top-of-file comment.",
                  file=sys.stderr)
            return 1
        return cmd_decomposition_review_status(cfg)
    if argv and argv[0] == "briefing":
        if len(argv) != 1:
            print(f"led briefing: REFUSED -- unrecognized argument '{argv[1]}'.", file=sys.stderr)
            print("  This verb takes NO flags or arguments -- see top-of-file comment.",
                  file=sys.stderr)
            return 1
        return cmd_briefing()
    if argv and argv[0] == "work":
        sub = argv[1] if len(argv) > 1 else ""
        rest = argv[2:]
        if sub == "open":
            return cmd_work_open(cfg, rest)
        if sub == "claim":
            return cmd_work_claim(cfg, rest)
        if sub == "depends":
            return cmd_work_depends(cfg, rest)
        if sub == "close":
            return cmd_work_close(cfg, rest)
        if sub == "list":
            if rest and rest != ["--all"]:
                print("usage: led work list [--all]", file=sys.stderr)
                return 4
            return cmd_work_list(cfg, show_all=(rest == ["--all"]))
        if sub == "violations":
            return cmd_work_violations(cfg)
        if sub == "asof":
            if len(rest) != 1:
                print("usage: led work asof <timestamp>", file=sys.stderr)
                return 4
            return cmd_work_asof(cfg, rest[0])
        if sub == "review-gap":
            return cmd_work_review_gap(cfg)
        if sub == "startable":
            return cmd_work_startable(cfg)
        if sub == "resolve-violation":
            return cmd_work_resolve_violation(cfg, rest)
        if sub == "supersede-cascade":
            return cmd_work_supersede_cascade(cfg, rest)
        print(f"led work {sub}: REFUSED -- not a recognized `led work` sub-verb (open|claim|"
              f"depends|close|list|violations|asof|review-gap|startable|resolve-violation|"
              f"supersede-cascade -- all eleven `led work *` sub-verbs are covered by this "
              f"served path, legacy-led-retirement, ledger row 1149/1150).",
              file=sys.stderr)
        return 4
    if argv and argv[0] == "artifact":
        sub = argv[1] if len(argv) > 1 else ""
        if sub == "put":
            p = argparse.ArgumentParser(prog="led artifact put", add_help=False)
            p.add_argument("path")
            p.add_argument("--media-type", dest="media_type", default=None)
            try:
                ns = p.parse_args(argv[2:])
            except SystemExit:
                print("usage: led artifact put <path> [--media-type text/markdown|text/plain|"
                      "application/toml|application/json]", file=sys.stderr)
                return 4
            return cmd_artifact_put(cfg, ns.path, ns.media_type)
        if sub == "get":
            p = argparse.ArgumentParser(prog="led artifact get", add_help=False)
            p.add_argument("hash")
            p.add_argument("--out", default=None)
            try:
                ns = p.parse_args(argv[2:])
            except SystemExit:
                print("usage: led artifact get <64-hex-char-sha256-hash> [--out <path>]",
                      file=sys.stderr)
                return 4
            return cmd_artifact_get(cfg, ns.hash, ns.out)
        if sub == "stat":
            if len(argv) != 3:
                print("usage: led artifact stat <64-hex-char-sha256-hash>", file=sys.stderr)
                return 4
            return cmd_artifact_stat(cfg, argv[2])
        print(f"led artifact {sub}: REFUSED -- usage: led artifact put <path> [--media-type ...] "
              f"| get <hash> [--out <path>] | stat <hash>", file=sys.stderr)
        return 4
    if argv and argv[0] == "principal":
        return cmd_principal(cfg, argv[1:], shared)

    # The generic <kind> <statement...> write path -- the shared flags (-f/-e/--supersedes/
    # --amends/--amends-scope/--answers/--refs/--concern/--evidence/--confidence/--event-time)
    # are ALREADY stripped, front-anchored, into `shared` above; only `--grade` (decision's own
    # value flag) and `--statement-really-contains-cli-text` (the garbage-statement guard's
    # override, row 1159 -- NOT part of legacy's shared vocabulary at all, a new flag) remain for
    # this path's own argparse to recognize, alongside `kind`/`statement`.
    p = argparse.ArgumentParser(prog="led", add_help=False)
    p.add_argument("--grade", default=None)
    p.add_argument("--statement-really-contains-cli-text",
                    dest="statement_really_contains_cli_text", action="store_true")
    p.add_argument("kind")
    p.add_argument("statement", nargs="+")
    try:
        ns = p.parse_args(argv)
    except SystemExit:
        return 4
    return cmd_generic(cfg, ns.kind, " ".join(ns.statement), shared, ns.grade,
                        ns.statement_really_contains_cli_text)


if __name__ == "__main__":
    try:
        sys.exit(main(sys.argv[1:]))
    except (bcc.BoundaryRefusal, bcc.BoundaryUnreachable, bcc.BoundaryClientError) as e:
        # Part C completion item 5 (ledger row 1158/1159): best-effort re-read of this
        # deployment's own boundary_url for the restart teach-text -- wrapped so a SECOND
        # failure here (a missing/malformed deployment.json) never masks the original
        # exception `e` this handler exists to report.
        _boundary_url = None
        try:
            _boundary_url = bcc.load_served_config(DEPLOYMENT_PATH).record.boundary_url
        except Exception:
            pass
        sys.exit(bcc.report_boundary_exception("led", e, boundary_url=_boundary_url))
