        print("    outcome: <TASK-SLUG> | <MODEL> | <SEAM-VERDICT> | <DEFECTS-FOUND-AT-SEAM> | <NOTES>", file=sys.stderr)
        print(f"  the five fields, in order: {', '.join(fields)}", file=sys.stderr)
        print("  TASK-SLUG must match ^[a-z0-9][a-z0-9-]*$ (a bare slug, no spaces -- the same slug a", file=sys.stderr)
        print("  'led work open <slug>'/'estimate:' row for it would use, so a retrospective can join", file=sys.stderr)
        print("  on it)", file=sys.stderr)
