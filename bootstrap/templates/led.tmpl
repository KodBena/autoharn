import re
import sys

# The four fields, in order, are transcribed VERBATIM from design/USER-TAXONOMY-DECLARATION.md's
# "The statement grammars" section -- the ONE documented home of this grammar (a transcription,
# not a second, driftable definition of it -- ADR-0012 P1). bootstrap/templates/pickup.tmpl's own
# _TAXON_FIELDS tuple is the sibling reader of the same four names on the display side. TAXONOMY
# and TAXON are both machine keys design/ORCH-SPEC-TASK-TAXONOMY.md §4's predicates quantify over
# (`single-taxon-task(T)`, `no-cross-taxon-write(T)`) -- held to the same bare-slug shape
# `estimate:`'s TASK-SLUG field already uses, so a predicate never has to guess whether two
# differently-cased or differently-punctuated spellings name the same taxon.
FIELDS = ("TAXONOMY", "TAXON", "PATTERNS", "GLOSS")
_SLUG_RE = re.compile(r"^[a-z0-9][a-z0-9-]*$")

raw = sys.argv[1]
normalized = re.sub(r"[\r\n]+[ \t]*", " ", raw).strip()
body = normalized[len("taxon:"):]
parts = [p.strip() for p in body.split("|")]


def refuse(msg: str) -> None:
    print(f"led: REFUSED -- malformed 'taxon:' statement -- {msg}.", file=sys.stderr)
    print("  grammar (design/USER-TAXONOMY-DECLARATION.md 'The statement grammars'):", file=sys.stderr)
    print("    taxon: <TAXONOMY> | <TAXON> | <PATTERNS> | <GLOSS>", file=sys.stderr)
    print(f"  the four fields, in order: {', '.join(FIELDS)}", file=sys.stderr)
    print("  TAXONOMY and TAXON must each match ^[a-z0-9][a-z0-9-]*$ (a bare slug, no spaces)", file=sys.stderr)
    print("  PATTERNS must be non-empty (one or more path globs assigning artifacts to the taxon)", file=sys.stderr)
    print("  GLOSS must be non-empty (state what the taxon means, for a human reader)", file=sys.stderr)
    print(f"  received ({len(parts)} field(s), whitespace-normalized): {normalized}", file=sys.stderr)
    print("  NOTHING was written -- fix the statement and re-run.", file=sys.stderr)
    sys.exit(1)


if len(parts) != len(FIELDS):
    refuse(f"expected exactly {len(FIELDS)} '|'-separated fields, got {len(parts)}")

taxonomy, taxon, patterns, gloss = parts
if not _SLUG_RE.match(taxonomy):
    refuse(f"TAXONOMY field {taxonomy!r} does not match ^[a-z0-9][a-z0-9-]*$ (a bare slug, no spaces)")
if not _SLUG_RE.match(taxon):
    refuse(f"TAXON field {taxon!r} does not match ^[a-z0-9][a-z0-9-]*$ (a bare slug, no spaces)")
if not patterns:
    refuse("PATTERNS field is empty -- name at least one path glob assigning artifacts to the taxon")
if not gloss:
    refuse("GLOSS field is empty -- state what the taxon means, for a human reader")

sys.exit(0)
PYEOF
    then
      exit 1
    fi
    ;;
esac

