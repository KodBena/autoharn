          SET ROLE ${ROLE};
          SET search_path = ${SCHEMA}, ${KERNEL};
          SELECT state FROM ${SCHEMA}.work_item_current WHERE slug = :'slug';
SQL
        )
        if [ "$child_state" = "closed" ]; then
          # A closed child's slug can carry MULTIPLE live orphaned_by_retraction rows (e.g. a
          # parent-edge orphan and a separate orphaned claim/edge on the same slug) -- walk to a
          # bounded fixpoint the same way the OPEN-child branch below does (element 6), rather
          # than disposing of a single nondeterministic LIMIT 1 row and silently leaving the rest
          # as debt.
          iter=0
          while :; do
            child_target=$(psql -h "$PGHOST" -d "$PGDB" -tAq -v slug="$child" <<SQL
              SET ROLE ${ROLE};
              SET search_path = ${SCHEMA}, ${KERNEL};
              SELECT target_id FROM ${SCHEMA}.work_item_violations
              WHERE violation = 'orphaned_by_retraction' AND slug = :'slug'
              ORDER BY target_id LIMIT 1;
SQL
            )
            if [ -z "$child_target" ]; then
              if [ "$iter" -eq 0 ]; then
                echo "led work supersede-cascade: '${child}' is closed but no orphaned_by_retraction" >&2
                echo "  violation surfaced for it -- skipping (already answered, or nothing to answer)." >&2
              fi
              break
            fi
            iter=$((iter + 1))
            if [ "$iter" -gt 20 ]; then
              echo "led work supersede-cascade: REFUSED -- the closed-child orphan disposal for" >&2
              echo "  '${child}' did not converge after 20 steps -- refusing rather than looping" >&2
              echo "  forever. Repair the remainder by hand (led work resolve-violation ...)." >&2
              exit 1
            fi
            ./led work resolve-violation "$child_target" retired \
              "child closed and settled at cascade time (supersede-cascade, parent superseded ${old_slug} -> ${new_slug})" \
              --review-deferred
          done
        else
          new_child="${child}--via-${new_slug}"
          child_open_id=$(psql -h "$PGHOST" -d "$PGDB" -tAq -v slug="$child" <<SQL
            SET ROLE ${ROLE};
            SET search_path = ${SCHEMA}, ${KERNEL};
            SELECT id FROM ${SCHEMA}.ledger_current WHERE kind = 'work_opened' AND work_slug = :'slug';
SQL
          )
          ./led work open "$new_child" "reopened under ${new_slug} (supersede-cascade)" \
            --parent "$new_slug" --supersedes "$child_open_id" --refs "row:${child_open_id}"
          new_child_open_id=$(psql -h "$PGHOST" -d "$PGDB" -tAq -v slug="$new_child" <<SQL
            SET ROLE ${ROLE};
            SET search_path = ${SCHEMA}, ${KERNEL};
            SELECT id FROM ${SCHEMA}.ledger_current WHERE kind = 'work_opened' AND work_slug = :'slug';
SQL
          )
          # Element 6, "reissue recursion, named plainly": retracting the child's own opening row
          # orphans that child's OWN surviving claims/edges one level down. Walked to a fixpoint,
          # BOUNDED (refuses loudly rather than looping forever -- "refuse on a dirty state it
          # cannot reason about") -- each surfacing orphan on the OLD child slug is answered
          # `reissued`, citing the SAME successor.
          iter=0
          while :; do
            recursed_target=$(psql -h "$PGHOST" -d "$PGDB" -tAq -v slug="$child" <<SQL
              SET ROLE ${ROLE};
              SET search_path = ${SCHEMA}, ${KERNEL};
              SELECT target_id FROM ${SCHEMA}.work_item_violations
              WHERE violation = 'orphaned_by_retraction' AND slug = :'slug' LIMIT 1;
SQL
            )
            [ -z "$recursed_target" ] && break
            iter=$((iter + 1))
            if [ "$iter" -gt 20 ]; then
              echo "led work supersede-cascade: REFUSED -- the orphan recursion for '${child}'" >&2
              echo "  did not converge after 20 steps -- refusing rather than looping forever." >&2
              echo "  Repair the remainder by hand (led work resolve-violation ...)." >&2
              exit 1
            fi
            ./led work resolve-violation "$recursed_target" reissued \
              "surviving act on the old slug '${child}' orphaned one level down by the reopen (supersede-cascade recursion)" \
              --review-deferred --witness "$new_child_open_id"
          done
        fi
      done
      echo "led work supersede-cascade: done -- '${new_slug}' opened, direct children of" >&2
      echo "  '${old_slug}' cascaded. Run 'led work violations' to confirm." >&2
      # EXPLICIT exit (every OTHER work) leaf ends in `exec psql`, which replaces the process and
      # never falls through -- this leaf runs MULTIPLE psql calls in a loop and cannot `exec` its
      # last one alone, so it must exit here or fall through into the generic top-of-file
      # `led [flags] <kind> <statement...>` dispatch below, misinterpreting this command's own
      # already-consumed arguments (caught live on this verb's own first scratch witness).
      exit 0
      ;;
    list)
      shift
      # DEFAULT ANSWERS "what is open or claimed right now" (maintainer directive 2026-07-13,
      # led-work-list-state-filter): the unfiltered dump grows with every lifetime item (~60 and
      # counting, closed included), and just overflowed an orchestrator context read. --all
      # restores the pre-existing full-history behavior (closed included) -- one explicit,
      # discoverable flag away, never deleted or hidden from the ledger itself (this is a
      # read-verb default only; `led work asof <ts>` and the raw ledger rows stay the complete,
      # unfiltered record). work_item_current's `state` column is exactly {open, closed} (verified
      # live against this project's own deployment: claimed-but-not-yet-closed items also carry
      # state='open', distinguished by a non-NULL claimant) -- so the default filter is
      # `state <> 'closed'`, not a third value that does not exist in the view.
      show_all=false
      case "${1:-}" in
        --all) show_all=true; shift ;;
        "") : ;;
        *) echo "usage: led work list [--all]" >&2; exit 1 ;;
      esac
      # EFFECTIVE_STATE (kernel/lineage/s33-composite-discharge.sql, ledger item
      # composite-parent-autodischarge): work_item_current gains a DERIVED effective_state column
      # on an s33-carrying kernel -- LIVE column-existence check (the SAME convention this file's
      # own `standing`/`violations` cases and pickup.tmpl's `in_flight()` all already use), never a
      # hardcoded kernel-version assumption, since s33 is not wired into every world's birth chain.
      # A pre-s33 kernel degrades to the plain state-only SELECT below, byte-identical to this
      # command's own pre-s33 output. DISPLAY-ONLY: the WHERE filter (show_all vs default) is
      # UNCHANGED either way -- which rows are returned never depends on effective_state, only
      # what is printed alongside them does.
      has_eff=$(psql -h "$PGHOST" -d "$PGDB" -tAq -v schema="$SCHEMA" <<SQL
        SELECT EXISTS (SELECT 1 FROM information_schema.columns
                       WHERE table_schema = :'schema' AND table_name = 'work_item_current'
                         AND column_name = 'effective_state');
SQL
      )
      if [ "$has_eff" = "t" ]; then
        # Blank (NULL) when effective_state agrees with the raw state -- draws the eye only when
        # they DIFFER (a composite item's derived discharge status), never adds visual noise to
        # the common non-composite case where the two columns are byte-identical by construction.
        eff_col=", CASE WHEN w.effective_state IS DISTINCT FROM w.state THEN w.effective_state ELSE NULL END AS effective_state_if_diff"
      else
        eff_col=""
      fi
      if [ "$show_all" = true ]; then
        exec psql -h "$PGHOST" -d "$PGDB" -c "
          SELECT w.slug, w.title, w.state, w.resolution, w.witness, p.name AS claimant${eff_col}
          FROM ${SCHEMA}.work_item_current w LEFT JOIN ${KERNEL}.principal p ON p.id = w.claimant
          ORDER BY w.slug;"
      else
        exec psql -h "$PGHOST" -d "$PGDB" -c "
          SELECT w.slug, w.title, w.state, w.resolution, w.witness, p.name AS claimant${eff_col}
          FROM ${SCHEMA}.work_item_current w LEFT JOIN ${KERNEL}.principal p ON p.id = w.claimant
          WHERE w.state <> 'closed'
          ORDER BY w.slug;"
      fi
      ;;
    violations)
      # s37 (consult A6, spec element 6): each row gains the discharge path, the same way the
      # stop-gate's debt lines name theirs (hooks/stop_clean_exit.py's own violations else-branch,
      # rewritten alongside this). LIVE column-existence gate -- a pre-s37 world has no target_id
      # column on the view at all, so the query degrades to the pre-s37 3-column read.
      has_target_id_col=$(psql -h "$PGHOST" -d "$PGDB" -tAq -v schema="$SCHEMA" <<SQL
        SELECT EXISTS (SELECT 1 FROM information_schema.columns
                       WHERE table_schema = :'schema' AND table_name = 'work_item_violations'
                         AND column_name = 'target_id');
SQL
      )
      if [ "$has_target_id_col" = "t" ]; then
        exec psql -h "$PGHOST" -d "$PGDB" -c "
          SELECT violation, slug, detail, target_id,
                 'led work resolve-violation ' || target_id || ' <reissued|retired> \"<basis>\" (--review-witness <ref> | --review-deferred)' AS resolve_with
          FROM ${SCHEMA}.work_item_violations ORDER BY violation, slug;"
      else
        exec psql -h "$PGHOST" -d "$PGDB" -c "
          SELECT violation, slug, detail FROM ${SCHEMA}.work_item_violations ORDER BY violation, slug;"
      fi
      ;;
    startable)
      # kernel/lineage/s39-blocks-start.sql's work_startable: open, unclaimed items whose
      # blocks-start antecedents (if any) are all resolved (closed) -- "what can I legitimately
      # claim right now". LIVE relation-existence gate (the SAME convention `list`'s effective_state
      # check and `violations`' target_id check already use) -- a pre-s39 kernel has no such view at
      # all, refused with teach-text rather than a bare psql "relation does not exist" error.
      has_startable=$(psql -h "$PGHOST" -d "$PGDB" -tAq -v schema="$SCHEMA" <<SQL
        SELECT EXISTS (SELECT 1 FROM information_schema.views
                       WHERE table_schema = :'schema' AND table_name = 'work_startable');
SQL
      )
      if [ "$has_startable" != "t" ]; then
        echo "led work startable: REFUSED -- requires kernel/lineage/s39-blocks-start.sql applied" >&2
        echo "  to this project's schema (work_startable view not found on ${SCHEMA} -- this" >&2
        echo "  world's kernel predates s39). Apply s39 as a maintainer act (ORCH-OPERATING-" >&2
        echo "  CARD.md's kernel-delta decision tree), or use 'led work list' in the meantime." >&2
        exit 1
      fi
      exec psql -h "$PGHOST" -d "$PGDB" -c "
        SELECT slug, title FROM ${SCHEMA}.work_startable ORDER BY slug;"
      ;;
    asof)
      shift
      if [ $# -lt 1 ]; then
        echo "usage: led work asof <timestamp>" >&2
        echo "       point-in-time backlog reconstruction -- work-item states AS OF <timestamp>," >&2
        echo "       derived purely by filtering the append-only work_* ledger rows to ts <=" >&2
        echo "       <timestamp> (read-only; no kernel change, no new table -- BACKLOG 'Omega" >&2
        echo "       work-tracking disposition' 2026-07-11, item 2). <timestamp> is anything" >&2
        echo "       postgres's timestamptz cast accepts, e.g. '2026-07-11 10:23:00' or an ISO" >&2
        echo "       8601 string; quote it if it contains a space." >&2
        exit 1
      fi
      asof="$1"
      # Three states (open/claimed/closed), NOT work_item_current's two (open/closed +
      # claimant column) -- the omega-disposition ask was explicitly "open/claimed/closed as of
      # T", so this mirrors work_item_current's own opened/claimed/closed CTE shape (s22) with
      # ONE addition: every CTE is filtered to ts <= :asof before the DISTINCT ON latest-row
      # pick, so "latest as of T" replaces "latest ever". An item whose opening act is itself
      # after T does not exist yet as of T and is correctly absent (INNER JOIN on opened).
      # Bound via psql -v/heredoc (a psql bind, not string concatenation or -c), same convention
      # this file's own generic <kind> <statement> path documents below: psql's :'var'
      # interpolation is only applied to a script read from stdin/-f, NOT to a -c argument -- so
      # this is fed via stdin like every OTHER work verb above, not -c like the parameter-free
      # list/violations reads.
      #
      # HONESTY NOTE (kernel/lineage/s33-composite-discharge.sql): this reconstruction is RAW
      # event-replay only -- state_asof is derived purely from work_opened/work_claimed/
      # work_closed rows filtered to ts <= <timestamp>, never re-derived through s33's
      # effective_state logic. A composite item's DERIVED discharge status is a CURRENT-view
      # concept (it re-checks live obligation-tree state on every read), not a temporal one, and
      # is deliberately NOT retrofitted onto this historical reconstruction -- see
      # `led work list`'s effective_state_if_diff column for that view instead.
      echo "note: asof is a RAW event-reconstruction (open/claimed/closed only) -- a composite" >&2
      echo "      item's DERIVED discharge status is a current-view concept, see 'led work list'." >&2
      exec psql -h "$PGHOST" -d "$PGDB" -v ON_ERROR_STOP=1 -v asof="$asof" <<SQL
        WITH opened AS (
          SELECT work_slug AS slug, work_title AS title, id AS opened_id
          FROM ${SCHEMA}.ledger
          WHERE kind = 'work_opened' AND ts <= :'asof'::timestamptz
        ),
        claimed AS (
          SELECT DISTINCT ON (work_slug) work_slug AS slug, actor AS claimant, id AS claimed_id
          FROM ${SCHEMA}.ledger
          WHERE kind = 'work_claimed' AND ts <= :'asof'::timestamptz
          ORDER BY work_slug, id DESC
        ),
        closed AS (
          SELECT DISTINCT ON (work_slug) work_slug AS slug, work_resolution AS resolution,
                 work_witness AS witness, id AS closed_id
          FROM ${SCHEMA}.ledger
          WHERE kind = 'work_closed' AND ts <= :'asof'::timestamptz
          ORDER BY work_slug, id DESC
        )
        SELECT o.slug, o.title,
               CASE WHEN c.slug IS NOT NULL THEN 'closed'
                    WHEN cl.slug IS NOT NULL THEN 'claimed'
                    ELSE 'open' END AS state_asof,
               c.resolution, c.witness, p.name AS claimant
        FROM opened o
        LEFT JOIN claimed cl ON cl.slug = o.slug
        LEFT JOIN closed  c  ON c.slug  = o.slug
        LEFT JOIN ${KERNEL}.principal p ON p.id = cl.claimant
        ORDER BY o.slug;
SQL
      ;;
    *)
      echo "usage: led work open <slug> <title...> [--parent <parent-slug>] [--discharge composite] [--refs <ref>] [--supersedes <id>]" >&2
      echo "       led work claim <slug>" >&2
      echo "       led work depends <slug> <on-slug>" >&2
      echo "       led work close <slug> <resolution> (--review-witness <ref> | --review-deferred) [--witness <ref>] [--strict]" >&2
      echo "       led work review-gap    (work_review_gap, item-keyed deferred/undischarged closes)" >&2
      echo "       led work list [--all]  (work_item_current; default open/claimed only, --all" >&2
      echo "                               for the full history including closed)" >&2
      echo "       led work violations    (work_item_violations)" >&2
      echo "       led work startable     (work_startable; open+unclaimed items whose blocks-start" >&2
      echo "                               antecedents, if any, are all resolved -- kernel/lineage/" >&2
      echo "                               s39-blocks-start.sql)" >&2
      echo "       led work resolve-violation <violating-act-id> <reissued|retired> \"<basis>\"" >&2
      echo "         (--review-witness <ref> | --review-deferred) [--witness <successor-ref>]" >&2
      echo "         [--supersedes <old-disposition-id>]" >&2
      echo "         (kernel/lineage/s37-violation-disposition.sql -- answers a work_item_violations" >&2
      echo "         member; debt until answered, record forever; --supersedes corrects a wrong" >&2
      echo "         disposition, consult A3)" >&2
      echo "       led work supersede-cascade <old-slug> <new-slug> <title...>" >&2
      echo "         [--parent <grandparent-slug>] [--discharge composite] [--refs <ref>]" >&2
      echo "         (supersedes <old-slug>, cascades its direct children -- retired for closed," >&2
      echo "         reissued for open -- s37 element 5)" >&2
      echo "       led work asof <timestamp>  (point-in-time reconstruction, read-only)" >&2
      exit 1
      ;;
  esac
fi

if [ $# -lt 2 ]; then
  echo "usage: led [flags] <kind> <statement...>   (see top-of-file comment for the full flag list:" >&2
  echo "       -f -e --supersedes --amends --amends-scope --answers --refs --concern --evidence" >&2
  echo "       --confidence; cite an antecedent row from any kind via --refs row:<id>)" >&2
  echo "       led --recent [N] | led current [N] | led show <id> | led question-status | led review-gap | led stamp-distinctness | led standing" >&2
  echo "       led decomposition-review-status  (mode + countersign_obligation counts + verdict, read-only)" >&2
  echo "       led briefing  (fresh-agent rules briefing, read-only, no DB access)" >&2
  echo "       led decision [--grade <word>] <statement...>  (kernel/lineage/s36-decision-grade.sql)" >&2
  echo "       led register-principal <name> <class>" >&2
  echo "       led obligate <scope> <assigned-by-principal> <obliged-actor-principal>" >&2
  echo "       led obligate revoke <scope>" >&2
  echo "       led review <entry-id> <verdict> <independence> [--antecedent id] <statement...>" >&2
  echo "       led work open|claim|depends|close|list|violations|asof  (see top-of-file comment)" >&2
  exit 1
fi

kind="$1"; shift

# --- --grade <word> (kind="decision" ONLY; kernel/lineage/s36-decision-grade.sql, design/
# FABLE-GRADED-DECISIONS-SPEC.md element 2) -- parsed in DECISION'S OWN loop here, immediately
# after kind is known and BEFORE the generic statement="$*" assembly below, mirroring `led work
# open`'s --parent idiom AND its own UNKNOWN-FLAG REFUSAL fix (ledger item
# led-work-open-refs-swallowed, found the same day this spec was ratified: a flag the subcommand
# loop does not parse is silently swallowed into statement prose). --grade MUST NOT repeat that
# shape: an unrecognized --flag among the remaining `decision` args is refused here, loudly,
# rather than silently becoming part of the decision's own statement text.
#
# A recognized top-of-file flag (LED_FLAG_VOCAB) placed AFTER 'decision' is deliberately left
# alone here (re-collected into args, not claimed as "unrecognized") -- refuse_flag_in_statement
# below already teaches the correct fix for THAT mistake (flags belong BEFORE the kind word); this
# loop's own refusal is reserved for a flag that is genuinely unknown to led anywhere.
grade=""
if [ "$kind" = "decision" ]; then
  args=()
  while [ $# -gt 0 ]; do
    case "$1" in
      --grade) grade="${2:-}"; shift 2 ;;
      --*)
        case " $LED_FLAG_VOCAB " in
          *" $1 "*) args+=("$1"); shift ;;
          *)
            echo "led decision: REFUSED -- unrecognized flag '$1'." >&2
            echo "  led decision [--grade <word>] <statement...> accepts --grade (kernel/lineage/" >&2
            echo "  s36-decision-grade.sql) plus led's standing top-of-file flags (-f -e" >&2
            echo "  --supersedes --amends --amends-scope --answers --refs --concern --evidence" >&2
            echo "  --confidence --event-time, given BEFORE the 'decision' kind word -- see led's" >&2
            echo "  own usage header). An unrecognized --flag here would otherwise be silently" >&2
            echo "  concatenated into the decision statement text instead of erroring -- the exact" >&2
            echo "  defect class ledger item led-work-open-refs-swallowed found and fixed for" >&2
            echo "  'led work open'; this loop applies the same fix to 'led decision --grade'." >&2
            echo "  NOTHING was written. Fix the flag name, or drop it if it was meant as" >&2
            echo "  ordinary statement text." >&2
            exit 1
            ;;
        esac
        ;;
      *) args+=("$1"); shift ;;
    esac
  done
  set -- "${args[@]}"
fi

refuse_flag_in_statement "[flags] ${kind}" "$@"
statement="$*"

# --- resource: intake validation (BACKLOG 2026-07-12, run12 witness) ------------------------
# A statement beginning `resource:` (after stripping leading whitespace) declares one Pillar-1
# Capability Registry entry (design/USER-BLESSED-TABLE-TEMPLATE.md) and MUST carry the doc's
# six-field grammar before ANY write is attempted -- refuse loudly here, at the boundary
# (ADR-0002 rule 2: validate at boundaries, do not coerce), rather than let a malformed
# declaration land silently and only be discovered later by pickup's own resources() parser.
# Witnessed live, 2026-07-12 (run12, LED_ACTOR=commissioner): a maintainer-pasted `resource:`
# statement carried an embedded newline from terminal line-wrap mid-word; the write SUCCEEDED
# with only 4 of 6 fields, and pickup's own parser then further shredded the row into two
# spurious MALFORMED entries because it iterates psql's own physical output lines, one of them
# even reporting `id=experiments` (see bootstrap/templates/pickup.tmpl's sibling fix -- the
# newline-normalization half of this same defect class -- for the read-side repair).
#
# The grammar check below runs against a WHITESPACE-NORMALIZED COPY only (every run of \n/\r
# plus its following indentation collapsed to one space) -- so a legitimate embedded newline (a
# paste reflowed by a terminal, exactly the witnessed run12 specimen) is ACCEPTED rather than
# refused. The row actually written below on success is $statement, completely untouched --
# byte fidelity matters for a later GPG signing ceremony over this exact row (design/
# USER-GPG-TRUST-LAYER-FAQ.md), so the normalized copy is validation-only scratch, never
# persisted; nothing is written at all if validation fails (atomicity by refusal-before-write).
#
# COHERENCE PARTNER: the trigger condition below (leading POSIX [:space:] stripped, then a
# `resource:` prefix) and bootstrap/templates/pickup.tmpl resources()'s SQL filter
# (`statement ~ '^[[:space:]]*resource:'`) define "a resource declaration" IDENTICALLY, by
# construction -- every statement this validator accepts is exactly a statement that SELECT
# reads, no more and no fewer (a position-0-only read filter once let a validated-but-indented
# declaration vanish from pickup's RESOURCES section). Change either side only in lockstep with
# the other.
_resource_trimmed="${statement#"${statement%%[![:space:]]*}"}"
case "$_resource_trimmed" in
  resource:*)
    if ! python3 - "$_resource_trimmed" <<'PYEOF'
import re
import sys

# The six fields, in order, and the closed CLASS/TIER vocabularies below are transcribed
# VERBATIM from design/USER-BLESSED-TABLE-TEMPLATE.md's "The statement grammars" section -- the
# ONE documented home of this grammar (a transcription, not a second, driftable definition of
# it -- ADR-0012 P1). bootstrap/templates/pickup.tmpl's own _RESOURCE_FIELDS tuple is the
# sibling reader of the same six names on the display side.
#
# TIER gained a fourth value, `forbidden: <task-shape>` (tracker item `accounting-stage-a`,
# design/ORCH-SPEC-RESOURCE-ACCOUNTING.md §3/§8 stage A): the missing MUST-NOT modality
# completing the MAY/SHOULD/MUST/MUST-NOT deontic register available/blessed/mandated already
# covered three-quarters of. This is the fail-safe additive-vocabulary class CLAUDE.md's
# ORCHESTRATION section pre-ratifies (nothing existing relaxed -- available/blessed/mandated
# accept exactly what they always accepted). What this validator does NOT do: refuse an
# invocation that actually reaches a `forbidden`-tier resource -- that write-time enforcement is
# named out of scope in the spec's §7 ("a possible later mechanism ... declaring it in scope
# would promise an enforcement grade nothing in this spec builds"). This block only accepts or
# refuses the DECLARATION's grammar, exactly as it already did for available/blessed/mandated.
FIELDS = ("NAME", "CLASS", "REACH", "WHAT-IT-PROVES", "GUIDANCE", "TIER")
VALID_CLASSES = ("solver", "service", "backend", "binary", "library")

raw = sys.argv[1]
normalized = re.sub(r"[\r\n]+[ \t]*", " ", raw).strip()
body = normalized[len("resource:"):]
parts = [p.strip() for p in body.split("|")]


def refuse(msg: str) -> None:
    print(f"led: REFUSED -- malformed 'resource:' statement -- {msg}.", file=sys.stderr)
    print("  grammar (design/USER-BLESSED-TABLE-TEMPLATE.md 'The statement grammars'):", file=sys.stderr)
    print("    resource: <NAME> | <CLASS> | <REACH> | <WHAT-IT-PROVES> | <GUIDANCE> | <TIER>", file=sys.stderr)
    print(f"  the six fields, in order: {', '.join(FIELDS)}", file=sys.stderr)
    print(f"  CLASS must be one of: {' | '.join(VALID_CLASSES)}", file=sys.stderr)
    print("  TIER must be one of: available | blessed: <task-shape> | mandated: <task-shape> | "
          "forbidden: <task-shape>", file=sys.stderr)
    print(f"  received ({len(parts)} field(s), whitespace-normalized): {normalized}", file=sys.stderr)
    print("  NOTHING was written -- fix the statement and re-run.", file=sys.stderr)
    sys.exit(1)


if len(parts) != len(FIELDS):
    refuse(f"expected exactly {len(FIELDS)} '|'-separated fields, got {len(parts)}")

_name, cls, _reach, _proves, _guidance, tier = parts
if cls not in VALID_CLASSES:
    refuse(f"CLASS field {cls!r} is not one of {VALID_CLASSES}")
_TIER_PREFIXES = ("blessed:", "mandated:", "forbidden:")
if not (tier == "available" or tier.startswith(_TIER_PREFIXES)):
    refuse(f"TIER field {tier!r} is not 'available', 'blessed: <task-shape>', "
           f"'mandated: <task-shape>', or 'forbidden: <task-shape>'")
if tier.startswith(_TIER_PREFIXES) and not tier.split(":", 1)[1].strip():
    refuse(f"TIER field {tier!r} names no <task-shape> after the colon")

sys.exit(0)
PYEOF
    then
      exit 1
    fi
