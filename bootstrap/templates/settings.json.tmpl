{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "env LEDGER_DB=__DB__ GATE_LEDGER=__SCHEMA__.ledger GATE_SUBJECT_ROOT=__PROJECT_ROOT__ GATE_STATE=__PROJECT_ROOT__/.claude/change_gate_state.json GATE_JOURNAL=__PROJECT_ROOT__/.claude/logs/change_gate.journal.jsonl GOVERNED_CONFIG=__PROJECT_ROOT__/.claude/governed_files.json 'DENY_HINT=Run:  ./led -f <basename-of-the-file-you-are-editing> decision \"<why this change>\"   then re-issue the SAME edit -- the gate re-checks on every attempt, so retrying is the whole fix.' python3 __AUTOHARN_ROOT__/hooks/pretooluse_change_gate.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "env STAMP_SECRET=__PROJECT_ROOT__/.claude/secrets/stamp_secret.hex python3 __AUTOHARN_ROOT__/hooks/stamp_intercept.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "env GATE_SUBJECT_ROOT=__PROJECT_ROOT__ python3 __AUTOHARN_ROOT__/hooks/pretooluse_sql_block.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "python3 __AUTOHARN_ROOT__/hooks/demurral_detect.py",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "env LEDGER_HOST=__HOST__ LEDGER_DB=__DB__ GATE_LEDGER=__SCHEMA__.ledger GATE_SUBJECT_ROOT=__PROJECT_ROOT__ python3 __AUTOHARN_ROOT__/hooks/posttooluse_mutation_observer.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Task|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "env LEDGER_HOST=__HOST__ LEDGER_DB=__DB__ GATE_LEDGER=__SCHEMA__.ledger GATE_SUBJECT_ROOT=__PROJECT_ROOT__ python3 __AUTOHARN_ROOT__/hooks/pretooluse_delegation_observer.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "env GATE_SUBJECT_ROOT=__PROJECT_ROOT__ python3 __AUTOHARN_ROOT__/hooks/pretooluse_doc_shapes_gate.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "env GATE_SUBJECT_ROOT=__PROJECT_ROOT__ python3 __AUTOHARN_ROOT__/hooks/pretooluse_read_observer.py",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "env LEDGER_HOST=__HOST__ LEDGER_DB=__DB__ GATE_LEDGER=__SCHEMA__.ledger GATE_SUBJECT_ROOT=__PROJECT_ROOT__ python3 __AUTOHARN_ROOT__/hooks/posttooluse_mutation_observer.py",
            "timeout": 20
          },
          {
            "type": "command",
            "command": "env GATE_SUBJECT_ROOT=__PROJECT_ROOT__ python3 __AUTOHARN_ROOT__/hooks/posttooluse_bash_completion.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "env GATE_SUBJECT_ROOT=__PROJECT_ROOT__ python3 __AUTOHARN_ROOT__/hooks/posttooluse_apparatus_flip.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Task|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "env LEDGER_HOST=__HOST__ LEDGER_DB=__DB__ GATE_LEDGER=__SCHEMA__.ledger GATE_SUBJECT_ROOT=__PROJECT_ROOT__ python3 __AUTOHARN_ROOT__/hooks/pretooluse_delegation_observer.py",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "env LEDGER_HOST=__HOST__ LEDGER_DB=__DB__ GATE_LEDGER=__SCHEMA__.ledger GATE_SUBJECT_ROOT=__PROJECT_ROOT__ STOP_CLEAN_EXIT_STATE=__PROJECT_ROOT__/.claude/stop_clean_exit_state.json python3 __AUTOHARN_ROOT__/hooks/stop_clean_exit.py",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "python3 __AUTOHARN_ROOT__/hooks/demurral_detect.py",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
