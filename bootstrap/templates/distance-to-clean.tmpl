#!/usr/bin/env python3
"""distance-to-clean -- REBASED onto the boundary service (design/FABLE-BOUNDARY-MULTIPLEX-AND-
CLI-REBASE-SPEC.md §5, ratified ledger row 1631; design/FABLE-BOUNDARY-READ-SURFACE-SPEC.md,
ratified row 1652, whose `GET /d/{deployment}/views/{view}` route is what makes this rebase
possible at all -- `review_gap`/`question_status`/`work_item_violations`/`work_review_gap` have
no home on the boundary's original eleven routes). Same argv surface, same five-section report,
same TOTAL/exit-code convention as the legacy direct-psql original (now
`legacy-distance-to-clean.tmpl`, reachable via `./legacy/distance-to-clean`) -- only the
TRANSPORT differs. DOC-ATTESTATION stays untouched (pure filesystem + local JSONL ledger, no DB
involved at all, spec is silent on it because there is nothing to rebase).

CAPABILITY GAPS, RE-EXPRESSED VIA TYPED BOUNDARY SHAPES (an IMPROVEMENT in signal quality, not
just a transport swap): the legacy tool distinguishes "pre-s20 grants gap" from "pre-s22/s29
capability absent" from "a genuine error" by GREPPING `r.stderr` for the substrings "permission
denied" / "does not exist" -- fragile, and exactly the kind of text-matching this project's own
house style otherwise avoids. The served path gets the SAME three-way distinction for free, from
the boundary's own TYPED status codes: `capability_absent` (409, the view/table object itself
does not exist -- pre-s22/s29) vs any OTHER non-200 (a genuine defect, including the pre-s20
grants gap, which surfaces server-side as a typed `unclassified_failure` 500 rather than a raw
"permission denied" string this client would have to grep for).

Lazy imports banned (CLAUDE.md, 2026-07-02): every import is top-of-file."""
from __future__ import annotations

import json
import os
import sys
from pathlib import Path

HERE = Path(__file__).resolve().parent
AUTOHARN = Path(os.environ.get("AUTOHARN", str(HERE / ".." / ".."))).resolve()
DEPLOYMENT_PATH = Path(os.environ.get("PICKUP_DEPLOYMENT", str(HERE / "deployment.json")))
PROJECT_ROOT = DEPLOYMENT_PATH.parent

sys.path.insert(0, str(AUTOHARN / "serving"))
sys.path.insert(0, str(AUTOHARN / "filing"))
try:
    import boundary_cli_client as bcc  # noqa: E402
except ImportError as _e:
    print(f"distance-to-clean: cannot import autoharn's serving/boundary_cli_client.py under "
          f"AUTOHARN={AUTOHARN} ({_e.__class__.__name__}: {_e})", file=sys.stderr)
    print("        set AUTOHARN=/path/to/autoharn, or place a sibling checkout at ../autoharn", file=sys.stderr)
    sys.exit(4)

sys.path.insert(0, str(AUTOHARN / "gates"))
try:
    import doc_attestation_presence as dap  # noqa: E402  (autoharn's own gate module, the ONE home of the classifier)
except ImportError as _e:
    print(f"distance-to-clean: cannot import autoharn's gates/doc_attestation_presence.py under "
          f"AUTOHARN={AUTOHARN} ({_e.__class__.__name__}: {_e})", file=sys.stderr)
    print("        set AUTOHARN=/path/to/autoharn, or place a sibling checkout at ../autoharn", file=sys.stderr)
    sys.exit(4)
dap.REPO_ROOT = PROJECT_ROOT
dap.LEDGER_PATH = PROJECT_ROOT / "attestations" / "doc-legibility-attestations.jsonl"

MECHANISM_KEY = "doc_attestation"
_VALID_DOC_ATTESTATION_MODES = ("off", "observe")


def _doc_attestation_mode(project_root: Path) -> str:
    """Byte-identical to the legacy tool's own `_doc_attestation_mode` -- pure filesystem, no
    boundary involved, so nothing here needed to change; reproduced rather than imported across
    the served/legacy module boundary because DOC-ATTESTATION is the one section that owes
    NOTHING to this rebase (ADR-0012 P1 would normally argue for import-not-duplicate, but the
    two templates are meant to keep working independently of one another -- see
    legacy-distance-to-clean.tmpl's own note on the SAME tension asof-export.tmpl resolved the
    other way; this function is four lines and has no boundary/DB dependency to drift against)."""
    path = project_root / ".claude" / "apparatus.json"
    try:
        with open(path, encoding="utf-8") as f:
            apparatus = json.load(f)
    except Exception:
        return "off"
    if not isinstance(apparatus, dict):
        return "off"
    mechs = apparatus.get("mechanisms")
    entry = mechs.get(MECHANISM_KEY) if isinstance(mechs, dict) else None
    entry = entry if isinstance(entry, dict) else {}
    raw = entry.get("mode")
    if raw is None:
        return "off"
    if raw == "enforce":
        print(f"[apparatus] WARNING: mechanisms.{MECHANISM_KEY}.mode='enforce' is not "
              f"applicable ({MECHANISM_KEY} only ever REPORTS debt, it has no deny path) -- "
              f"behaving as 'observe'. ({path})", file=sys.stderr)
        return "observe"
    if raw in _VALID_DOC_ATTESTATION_MODES:
        return raw
    print(f"[apparatus] WARNING: mechanisms.{MECHANISM_KEY}.mode={raw!r} in {path} is "
          f"unrecognized (must be one of {_VALID_DOC_ATTESTATION_MODES}) -- never widening; "
          f"falling back to 'off'.", file=sys.stderr)
    return "off"


def doc_attestation_debt(project_root: Path) -> tuple[int, dict[str, int], list[str]]:
    targets = dap.discover_md(project_root)
    scope = [t for t in targets if dap.deployment_in_scope(t)
             and not dap._has_waiver(project_root / t)]
    records = dap.load_ledger()
    counts = {"ATTESTED": 0, "STALE": 0, "NO-ATTESTATION": 0}
    debt_docs: list[str] = []
    for rel in sorted(scope):
        verdict = dap.classify(rel, records, project_root)
        counts[verdict] += 1
        if verdict != "ATTESTED":
            debt_docs.append(f"{rel} ({verdict})")
    return counts["STALE"] + counts["NO-ATTESTATION"], counts, debt_docs


def _load_config() -> bcc.ServedConfig:
    try:
        cfg = bcc.load_served_config(DEPLOYMENT_PATH)
    except bcc.BoundaryClientError as e:
        print(f"distance-to-clean: {e}", file=sys.stderr)
        sys.exit(4)
    # Version handshake (design/FABLE-AUTOHARN-UMBRELLA-CLI-SPEC.md §3): checked here, the one
    # choke point every served call passes through (ADR-0012 P1), before any real read is issued.
    bcc.check_protocol_version(cfg.base, cfg.record.boundary_url)
    return cfg


def _view_debt(cfg: bcc.ServedConfig, view: str, cursor: str,
                capability_hint: str) -> tuple[int, list, str | None]:
    """Returns (count, key-values, reason). `reason` is set (count meaningless) iff the boundary
    refused -- `capability_absent` (409) becomes an UNAVAILABLE line (mirrors the legacy tool's
    own "does not exist" leg) -- the boundary's OWN message is used when it carries one (as of
    the /views/{view} column-shape check, `capability_absent` covers TWO distinct facts: the
    view object itself is absent, OR the object exists but lacks the key column this route's
    pagination needs -- e.g. a pre-s37 world's `work_item_violations`, live-witnessed against
    this repo's own `autoharn1` world; the boundary's own message already distinguishes them
    precisely, so `capability_hint` is only a FALLBACK for the rare case its body carries no
    `message` key at all); any other non-200 becomes an ERROR/BLOCKED line (mirrors the legacy
    tool's own "permission denied"/generic-error legs, INCLUDING the pre-s20 grants gap, which
    the boundary itself now types as `unclassified_failure` rather than this client grepping
    stderr text for it)."""
    try:
        rows = bcc.get_all_rows(cfg.base, f"/views/{view}", cursor=cursor)
    except bcc.BoundaryRefusal as e:
        if e.status == 409:
            message = e.body.get("message") if isinstance(e.body, dict) else None
            return 0, [], (f"UNAVAILABLE ({message or capability_hint})")
        detail = e.body.get("message") if isinstance(e.body, dict) else e.body
        return 0, [], f"ERROR/BLOCKED (boundary HTTP {e.status}): {detail}"
    return len(rows), rows, None


def main() -> int:
    cfg = _load_config()
    print("### SECTION: DISTANCE-TO-CLEAN")
    print()
    print("(served via the boundary, design/FABLE-BOUNDARY-MULTIPLEX-AND-CLI-REBASE-SPEC.md §5 -- "
          "reads the SAME views `led review-gap` / `led question-status` / `led work violations` "
          "already expose, PLUS the two categories the stop-gate hook (hooks/stop_clean_exit.py) "
          "also checks that those three commands don't -- computes nothing new)")
    print()

    total = 0
    any_blocked = False

    rg_count, rg_rows, rg_reason = _view_debt(
        cfg, "review_gap", "after_id", "no countersign_obligation/review_gap object -- pre-s20")
    if rg_reason:
        print(f"review-gap        : {rg_reason}")
        any_blocked = True
    else:
        total += rg_count
        rg_ids = [r["id"] for r in rg_rows]
        print(f"review-gap        : {rg_count} row(s)" + (f" -- ids: {rg_ids}" if rg_ids else ""))

    qs_count, qs_rows, qs_reason = _view_debt(
        cfg, "question_status", "after_id", "no question_status object -- pre-s14")
    if qs_reason:
        print(f"question-status   : {qs_reason}")
        any_blocked = True
    else:
        qs_open_ids = [r["question_id"] for r in qs_rows if r.get("answered") is False]
        total += len(qs_open_ids)
        print(f"question-status   : {len(qs_open_ids)} open of {len(qs_rows)} total" +
              (f" -- open ids: {qs_open_ids}" if qs_open_ids else ""))

    wv_count, wv_rows, wv_reason = _view_debt(
        cfg, "work_item_violations", "after_slug",
        "no work-item layer -- this world's applied kernel predates "
        "kernel/lineage/s22-work-item-ledger.sql")
    if wv_reason:
        print(f"work-violations   : {wv_reason}")
        if wv_reason.startswith("ERROR"):
            any_blocked = True
    else:
        total += wv_count
        wv_slugs = [r["slug"] for r in wv_rows]
        print(f"work-violations   : {wv_count} violation(s)" +
              (f" -- slugs: {wv_slugs}" if wv_slugs else ""))

    # work_item_current, filtered client-side to open+claimed (spec's own "no server-side filter
    # grammar in v1: shims filter client-side over paginated output" discipline) -- the SAME
    # conservative DEGRADE predicate the legacy tool's own `work_item_current_debt` uses (this
    # tool has no session identity to narrow claims with, exactly like the legacy original).
    try:
        wi_rows_all = bcc.get_all_rows(cfg.base, "/work/items", cursor="after_slug")
        wi_rows = [r for r in wi_rows_all if r.get("state") == "open" and r.get("claimant") is not None]
        wi_reason = None
    except bcc.BoundaryRefusal as e:
        wi_rows = []
        if e.status == 409:
            wi_reason = ("UNAVAILABLE (no work-item layer -- this world's applied kernel "
                          "predates kernel/lineage/s22-work-item-ledger.sql)")
        else:
            detail = e.body.get("message") if isinstance(e.body, dict) else e.body
            wi_reason = f"ERROR/BLOCKED (boundary HTTP {e.status}): {detail}"
    if wi_reason:
        print(f"work-items        : {wi_reason}")
        if wi_reason.startswith("ERROR"):
            any_blocked = True
    else:
        total += len(wi_rows)
        wi_slugs = [r["slug"] for r in wi_rows]
        print(f"work-items        : {len(wi_rows)} open+claimed item(s) [CAVEAT: this tool has "
              f"no session identity, unlike the stop-gate hook -- it cannot narrow to only THIS "
              f"session's claims, so it counts every claimed-open item, matching the hook's own "
              f"DEGRADE fallback for when session ownership can't be proven]" +
              (f" -- slugs: {wi_slugs}" if wi_slugs else ""))

    wrg_count, wrg_rows, wrg_reason = _view_debt(
        cfg, "work_review_gap", "after_slug",
        "no deferred-review layer -- this world's applied kernel predates the s29 "
        "work_review_gap view")
    if wrg_reason:
        print(f"work-review-gap   : {wrg_reason}")
        if wrg_reason.startswith("ERROR"):
            any_blocked = True
    else:
        total += wrg_count
        wrg_slugs = [r["slug"] for r in wrg_rows]
        print(f"work-review-gap   : {wrg_count} deferred-review item(s)" +
              (f" -- slugs: {wrg_slugs}" if wrg_slugs else ""))

    da_mode = _doc_attestation_mode(PROJECT_ROOT)
    if da_mode == "off":
        print(f"doc-attestation   : off (opt-in -- set mechanisms.{MECHANISM_KEY}.mode to "
              f"'observe' in .claude/apparatus.json once you're running the ADR-0017 A:B:C "
              f"loop, so debt here reflects a discipline you actually adopted)")
    else:
        da_debt, da_counts, da_docs = doc_attestation_debt(PROJECT_ROOT)
        total += da_debt
        print(f"doc-attestation   : {da_debt} debt ({da_counts['NO-ATTESTATION']} "
              f"NO-ATTESTATION, {da_counts['STALE']} STALE, {da_counts['ATTESTED']} ATTESTED)" +
              (f" -- {da_docs}" if da_docs else ""))

    print()
    if any_blocked:
        print(f"TOTAL debt: {total} counted (+ one or more dimensions blocked/errored above -- "
              f"not a clean read; see the lines above for the reason)")
        return 1
    print(f"TOTAL debt: {total}" + ("  (0 = clean)" if total == 0 else ""))
    return 0 if total == 0 else 1


if __name__ == "__main__":
    try:
        sys.exit(main())
    except bcc.ProtocolVersionMismatch as e:
        sys.exit(bcc.report_protocol_mismatch("distance-to-clean", e))
    except (bcc.BoundaryRefusal, bcc.BoundaryUnreachable, bcc.BoundaryClientError) as e:
        sys.exit(bcc.report_boundary_exception("distance-to-clean", e))
