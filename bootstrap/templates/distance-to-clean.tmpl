#!/usr/bin/env python3
"""distance-to-clean — the composed closure-debt verb (BACKLOG "Five-item batch,
maintainer-approved 2026-07-11 evening", item 1; design/RETROSPECTIVE-RUN10.md Finding 1).

WHAT THIS IS FOR, VERBATIM FROM THE MAINTAINER'S CONDITION: "we shouldn't aggregate
something ... that may have valid use-cases disaggregated (indeed, it is my sense that the
disaggregated view ... is the default). If that can work simultaneously, I'd concur." So:
`led review-gap`, `led question-status`, and `led work violations` are UNTOUCHED by this file
and remain the documented default, disaggregated way to read closure debt. This verb is
strictly ADDITIVE — it reads the SAME THREE EXISTING VIEWS those three commands already read
(`review_gap`, `question_status`, `work_item_violations`) and prints their counts and ids in
ONE pass, computing nothing new: no new SQL logic, no new join, no derived predicate beyond
what those views already compute. It exists to kill the run10 pattern the retrospective named:
47 of run10's 299 invocations (about 16%) were bare polls of `./led review-gap` alone, because
one call could not answer "how far am I from a clean stop" — this call can.

WHY A NEW VERB, NOT A `led` SUBCOMMAND: `bootstrap/templates/led.tmpl` is a live-executed
template (the "live verbs" ruling, 2026-07-11 — every scaffolded world's `./led` shim `exec`s
this file directly, every invocation) and is therefore freeze-bound: it may only be edited
while no wired session is live anywhere. A brand-new template file carries no such constraint
(a file nothing yet execs is safe to add at any time), and mirrors this project's own existing
precedent for growing the verb surface without touching an existing live verb: `audit.tmpl`
landed as a fifth verb alongside led/judge/pickup exactly this way (BACKLOG "Contemporaneity
indictment"). `bootstrap/new-project.sh`'s shim-writing loop is extended by one name
(`distance-to-clean`) to wire it in — that script is not itself live-executed by any running
world (only the scaffold-time act reads it), so widening its verb list carries none of
led.tmpl's freeze risk.

Sections emitted, one call, one pass:
  REVIEW-GAP        — `review_gap` (the SAME view `led review-gap` reads): every row (id) an
                      obliged actor wrote with no distinct-actor attest countersign yet.
  QUESTION-STATUS   — `question_status` (the SAME view `led question-status` reads): every
                      open (unanswered) question, by id — the view's own pre-computed
                      `answered` column is READ, not re-derived.
  WORK-VIOLATIONS   — `work_item_violations` (the SAME view `led work violations` reads): every
                      violation row, by slug — UNAVAILABLE (not zero) on a world whose kernel
                      predates kernel/lineage/s22-work-item-ledger.sql, mirroring pickup.tmpl's
                      own honest IN-FLIGHT fallback for the identical capability gap.
  TOTAL             — the sum of the three counts above (0 iff all three are individually
                      clean) plus the one-line verdict `led review-gap`/`question-status`/
                      `work violations` would each print separately today, now in one place.

Deployment resolution, connection posture, and path resolution: byte-identical to
pickup.tmpl's own module docstring section of the same name — this file executes IN PLACE out
of the autoharn checkout (the "live verbs" ruling), `PICKUP_DEPLOYMENT` is set by the
scaffolded shim to the world's own `deployment.json`, `AUTOHARN` resolves from this file's own
on-disk path (overridable), and every query here queries under the project's OWN granted role
(`SET ROLE <dep.role>`) — the same "what can the OPERATING AGENT see" posture pickup.tmpl's
REVIEW-DEBT section already documents, reused rather than re-derived (ADR-0012 P1: one
resolution mechanism, not a second copy).

Read-only throughout: every query here is a SELECT; this script issues no INSERT/UPDATE/DELETE.
Lazy imports banned (top-of-file only, per this project's inherited convention).
"""
from __future__ import annotations

import os
import subprocess
import sys
from pathlib import Path

HERE = Path(__file__).resolve().parent
AUTOHARN = Path(os.environ.get("AUTOHARN", str(HERE / ".." / ".."))).resolve()
DEPLOYMENT_PATH = Path(os.environ.get("PICKUP_DEPLOYMENT", str(HERE / "deployment.json")))

sys.path.insert(0, str(AUTOHARN / "filing"))
try:
    import deployment_record  # noqa: E402  (filing/deployment_record.py, the ONE home for the shape)
except ImportError as _e:
    print(f"distance-to-clean: cannot import autoharn's filing/deployment_record.py under "
          f"AUTOHARN={AUTOHARN} ({_e.__class__.__name__}: {_e})", file=sys.stderr)
    print("        set AUTOHARN=/path/to/autoharn, or place a sibling checkout at ../autoharn", file=sys.stderr)
    sys.exit(2)


def _load_deployment():
    try:
        return deployment_record.load_deployment(DEPLOYMENT_PATH)
    except deployment_record.DeploymentError as e:
        print(f"distance-to-clean: {e}", file=sys.stderr)
        sys.exit(2)


def _psql_tuples(dep, sql: str) -> subprocess.CompletedProcess:
    """SET ROLE <dep.role> first (pickup.tmpl's REVIEW-DEBT posture, reused here for every
    section, not just one): this verb's honest job is "what can the OPERATING AGENT see", so a
    pre-s20 grants gap surfaces as the same BLOCKED report pickup.tmpl already gives, never a
    silently-empty debt count that would misreport a world as cleaner than it is."""
    full = f"SET ROLE {dep.role};\n{sql}"
    return subprocess.run(
        ["psql", "-h", dep.host, "-d", dep.db, "-t", "-A", "-v", "ON_ERROR_STOP=1", "-c", full],
        capture_output=True, text=True, timeout=15)


def _last_stmt_rows(r: subprocess.CompletedProcess) -> list[str]:
    """-t -A still echoes one line per statement executed (the preceding SET ROLE included, per
    pickup.tmpl's own _psql_tuples docstring) -- drop exactly that leading line, keep the rest."""
    lines = r.stdout.strip("\n").splitlines()
    return lines[1:] if lines else []


def review_gap_debt(dep) -> tuple[int, list[str], str | None]:
    """Returns (count, ids, blocked_reason). blocked_reason is set, and count/ids are
    meaningless, iff the pre-s20 grants gap denies this read (pickup.tmpl's own named case)."""
    r = _psql_tuples(dep, f"SELECT id FROM {dep.schema}.review_gap ORDER BY id;")
    if r.returncode != 0:
        if "permission denied" in r.stderr:
            return 0, [], ("BLOCKED: pre-s20 grants -- the granted role has no SELECT on "
                            "countersign_obligation in the applied kernel lineage (see "
                            "pickup's REVIEW-DEBT section for the identical, pre-existing gap)")
        return 0, [], f"ERROR: {r.stderr.strip()}"
    rows = _last_stmt_rows(r)
    return len(rows), rows, None


def question_status_debt(dep) -> tuple[int, int, list[str], str | None]:
    """Returns (open_count, total_count, open_ids, error). `answered` is the view's OWN
    pre-computed column (question_status, s15-schema.sql) -- read here, not re-derived."""
    r = _psql_tuples(dep, f"SELECT question_id, answered FROM {dep.schema}.question_status "
                          f"ORDER BY question_id;")
    if r.returncode != 0:
        return 0, 0, [], f"ERROR: {r.stderr.strip()}"
    rows = _last_stmt_rows(r)
    open_ids = []
    for row in rows:
        qid, _, answered = row.partition("|")
        if answered.strip() == "f":
            open_ids.append(qid.strip())
    return len(open_ids), len(rows), open_ids, None


def work_violations_debt(dep) -> tuple[int, list[str], str | None]:
    """Returns (count, slugs, unavailable_reason). UNAVAILABLE (not zero) mirrors pickup.tmpl's
    IN-FLIGHT section: a pre-s22 world has no work_item_violations at all -- absence of the
    view is a capability gap, not evidence of zero debt."""
    r = _psql_tuples(dep, f"SELECT slug FROM {dep.schema}.work_item_violations ORDER BY slug;")
    if r.returncode != 0:
        if "does not exist" in r.stderr:
            return 0, [], ("UNAVAILABLE (no work-item layer -- this world's applied kernel "
                            "predates kernel/lineage/s22-work-item-ledger.sql)")
        return 0, [], f"ERROR: {r.stderr.strip()}"
    rows = _last_stmt_rows(r)
    return len(rows), rows, None


def main() -> int:
    dep = _load_deployment()
    print("### SECTION: DISTANCE-TO-CLEAN")
    print()
    print("(reads the SAME three views `led review-gap` / `led question-status` / "
          "`led work violations` already expose, in one pass -- computes nothing new; "
          "those three commands remain the disaggregated default, unchanged by this verb)")
    print()

    total = 0
    any_blocked = False

    rg_count, rg_ids, rg_blocked = review_gap_debt(dep)
    if rg_blocked:
        print(f"review-gap        : {rg_blocked}")
        any_blocked = True
    else:
        total += rg_count
        print(f"review-gap        : {rg_count} row(s)" +
              (f" -- ids: {rg_ids}" if rg_ids else ""))

    qs_open, qs_total, qs_ids, qs_err = question_status_debt(dep)
    if qs_err:
        print(f"question-status   : {qs_err}")
        any_blocked = True
    else:
        total += qs_open
        print(f"question-status   : {qs_open} open of {qs_total} total" +
              (f" -- open ids: {qs_ids}" if qs_ids else ""))

    wv_count, wv_slugs, wv_reason = work_violations_debt(dep)
    if wv_reason:
        print(f"work-violations   : {wv_reason}")
        if wv_reason.startswith("ERROR"):
            any_blocked = True
    else:
        total += wv_count
        print(f"work-violations   : {wv_count} violation(s)" +
              (f" -- slugs: {wv_slugs}" if wv_slugs else ""))

    print()
    if any_blocked:
        print(f"TOTAL debt: {total} counted (+ one or more dimensions blocked/errored above -- "
              f"not a clean read; see the lines above for the reason)")
        return 1
    print(f"TOTAL debt: {total}" + ("  (0 = clean)" if total == 0 else ""))
    return 0 if total == 0 else 1


if __name__ == "__main__":
    sys.exit(main())
