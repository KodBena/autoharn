#!/usr/bin/env python3
"""pickup -- REBASED onto the boundary service (design/FABLE-BOUNDARY-MULTIPLEX-AND-CLI-REBASE-
SPEC.md §5, ratified ledger row 1631; design/FABLE-BOUNDARY-READ-SURFACE-SPEC.md, ratified row
1652). The direct-psql original is `legacy-pickup.tmpl` (`./legacy/pickup`) -- 1200+ lines and a
dozen sections; see "SCOPE, HONESTLY NAMED" below for exactly what runs through the boundary here.

SCOPE, HONESTLY NAMED:
  COVERED  STANDING-DECISIONS (design/FABLE-GRADED-DECISIONS-SPEC.md, /views/standing_decisions),
           IN-FORCE-DECISIONS (/rows/current, id-descending, the SQL-floor reading),
           OPEN-QUESTIONS (/views/question_status), REVIEW-DEBT (/views/review_gap) -- the FOUR
           sections the read-surface amendment's own §5 seam stop named explicitly as blocked
           without the /views/{view} route; now unblocked, rebased first.
  NOT COVERED (UNEXERCISED by this build, named rather than silently dropped -- run
           `./legacy/pickup` for these): RESOURCES/ESTIMATES/TAXONOMIES/MAINTAINER-REVIEW-QUEUE
           (each its own statement-prefix-convention scan over the WHOLE ledger_current, with
           substantial parsing logic this rebase did not have room to port faithfully),
           RECENT-CHANGES (git log), GIT-STATE (git status), IN-FLIGHT (a session-journal join),
           ROLLUP (a composed summary over several of the above). This is a real, bounded scope
           decision for THIS commission, not a structural incompatibility the way `led obligate
           revoke` is elsewhere in this rebase -- a future pass can extend
           `boundary_cli_client.py`'s coverage to them the same way this one did for the four
           sections above.

Lazy imports banned (CLAUDE.md, 2026-07-02): every import is top-of-file."""
from __future__ import annotations

import argparse
import json
import os
import sys
from pathlib import Path

HERE = Path(__file__).resolve().parent
AUTOHARN = Path(os.environ.get("AUTOHARN", str(HERE / ".." / ".."))).resolve()
DEPLOYMENT_PATH = Path(os.environ.get("PICKUP_DEPLOYMENT", str(HERE / "deployment.json")))

sys.path.insert(0, str(AUTOHARN / "serving"))
sys.path.insert(0, str(AUTOHARN / "filing"))
try:
    import boundary_cli_client as bcc  # noqa: E402
    import standing_decisions_config  # noqa: E402  (filing/standing_decisions_config.py, the ONE
                                       # home for the grades/byte_cap defaulting logic -- shared
                                       # with hooks/sessionstart_durable_decisions.py AND the
                                       # legacy pickup, ADR-0012 P1, no DB dependency of its own)
except ImportError as _e:
    print(f"pickup: cannot import autoharn's serving/boundary_cli_client.py or "
          f"filing/standing_decisions_config.py under AUTOHARN={AUTOHARN} "
          f"({_e.__class__.__name__}: {_e})", file=sys.stderr)
    print("        set AUTOHARN=/path/to/autoharn, or place a sibling checkout at ../autoharn", file=sys.stderr)
    sys.exit(4)


def _load_config() -> bcc.ServedConfig:
    try:
        cfg = bcc.load_served_config(DEPLOYMENT_PATH)
    except bcc.BoundaryClientError as e:
        print(f"pickup: {e}", file=sys.stderr)
        sys.exit(4)
    # Version handshake (design/FABLE-AUTOHARN-UMBRELLA-CLI-SPEC.md §3): checked here, the one
    # choke point every served call passes through (ADR-0012 P1), before any real read is issued.
    bcc.check_protocol_version(cfg.base, cfg.record.boundary_url)
    return cfg


def _section(name: str) -> None:
    print(f"\n### SECTION: {name}\n")


def _load_apparatus(dep_dir: Path) -> dict:
    path = dep_dir / ".claude" / "apparatus.json"
    try:
        with open(path, encoding="utf-8") as f:
            cfg = json.load(f)
        return cfg if isinstance(cfg, dict) else {}
    except Exception:
        return {}


def standing_decisions(cfg: bcc.ServedConfig) -> None:
    _section("STANDING-DECISIONS")
    apparatus = _load_apparatus(DEPLOYMENT_PATH.parent)
    mechs = apparatus.get("mechanisms")
    entry = mechs.get("standing_decisions") if isinstance(mechs, dict) else None
    grades, byte_cap, max_items = standing_decisions_config.resolve_standing_decisions_config(entry)
    try:
        rows = bcc.get_all_rows(cfg.base, "/views/standing_decisions", cursor="after_id")
    except bcc.BoundaryRefusal as e:
        if e.status == 409:
            print("(this world's kernel predates kernel/lineage/s36-decision-grade.sql -- no "
                  "standing decisions to show; apply s36 to this schema as a maintainer act to "
                  "adopt graded decisions, or there is nothing more to do here)")
            return
        detail = e.body.get("message") if isinstance(e.body, dict) else e.body
        print(f"ERROR: boundary HTTP {e.status}: {detail}")
        return
    rows = [r for r in rows if r.get("grade") in grades]
    if not rows:
        print(f"(no standing decisions on record in this deployment's configured grade set: {grades})")
        return
    rendered: list[str] = []
    budget = byte_cap
    shown = 0
    for r in sorted(rows, key=lambda r: r["id"]):
        if max_items is not None and shown >= max_items:
            break
        statement = " ".join(str(r.get("statement", "")).splitlines())
        line = f"{r['id']}\t{r['grade']}\t{statement}"
        cost = len(line.encode("utf-8")) + 1
        if cost > budget:
            break
        rendered.append(line)
        budget -= cost
        shown += 1
    remaining = len(rows) - shown
    if remaining > 0:
        rendered.append(f"ACTION REQUIRED: {remaining} more standing decision(s) omitted -- run "
                         f"`./led standing` NOW to read them before proceeding.")
    print("\n".join(rendered))


def in_force_decisions(cfg: bcc.ServedConfig, n: int) -> None:
    _section("IN-FORCE-DECISIONS")
    rows = bcc.get_all_rows(cfg.base, "/rows/current", cursor="after_id")
    top = sorted(rows, key=lambda r: -r["id"])[:n]
    if not top:
        print("(no rows)")
        return
    for r in top:
        print(f"{r['id']}\t{r['kind']}\t{r.get('statement', '')}")


def open_questions(cfg: bcc.ServedConfig) -> None:
    _section("OPEN-QUESTIONS")
    try:
        rows = bcc.get_all_rows(cfg.base, "/views/question_status", cursor="after_id")
    except bcc.BoundaryRefusal as e:
        detail = e.body.get("message") if isinstance(e.body, dict) else e.body
        print(f"ERROR: boundary HTTP {e.status}: {detail}")
        return
    if not rows:
        print("(no questions on record)")
        return
    for r in sorted(rows, key=lambda r: r["question_id"]):
        print(json.dumps(r, sort_keys=True))


def review_debt(cfg: bcc.ServedConfig) -> None:
    _section("REVIEW-DEBT")
    try:
        rows = bcc.get_all_rows(cfg.base, "/views/review_gap", cursor="after_id")
    except bcc.BoundaryRefusal as e:
        if e.status == 409:
            print("BLOCKED: pre-s20 grants, OR this world's kernel predates review_gap "
                  "(autoharn BACKLOG.md, 2026-07-09) -- the boundary reports this as a typed "
                  "capability_absent (see its own message below), not a bug in this script.")
            detail = e.body.get("message") if isinstance(e.body, dict) else e.body
            print(f"  {detail}")
            return
        detail = e.body.get("message") if isinstance(e.body, dict) else e.body
        print(f"ERROR: boundary HTTP {e.status}: {detail}")
        return
    if not rows:
        print("(no review debt outstanding)")
        return
    for r in sorted(rows, key=lambda r: r["id"]):
        print(json.dumps(r, sort_keys=True))


def main(argv: list[str] | None = None) -> int:
    ap = argparse.ArgumentParser(description=__doc__.splitlines()[0])
    ap.add_argument("--since", default=None, help="UNEXERCISED by this rebase -- see module docstring")
    ap.add_argument("-n", "--limit", type=int, default=10)
    args = ap.parse_args(argv)

    cfg = _load_config()
    try:
        bcc.get_json(cfg.base, "/health")
    except bcc.BoundaryRefusal as e:
        print(f"pickup: CANNOT-HYDRATE -- the boundary refused /health (HTTP {e.status}): "
              f"{e.body}", file=sys.stderr)
        return 3

    standing_decisions(cfg)
    in_force_decisions(cfg, args.limit)
    open_questions(cfg)
    review_debt(cfg)
    print()
    print("### SECTION: NOT-REBASED")
    print()
    print("RESOURCES / ESTIMATES / TAXONOMIES / MAINTAINER-REVIEW-QUEUE / RECENT-CHANGES / "
          "GIT-STATE / IN-FLIGHT / ROLLUP are UNEXERCISED by this rebase -- run ./legacy/pickup "
          "for the full brief (design/FABLE-BOUNDARY-MULTIPLEX-AND-CLI-REBASE-SPEC.md §5; see "
          "this file's own module docstring SCOPE section).")
    return 0


if __name__ == "__main__":
    try:
        sys.exit(main())
    except bcc.ProtocolVersionMismatch as e:
        sys.exit(bcc.report_protocol_mismatch("pickup", e))
    except (bcc.BoundaryRefusal, bcc.BoundaryUnreachable, bcc.BoundaryClientError) as e:
        sys.exit(bcc.report_boundary_exception("pickup", e))
