#!/usr/bin/env python3
"""pickup — the resume verb (design/ORCH-OPUS-READINESS.md move 3; the fourth verb alongside
led/judge/the scaffold). The operator's cold-start problem: "with a complex project I never
know how to restart." The rule this script exists to honor: the brief is DERIVED AT PICKUP
TIME, never stored — a stored handoff decays from the moment of writing. Every section below
reads a LIVE source and prints it; nothing here is cached or written back.

Sections emitted, each under a machine-parseable `### SECTION: <NAME>` header (grep
`^### SECTION: ` to split this script's own output programmatically):

  IN-FORCE-DECISIONS  — the SQL floor `ledger_current` view (supersedes-filtered). v1 ships the
                        SQL floor only; a future pass may also print the ASP T_now verdict via
                        `judge`, once the engine wiring is the routine path here too.
  OPEN-QUESTIONS      — the `question_status` view: every open/answered question.
  REVIEW-DEBT         — the `review_gap` view: obliged-actor rows with no distinct-actor attest
                        countersign yet. Queried under `SET ROLE <this project's granted role>`
                        (not the operator identity `led`'s own display verbs use) because this
                        section's honest job is "what can the OPERATING AGENT see" — and a known
                        kernel grants gap (autoharn BACKLOG, 2026-07-09, "pre-s20") means this can
                        legitimately come back `permission denied`; that is caught and reported as
                        `BLOCKED: pre-s20 grants`, not papered over as an empty result.
  RESOURCES           — design/ORCH-SPEC-RESOURCE-REGISTRY.md stage 1 (the Pillar-1 capability
                        registry, GLOSSARY.md#pillar-1): every unsuperseded `kind=decision` row
                        whose statement carries the `resource:` prefix convention (§2 — no kernel
                        `resource` kind exists yet; that is stage 3), read from the same
                        supersedes-filtered `ledger_current` view IN-FORCE-DECISIONS above already
                        uses. Printed TIER-SORTED, mandated first (spec §3), one block per
                        resource. Malformed statements (not exactly the six `|`-separated fields
                        §2 fixes: NAME/CLASS/REACH/WHAT-IT-PROVES/GUIDANCE/TIER) print flagged
                        MALFORMED rather than being silently dropped — a bad declaration is a
                        visible defect, not a swallowed one. An empty registry prints its own
                        explicit "(no resource declarations on record)" line — never omitted
                        silently, honesty over a section nobody has adopted yet.
  RECENT-CHANGES      — ledger rows since `--since <timestamptz>`, or the last `-n` rows (default
                        10) if `--since` is omitted.
  GIT-STATE           — this project's own git repo: uncommitted changes and (if it has an
                        upstream) unpushed commits.
  IN-FLIGHT           — derived live from the `work_item_current` view (open items: slug, title,
                        claimant), then -- for each open item -- the FULL statement text of its
                        `work_opened` ledger row, printed in full between `--- SPEC: <slug> ---`
                        / `--- END SPEC: <slug> ---` markers (BACKLOG "Run-8 mid-run forensics",
                        2026-07-11: slug/title/claimant alone left a resumed agent with no spec to
                        rebuild the task from -- the statement IS the spec). Then a violations line
                        from `work_item_violations` (count + kinds if non-empty; the explicit
                        "violations: none" if empty -- a silent absence must be distinguishable
                        from not-run, house rule). UNAVAILABLE, with the reason, if this world's
                        kernel predates the work-item layer (kernel/lineage/s22-work-item-
                        ledger.sql not applied here yet) -- the honest fallback, not a crash and
                        not the old stale text.

Deployment resolution: reads `deployment.json` next to this script (override with
`PICKUP_DEPLOYMENT=/path/to/deployment.json`), via autoharn's `filing/deployment_record.py` (the
ONE home for that JSON shape — this script derives from it rather than growing a second parser).
As of BACKLOG maintainer ruling 2026-07-11 ("live verbs"), this file executes IN PLACE out of the
autoharn checkout — the scaffolded `./pickup` is a 3-line shim that `exec`s THIS file directly,
never a copy — so `PICKUP_DEPLOYMENT` is ALWAYS set by that shim (to the shim's own directory,
i.e. the world root, `/deployment.json`); the `HERE`-relative default below only fires on a direct
invocation of this file with no shim (e.g. manual testing). GIT-STATE (below) reports on the
directory the deployment record was found in — the world root, not wherever this file itself
happens to live — for exactly this reason. autoharn's own location: two directories up from this
file's own on-disk path (it lives at `bootstrap/templates/pickup.tmpl` inside the real checkout
now), overridable with `AUTOHARN=/path/to/autoharn` (same convention as `judge`).

Read-only throughout: every query here is a SELECT; this script issues no INSERT/UPDATE/DELETE.
Lazy imports banned (top-of-file only, per this project's inherited convention).
"""
from __future__ import annotations

import argparse
import os
import subprocess
import sys
from pathlib import Path

HERE = Path(__file__).resolve().parent
AUTOHARN = Path(os.environ.get("AUTOHARN", str(HERE / ".." / ".."))).resolve()
DEPLOYMENT_PATH = Path(os.environ.get("PICKUP_DEPLOYMENT", str(HERE / "deployment.json")))

# eager, top-of-file (lazy imports banned): AUTOHARN is resolved above from env/the sibling-
# checkout convention BEFORE this insert+import runs, exactly the pattern
# instruments/ledger_target.py and engine/targets.py already use to reach a sibling module.
sys.path.insert(0, str(AUTOHARN / "filing"))
try:
    import deployment_record  # noqa: E402  (filing/deployment_record.py, the ONE home for the shape)
except ImportError as _e:
    print(f"pickup: cannot import autoharn's filing/deployment_record.py under "
          f"AUTOHARN={AUTOHARN} ({_e.__class__.__name__}: {_e})", file=sys.stderr)
    print("        set AUTOHARN=/path/to/autoharn, or place a sibling checkout at ../autoharn", file=sys.stderr)
    sys.exit(2)


def _load_deployment():
    try:
        return deployment_record.load_deployment(DEPLOYMENT_PATH)
    except deployment_record.DeploymentError as e:
        print(f"pickup: {e}", file=sys.stderr)
        sys.exit(2)


def _psql(dep, sql: str) -> subprocess.CompletedProcess:
    """Run `sql` as the project's granted subject role (SET ROLE dep.role) -- see module
    docstring on why REVIEW-DEBT deliberately queries under the constrained role."""
    full = f"SET ROLE {dep.role};\n{sql}"
    return subprocess.run(
        ["psql", "-h", dep.host, "-d", dep.db, "-v", "ON_ERROR_STOP=1", "-c", full],
        capture_output=True, text=True, timeout=15)


def _psql_tuples(dep, sql: str) -> subprocess.CompletedProcess:
    """Like `_psql` but with `-t -A` (tuples-only, unaligned) -- for a query this script's own
    logic branches on (the IN-FLIGHT violations line's count-vs-none house rule) or reproduces
    close to verbatim (the IN-FLIGHT spec block, which needs the exact statement text with no
    table borders/wrapping in the way) rather than a query merely displayed as psql's own
    formatted table."""
    full = f"SET ROLE {dep.role};\n{sql}"
    return subprocess.run(
        ["psql", "-h", dep.host, "-d", dep.db, "-t", "-A", "-v", "ON_ERROR_STOP=1", "-c", full],
        capture_output=True, text=True, timeout=15)


def _section(name: str) -> None:
    print(f"\n### SECTION: {name}\n")


def in_force_decisions(dep, n: int) -> None:
    _section("IN-FORCE-DECISIONS")
    r = _psql(dep, f"SELECT id, kind, statement FROM {dep.schema}.ledger_current "
                    f"ORDER BY id DESC LIMIT {int(n)};")
    if r.returncode != 0:
        print(f"ERROR: {r.stderr.strip()}")
    else:
        print(r.stdout.strip() or "(no rows)")


def open_questions(dep) -> None:
    _section("OPEN-QUESTIONS")
    r = _psql(dep, f"SELECT * FROM {dep.schema}.question_status ORDER BY question_id;")
    if r.returncode != 0:
        print(f"ERROR: {r.stderr.strip()}")
    else:
        print(r.stdout.strip() or "(no questions on record)")


def review_debt(dep) -> None:
    _section("REVIEW-DEBT")
    r = _psql(dep, f"SELECT * FROM {dep.schema}.review_gap ORDER BY id;")
    if r.returncode != 0:
        if "permission denied" in r.stderr:
            print("BLOCKED: pre-s20 grants -- the granted role has no SELECT on "
                  "countersign_obligation in the applied kernel lineage (autoharn BACKLOG.md, "
                  "2026-07-09; a kernel/lineage/s20 delta exists to fix this, apply is a "
                  "maintainer act). review_gap is security_invoker, so this is the constrained "
                  "role's own honest view, not a bug in this script.")
        else:
            print(f"ERROR: {r.stderr.strip()}")
    else:
        print(r.stdout.strip() or "(no review debt outstanding)")


# Field order §2 fixes for a `resource:`-prefixed decision statement (see this file's docstring
# RESOURCES entry and design/USER-BLESSED-TABLE-TEMPLATE.md's "statement grammars" section, the
# ONE place both this parser and an authoring agent read the grammar from -- this list is that
# grammar transcribed, not a second definition of it).
_RESOURCE_FIELDS = ("NAME", "CLASS", "REACH", "WHAT-IT-PROVES", "GUIDANCE", "TIER")


def _resource_tier_rank(tier: str) -> int:
    """mandated first, then blessed, then everything else (available, or an unrecognized tier
    string -- both sort last rather than erroring, since sorting is a display convenience, never
    a validation gate)."""
    t = tier.strip().lower()
    if t.startswith("mandated"):
        return 0
    if t.startswith("blessed"):
        return 1
    return 2


def resources(dep) -> None:
    _section("RESOURCES")
    r = _psql_tuples(dep, f"SELECT id, statement FROM {dep.schema}.ledger_current "
                           f"WHERE kind = 'decision' AND statement LIKE 'resource:%' ORDER BY id;")
    if r.returncode != 0:
        print(f"ERROR: {r.stderr.strip()}")
        return
    # -t -A echoes one leading line for the preceding `SET ROLE` statement (see _psql_tuples
    # docstring) -- drop exactly that one line, same convention as in_flight()'s spec block above.
    lines = [ln for ln in r.stdout.split("\n")[1:] if ln.strip()]
    if not lines:
        print("(no resource declarations on record)")
        return

    parsed: list[tuple[int, str, str]] = []  # (tier_rank, name, formatted block)
    malformed: list[str] = []
    for ln in lines:
        row_id, _, statement = ln.partition("|")
        body = statement.split(":", 1)[1] if ":" in statement else ""
        fields = [f.strip() for f in body.split("|")]
        if len(fields) != len(_RESOURCE_FIELDS):
            malformed.append(f"id={row_id.strip()}: MALFORMED resource statement (expected "
                              f"{len(_RESOURCE_FIELDS)} '|'-separated fields "
                              f"{_RESOURCE_FIELDS}, got {len(fields)}) -- raw: {statement.strip()}")
            continue
        name, cls, reach, proves, guidance, tier = fields
        block = (f"[{tier}] {name} ({cls})  (ledger row id={row_id.strip()})\n"
                 f"  reach:      {reach}\n"
                 f"  proves:     {proves}\n"
                 f"  guidance:   {guidance}")
        parsed.append((_resource_tier_rank(tier), name, block))

    parsed.sort(key=lambda t: (t[0], t[1]))
    for _, _, block in parsed:
        print(block)
    for m in malformed:
        print(m)


def recent_changes(dep, since: str | None, n: int) -> None:
    _section("RECENT-CHANGES")
    if since:
        sql = (f"SELECT id, ts, kind, statement FROM {dep.schema}.ledger "
               f"WHERE ts > '{since}'::timestamptz ORDER BY id DESC;")
    else:
        sql = (f"SELECT id, ts, kind, statement FROM {dep.schema}.ledger "
               f"ORDER BY id DESC LIMIT {int(n)};")
    r = _psql(dep, sql)
    if r.returncode != 0:
        print(f"ERROR: {r.stderr.strip()}")
    else:
        print(r.stdout.strip() or "(no rows)")


def git_state(repo_root: Path) -> None:
    _section("GIT-STATE")
    if not (repo_root / ".git").exists():
        print(f"(no git repo found at {repo_root})")
        return
    status = subprocess.run(["git", "-C", str(repo_root), "status", "--porcelain"],
                             capture_output=True, text=True)
    dirty = [ln for ln in status.stdout.splitlines() if ln.strip()]
    print(f"uncommitted: {len(dirty)} path(s)" + (f" -- {dirty[:10]}" if dirty else ""))
    upstream = subprocess.run(
        ["git", "-C", str(repo_root), "rev-parse", "--abbrev-ref", "--symbolic-full-name", "@{u}"],
        capture_output=True, text=True)
    if upstream.returncode != 0:
        print("unpushed: no upstream configured for the current branch")
    else:
        ahead = subprocess.run(["git", "-C", str(repo_root), "rev-list", "--count", "@{u}..HEAD"],
                                capture_output=True, text=True)
        n_ahead = ahead.stdout.strip() if ahead.returncode == 0 else "?"
        print(f"unpushed: {n_ahead} commit(s) ahead of {upstream.stdout.strip()}")


def in_flight(dep) -> None:
    _section("IN-FLIGHT")
    r = _psql(dep, f"SELECT w.slug, w.title, p.name AS claimant "
                    f"FROM {dep.schema}.work_item_current w "
                    f"LEFT JOIN {dep.kern}.principal p ON p.id = w.claimant "
                    f"WHERE w.state = 'open' ORDER BY w.slug;")
    if r.returncode != 0:
        if "does not exist" in r.stderr:
            print("UNAVAILABLE (no work-item layer -- this world's applied kernel predates "
                  "kernel/lineage/s22-work-item-ledger.sql, so work_item_current/"
                  "work_item_violations do not exist here yet; apply is a maintainer act)")
        else:
            print(f"ERROR: {r.stderr.strip()}")
        return
    open_rows = r.stdout.strip()
    print(open_rows or "(no open work items)")

    if open_rows:
        # The full statement text of each open item's OPENING act -- the actual spec a fresh
        # session has to build the task from (BACKLOG "Run-8 mid-run forensics", 2026-07-11: run
        # 8 proved slug/title/claimant alone is not enough to resume from). Live SELECT, printed
        # in FULL -- never truncated, truncating the spec would recreate the defect this exists
        # to fix. The `--- SPEC ---` / `--- END SPEC ---` markers are baked into the SQL result
        # text itself, not reconstructed from row boundaries in Python: in `-t -A` output a
        # multi-line statement's own embedded newlines are indistinguishable from a row
        # separator, so only a marker INSIDE the printed text can delimit one item's spec from
        # the next reliably. One opening act per slug is trigger-enforced (validate_work_item,
        # s22), so a plain JOIN is safe -- no open item can lack one.
        spec = _psql_tuples(dep,
            f"SELECT '--- SPEC: ' || w.slug || E' ---\\n' || o.statement || "
            f"E'\\n--- END SPEC: ' || w.slug || E' ---' "
            f"FROM {dep.schema}.work_item_current w "
            f"JOIN {dep.schema}.ledger o ON o.kind = 'work_opened' AND o.work_slug = w.slug "
            f"WHERE w.state = 'open' ORDER BY w.slug;")
        if spec.returncode != 0:
            print(f"ERROR: {spec.stderr.strip()}")
        else:
            # -t -A still echoes one leading line for the preceding `SET ROLE` statement (see
            # _psql_tuples docstring) -- drop exactly that one line, print the rest verbatim.
            lines = spec.stdout.strip("\n").splitlines()
            print("\n".join(lines[1:]))

    v = _psql_tuples(dep, f"SELECT count(*), coalesce(string_agg(DISTINCT violation, ', '), '') "
                           f"FROM {dep.schema}.work_item_violations;")
    if v.returncode != 0:
        print(f"ERROR: {v.stderr.strip()}")
        return
    # -t -A still echoes one output line per statement (the preceding `SET ROLE` included) --
    # the query's own result is always the LAST line, never the first.
    last_line = v.stdout.strip().splitlines()[-1]
    count_str, _, kinds = last_line.partition("|")
    count = int(count_str)
    print("violations: none" if count == 0 else f"violations: {count} ({kinds})")


def main(argv: list[str] | None = None) -> int:
    ap = argparse.ArgumentParser(description=__doc__.splitlines()[0])
    ap.add_argument("--since", default=None, help="timestamptz: only ledger rows newer than this")
    ap.add_argument("-n", "--limit", type=int, default=10, help="row limit where --since is not given (default 10)")
    args = ap.parse_args(argv)

    dep = _load_deployment()
    in_force_decisions(dep, args.limit)
    open_questions(dep)
    review_debt(dep)
    recent_changes(dep, args.since, args.limit)
    # World root == the directory deployment.json was actually found in, NOT this script's own
    # on-disk location -- since this file now executes in place out of the autoharn checkout
    # (BACKLOG maintainer ruling 2026-07-11, "live verbs"), `HERE` is autoharn's own
    # bootstrap/templates/, and this project's git repo lives at the world root instead (where the
    # scaffolded ./pickup shim -- and deployment.json itself -- actually sit).
    git_state(DEPLOYMENT_PATH.parent)
    resources(dep)
    in_flight(dep)
    print()
    return 0


if __name__ == "__main__":
    sys.exit(main())
