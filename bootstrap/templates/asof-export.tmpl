#!/usr/bin/env python3
"""asof-export -- REBASED onto the boundary service (design/FABLE-BOUNDARY-MULTIPLEX-AND-CLI-
REBASE-SPEC.md §5, ratified ledger row 1631; design/FABLE-BOUNDARY-READ-SURFACE-SPEC.md, ratified
row 1652, which added the `GET /d/{deployment}/rows/asof/{ts}` route this shim is a client of).
Same argv surface as the legacy direct-psql original (now `legacy-asof-export.tmpl`, reachable via
`./legacy/asof-export`): `read --asof <ts>` prints the whole-ledger as-of reconstruction;
`export --asof <ts> --out <dir> [--force]` writes the same three-file inspection copy. The
RENDERING (human-readable/JSON text, the sha256 manifest) is REUSED, not re-derived (ADR-0012 P1)
-- `render_human_readable`/`render_json` are imported directly from `legacy-asof-export.tmpl`, so
this shim's output carries the SAME row set, the SAME field set, and the SAME values per row as
the legacy tool's, for the same as-of moment (live-witnessed against this repo's own 1485-row
world: identical row count, identical per-field content). ONE COSMETIC DIVERGENCE, disclosed
rather than chased: the per-row COLUMN PRINT ORDER differs from the legacy tool's -- Postgres's
`jsonb` type does not preserve object key order (its own documented property, independent of this
build: `to_jsonb`/`jsonb_agg`, which every boundary route including this one uses, sorts keys by
an internal (length, value) scheme for its binary representation), where the legacy tool's
`row_to_json` over plain `json` text happens to preserve `ledger`'s own physical column order.
Hardcoding a column-order list here to paper over it would reintroduce exactly the
"column-complete by construction" liability the legacy tool's own docstring names as a virtue of
`l.*` (a future `ALTER TABLE ledger ADD COLUMN` would then need a second edit site to stay
represented) -- for a purely presentational difference with no effect on content, that trade is
not taken.

ONE DISCLOSED NARROWING (spec's own choice, not softened here): the boundary's `--asof` grammar
is ISO-8601 only (`datetime.fromisoformat`), typed 422 on anything else, refused BEFORE any
kernel call -- the legacy tool accepts anything postgres's own timestamptz cast honors (e.g. a
bare `2026-07-18 10:23:00` with a space). A caller who needs the looser grammar uses
`./legacy/asof-export` instead; this shim's own error path echoes the boundary's typed 422
message verbatim, never silently reformatting it into ISO-8601 on the caller's behalf (this
project's own "a boundary validates, it does not guess" convention, ADR-0002 Rule 2).

`actor_name` enrichment: the served `/rows/asof/{ts}` route serves RAW ledger columns only (no
join -- see `serving/boundary_service.py`'s own `rows_asof` comment for why), so this shim
performs the SAME left-join CLIENT-SIDE, over `/standing/principals`' own paginated output (spec's
own "no server-side filter grammar in v1: shims filter client-side" discipline) -- a
capability-absent world (pre-s41, no `principal_standing_current`) degrades to `actor_name: None`
on every row rather than refusing the whole read (an as-of reconstruction is still a legitimate,
useful result without the enrichment).

Lazy imports banned (CLAUDE.md, 2026-07-02): every import is top-of-file."""
from __future__ import annotations

import argparse
import hashlib
import importlib.machinery
import importlib.util
import os
import sys
import urllib.parse
from datetime import datetime, timezone
from pathlib import Path

HERE = Path(__file__).resolve().parent
AUTOHARN = Path(os.environ.get("AUTOHARN", str(HERE / ".." / ".."))).resolve()
DEPLOYMENT_PATH = Path(os.environ.get("PICKUP_DEPLOYMENT", str(HERE / "deployment.json")))

sys.path.insert(0, str(AUTOHARN / "serving"))
sys.path.insert(0, str(AUTOHARN / "filing"))
try:
    import boundary_cli_client as bcc  # noqa: E402
    import ensure_running as er  # noqa: E402  (round-1 review DIRECTED WORK: shared ensure-running policy, design/FABLE-AUTOHARN-UMBRELLA-CLI-SPEC.md §2)
    import deployment_record  # noqa: E402
except ImportError as _e:
    print(f"asof-export: cannot import autoharn's serving/boundary_cli_client.py or "
          f"filing/deployment_record.py under AUTOHARN={AUTOHARN} "
          f"({_e.__class__.__name__}: {_e})", file=sys.stderr)
    print("        set AUTOHARN=/path/to/autoharn, or place a sibling checkout at ../autoharn", file=sys.stderr)
    sys.exit(4)

# Reuse the legacy tool's OWN rendering functions (ADR-0012 P1) -- loaded by file path (a .tmpl
# extension is not one importlib infers a loader for), the same trick this build's own
# seen-red/boundary-read-surface/run_fixtures.py already uses for the identical reason.
_LEGACY = HERE / "legacy-asof-export.tmpl"
_lspec = importlib.util.spec_from_file_location(
    "legacy_asof_export", _LEGACY,
    loader=importlib.machinery.SourceFileLoader("legacy_asof_export", str(_LEGACY)))
assert _lspec is not None and _lspec.loader is not None
legacy = importlib.util.module_from_spec(_lspec)
sys.modules["legacy_asof_export"] = legacy
_lspec.loader.exec_module(legacy)


def _load_config() -> bcc.ServedConfig:
    try:
        cfg = bcc.load_served_config(DEPLOYMENT_PATH)
    except bcc.BoundaryClientError as e:
        print(f"asof-export: {e}", file=sys.stderr)
        sys.exit(4)
    # Version handshake (design/FABLE-AUTOHARN-UMBRELLA-CLI-SPEC.md §3): checked here, the one
    # choke point every served call passes through (ADR-0012 P1), before any real read is issued.
    try:
        bcc.check_protocol_version(cfg.base, cfg.record.boundary_url)
    except bcc.BoundaryUnreachable:
        # Ensure-running (design/FABLE-AUTOHARN-UMBRELLA-CLI-SPEC.md §2, round-1 review
        # DIRECTED WORK): unreachable -> spawn per this deployment's own record, print ONE
        # line, then proceed -- retried below ONCE; if that retry still raises, the
        # EXISTING BoundaryUnreachable handling in this file's own top-level dispatch is
        # the refusal shown (this call invents no new refusal shape of its own).
        er.ensure_running_or_leave_unreachable(DEPLOYMENT_PATH, 'asof-export')
        bcc.check_protocol_version(cfg.base, cfg.record.boundary_url)
    return cfg


def _actor_name_map(cfg: bcc.ServedConfig) -> dict[int, str]:
    """Best-effort id->name map from `/standing/principals` -- a capability_absent (409, pre-s41)
    is swallowed to an EMPTY map here (not a refusal): the as-of reconstruction itself is still a
    complete, honest result without the enrichment, and every row's `actor_name` degrades to None
    rather than the whole read failing over a display-only convenience."""
    try:
        rows = bcc.get_all_rows(cfg.base, "/standing/principals", cursor="after_id")
    except bcc.BoundaryRefusal:
        return {}
    return {r["id"]: r["name"] for r in rows if "id" in r and "name" in r}


def ledger_asof_rows(cfg: bcc.ServedConfig, asof: str) -> tuple[list[dict], str | None]:
    """Served equivalent of legacy `ledger_asof_rows`: (rows, error). `error` is set (rows
    meaningless) iff the boundary refused the call -- the malformed-ts 422 case included, whose
    message is the boundary's own verbatim (never silently reformatted)."""
    try:
        encoded_ts = urllib.parse.quote(asof, safe="")
        rows = bcc.get_all_rows(cfg.base, f"/rows/asof/{encoded_ts}", cursor="after_id")
    except bcc.BoundaryRefusal as e:
        detail = e.body.get("detail") if isinstance(e.body, dict) else e.body
        return [], f"boundary refused (HTTP {e.status}): {detail}"
    names = _actor_name_map(cfg)
    for r in rows:
        r["actor_name"] = names.get(r.get("actor"))
    return rows, None


def cmd_read(args: argparse.Namespace) -> int:
    cfg = _load_config()
    rows, err = ledger_asof_rows(cfg, args.asof)
    if err is not None:
        print(f"asof-export read: REFUSED -- as-of query failed: {err}", file=sys.stderr)
        return 2
    generated_at = datetime.now(timezone.utc).isoformat()
    dep = cfg.record
    print(legacy.render_human_readable(dep, args.asof, generated_at, rows))
    return 0


def cmd_export(args: argparse.Namespace) -> int:
    cfg = _load_config()
    rows, err = ledger_asof_rows(cfg, args.asof)
    if err is not None:
        print(f"asof-export export: REFUSED -- as-of query failed: {err}", file=sys.stderr)
        return 2

    out_dir = Path(args.out)
    txt_path = out_dir / "ledger-asof.txt"
    json_path = out_dir / "ledger-asof.json"
    manifest_path = out_dir / "manifest.sha256"

    existing = [p for p in (txt_path, json_path, manifest_path) if p.exists()]
    if existing and not args.force:
        print(f"asof-export export: REFUSED -- {len(existing)} output file(s) already exist "
              f"under {out_dir}: {[str(p) for p in existing]}", file=sys.stderr)
        print("  An inspection copy is not silently overwritten (ADR-0002). Pass --force to "
              "replace it deliberately, or choose a different --out.", file=sys.stderr)
        return 1

    out_dir.mkdir(parents=True, exist_ok=True)
    generated_at = datetime.now(timezone.utc).isoformat()
    dep = cfg.record
    txt_content = legacy.render_human_readable(dep, args.asof, generated_at, rows)
    json_content = legacy.render_json(dep, args.asof, generated_at, rows)
    txt_path.write_text(txt_content, encoding="utf-8")
    json_path.write_text(json_content, encoding="utf-8")

    manifest_lines = []
    for p in (txt_path, json_path):
        digest = hashlib.sha256(p.read_bytes()).hexdigest()
        manifest_lines.append(f"{digest}  {p.name}")
    manifest_path.write_text("\n".join(manifest_lines) + "\n", encoding="utf-8")

    print(f"asof-export export: wrote {txt_path}, {json_path}, {manifest_path} "
          f"({len(rows)} row(s) as of {args.asof}).")
    print(f"  Verify with: (cd {out_dir} && sha256sum -c manifest.sha256)")
    print(f"  {legacy.SIGNING_NOTE}")
    return 0


def main(argv: list[str]) -> int:
    p = argparse.ArgumentParser(
        prog="asof-export",
        description="Ledger-wide AS-OF read (deliverable 1) plus §11.10(b) inspection-copy "
                    "export (deliverable 2). Read-only throughout. Served via the boundary "
                    "(design/FABLE-BOUNDARY-MULTIPLEX-AND-CLI-REBASE-SPEC.md §5) -- "
                    "./legacy/asof-export is the direct-psql original.")
    sub = p.add_subparsers(dest="cmd", required=True)

    p_read = sub.add_parser("read", help="print the whole-ledger as-of reconstruction to stdout")
    p_read.add_argument("--asof", required=True,
                         help="an ISO-8601 timestamp (the boundary's own grammar, stricter than "
                              "the legacy tool's -- see this file's own module docstring)")
    p_read.set_defaults(func=cmd_read)

    p_export = sub.add_parser("export", help="write the inspection copy (txt + json + sha256 manifest)")
    p_export.add_argument("--asof", required=True, help="see 'read --help'")
    p_export.add_argument("--out", required=True,
                           help="directory to write ledger-asof.txt / ledger-asof.json / "
                                "manifest.sha256 into (created if missing; REQUIRED -- this verb "
                                "never picks a location on its own, ADR-0002)")
    p_export.add_argument("--force", action="store_true",
                           help="overwrite existing output files under --out")
    p_export.set_defaults(func=cmd_export)

    args = p.parse_args(argv)
    try:
        return args.func(args)
    except bcc.ProtocolVersionMismatch as e:
        return bcc.report_protocol_mismatch("asof-export", e)
    except (bcc.BoundaryRefusal, bcc.BoundaryUnreachable, bcc.BoundaryClientError) as e:
        return bcc.report_boundary_exception("asof-export", e)


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
