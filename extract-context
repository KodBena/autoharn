#!/bin/sh
# extract-context — repo-root shim for bootstrap/extract_context.py (the mechanized world-context
# extraction the world-context consult designed; vestigial_documentation/design/
# FABLE-WORLD-CONTEXT-MIGRATION-CONSULT-2026-07-19.md; autoharn ledger row 1942 step 1). Unlike
# led/judge/pickup/audit/distance-to-clean this is NOT bound to "this deployment's own
